<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --accent: #4B6CF7;
    --accent-2: #7B93FF;
    --cyan: #00D4FF;
    --cyan-2: #00B8E0;
    --bg: #F5F7FF;
    --bg-2: #FFFFFF;
    --bg-3: #EEF1FB;
    --text-1: #0D1236;
    --text-2: #3D4570;
    --text-3: #7B84AD;
    --border: #DDE2F4;
  }

  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text-2);
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ─── NAVBAR ─────────────────────────────────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 2rem;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(245, 247, 255, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(221, 226, 244, 0.6);
  }
  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--text-1);
    display: flex; align-items: center; gap: 10px;
    text-decoration: none;
  }
  .logo-mark {
    width: 36px; height: 36px; border-radius: 10px;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; font-weight: 900; color: #fff;
    flex-shrink: 0;
  }
  .nav-cta {
    display: flex; gap: 12px; align-items: center;
  }
  .nav-link {
    font-size: 0.85rem; font-weight: 500; color: var(--text-2);
    text-decoration: none; padding: 6px 14px; border-radius: 8px;
    transition: background 0.2s;
  }
  .nav-link:hover { background: var(--bg-3); }
  .btn-primary {
    font-size: 0.85rem; font-weight: 700; color: #fff;
    background: var(--accent);
    padding: 8px 20px; border-radius: 50px;
    text-decoration: none; border: none; cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(75, 108, 247, 0.35);
    display: inline-block;
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(75, 108, 247, 0.45); }

  /* ─── HERO ───────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    padding: 110px 2rem 80px;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .hero-orb-1 {
    position: absolute; top: -15%; left: -10%;
    width: 60vw; height: 60vw; max-width: 700px; max-height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(75,108,247,0.18) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-orb-2 {
    position: absolute; bottom: -15%; right: -10%;
    width: 55vw; height: 55vw; max-width: 650px; max-height: 650px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,212,255,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-grid {
    max-width: 1200px; width: 100%;
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem;
    align-items: center; position: relative; z-index: 1;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(0, 212, 255, 0.1);
    border: 1px solid rgba(0, 212, 255, 0.25);
    color: var(--cyan-2); font-size: 0.78rem; font-weight: 600;
    padding: 6px 14px; border-radius: 50px; margin-bottom: 1.8rem;
  }
  .badge-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--cyan); flex-shrink: 0;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0, 212, 255, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(0, 212, 255, 0); }
  }
  .hero-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    font-weight: 800; line-height: 1.08;
    color: var(--text-1); margin-bottom: 1.4rem;
  }
  .hero-title .gradient-text {
    background: linear-gradient(90deg, var(--accent) 0%, var(--cyan) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.05rem; font-weight: 400; color: var(--text-2);
    line-height: 1.75; margin-bottom: 2.2rem; max-width: 480px;
  }
  .hero-actions {
    display: flex; gap: 14px; flex-wrap: wrap; align-items: center;
    margin-bottom: 3rem;
  }
  .btn-xl {
    font-family: 'Syne', sans-serif;
    font-size: 1rem; font-weight: 700; color: #fff;
    background: linear-gradient(135deg, var(--accent), #6B48FF);
    padding: 14px 32px; border-radius: 50px; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
    box-shadow: 0 8px 30px rgba(75, 108, 247, 0.4);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-xl:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(75, 108, 247, 0.5); }
  .btn-xl-outline {
    font-family: 'Syne', sans-serif;
    font-size: 1rem; font-weight: 600; color: var(--text-1);
    background: transparent;
    border: 2px solid var(--border);
    padding: 13px 28px; border-radius: 50px; text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-xl-outline:hover { border-color: var(--accent); background: rgba(75, 108, 247, 0.05); }
  .cta-phone-box {
    display: flex; align-items: center; gap: 14px;
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: 16px; padding: 14px 20px;
    max-width: 380px;
    box-shadow: 0 4px 24px rgba(75, 108, 247, 0.08);
    position: relative; overflow: hidden;
  }
  .cta-phone-box::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--cyan));
  }
  .cta-icon {
    width: 46px; height: 46px; border-radius: 12px; flex-shrink: 0;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
  }
  .cta-text-small { font-size: 0.72rem; color: var(--text-3); font-weight: 500; margin-bottom: 2px; }
  .cta-text-main {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem; font-weight: 700; color: var(--text-1);
  }
  .cta-badge {
    margin-left: auto; background: linear-gradient(135deg, rgba(16,185,129,0.12), rgba(0,212,255,0.12));
    border: 1px solid rgba(16, 185, 129, 0.25); border-radius: 50px;
    padding: 4px 10px; font-size: 0.7rem; font-weight: 700;
    color: #10B981; white-space: nowrap;
  }

  /* ─── PHONE MOCKUP ───────────────────────────────── */
  .phone-wrap {
    display: flex; justify-content: center; align-items: center;
    position: relative;
  }
  .phone-outer {
    width: 260px; height: 520px; border-radius: 40px;
    background: #1a1a2e;
    padding: 8px;
    box-shadow: 0 40px 80px rgba(13, 18, 54, 0.35), 0 0 0 1px rgba(255,255,255,0.08);
    position: relative;
    animation: float 4s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(-2deg); }
    50% { transform: translateY(-12px) rotate(-2deg); }
  }
  .phone-screen {
    width: 100%; height: 100%; border-radius: 33px;
    background: linear-gradient(160deg, #EEF1FB 0%, #DDEAFE 100%);
    overflow: hidden; position: relative;
    display: flex; flex-direction: column; align-items: center;
    padding: 20px 16px;
  }
  .phone-notch {
    width: 80px; height: 6px; border-radius: 3px;
    background: rgba(13, 18, 54, 0.15); margin-bottom: 20px; flex-shrink: 0;
  }
  .card-avatar {
    width: 72px; height: 72px; border-radius: 50%;
    border: 3px solid white;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 800;
    color: white; margin-bottom: 10px; flex-shrink: 0;
    box-shadow: 0 4px 20px rgba(75, 108, 247, 0.4);
  }
  .card-name {
    font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700;
    color: var(--text-1); text-align: center; margin-bottom: 2px;
  }
  .card-role {
    font-size: 0.72rem; color: var(--accent); font-weight: 600;
    text-align: center; margin-bottom: 4px;
  }
  .card-company { font-size: 0.68rem; color: var(--text-3); text-align: center; margin-bottom: 14px; }
  .card-links {
    width: 100%; display: flex; flex-direction: column; gap: 7px; margin-bottom: 12px;
  }
  .card-link-item {
    display: flex; align-items: center; gap: 8px;
    background: white; border-radius: 10px; padding: 8px 10px;
    font-size: 0.68rem; font-weight: 600; color: var(--text-1);
    box-shadow: 0 2px 8px rgba(75,108,247,0.08);
  }
  .link-icon {
    width: 24px; height: 24px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem; flex-shrink: 0;
  }
  .link-icon.blue { background: rgba(75,108,247,0.12); color: var(--accent); }
  .link-icon.cyan { background: rgba(0,212,255,0.12); color: var(--cyan-2); }
  .link-icon.green { background: rgba(16,185,129,0.12); color: #10B981; }
  .card-qr-row {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    background: var(--accent); border-radius: 10px;
    padding: 8px 14px; width: 100%;
  }
  .card-qr-text { font-size: 0.68rem; font-weight: 700; color: white; }
  .phone-glow {
    position: absolute; bottom: -40px; left: 50%;
    transform: translateX(-50%);
    width: 180px; height: 40px; border-radius: 50%;
    background: rgba(75, 108, 247, 0.25);
    filter: blur(20px); pointer-events: none;
  }
  .floating-badge {
    position: absolute; background: white; border-radius: 12px;
    padding: 8px 12px; box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    font-size: 0.72rem; font-weight: 600; color: var(--text-1);
    display: flex; align-items: center; gap: 6px;
    border: 1px solid var(--border);
    animation: float2 3.5s ease-in-out infinite;
  }
  @keyframes float2 {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }
  .floating-badge.top-right {
    top: 40px; right: -30px;
    animation-delay: 0.5s;
  }
  .floating-badge.bottom-left {
    bottom: 80px; left: -35px;
    animation-delay: 1s;
  }
  .badge-dot-green { width: 7px; height: 7px; border-radius: 50%; background: #10B981; flex-shrink: 0; }
  .badge-dot-blue { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }

  /* ─── TRUST BAR ──────────────────────────────────── */
  .trust-bar {
    background: white; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    padding: 20px 2rem;
    display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap;
  }
  .trust-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.82rem; font-weight: 500; color: var(--text-2);
  }
  .trust-icon { font-size: 1rem; }

  /* ─── SECTION BASE ───────────────────────────────── */
  section { padding: 90px 2rem; }
  .section-label {
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Syne', sans-serif; font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800; color: var(--text-1); margin-bottom: 1rem; line-height: 1.15;
  }
  .section-sub { font-size: 1.05rem; color: var(--text-2); max-width: 560px; line-height: 1.75; }
  .centered { text-align: center; }
  .centered .section-sub { margin: 0 auto; }

  /* ─── HOW IT WORKS ───────────────────────────────── */
  .how-section { background: white; }
  .steps-grid {
    max-width: 960px; margin: 4rem auto 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
  }
  .step-card {
    padding: 2rem; border-radius: 20px;
    border: 1.5px solid var(--border);
    background: var(--bg);
    position: relative; overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .step-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(75,108,247,0.12); }
  .step-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--cyan));
  }
  .step-number {
    font-family: 'Syne', sans-serif; font-size: 3rem; font-weight: 800;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text; margin-bottom: 0.75rem; display: block;
  }
  .step-title {
    font-family: 'Syne', sans-serif; font-size: 1.1rem; font-weight: 700;
    color: var(--text-1); margin-bottom: 0.5rem;
  }
  .step-desc { font-size: 0.9rem; color: var(--text-2); line-height: 1.7; }

  /* ─── FEATURES ───────────────────────────────────── */
  .features-section { background: var(--bg); }
  .features-grid {
    max-width: 1100px; margin: 4rem auto 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;
  }
  .feature-card {
    background: white; border-radius: 20px; border: 1.5px solid var(--border);
    padding: 2rem; display: flex; gap: 1.2rem; align-items: flex-start;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .feature-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(75,108,247,0.1); }
  .feature-icon-wrap {
    width: 48px; height: 48px; border-radius: 14px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
  }
  .fi-blue { background: rgba(75,108,247,0.1); }
  .fi-cyan { background: rgba(0,212,255,0.1); }
  .fi-green { background: rgba(16,185,129,0.1); }
  .fi-amber { background: rgba(245,158,11,0.1); }
  .feature-title { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; color: var(--text-1); margin-bottom: 0.4rem; }
  .feature-desc { font-size: 0.88rem; color: var(--text-2); line-height: 1.7; }

  /* ─── DESIGNS CAROUSEL ───────────────────────────── */
  .designs-section { background: white; overflow: hidden; }
  .designs-carousel {
    display: flex; gap: 1.5rem; margin-top: 3rem; padding-bottom: 1rem;
    overflow-x: auto; scroll-snap-type: x mandatory;
    scrollbar-width: none; padding: 1rem 2rem 2rem;
  }
  .designs-carousel::-webkit-scrollbar { display: none; }
  .design-card {
    flex-shrink: 0; width: 220px; height: 380px;
    border-radius: 24px; overflow: hidden;
    position: relative; scroll-snap-align: start;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    transition: transform 0.25s;
    cursor: pointer;
  }
  .design-card:hover { transform: scale(1.03) translateY(-4px); }
  .design-card img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .design-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(0deg, rgba(13,18,54,0.85) 0%, transparent 100%);
    padding: 20px 16px;
  }
  .design-label {
    font-family: 'Syne', sans-serif; font-size: 0.85rem; font-weight: 700;
    color: white; margin-bottom: 2px;
  }
  .design-sublabel { font-size: 0.7rem; color: rgba(255,255,255,0.7); }

  /* ─── TESTIMONIALS ───────────────────────────────── */
  .testimonials-section { background: var(--bg); }
  .testimonials-grid {
    max-width: 1000px; margin: 3.5rem auto 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .testimonial-card {
    background: white; border-radius: 20px; border: 1.5px solid var(--border);
    padding: 1.5rem; transition: transform 0.25s;
  }
  .testimonial-card:hover { transform: translateY(-3px); }
  .testimonial-stars { color: #F59E0B; font-size: 0.85rem; margin-bottom: 0.75rem; }
  .testimonial-text { font-size: 0.9rem; color: var(--text-2); line-height: 1.7; margin-bottom: 1rem; font-style: italic; }
  .testimonial-author { display: flex; align-items: center; gap: 10px; }
  .author-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.8rem;
    color: white; flex-shrink: 0;
  }
  .author-name { font-weight: 600; font-size: 0.85rem; color: var(--text-1); }
  .author-role { font-size: 0.75rem; color: var(--text-3); }

  /* ─── PRICING ────────────────────────────────────── */
  .pricing-section { background: white; }
  .pricing-card {
    max-width: 560px; margin: 3rem auto 0;
    background: linear-gradient(135deg, #0D1236 0%, #1a1f4e 100%);
    border-radius: 28px; padding: 3rem; text-align: center;
    position: relative; overflow: hidden;
    box-shadow: 0 24px 60px rgba(13,18,54,0.3);
  }
  .pricing-card::before {
    content: ''; position: absolute; top: -40%; left: -20%;
    width: 80%; height: 80%; border-radius: 50%;
    background: radial-gradient(circle, rgba(75,108,247,0.3) 0%, transparent 70%);
    pointer-events: none;
  }
  .pricing-card::after {
    content: ''; position: absolute; bottom: -30%; right: -10%;
    width: 60%; height: 60%; border-radius: 50%;
    background: radial-gradient(circle, rgba(0,212,255,0.2) 0%, transparent 70%);
    pointer-events: none;
  }
  .pricing-trial {
    display: inline-block;
    background: rgba(0,212,255,0.15); border: 1px solid rgba(0,212,255,0.3);
    color: var(--cyan); font-size: 0.78rem; font-weight: 700;
    padding: 6px 14px; border-radius: 50px; margin-bottom: 1.5rem;
    position: relative; z-index: 1;
  }
  .pricing-price {
    font-family: 'Syne', sans-serif; font-size: 4rem; font-weight: 800;
    color: white; margin-bottom: 0.25rem; position: relative; z-index: 1;
  }
  .pricing-sub { font-size: 0.9rem; color: rgba(255,255,255,0.6); margin-bottom: 2rem; position: relative; z-index: 1; }
  .pricing-features { list-style: none; text-align: left; margin-bottom: 2.5rem; position: relative; z-index: 1; }
  .pricing-features li {
    font-size: 0.92rem; color: rgba(255,255,255,0.85); padding: 8px 0;
    display: flex; align-items: center; gap: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .pricing-features li:last-child { border-bottom: none; }
  .check { color: var(--cyan); font-weight: 700; flex-shrink: 0; }
  .pricing-btn {
    width: 100%; padding: 16px; border-radius: 14px; border: none; cursor: pointer;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
    font-family: 'Syne', sans-serif; font-size: 1.05rem; font-weight: 800;
    color: white; transition: opacity 0.2s, transform 0.2s;
    position: relative; z-index: 1;
    box-shadow: 0 8px 30px rgba(75,108,247,0.5);
  }
  .pricing-btn:hover { opacity: 0.92; transform: translateY(-1px); }
  .pricing-footnote { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 1rem; position: relative; z-index: 1; }

  /* ─── FINAL CTA ──────────────────────────────────── */
  .final-cta {
    padding: 100px 2rem;
    background: linear-gradient(135deg, #0D1236 0%, #1a1f4e 100%);
    text-align: center; position: relative; overflow: hidden;
  }
  .final-cta::before {
    content: ''; position: absolute; top: -30%; left: 20%;
    width: 60%; height: 80%;
    background: radial-gradient(circle, rgba(75,108,247,0.25) 0%, transparent 70%);
    pointer-events: none;
  }
  .final-cta .section-title { color: white; position: relative; z-index: 1; }
  .final-cta .section-sub { color: rgba(255,255,255,0.65); margin: 0 auto 2.5rem; position: relative; z-index: 1; }
  .cta-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; position: relative; z-index: 1; }
  .btn-white {
    font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700;
    color: var(--accent); background: white;
    padding: 14px 32px; border-radius: 50px;
    text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
    box-shadow: 0 8px 30px rgba(255,255,255,0.25);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(255,255,255,0.35); }
  .btn-ghost-white {
    font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 600;
    color: white; background: transparent;
    border: 2px solid rgba(255,255,255,0.35);
    padding: 12px 28px; border-radius: 50px; text-decoration: none;
    transition: border-color 0.2s;
  }
  .btn-ghost-white:hover { border-color: rgba(255,255,255,0.7); }

  /* ─── FOOTER ─────────────────────────────────────── */
