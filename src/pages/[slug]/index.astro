---
// src/pages/[slug]/index.astro
// Para agregar un theme nuevo: solo tocar src/themes/index.ts
export const prerender = false

import CardLayout   from '../../layouts/CardLayout.astro'
import { createClient } from '@supabase/supabase-js'
import { getThemeParaPerfil } from '../../themes/index'
import type { CardProps } from '../../themes/types'
import type {
  Experiencia, Estudio, Capacitacion, Habilidad,
  Servicio, Proyecto, Red, Logro, Referencia
} from '../../themes/types'

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
)

const { slug } = Astro.params

// ── 1. Leer perfil desde la vista unificada ───────────────────
// Un solo round-trip — LEFT JOIN 1:1 sobre PK, O(1) por fila.
const { data: perfil, error } = await supabase
  .from('vista_perfiles_completos')
  .select('*')
  .eq('slug', slug)
  .maybeSingle()

if (error) {
  console.error('[slug] error BD:', error.message)
  return Astro.redirect('/404')
}
if (!perfil) {
  console.log('[slug] no encontrado:', slug)
  return Astro.redirect('/404')
}

const tipoPerfil    = (perfil.tipo_perfil ?? 'profesional') as 'profesional' | 'negocio'
const esProfesional = tipoPerfil === 'profesional'

// ── 2. Cargar datos satélite según tipo ───────────────────────
// Profesional: 9 queries en paralelo
// Negocio:     3 queries (servicios/catálogo, proyectos/galería, redes)
// Las tablas que no aplican al tipo no se consultan — ahorro en BD.

let experiencia:    Experiencia[]    = []
let estudios:       Estudio[]        = []
let capacitaciones: Capacitacion[]   = []
let habilidades:    Habilidad[]      = []
let logros:         Logro[]          = []
let referencias:    Referencia[]     = []
let servicios:      Servicio[]       = []
let proyectos:      Proyecto[]       = []
let redes:          Red[]            = []

if (esProfesional) {
  const [
    { data: _exp },
    { data: _est },
    { data: _cap },
    { data: _hab },
    { data: _svc },
    { data: _pry },
    { data: _red },
    { data: _log },
    { data: _ref },
  ] = await Promise.all([
    supabase.from('experiencia_laboral').select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('estudios')           .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('capacitaciones')     .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('habilidades')        .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('servicios')          .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('proyectos')          .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('redes_sociales')     .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('logros')             .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('referencias')        .select('*').eq('perfil_id', perfil.id).order('orden'),
  ])
  experiencia    = (_exp ?? []) as Experiencia[]
  estudios       = (_est ?? []) as Estudio[]
  capacitaciones = (_cap ?? []) as Capacitacion[]
  habilidades    = (_hab ?? []) as Habilidad[]
  servicios      = (_svc ?? []) as Servicio[]
  proyectos      = (_pry ?? []) as Proyecto[]
  redes          = (_red ?? []) as Red[]
  logros         = (_log ?? []) as Logro[]
  referencias    = (_ref ?? []) as Referencia[]

} else {
  const [
    { data: _svc },
    { data: _pry },
    { data: _red },
  ] = await Promise.all([
    supabase.from('servicios')      .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('proyectos')      .select('*').eq('perfil_id', perfil.id).order('orden'),
    supabase.from('redes_sociales') .select('*').eq('perfil_id', perfil.id).order('orden'),
  ])
  servicios = (_svc ?? []) as Servicio[]
  proyectos = (_pry ?? []) as Proyecto[]
  redes     = (_red ?? []) as Red[]
}

// ── 3. Seleccionar theme con fallback inteligente por tipo ────
// getThemeParaPerfil garantiza que un negocio nunca reciba
// un theme de profesional aunque tenga un template_id incorrecto.
const theme = getThemeParaPerfil(perfil.template_id, tipoPerfil)
const Card  = theme.componente as any

// ── 4. Construir metadatos para <head> ────────────────────────
const nombre = esProfesional
  ? [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')
  : (perfil.nombre_negocio ?? perfil.nombre)

const descripcion = esProfesional
  ? (perfil.bio ?? perfil.titulo_profesional ?? 'Tarjeta Digital Profesional')
  : (perfil.bio ?? perfil.tagline ?? perfil.categoria_negocio ?? 'Tarjeta Digital de Negocio')

const tituloProf = esProfesional
  ? (perfil.titulo_profesional ?? null)
  : (perfil.tagline ?? perfil.categoria_negocio ?? null)

// ── 5. Ensamblar props tipadas para el theme ──────────────────
const cardProps: CardProps = {
  perfil,
  experiencia,
  estudios,
  habilidades,
  servicios,
  proyectos,
  redes,
  logros,
  capacitaciones,
  referencias,
}
---

<CardLayout
  title={`${nombre} — Tarjeta digital`}
  description={descripcion}
  ogImage={perfil.foto_url ?? undefined}
  bgColor={theme.preview_bg || '#ffffff'}
  cardUrl={`${Astro.url.origin}/${slug}`}
  fotoUrl={perfil.foto_url ?? null}
  slug={slug}
  nombre={nombre}
  tituloProf={tituloProf}
  accentColor={perfil.color_primario ?? '#4B6CF7'}
>
  <Card {...cardProps} />
</CardLayout>

<div id="track-data" data-perfil-id={perfil.id} style="display:none"></div>

<script>
  const perfilId = document.getElementById('track-data')?.dataset.perfilId

  // Vista inicial
  if (perfilId) {
    fetch('/api/track', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ perfil_id: perfilId }),
    })
  }

  function track(tipo: string, metadata: Record<string, string>) {
    if (!perfilId) return
    fetch('/api/track', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ perfil_id: perfilId, tipo, metadata }),
    })
  }

  // Clicks en redes, CV y proyectos
  document.querySelectorAll<HTMLElement>('.track-red').forEach(el => {
    el.addEventListener('click', () =>
      track('click_red', { plataforma: el.dataset.plataforma ?? '' })
    )
  })
  document.querySelectorAll<HTMLElement>('.track-cv').forEach(el => {
    el.addEventListener('click', () => track('descarga_cv', {}))
  })
  document.querySelectorAll<HTMLElement>('.track-proyecto').forEach(el => {
    el.addEventListener('click', () =>
      track('click_proyecto', { titulo: el.dataset.titulo ?? '' })
    )
  })
</script>