---
// src/pages/index.astro
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<title>CardVirtual | Tu Identidad Profesional Digital</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --accent: #4B6CF7; --accent-2: #7B93FF; --cyan: #00D4FF; --cyan-2: #00B8E0;
    --bg: #F5F7FF; --bg-2: #FFFFFF; --bg-3: #EEF1FB;
    --text-1: #0D1236; --text-2: #3D4570; --text-3: #7B84AD; --border: #DDE2F4;
  }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text-2); overflow-x: hidden; min-height: 100vh; }

  /* ── NAVBAR ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 1.25rem; height: 60px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(245,247,255,0.9); backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(221,226,244,0.6);
  }
  .nav-logo {
    font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.1rem;
    color: var(--text-1); display: flex; align-items: center; gap: 8px; text-decoration: none;
  }
  .nav-logo img { height: 32px; width: auto; object-fit: contain; }
  .nav-right { display: flex; gap: 8px; align-items: center; }
  .nav-link {
    font-size: 0.82rem; font-weight: 500; color: var(--text-2);
    text-decoration: none; padding: 6px 10px; border-radius: 8px;
    transition: background 0.2s; display: none;
  }
  .nav-link:hover { background: var(--bg-3); }
  .btn-nav {
    font-size: 0.82rem; font-weight: 700; color: #fff; background: var(--accent);
    padding: 7px 16px; border-radius: 50px; text-decoration: none; border: none;
    cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 14px rgba(75,108,247,0.35); white-space: nowrap; display: inline-block;
  }
  .btn-nav:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(75,108,247,0.45); }

  /* ── HERO ── */
  .hero {
    min-height: 100svh; padding: 80px 1.25rem 60px;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .orb1 {
    position: absolute; top: -20%; left: -15%; width: 70vw; height: 70vw;
    max-width: 500px; max-height: 500px; border-radius: 50%;
    background: radial-gradient(circle, rgba(75,108,247,0.16) 0%, transparent 70%); pointer-events: none;
  }
  .orb2 {
    position: absolute; bottom: -20%; right: -15%; width: 65vw; height: 65vw;
    max-width: 450px; max-height: 450px; border-radius: 50%;
    background: radial-gradient(circle, rgba(0,212,255,0.13) 0%, transparent 70%); pointer-events: none;
  }
  .hero-inner {
    max-width: 1200px; width: 100%; position: relative; z-index: 1;
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 2.5rem;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.25);
    color: var(--cyan-2); font-size: 0.75rem; font-weight: 600;
    padding: 5px 12px; border-radius: 50px;
  }
  .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--cyan); flex-shrink: 0; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(0,212,255,0.4)} 50%{box-shadow:0 0 0 5px rgba(0,212,255,0)} }
  .hero-title {
    font-family: 'Syne', sans-serif; font-size: clamp(2.2rem, 8vw, 4.2rem);
    font-weight: 800; line-height: 1.08; color: var(--text-1); margin: 1rem 0 1.2rem;
  }
  .gradient-text {
    background: linear-gradient(90deg, var(--accent), var(--cyan));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hero-sub { font-size: clamp(0.95rem, 3vw, 1.1rem); color: var(--text-2); line-height: 1.75; max-width: 520px; margin-bottom: 2rem; }
  .hero-actions { display: flex; flex-direction: column; gap: 12px; width: 100%; max-width: 320px; margin-bottom: 2rem; }
  .btn-xl {
    font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; color: #fff;
    background: linear-gradient(135deg, var(--accent), #6B48FF);
    padding: 15px 24px; border-radius: 50px; text-decoration: none;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    box-shadow: 0 8px 28px rgba(75,108,247,0.4); transition: transform 0.2s, box-shadow 0.2s; width: 100%;
  }
  .btn-xl:hover { transform: translateY(-2px); box-shadow: 0 12px 36px rgba(75,108,247,0.5); }
  .btn-xl-outline {
    font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 600; color: var(--text-1);
    background: transparent; border: 2px solid var(--border);
    padding: 13px 24px; border-radius: 50px; text-decoration: none;
    display: flex; align-items: center; justify-content: center;
    transition: border-color 0.2s, background 0.2s; width: 100%;
  }
  .btn-xl-outline:hover { border-color: var(--accent); background: rgba(75,108,247,0.05); }
  .cta-box {
    display: flex; align-items: center; gap: 12px;
    background: #fff; border: 1.5px solid var(--border); border-radius: 16px;
    padding: 14px 16px; width: 100%; max-width: 340px;
    box-shadow: 0 4px 20px rgba(75,108,247,0.08); position: relative; overflow: hidden;
  }
  .cta-box::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--cyan));
  }
  .cta-icon {
    width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
    display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
  }
  .cta-text-small { font-size: 0.7rem; color: var(--text-3); font-weight: 500; margin-bottom: 2px; }
  .cta-text-main { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; color: var(--text-1); }
  .cta-badge {
    margin-left: auto; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.25);
    border-radius: 50px; padding: 4px 9px; font-size: 0.68rem; font-weight: 700;
    color: #10B981; white-space: nowrap; flex-shrink: 0;
  }

  /* ── PHONE MOCKUP ── */
  .phone-wrap { position: relative; display: flex; justify-content: center; align-items: center; }
  .phone-outer {
    width: 220px; height: 440px; border-radius: 36px; background: #1a1a2e; padding: 7px;
    box-shadow: 0 32px 64px rgba(13,18,54,0.3), 0 0 0 1px rgba(255,255,255,0.08);
    animation: float 4s ease-in-out infinite;
  }
  @keyframes float { 0%,100%{transform:translateY(0) rotate(-2deg)} 50%{transform:translateY(-10px) rotate(-2deg)} }
  .phone-screen {
    width: 100%; height: 100%; border-radius: 30px;
    background: linear-gradient(160deg, #EEF1FB, #DDEAFE); overflow: hidden;
    display: flex; flex-direction: column; align-items: center; padding: 16px 13px;
  }
  .phone-notch { width: 70px; height: 5px; border-radius: 3px; background: rgba(13,18,54,0.15); margin-bottom: 16px; flex-shrink: 0; }
  .card-avatar {
    width: 62px; height: 62px; border-radius: 50%; border: 3px solid white;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif; font-size: 1.3rem; font-weight: 800;
    color: white; margin-bottom: 8px; flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(75,108,247,0.4);
  }
  .card-name { font-family: 'Syne', sans-serif; font-size: 0.88rem; font-weight: 700; color: var(--text-1); text-align: center; margin-bottom: 2px; }
  .card-role { font-size: 0.65rem; color: var(--accent); font-weight: 600; text-align: center; margin-bottom: 3px; }
  .card-co { font-size: 0.6rem; color: var(--text-3); text-align: center; margin-bottom: 12px; }
  .card-links { width: 100%; display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px; }
  .card-link-item {
    display: flex; align-items: center; gap: 7px; background: white; border-radius: 9px;
    padding: 7px 9px; font-size: 0.6rem; font-weight: 600; color: var(--text-1);
    box-shadow: 0 2px 8px rgba(75,108,247,0.07);
  }
  .licon { width: 20px; height: 20px; border-radius: 5px; display: flex; align-items: center; justify-content: center; font-size: 0.58rem; flex-shrink: 0; }
  .licon.b { background: rgba(75,108,247,0.12); }
  .licon.c { background: rgba(0,212,255,0.12); }
  .licon.g { background: rgba(16,185,129,0.12); }
  .card-qr { display: flex; align-items: center; justify-content: center; gap: 5px; background: var(--accent); border-radius: 9px; padding: 7px 12px; width: 100%; }
  .card-qr span { font-size: 0.6rem; font-weight: 700; color: white; }
  .phone-glow { position: absolute; bottom: -35px; left: 50%; transform: translateX(-50%); width: 150px; height: 35px; border-radius: 50%; background: rgba(75,108,247,0.2); filter: blur(18px); pointer-events: none; }
  .fbadge {
    position: absolute; background: white; border-radius: 10px; padding: 7px 10px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.1); font-size: 0.68rem; font-weight: 600; color: var(--text-1);
    display: flex; align-items: center; gap: 5px; border: 1px solid var(--border);
    animation: float2 3.5s ease-in-out infinite;
  }
  @keyframes float2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-7px)} }
  .fbadge.tr { top: 30px; right: -20px; animation-delay: 0.5s; }
  .fbadge.bl { bottom: 70px; left: -25px; animation-delay: 1s; }
  .dot-g { width: 6px; height: 6px; border-radius: 50%; background: #10B981; flex-shrink: 0; }
  .dot-b { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }

  /* ── TRUST BAR ── */
  .trust-bar {
    background: white; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    padding: 16px 1.25rem; display: flex; align-items: center; justify-content: center;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .trust-item { display: flex; align-items: center; gap: 7px; font-size: 0.78rem; font-weight: 500; color: var(--text-2); }

  /* ── SECTIONS BASE ── */
  section { padding: 60px 1.25rem; }
  .section-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
  .section-title { font-family: 'Syne', sans-serif; font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 800; color: var(--text-1); margin-bottom: 0.9rem; line-height: 1.15; }
  .section-sub { font-size: 1rem; color: var(--text-2); max-width: 560px; line-height: 1.75; }
  .centered { text-align: center; }
  .centered .section-sub { margin: 0 auto; }

  /* ── HOW IT WORKS ── */
  .how-section { background: white; }
  .steps-grid { max-width: 960px; margin: 2.5rem auto 0; display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .step-card {
    padding: 1.5rem; border-radius: 18px; border: 1.5px solid var(--border); background: var(--bg);
    position: relative; overflow: hidden; transition: transform 0.25s, box-shadow 0.25s;
  }
  .step-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(75,108,247,0.1); }
  .step-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--accent), var(--cyan)); }
  .step-number { font-family: 'Syne', sans-serif; font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, var(--accent), var(--cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.6rem; display: block; }
  .step-title { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; color: var(--text-1); margin-bottom: 0.4rem; }
  .step-desc { font-size: 0.87rem; color: var(--text-2); line-height: 1.7; }

  /* ── FEATURES ── */
  .features-section { background: var(--bg); }
  .features-grid { max-width: 1100px; margin: 2.5rem auto 0; display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .feature-card {
    background: white; border-radius: 18px; border: 1.5px solid var(--border);
    padding: 1.5rem; display: flex; gap: 1rem; align-items: flex-start;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .feature-card:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(75,108,247,0.09); }
  .ficon { width: 46px; height: 46px; border-radius: 13px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
  .fi-b { background: rgba(75,108,247,0.1); } .fi-c { background: rgba(0,212,255,0.1); } .fi-g { background: rgba(16,185,129,0.1); } .fi-a { background: rgba(245,158,11,0.1); }
  .feature-title { font-family: 'Syne', sans-serif; font-size: 0.97rem; font-weight: 700; color: var(--text-1); margin-bottom: 0.35rem; }
  .feature-desc { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; }

  /* ── DESIGNS CAROUSEL ── */
  .designs-section { background: white; overflow: hidden; }
  .designs-carousel { display: flex; gap: 1.25rem; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; padding: 1rem 1.25rem 1.5rem; margin-top: 2rem; }
  .designs-carousel::-webkit-scrollbar { display: none; }
  .design-card { flex-shrink: 0; width: 180px; height: 320px; border-radius: 20px; overflow: hidden; position: relative; scroll-snap-align: start; box-shadow: 0 8px 28px rgba(0,0,0,0.12); transition: transform 0.25s; cursor: pointer; }
  .design-card:hover { transform: scale(1.03) translateY(-3px); }
  .design-card img { width: 100%; height: 100%; object-fit: cover; }
  .design-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(0deg, rgba(13,18,54,0.85) 0%, transparent 100%); padding: 16px 13px; }
  .design-label { font-family: 'Syne', sans-serif; font-size: 0.8rem; font-weight: 700; color: white; margin-bottom: 2px; }
  .design-sub { font-size: 0.65rem; color: rgba(255,255,255,0.7); }

  /* ── TESTIMONIALS ── */
  .testimonials-section { background: var(--bg); }
  .testimonials-grid { max-width: 1000px; margin: 2.5rem auto 0; display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .t-card { background: white; border-radius: 18px; border: 1.5px solid var(--border); padding: 1.4rem; transition: transform 0.25s; }
  .t-card:hover { transform: translateY(-2px); }
  .t-stars { color: #F59E0B; font-size: 0.82rem; margin-bottom: 0.7rem; }
  .t-text { font-size: 0.87rem; color: var(--text-2); line-height: 1.7; margin-bottom: 0.9rem; font-style: italic; }
  .t-author { display: flex; align-items: center; gap: 9px; }
  .t-avatar { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.75rem; color: white; flex-shrink: 0; }
  .t-name { font-weight: 600; font-size: 0.82rem; color: var(--text-1); }
  .t-role { font-size: 0.72rem; color: var(--text-3); }

  /* ── PRICING ── */
  .pricing-section { background: white; }
  .pricing-card {
    max-width: 520px; margin: 2.5rem auto 0;
    background: linear-gradient(135deg, #0D1236, #1a1f4e);
    border-radius: 24px; padding: 2.5rem 2rem; text-align: center;
    position: relative; overflow: hidden; box-shadow: 0 20px 50px rgba(13,18,54,0.28);
  }
  .pricing-card::before { content: ''; position: absolute; top: -40%; left: -20%; width: 80%; height: 80%; border-radius: 50%; background: radial-gradient(circle, rgba(75,108,247,0.28) 0%, transparent 70%); pointer-events: none; }
  .pricing-card::after { content: ''; position: absolute; bottom: -30%; right: -10%; width: 60%; height: 60%; border-radius: 50%; background: radial-gradient(circle, rgba(0,212,255,0.18) 0%, transparent 70%); pointer-events: none; }
  .pricing-trial { display: inline-block; background: rgba(0,212,255,0.15); border: 1px solid rgba(0,212,255,0.3); color: var(--cyan); font-size: 0.75rem; font-weight: 700; padding: 5px 12px; border-radius: 50px; margin-bottom: 1.25rem; position: relative; z-index: 1; }
  .pricing-price { font-family: 'Syne', sans-serif; font-size: 3.5rem; font-weight: 800; color: white; margin-bottom: 0.2rem; position: relative; z-index: 1; }
  .pricing-sub { font-size: 0.87rem; color: rgba(255,255,255,0.55); margin-bottom: 1.75rem; position: relative; z-index: 1; }
  .pricing-features { list-style: none; text-align: left; margin-bottom: 2rem; position: relative; z-index: 1; }
  .pricing-features li { font-size: 0.88rem; color: rgba(255,255,255,0.82); padding: 7px 0; display: flex; align-items: center; gap: 9px; border-bottom: 1px solid rgba(255,255,255,0.07); }
  .pricing-features li:last-child { border-bottom: none; }
  .check { color: var(--cyan); font-weight: 700; flex-shrink: 0; }
  .pricing-btn {
    width: 100%; padding: 15px; border-radius: 13px; border: none; cursor: pointer;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
    font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 800; color: white;
    transition: opacity 0.2s, transform 0.2s; position: relative; z-index: 1;
    box-shadow: 0 8px 28px rgba(75,108,247,0.45);
  }
  .pricing-btn:hover { opacity: 0.92; transform: translateY(-1px); }
  .pricing-footnote { font-size: 0.72rem; color: rgba(255,255,255,0.38); margin-top: 0.9rem; position: relative; z-index: 1; }

  /* ── FINAL CTA ── */
  .final-cta { padding: 80px 1.25rem; background: linear-gradient(135deg, #0D1236, #1a1f4e); text-align: center; position: relative; overflow: hidden; }
  .final-cta::before { content: ''; position: absolute; top: -30%; left: 20%; width: 60%; height: 80%; background: radial-gradient(circle, rgba(75,108,247,0.22) 0%, transparent 70%); pointer-events: none; }
  .final-cta .section-title { color: white; position: relative; z-index: 1; }
  .final-cta .section-sub { color: rgba(255,255,255,0.62); margin: 1rem auto 2rem; position: relative; z-index: 1; }
  .cta-actions { display: flex; flex-direction: column; gap: 12px; align-items: center; position: relative; z-index: 1; }
  .btn-white {
    font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; color: var(--accent); background: white;
    padding: 14px 32px; border-radius: 50px; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px; width: 100%; max-width: 280px; justify-content: center;
    box-shadow: 0 8px 28px rgba(255,255,255,0.22); transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 12px 36px rgba(255,255,255,0.32); }
  .btn-ghost-white {
    font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 600; color: white; background: transparent;
    border: 2px solid rgba(255,255,255,0.32); padding: 12px 32px; border-radius: 50px; text-decoration: none;
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; max-width: 280px; transition: border-color 0.2s;
  }
  .btn-ghost-white:hover { border-color: rgba(255,255,255,0.65); }

  /* ── FOOTER ── */
  footer { background: #0D1236; border-top: 1px solid rgba(255,255,255,0.06); padding: 1.75rem 1.25rem; text-align: center; font-size: 0.8rem; color: rgba(255,255,255,0.32); }
  .footer-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1rem; color: rgba(255,255,255,0.55); margin-bottom: 0.5rem; display: inline-flex; align-items: center; gap: 7px; }
  .footer-logo img { height: 26px; width: auto; object-fit: contain; }

  /* ── ANIMATIONS ── */
  .fade-up { opacity: 0; transform: translateY(22px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  /* ── TABLET (≥640px) ── */
  @media (min-width: 640px) {
    nav { padding: 0 2rem; height: 64px; }
    .nav-link { display: block; }
    .hero { padding: 100px 2rem 70px; }
    .hero-inner { flex-direction: row; text-align: left; align-items: center; gap: 4rem; }
    .hero-sub { max-width: 100%; }
    .hero-actions { max-width: 100%; flex-direction: row; flex-wrap: wrap; }
    .btn-xl { width: auto; flex: 1; min-width: 180px; }
    .btn-xl-outline { width: auto; flex: 1; min-width: 160px; }
    .cta-box { max-width: 100%; }
    .steps-grid { grid-template-columns: repeat(3, 1fr); }
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-actions { flex-direction: row; justify-content: center; }
    .btn-white, .btn-ghost-white { width: auto; }
    section { padding: 80px 2rem; }
    .design-card { width: 210px; height: 360px; }
    .fbadge.tr { right: -30px; }
    .fbadge.bl { left: -35px; }
  }

  /* ── DESKTOP (≥1024px) ── */
