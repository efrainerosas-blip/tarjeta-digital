---
// src/pages/auth/login.astro
// Login con número de móvil + contraseña.
// El admin crea las cuentas desde /admin/crear-usuario
// y comparte las credenciales por WhatsApp.
import Layout from '../../layouts/Layout.astro'

const redirectTo = Astro.url.searchParams.get('redirect') ?? '/dashboard'
const errorParam = Astro.url.searchParams.get('error') ?? ''
---

<Layout title="Acceder — Tarjeta Digital">
  <main class="min-h-screen flex items-center justify-center px-4 bg-gray-50">
    <div class="w-full max-w-sm">

      <!-- Encabezado -->
      <div class="text-center mb-8">
        <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Tarjeta Digital</h1>
        <p class="text-gray-500 text-sm mt-1">Ingresa con tu número de móvil</p>
      </div>

      <!-- Card del formulario -->
      <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">

        <!-- Error de sesión expirada u otros -->
        {errorParam && (
          <div class="bg-red-50 border border-red-200 text-red-600 text-xs px-3 py-2 rounded-lg mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
            </svg>
            {errorParam === 'forbidden'
              ? 'No tienes permisos para acceder a esa sección.'
              : 'Sesión expirada. Por favor ingresa de nuevo.'}
          </div>
        )}

        <div class="space-y-4">

          <!-- Campo móvil -->
          <div>
            <label for="movil" class="block text-sm font-medium text-gray-700 mb-1">
              Número de móvil
            </label>
            <div class="flex gap-2">
              <!-- Selector de prefijo -->
              <select
                id="prefijo"
                class="w-24 px-2 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50"
              >
                <option value="51">🇵🇪 +51</option>
                <option value="52">🇲🇽 +52</option>
                <option value="57">🇨🇴 +57</option>
                <option value="56">🇨🇱 +56</option>
                <option value="54">🇦🇷 +54</option>
                <option value="34">🇪🇸 +34</option>
                <option value="1">🇺🇸 +1</option>
              </select>
              <input
                type="tel"
                id="movil"
                inputmode="numeric"
                autocomplete="tel"
                placeholder="987 654 321"
                maxlength="12"
                class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>
          </div>

          <!-- Campo contraseña -->
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
              Contraseña
            </label>
            <div class="relative">
              <input
                type="password"
                id="password"
                autocomplete="current-password"
                placeholder="Tu contraseña"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent pr-10"
              />
              <!-- Toggle mostrar/ocultar contraseña -->
              <button
                type="button"
                id="toggle-password"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                tabindex="-1"
                aria-label="Mostrar contraseña"
              >
                <svg id="eye-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Error de login -->
          <p id="login-error" class="text-red-500 text-xs hidden flex items-center gap-1">
            <svg class="w-3 h-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <span id="login-error-text"></span>
          </p>

          <!-- Botón ingresar -->
          <button
            id="btn-login"
            type="button"
            class="w-full bg-blue-600 text-white text-sm font-medium py-2.5 rounded-lg hover:bg-blue-700 active:bg-blue-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Ingresar
          </button>

        </div>
      </div>

      <p class="text-center text-xs text-gray-400 mt-6">
        ¿No tienes cuenta? Contacta al administrador.
      </p>

    </div>
  </main>

  <!-- Datos del servidor → script, sin define:vars -->
  <div
    id="app-config"
    data-url={import.meta.env.PUBLIC_SUPABASE_URL}
    data-anon={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    data-redirect={redirectTo}
    style="display:none"
  ></div>
</Layout>

<script>
  import { createBrowserClient } from '@supabase/ssr'

  // ── Config ──────────────────────────────────────────────────
  const cfg        = document.getElementById('app-config')!
  const supabase   = createBrowserClient(cfg.dataset.url!, cfg.dataset.anon!)
  const redirectTo = cfg.dataset.redirect!

  // ── Elementos ───────────────────────────────────────────────
  const prefijoInput  = document.getElementById('prefijo')         as HTMLSelectElement
  const movilInput    = document.getElementById('movil')           as HTMLInputElement
  const passwordInput = document.getElementById('password')        as HTMLInputElement
  const btnLogin      = document.getElementById('btn-login')       as HTMLButtonElement
  const errorEl       = document.getElementById('login-error')!
  const errorText     = document.getElementById('login-error-text')!
  const toggleBtn     = document.getElementById('toggle-password') as HTMLButtonElement

  // ── Limpiar error al escribir ────────────────────────────────
  function ocultarError() {
    errorEl.classList.add('hidden')
    movilInput.classList.remove('border-red-300')
    passwordInput.classList.remove('border-red-300')
  }

  // ── Mostrar error ────────────────────────────────────────────
  function mostrarError(msg: string) {
    errorText.textContent = msg
    errorEl.classList.remove('hidden')
    movilInput.classList.add('border-red-300')
    passwordInput.classList.add('border-red-300')
    // Shake animation en los inputs
    ;[movilInput, passwordInput].forEach(el => {
      el.style.animation = 'none'
      void el.offsetHeight // reflow
      el.style.animation = 'shake .3s ease'
    })
  }

  movilInput.addEventListener('input', () => {
    // Solo dígitos
    movilInput.value = movilInput.value.replace(/\D/g, '')
    ocultarError()
  })
  passwordInput.addEventListener('input', ocultarError)

  // ── Toggle mostrar/ocultar contraseña ────────────────────────
  toggleBtn.addEventListener('click', () => {
    const mostrar = passwordInput.type === 'password'
    passwordInput.type = mostrar ? 'text' : 'password'
    // Cambiar ícono: ojo abierto ↔ ojo tachado
    document.getElementById('eye-icon')!.innerHTML = mostrar
      ? `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>` // ojo tachado
      : `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>` // ojo normal
  })

  // ── Enter en cualquier campo dispara el login ─────────────────
  ;[movilInput, passwordInput].forEach(el => {
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') btnLogin.click()
    })
  })

  // ── Login principal ──────────────────────────────────────────
  btnLogin.addEventListener('click', async () => {
    const prefijo  = prefijoInput.value.trim()
    const movil    = movilInput.value.trim()
    const password = passwordInput.value

    // Validaciones cliente
    if (!movil) {
      mostrarError('Ingresa tu número de móvil.')
      movilInput.focus()
      return
    }
    if (movil.length < 7) {
      mostrarError('El número de móvil parece muy corto.')
      movilInput.focus()
      return
    }
    if (!password) {
      mostrarError('Ingresa tu contraseña.')
      passwordInput.focus()
      return
    }

    // Construir email ficticio — mismo formato que el endpoint de creación
    const emailFicto = `${prefijo}${movil}@tarjetadigital.app`

    btnLogin.disabled    = true
    btnLogin.textContent = 'Verificando...'
    ocultarError()

    const { data, error } = await supabase.auth.signInWithPassword({
      email:    emailFicto,
      password,
    })

    if (error) {
      // Mensajes de error amigables en español
      const msg =
        error.message.includes('Invalid login')   ? 'Número o contraseña incorrectos.' :
        error.message.includes('Email not confirm') ? 'Cuenta no confirmada. Contacta al administrador.' :
        error.message.includes('Too many requests') ? 'Demasiados intentos. Espera un momento.' :
        'Error al ingresar. Intenta de nuevo.'

      mostrarError(msg)
      btnLogin.disabled    = false
      btnLogin.textContent = 'Ingresar'
      passwordInput.value  = '' // limpiar contraseña por seguridad
      passwordInput.focus()
      return
    }

    // ── Login exitoso ────────────────────────────────────────
    btnLogin.textContent = '✓ Ingresando...'

    // Verificar si debe cambiar contraseña (primer login)
    // Consultamos el perfil para ver el flag debe_cambiar_password
    const { data: perfil } = await supabase
      .from('perfiles')
      .select('debe_cambiar_password')
      .eq('user_id', data.user.id)
      .single()

    if (perfil?.debe_cambiar_password) {
      // Redirigir al tab de seguridad para cambiar la contraseña temporal
      window.location.href = '/dashboard/seguridad?primer-login=1'
    } else {
      window.location.href = redirectTo
    }
  })
</script>

<!-- Animación shake para inputs con error -->
<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0) }
    25%       { transform: translateX(-4px) }
    75%       { transform: translateX(4px) }
  }
</style>