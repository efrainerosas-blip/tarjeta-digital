---
// src/pages/auth/login.astro
// Login usuarios — dos columnas, imagen izquierda, formulario derecho.
// Patrón idéntico al proyecto MenuHoy para garantizar que la imagen cargue.
import Layout from '../../layouts/Layout.astro'

const redirectTo = Astro.url.searchParams.get('redirect') ?? '/dashboard'
const errorParam = Astro.url.searchParams.get('error') ?? ''
---

<Layout title="Acceder — Tarjeta Digital">
  <div class="min-h-screen flex bg-white">

    <!-- ── COLUMNA IZQUIERDA — imagen + branding ──────────────── -->
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-slate-900">

      <!-- Imagen Unsplash — profesional con tarjetas de presentación -->
      <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=1974&auto=format&fit=crop')] bg-cover bg-center opacity-60"></div>

      <!-- Overlay degradado -->
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>

      <!-- Contenido sobre la imagen -->
      <div class="relative z-10 flex flex-col justify-between p-14 text-white h-full">

        <!-- Logo arriba -->
        <div class="flex items-start">
          <div class="w-28 h-28 bg-white rounded-[2rem] flex items-center justify-center shadow-[0_8px_30px_rgb(0,0,0,0.2)] ring-4 ring-white/20 overflow-hidden transition-transform hover:scale-105 duration-300">
            <img
              src="/CardVirtual.png"
              alt="Tarjeta Digital"
              class="w-20 h-20 object-contain drop-shadow-sm"
              onerror="this.parentElement.innerHTML='<span class=\'text-5xl\'>🪪</span>'"
            />
          </div>
        </div>

        <!-- Tagline abajo -->
        <div>
          <h2 class="text-5xl font-black mb-4 leading-tight">
            Tu tarjeta digital,<br/>
            <span class="text-indigo-400">siempre contigo.</span>
          </h2>
          <p class="text-white/70 text-lg mb-8">
            Comparte tu perfil profesional con un solo enlace.
          </p>

          <!-- Features -->
          <div class="flex flex-col gap-3">
            {['Sin papel ni impresión', 'Actualización instantánea', 'Siempre disponible'].map(f => (
              <div class="flex items-center gap-3 text-white/80 text-sm">
                <svg class="w-4 h-4 text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
                {f}
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

    <!-- ── COLUMNA DERECHA — formulario ──────────────────────── -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 sm:p-12 bg-slate-50">
      <div class="w-full max-w-[400px] space-y-8">

        <!-- Logo mobile — solo visible cuando la imagen está oculta -->
        <div class="flex justify-center lg:hidden mb-2">
          <div class="w-28 h-28 bg-white shadow-2xl rounded-[2rem] flex items-center justify-center ring-4 ring-indigo-50 overflow-hidden">
            <img
              src="/CardVirtual.png"
              alt="Tarjeta Digital"
              class="w-20 h-20 object-contain"
              onerror="this.parentElement.innerHTML='<span class=\'text-5xl\'>🪪</span>'"
            />
          </div>
        </div>

        <!-- Header -->
        <div>
          <h1 class="text-3xl font-black text-slate-900">Bienvenido</h1>
          <p class="mt-2 text-slate-500">Ingresa con tu número de WhatsApp.</p>
        </div>

        <!-- Error de URL param -->
        {errorParam && (
          <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl text-sm flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
            </svg>
            {errorParam === 'forbidden'
              ? 'No tienes permisos para acceder a esa sección.'
              : 'Sesión expirada. Por favor ingresa de nuevo.'}
          </div>
        )}

        <div class="space-y-5">

          <!-- Campo WhatsApp -->
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2" for="movil">
              Número de WhatsApp
            </label>
            <div class="flex">
              <select
                id="prefijo"
                class="px-3 py-3 rounded-l-xl border border-r-0 border-slate-200 bg-slate-100 text-slate-600 text-sm font-medium outline-none focus:border-indigo-500 cursor-pointer"
              >
                <option value="51">🇵🇪 +51</option>
                <option value="52">🇲🇽 +52</option>
                <option value="57">🇨🇴 +57</option>
                <option value="56">🇨🇱 +56</option>
                <option value="54">🇦🇷 +54</option>
                <option value="34">🇪🇸 +34</option>
                <option value="1">🇺🇸 +1</option>
              </select>
              <input
                type="tel"
                id="movil"
                inputmode="numeric"
                autocomplete="tel"
                placeholder="987654321"
                maxlength="12"
                class="flex-1 px-4 py-3 rounded-r-xl border border-slate-200 bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all outline-none text-slate-900 font-mono text-base tracking-wide placeholder-slate-300"
              />
            </div>
            <p class="text-xs text-slate-400 mt-1">El mismo número que usaste al activar tu cuenta</p>
          </div>

          <!-- Campo contraseña -->
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2" for="password">
              Contraseña
            </label>
            <div class="relative">
              <input
                type="password"
                id="password"
                autocomplete="current-password"
                placeholder="••••••••"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all outline-none text-slate-900 pr-11"
              />
              <button
                type="button"
                id="toggle-password"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors"
                tabindex="-1"
              >
                <svg id="eye-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Error inline -->
          <div id="login-error" class="hidden bg-red-50 border border-red-100 text-red-600 px-4 py-3 rounded-xl text-sm flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <span id="login-error-text"></span>
          </div>

          <!-- Botón ingresar -->
          <button
            id="btn-login"
            type="button"
            class="w-full bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 disabled:opacity-60 disabled:cursor-not-allowed text-base"
          >
            Ingresar
          </button>

        </div>

        <!-- Footer -->
        <div class="text-center space-y-2">
          <p class="text-sm text-slate-400">¿No tienes cuenta? Contacta al administrador.</p>
          <!-- Link admin — muy discreto -->
          <a
            href="/admin/login"
            class="text-xs text-slate-300 hover:text-slate-500 transition-colors block"
          >
            Admin
          </a>
        </div>

      </div>
    </div>

  </div>

  <!-- Config -->
  <div
    id="app-config"
    data-url={import.meta.env.PUBLIC_SUPABASE_URL}
    data-anon={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    data-redirect={redirectTo}
    style="display:none"
  ></div>
</Layout>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25%       { transform: translateX(-4px); }
    75%       { transform: translateX(4px); }
  }
  .shake { animation: shake .3s ease; }
</style>

<script>
  import { createBrowserClient } from '@supabase/ssr'

  const cfg        = document.getElementById('app-config')!
  const supabase   = createBrowserClient(cfg.dataset.url!, cfg.dataset.anon!)
  const redirectTo = cfg.dataset.redirect!

  const prefijoInput  = document.getElementById('prefijo')          as HTMLSelectElement
  const movilInput    = document.getElementById('movil')            as HTMLInputElement
  const passwordInput = document.getElementById('password')         as HTMLInputElement
  const btnLogin      = document.getElementById('btn-login')        as HTMLButtonElement
  const errorEl       = document.getElementById('login-error')      as HTMLDivElement
  const errorText     = document.getElementById('login-error-text') as HTMLSpanElement
  const toggleBtn     = document.getElementById('toggle-password')  as HTMLButtonElement

  function ocultarError() {
    errorEl.classList.add('hidden')
    movilInput.classList.remove('border-red-400')
    passwordInput.classList.remove('border-red-400')
  }

  function mostrarError(msg: string) {
    errorText.textContent = msg
    errorEl.classList.remove('hidden')
    movilInput.classList.add('border-red-400', 'shake')
    passwordInput.classList.add('border-red-400', 'shake')
    setTimeout(() => {
      movilInput.classList.remove('shake')
      passwordInput.classList.remove('shake')
    }, 300)
  }

  movilInput.addEventListener('input', () => {
    movilInput.value = movilInput.value.replace(/\D/g, '')
    ocultarError()
  })
  passwordInput.addEventListener('input', ocultarError)

  // Toggle ojo
  toggleBtn.addEventListener('click', () => {
    const mostrar = passwordInput.type === 'password'
    passwordInput.type = mostrar ? 'text' : 'password'
    document.getElementById('eye-icon')!.innerHTML = mostrar
      ? `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>`
      : `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`
  })

  // Enter dispara login
  ;[movilInput, passwordInput].forEach(el => {
    el.addEventListener('keydown', (e) => { if (e.key === 'Enter') btnLogin.click() })
  })

  // Login
  btnLogin.addEventListener('click', async () => {
    const prefijo  = prefijoInput.value.trim()
    const movil    = movilInput.value.trim()
    const password = passwordInput.value

    if (!movil) { mostrarError('Ingresa tu número de móvil.'); movilInput.focus(); return }
    if (movil.length < 7) { mostrarError('El número parece muy corto.'); movilInput.focus(); return }
    if (!password) { mostrarError('Ingresa tu contraseña.'); passwordInput.focus(); return }

    const emailFicto = `${prefijo}${movil}@tarjetadigital.app`

    btnLogin.disabled    = true
    btnLogin.textContent = 'Verificando...'
    ocultarError()

    const { data, error } = await supabase.auth.signInWithPassword({
      email: emailFicto, password,
    })

    if (error) {
      const msg =
        error.message.includes('Invalid login')    ? 'Número o contraseña incorrectos.' :
        error.message.includes('Email not confirm') ? 'Cuenta no confirmada. Contacta al administrador.' :
        error.message.includes('Too many requests') ? 'Demasiados intentos. Espera un momento.' :
        'Error al ingresar. Intenta de nuevo.'
      mostrarError(msg)
      btnLogin.disabled    = false
      btnLogin.textContent = 'Ingresar'
      passwordInput.value  = ''
      passwordInput.focus()
      return
    }

    btnLogin.textContent = '✓ Ingresando...'

    const { data: perfil } = await supabase
      .from('perfiles')
      .select('debe_cambiar_password')
      .eq('user_id', data.user.id)
      .maybeSingle()

    window.location.href = perfil?.debe_cambiar_password
      ? '/dashboard/seguridad?primer-login=1'
      : redirectTo
  })
</script>