---
import { createServerClient, parseCookieHeader } from '@supabase/ssr'

export const prerender = false;

const requestUrl = new URL(Astro.request.url)
const code = requestUrl.searchParams.get('code')
const next = requestUrl.searchParams.get('redirect') ?? '/dashboard'

if (code) {
  const supabase = createServerClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    {
      cookies: {
        getAll() {
          const parsedCookies = parseCookieHeader(Astro.request.headers.get('Cookie') ?? '')
          return parsedCookies.map(cookie => ({
            name: cookie.name,
            value: cookie.value ?? '' 
          }))
        },
        setAll(cookiesToSet) {
          cookiesToSet.forEach(({ name, value, options }) => {
            Astro.cookies.set(name, value, options)
          })
        },
      },
    }
  )

  const { error } = await supabase.auth.exchangeCodeForSession(code)
  
  if (!error) {
    return Astro.redirect(next)
  }
}

return Astro.redirect('/auth/login?error=InvalidLink')
---