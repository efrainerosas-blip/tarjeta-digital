---
// src/pages/admin/analytics.astro
// Métricas globales del SuperAdmin.
// Lee directamente de perfil_vistas y eventos con service role.
export const prerender = false

import AdminLayout from '../../layouts/AdminLayout.astro'
import { getSupabaseAdmin, isAdmin } from '../../lib/supabase-admin'
import { createServerClient } from '@supabase/ssr'

// ── 1. Verificar sesión + permisos ────────────────────────────
const supabaseAuth = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      getAll() {
        return (Astro.request.headers.get('Cookie') ?? '')
          .split(';').filter(Boolean)
          .map(c => { const [k,...v]=c.trim().split('='); return { name:k, value:v.join('=') } })
      },
      setAll(cs) { cs.forEach(({name,value,options}) => Astro.cookies.set(name,value,options)) },
    },
  }
)

const { data: { user }, error: authError } = await supabaseAuth.auth.getUser()
if (authError || !user || !isAdmin(user.email)) {
  return Astro.redirect('/dashboard?error=forbidden')
}

const db = getSupabaseAdmin()

// ── 2. Fechas de referencia ───────────────────────────────────
const ahora      = new Date()
const hace7d     = new Date(ahora.getTime() - 7  * 24 * 60 * 60 * 1000).toISOString()
const hace30d    = new Date(ahora.getTime() - 30 * 24 * 60 * 60 * 1000).toISOString()

// ── 3. Queries en paralelo ────────────────────────────────────
const [
  { count: totalVistas },
  { count: vistas7d },
  { count: vistas30d },
  { count: totalEventos },
  { count: eventos7d },
  { data: todasVistas },
  { data: todosEventos },
  { data: perfiles },
] = await Promise.all([

  // Totales globales
  db.from('perfil_vistas').select('*', { count: 'exact', head: true }),
  db.from('perfil_vistas').select('*', { count: 'exact', head: true }).gte('visited_at', hace7d),
  db.from('perfil_vistas').select('*', { count: 'exact', head: true }).gte('visited_at', hace30d),
  db.from('eventos').select('*', { count: 'exact', head: true }),
  db.from('eventos').select('*', { count: 'exact', head: true }).gte('created_at', hace7d),

  // Datos para procesar en servidor
  db.from('perfil_vistas')
    .select('perfil_id, visited_at, referrer, user_agent')
    .order('visited_at', { ascending: false })
    .limit(500),        // suficiente para análisis sin sobrecargar

  db.from('eventos')
    .select('perfil_id, tipo, created_at, metadata')
    .order('created_at', { ascending: false })
    .limit(500),

  // Mapa de perfiles para enrichment
  db.from('perfiles').select('id, slug, nombre'),
])

// ── 4. Construir mapa perfil_id → slug ────────────────────────
const perfilMap: Record<string, string> = {}
;(perfiles ?? []).forEach(p => { perfilMap[p.id] = p.slug })

// ── 5. Tarjetas más visitadas (top 5) ────────────────────────
const visitasPorPerfil: Record<string, number> = {}
;(todasVistas ?? []).forEach(v => {
  visitasPorPerfil[v.perfil_id] = (visitasPorPerfil[v.perfil_id] ?? 0) + 1
})
const topPerfiles = Object.entries(visitasPorPerfil)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5)
  .map(([id, count]) => ({ slug: perfilMap[id] ?? id.slice(0, 8), count }))

// ── 6. Breakdown de tipos de eventos ─────────────────────────
const eventosPorTipo: Record<string, number> = {}
;(todosEventos ?? []).forEach(e => {
  eventosPorTipo[e.tipo] = (eventosPorTipo[e.tipo] ?? 0) + 1
})
const topEventos = Object.entries(eventosPorTipo)
  .sort((a, b) => b[1] - a[1])

// ── 7. Breakdown de referrers ─────────────────────────────────
const referrerCount: Record<string, number> = {}
;(todasVistas ?? []).forEach(v => {
  let ref = 'Directo'
  if (v.referrer) {
    try { ref = new URL(v.referrer).hostname.replace('www.', '') }
    catch { ref = v.referrer.slice(0, 30) }
  }
  referrerCount[ref] = (referrerCount[ref] ?? 0) + 1
})
const topReferrers = Object.entries(referrerCount)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)

// ── 8. Breakdown de dispositivos ─────────────────────────────
let mobile = 0, desktop = 0, tablet = 0
;(todasVistas ?? []).forEach(v => {
  const ua = v.user_agent ?? ''
  if (ua.includes('Mobile'))      mobile++
  else if (ua.includes('Tablet')) tablet++
  else                            desktop++
})
const totalUA = mobile + desktop + tablet || 1

// ── 9. Visitas por día (últimos 14 días) ──────────────────────
// Construimos un mapa fecha → count para el sparkline
const hace14d = new Date(ahora.getTime() - 14 * 24 * 60 * 60 * 1000)
const visitasPorDia: Record<string, number> = {}

// Inicializar todos los días en 0
for (let i = 0; i < 14; i++) {
  const d = new Date(hace14d.getTime() + i * 24 * 60 * 60 * 1000)
  const key = d.toISOString().slice(0, 10)
  visitasPorDia[key] = 0
}

;(todasVistas ?? []).forEach(v => {
  if (!v.visited_at) return
  const key = v.visited_at.slice(0, 10)
  if (visitasPorDia[key] !== undefined) {
    visitasPorDia[key]++
  }
})

const diasData    = Object.entries(visitasPorDia).sort((a, b) => a[0].localeCompare(b[0]))
const maxDiaCount = Math.max(...diasData.map(d => d[1]), 1)

// ── 10. Últimas visitas enriquecidas ──────────────────────────
const ultimasVistas = (todasVistas ?? []).slice(0, 12).map(v => ({
  slug:       perfilMap[v.perfil_id] ?? v.perfil_id.slice(0, 8),
  visitedAt:  v.visited_at,
  referrer:   v.referrer,
  dispositivo: (v.user_agent ?? '').includes('Mobile') ? '📱' : '🖥',
}))

// ── Helpers ───────────────────────────────────────────────────
function formatHora(iso: string | null): string {
  if (!iso) return '—'
  return new Date(iso).toLocaleString('es-PE', {
    day: '2-digit', month: 'short',
    hour: '2-digit', minute: '2-digit',
  })
}
function formatRef(ref: string | null): string {
  if (!ref) return 'Directo'
  try { return new URL(ref).hostname.replace('www.', '') }
  catch { return ref.slice(0, 25) }
}
function pct(n: number, total: number): number {
  return Math.round((n / total) * 100)
}

// Etiquetas legibles para tipos de eventos
const EVENTO_LABELS: Record<string, string> = {
  vista:          '👁 Vista de tarjeta',
  click_red:      '🔗 Clic en red social',
  descarga_cv:    '📄 Descarga de CV',
  click_proyecto: '🚀 Clic en proyecto',
}
---

<AdminLayout title="Analytics" tabActivo="analytics" user={{ email: user.email!, id: user.id }}>

  <div class="page-header">
    <h1 class="page-title">Analytics global</h1>
    <p class="page-desc">Métricas de todas las tarjetas de la plataforma.</p>
  </div>

  <!-- ── STAT CARDS PRINCIPALES ────────────────────────────── -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;margin-bottom:28px">

    <div class="stat-card">
      <div class="stat-label">Visitas totales</div>
      <div class="stat-value">{totalVistas ?? 0}</div>
      <div class="stat-delta up">↑ {vistas7d ?? 0} esta semana</div>
    </div>

    <div class="stat-card">
      <div class="stat-label">Visitas (30 días)</div>
      <div class="stat-value">{vistas30d ?? 0}</div>
      <div class="stat-delta" style="color:var(--text-3)">Último mes</div>
    </div>

    <div class="stat-card">
      <div class="stat-label">Eventos totales</div>
      <div class="stat-value">{totalEventos ?? 0}</div>
      <div class="stat-delta up">↑ {eventos7d ?? 0} esta semana</div>
    </div>

    <div class="stat-card">
      <div class="stat-label">Tasa de interacción</div>
      <div class="stat-value">
        {(totalVistas ?? 0) > 0
          ? `${pct(totalEventos ?? 0, totalVistas ?? 1)}%`
          : '—'
        }
      </div>
      <div class="stat-delta" style="color:var(--text-3)">Eventos / Visitas</div>
    </div>

  </div>

  <!-- ── SPARKLINE DE VISITAS (14 días) ────────────────────── -->
  <div class="section-card" style="margin-bottom:20px">
    <div class="section-card-title">
      <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/>
      </svg>
      Visitas por día — últimos 14 días
    </div>

    <!-- Barras del sparkline generadas en servidor, sin JS ni canvas -->
    <div style="display:flex;align-items:flex-end;gap:4px;height:80px;padding-bottom:24px;position:relative">
      {diasData.map(([fecha, count]) => {
        const h   = maxDiaCount > 0 ? Math.max(4, Math.round((count / maxDiaCount) * 72)) : 4
        const dia = new Date(fecha + 'T12:00:00').toLocaleDateString('es-PE', { day: '2-digit', month: 'short' })
        return (
          <div
            title={`${dia}: ${count} vista${count !== 1 ? 's' : ''}`}
            style={`
              flex: 1;
              height: ${h}px;
              background: ${count > 0 ? 'var(--admin)' : 'var(--bg-4)'};
              border-radius: 3px 3px 0 0;
              opacity: ${count > 0 ? 0.7 + (count / maxDiaCount) * 0.3 : 0.3};
              transition: opacity .15s;
              cursor: default;
              position: relative;
            `}
          >
          </div>
        )
      })}
      {/* Línea base */}
      <div style="position:absolute;bottom:24px;left:0;right:0;height:1px;background:var(--border)"></div>
    </div>

    {/* Etiquetas de fecha inicio/fin */}
    <div style="display:flex;justify-content:space-between;margin-top:4px">
      <span style="font-size:10px;color:var(--text-3);font-family:var(--font-mono)">
        {diasData[0]?.[0] ? new Date(diasData[0][0] + 'T12:00:00').toLocaleDateString('es-PE', { day: '2-digit', month: 'short' }) : ''}
      </span>
      <span style="font-size:10px;color:var(--text-3);font-family:var(--font-mono)">
        {diasData[diasData.length - 1]?.[0] ? new Date(diasData[diasData.length - 1][0] + 'T12:00:00').toLocaleDateString('es-PE', { day: '2-digit', month: 'short' }) : ''}
      </span>
    </div>
  </div>

  <!-- ── FILA DE 3 COLUMNAS ─────────────────────────────────── -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;margin-bottom:20px">

    <!-- Top tarjetas -->
    <div class="section-card" style="margin-bottom:0">
      <div class="section-card-title">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/>
        </svg>
        Top tarjetas
      </div>
      {topPerfiles.length === 0 ? (
        <p style="font-size:12px;color:var(--text-3);text-align:center;padding:12px 0">Sin datos aún</p>
      ) : (
        <div style="display:flex;flex-direction:column;gap:8px">
          {topPerfiles.map(({ slug, count }, i) => (
            <div style="display:flex;align-items:center;gap:8px">
              <span style={`font-size:11px;font-weight:700;color:${i === 0 ? 'var(--warn)' : 'var(--text-3)'};width:16px;flex-shrink:0`}>
                #{i + 1}
              </span>
              <a
                href={`/${slug}`}
                target="_blank"
                style="font-size:12px;font-family:var(--font-mono);color:var(--accent-2);text-decoration:none;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
              >
                /{slug}
              </a>
              <span style="font-size:12px;font-weight:600;color:var(--text-1);flex-shrink:0">
                {count}
              </span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Tipos de eventos -->
    <div class="section-card" style="margin-bottom:0">
      <div class="section-card-title">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
        </svg>
        Eventos por tipo
      </div>
      {topEventos.length === 0 ? (
        <p style="font-size:12px;color:var(--text-3);text-align:center;padding:12px 0">Sin eventos aún</p>
      ) : (
        <div style="display:flex;flex-direction:column;gap:8px">
          {topEventos.map(([tipo, count]) => {
            const total = topEventos.reduce((s, [,c]) => s + c, 0)
            const width = pct(count, total)
            return (
              <div>
                <div style="display:flex;justify-content:space-between;margin-bottom:3px">
                  <span style="font-size:11px;color:var(--text-2)">
                    {EVENTO_LABELS[tipo] ?? tipo}
                  </span>
                  <span style="font-size:11px;font-weight:600;color:var(--text-1)">{count}</span>
                </div>
                <div style="height:4px;background:var(--bg-4);border-radius:99px;overflow:hidden">
                  <div style={`height:100%;width:${width}%;background:var(--admin);border-radius:99px;transition:width .3s`}></div>
                </div>
              </div>
            )
          })}
        </div>
      )}
    </div>

    <!-- Dispositivos -->
    <div class="section-card" style="margin-bottom:0">
      <div class="section-card-title">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 15.75h3"/>
        </svg>
        Dispositivos
      </div>
      <div style="display:flex;flex-direction:column;gap:10px">
        {[
          { label: '🖥 Desktop', count: desktop },
          { label: '📱 Móvil',   count: mobile  },
          { label: '📱 Tablet',  count: tablet  },
        ].map(({ label, count: c }) => (
          <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:3px">
              <span style="font-size:12px;color:var(--text-2)">{label}</span>
              <span style="font-size:12px;font-weight:600;color:var(--text-1)">
                {pct(c, totalUA)}%
              </span>
            </div>
            <div style="height:5px;background:var(--bg-4);border-radius:99px;overflow:hidden">
              <div style={`height:100%;width:${pct(c, totalUA)}%;background:var(--accent);border-radius:99px`}></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Referrers debajo de dispositivos -->
      <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
        <div style="font-size:12px;font-weight:600;color:var(--text-2);margin-bottom:10px">
          Fuentes de tráfico
        </div>
        {topReferrers.length === 0 ? (
          <p style="font-size:12px;color:var(--text-3)">Sin datos</p>
        ) : (
          <div style="display:flex;flex-direction:column;gap:6px">
            {topReferrers.map(([ref, count]) => {
              const total = topReferrers.reduce((s, [,c]) => s + c, 0)
              return (
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px">
                  <span style="font-size:11px;color:var(--text-3);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    {ref}
                  </span>
                  <span style="font-size:11px;font-weight:600;color:var(--text-1);flex-shrink:0">
                    {count}
                  </span>
                  <span style="font-size:10px;color:var(--text-3);flex-shrink:0">
                    {pct(count, total)}%
                  </span>
                </div>
              )
            })}
          </div>
        )}
      </div>
    </div>

  </div>

  <!-- ── TABLA DE ÚLTIMAS VISITAS ───────────────────────────── -->
  <div class="section-card" style="margin-bottom:0">
    <div class="section-card-title">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Últimas visitas
    </div>
    {ultimasVistas.length === 0 ? (
      <p style="font-size:13px;color:var(--text-3);text-align:center;padding:20px 0">
        Sin visitas registradas aún
      </p>
    ) : (
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Tarjeta</th>
              <th>Dispositivo</th>
              <th>Fuente</th>
              <th>Fecha y hora</th>
            </tr>
          </thead>
          <tbody>
            {ultimasVistas.map(v => (
              <tr>
                <td>
                  <a
                    href={`/${v.slug}`}
                    target="_blank"
                    style="font-family:var(--font-mono);font-size:12px;color:var(--accent-2);text-decoration:none"
                  >
                    /{v.slug}
                  </a>
                </td>
                <td style="font-size:16px">{v.dispositivo}</td>
                <td style="font-size:12px;color:var(--text-3)">{formatRef(v.referrer)}</td>
                <td>
                  <span style="font-size:11px;font-family:var(--font-mono);color:var(--text-3)">
                    {formatHora(v.visitedAt)}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

</AdminLayout>