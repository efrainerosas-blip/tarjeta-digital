---
// src/pages/admin/index.astro
// Dashboard global del SuperAdmin.

export const prerender = false

import AdminLayout from '../../layouts/AdminLayout.astro'
import { getSupabaseAdmin, isAdmin } from '../../lib/supabase-admin'
import { createServerClient } from '@supabase/ssr'

// ── 1. Verificar sesión ───────────────────────────────────────
const supabaseAuth = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      getAll() {
        return (Astro.request.headers.get('Cookie') ?? '')
          .split(';').filter(Boolean)
          .map(c => { const [k,...v]=c.trim().split('='); return { name:k, value:v.join('=') } })
      },
      setAll(cs) { cs.forEach(({name,value,options}) => Astro.cookies.set(name,value,options)) },
    },
  }
)

const { data: { user }, error: authError } = await supabaseAuth.auth.getUser()

// Doble capa: middleware ya bloqueó, pero verificamos de nuevo en la página
if (authError || !user || !isAdmin(user.email)) {
  return Astro.redirect('/dashboard?error=forbidden')
}

// ── 2. Cargar stats con el cliente admin (service role, sin RLS) ─
const db = getSupabaseAdmin()

// Todas las queries en paralelo para minimizar latencia
const [
  { count: totalPerfiles },
  { count: nuevos7d },
  { count: totalVistas },
  { count: totalEventos },
  { data: planBreakdown },
  { data: ultimosPerfiles },
  { data: ultimasVistas },
] = await Promise.all([

  // Total de perfiles
  db.from('perfiles').select('*', { count: 'exact', head: true }),

  // Nuevos en últimos 7 días
  db.from('perfiles')
    .select('*', { count: 'exact', head: true })
    .gte('created_at', new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString()),

  // Total de visitas
  db.from('perfil_vistas').select('*', { count: 'exact', head: true }),

  // Total de eventos (clics en redes, descargas CV, etc.)
  db.from('eventos').select('*', { count: 'exact', head: true }),

  // Breakdown por plan
  db.from('perfiles').select('plan_id'),

  // Últimos 8 perfiles registrados
  db.from('perfiles')
    .select('id, slug, nombre, apellidos, plan_id, created_at, foto_url, template_id')
    .order('created_at', { ascending: false })
    .limit(8),

  // Últimas 10 visitas con info del perfil
  db.from('perfil_vistas')
    .select('id, perfil_id, visited_at, referrer, user_agent')
    .order('visited_at', { ascending: false })
    .limit(10),
])

// ── 3. Calcular breakdown de planes ──────────────────────────
// Agrupa manualmente porque Supabase no tiene GROUP BY en el cliente
const planCount: Record<string, number> = {}
;(planBreakdown ?? []).forEach(p => {
  const plan = p.plan_id ?? 'sin plan'
  planCount[plan] = (planCount[plan] ?? 0) + 1
})

// ── 4. Enriquecer vistas con nombre del perfil ────────────────
// Construimos un mapa id→slug para mostrar en la tabla de actividad
const perfilMap: Record<string, string> = {}
;(ultimosPerfiles ?? []).forEach(p => { perfilMap[p.id] = p.slug })

// Para las vistas que pueden tener perfiles no en los últimos 8,
// hacemos una query adicional solo si hay IDs sin mapear
const vistasIds = [...new Set((ultimasVistas ?? []).map(v => v.perfil_id))]
const idsNuevos = vistasIds.filter(id => !perfilMap[id])

if (idsNuevos.length > 0) {
  const { data: extraPerfiles } = await db
    .from('perfiles')
    .select('id, slug')
    .in('id', idsNuevos)
  ;(extraPerfiles ?? []).forEach(p => { perfilMap[p.id] = p.slug })
}

// ── 5. Helpers de formato ─────────────────────────────────────
function formatFecha(iso: string | null): string {
  if (!iso) return '—'
  return new Date(iso).toLocaleDateString('es-PE', {
    day: '2-digit', month: 'short', year: 'numeric'
  })
}

function formatHora(iso: string | null): string {
  if (!iso) return '—'
  return new Date(iso).toLocaleTimeString('es-PE', {
    hour: '2-digit', minute: '2-digit'
  })
}

function formatReferrer(ref: string | null): string {
  if (!ref) return 'Directo'
  try {
    return new URL(ref).hostname.replace('www.', '')
  } catch {
    return ref.slice(0, 30)
  }
}

function formatUA(ua: string | null): string {
  if (!ua) return '—'
  if (ua.includes('Mobile')) return '📱 Móvil'
  if (ua.includes('Tablet')) return '📱 Tablet'
  return '🖥 Desktop'
}
---

<AdminLayout title="Overview" tabActivo="overview" user={{ email: user.email!, id: user.id }}>

  <div class="page-header">
    <h1 class="page-title">Overview</h1>
    <p class="page-desc">Estado global de la plataforma en tiempo real.</p>
  </div>

  <!-- ── STAT CARDS ─────────────────────────────────────────── -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:28px">

    <!-- Total usuarios -->
    <div class="stat-card">
      <div class="stat-label">
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:inline;margin-right:4px">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
        </svg>
        Usuarios totales
      </div>
      <div class="stat-value">{totalPerfiles ?? 0}</div>
      <div class="stat-delta up">
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18"/>
        </svg>
        {nuevos7d ?? 0} nuevos esta semana
      </div>
    </div>

    <!-- Total visitas -->
    <div class="stat-card">
      <div class="stat-label">
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:inline;margin-right:4px">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><circle cx="12" cy="12" r="3"/>
        </svg>
        Visitas totales
      </div>
      <div class="stat-value">{totalVistas ?? 0}</div>
      <div class="stat-delta" style="color:var(--text-3)">Todas las tarjetas</div>
    </div>

    <!-- Total eventos -->
    <div class="stat-card">
      <div class="stat-label">
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:inline;margin-right:4px">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
        </svg>
        Eventos
      </div>
      <div class="stat-value">{totalEventos ?? 0}</div>
      <div class="stat-delta" style="color:var(--text-3)">Clics, descargas, etc.</div>
    </div>

    <!-- Plan breakdown -->
    <div class="stat-card">
      <div class="stat-label">
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:inline;margin-right:4px">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/>
        </svg>
        Distribución planes
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;margin-top:4px">
        {Object.entries(planCount).map(([plan, count]) => (
          <div style="display:flex;align-items:center;justify-content:space-between;gap:8px">
            <span class={`badge badge-${plan === 'premium' ? 'premium' : 'free'}`} style="font-size:10px">
              {plan}
            </span>
            <span style="font-size:18px;font-weight:700;color:var(--text-1);font-variant-numeric:tabular-nums">
              {count}
            </span>
          </div>
        ))}
        {Object.keys(planCount).length === 0 && (
          <span style="font-size:13px;color:var(--text-3)">Sin datos</span>
        )}
      </div>
    </div>

  </div>

  <!-- ── DOS COLUMNAS: últimos usuarios + actividad reciente ── -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start">

    <!-- Últimos usuarios registrados -->
    <div class="section-card" style="margin-bottom:0">
      <div class="section-card-title">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
        </svg>
        Últimos registros
        <a href="/admin/usuarios" style="margin-left:auto;font-size:11px;color:var(--text-3);text-decoration:none;font-weight:400">
          Ver todos →
        </a>
      </div>

      {(ultimosPerfiles ?? []).length === 0 ? (
        <p style="font-size:13px;color:var(--text-3);text-align:center;padding:20px 0">
          Sin registros aún
        </p>
      ) : (
        <div style="display:flex;flex-direction:column;gap:8px">
          {(ultimosPerfiles ?? []).map(p => (
            <div style="display:flex;align-items:center;gap:10px;padding:10px;background:var(--bg-3);border-radius:var(--radius);border:1px solid var(--border)">
              <!-- Avatar -->
              <div style={`width:32px;height:32px;border-radius:50%;background:var(--bg-4);overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--text-3)`}>
                {p.foto_url
                  ? <img src={p.foto_url} style="width:100%;height:100%;object-fit:cover" alt="" />
                  : (p.nombre?.[0] ?? '?').toUpperCase()
                }
              </div>
              <!-- Info -->
              <div style="flex:1;min-width:0">
                <div style="font-size:13px;font-weight:600;color:var(--text-1);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                  {p.nombre} {p.apellidos ?? ''}
                </div>
                <div style="font-size:11px;color:var(--text-3)">
                  /{p.slug} · {formatFecha(p.created_at)}
                </div>
              </div>
              <!-- Plan badge -->
              <span class={`badge badge-${p.plan_id === 'premium' ? 'premium' : 'free'}`} style="font-size:10px;flex-shrink:0">
                {p.plan_id ?? 'free'}
              </span>
              <!-- Ver tarjeta -->
              <a
                href={`/${p.slug}`}
                target="_blank"
                title="Ver tarjeta"
                style="color:var(--text-3);display:flex;flex-shrink:0"
              >
                <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Actividad reciente (últimas visitas) -->
    <div class="section-card" style="margin-bottom:0">
      <div class="section-card-title">
        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
        </svg>
        Actividad reciente
        <a href="/admin/analytics" style="margin-left:auto;font-size:11px;color:var(--text-3);text-decoration:none;font-weight:400">
          Ver analytics →
        </a>
      </div>

      {(ultimasVistas ?? []).length === 0 ? (
        <p style="font-size:13px;color:var(--text-3);text-align:center;padding:20px 0">
          Sin visitas registradas aún
        </p>
      ) : (
        <div style="display:flex;flex-direction:column;gap:6px">
          {(ultimasVistas ?? []).map(v => (
            <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:var(--bg-3);border-radius:var(--radius);border:1px solid var(--border)">
              <!-- Ícono de dispositivo -->
              <span style="font-size:16px;flex-shrink:0">{formatUA(v.user_agent).split(' ')[0]}</span>
              <!-- Info -->
              <div style="flex:1;min-width:0">
                <div style="font-size:12px;font-weight:600;color:var(--text-1)">
                  /{perfilMap[v.perfil_id] ?? v.perfil_id.slice(0,8)}
                </div>
                <div style="font-size:11px;color:var(--text-3)">
                  {formatReferrer(v.referrer)} · {formatUA(v.user_agent).split(' ').slice(1).join(' ')}
                </div>
              </div>
              <!-- Hora -->
              <span style="font-size:11px;color:var(--text-3);flex-shrink:0;font-family:var(--font-mono)">
                {formatHora(v.visited_at)}
              </span>
            </div>
          ))}
        </div>
      )}
    </div>

  </div>

  <!-- ── ACCESOS RÁPIDOS ─────────────────────────────────────── -->
  <div style="margin-top:24px;display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px">

    <a href="/admin/usuarios" style="display:flex;align-items:center;gap:10px;padding:14px 16px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);text-decoration:none;color:var(--text-2);transition:all var(--transition);font-size:13px;font-weight:500" onmouseover="this.style.borderColor='var(--admin-border)';this.style.color='var(--text-1)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-2)'">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0;color:var(--admin)">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
      </svg>
      Gestionar usuarios
    </a>

    <a href="/admin/planes" style="display:flex;align-items:center;gap:10px;padding:14px 16px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);text-decoration:none;color:var(--text-2);transition:all var(--transition);font-size:13px;font-weight:500" onmouseover="this.style.borderColor='var(--admin-border)';this.style.color='var(--text-1)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-2)'">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0;color:var(--admin)">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 6h.008v.008H6V6z"/>
      </svg>
      Editar planes
    </a>

    <a href="/admin/analytics" style="display:flex;align-items:center;gap:10px;padding:14px 16px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);text-decoration:none;color:var(--text-2);transition:all var(--transition);font-size:13px;font-weight:500" onmouseover="this.style.borderColor='var(--admin-border)';this.style.color='var(--text-1)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-2)'">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0;color:var(--admin)">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
      </svg>
      Ver analytics
    </a>

    <a href="/dashboard" style="display:flex;align-items:center;gap:10px;padding:14px 16px;background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);text-decoration:none;color:var(--text-2);transition:all var(--transition);font-size:13px;font-weight:500" onmouseover="this.style.borderColor='var(--border-2)';this.style.color='var(--text-1)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-2)'">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0;color:var(--text-3)">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"/>
      </svg>
      Mi dashboard
    </a>

  </div>

</AdminLayout>