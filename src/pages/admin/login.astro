---
// src/pages/admin/login.astro
// Login exclusivo SuperAdmin — fondo oscuro, email + contraseña.
// URL: /admin/login
export const prerender = false

import Layout from '../../layouts/Layout.astro'
import { createServerClient } from '@supabase/ssr'
import { isAdmin } from '../../lib/supabase-admin'

// Si ya tiene sesión admin válida → redirigir directo
const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      getAll() {
        return (Astro.request.headers.get('Cookie') ?? '')
          .split(';').filter(Boolean)
          .map(c => { const [k,...v]=c.trim().split('='); return { name:k, value:v.join('=') } })
      },
      setAll(cs) { cs.forEach(({name,value,options}) => Astro.cookies.set(name,value,options)) },
    },
  }
)

const { data: { user } } = await supabase.auth.getUser()
if (user && await isAdmin(user.email)) return Astro.redirect('/admin')
---

<Layout title="Admin Portal — Tarjeta Digital">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 p-4">
    <div class="w-full max-w-md">

      <!-- Logo + título -->
      <div class="text-center mb-8">
        <div class="w-20 h-20 bg-white/10 backdrop-blur-sm rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-2xl ring-2 ring-white/10 overflow-hidden">
          <img
            src="/CardVirtual-logo.png"
            alt="Tarjeta Digital"
            class="w-14 h-14 object-contain"
            onerror="this.parentElement.innerHTML='<span class=\'text-4xl\'>👑</span>'"
          />
        </div>
        <h1 class="text-3xl font-black text-white">Admin Portal</h1>
        <p class="text-slate-400 text-sm mt-2">Panel de super administrador</p>
      </div>

      <!-- Card -->
      <div class="bg-slate-800/50 backdrop-blur-xl rounded-2xl p-8 border border-slate-700/50 shadow-2xl">

        <!-- Error banner -->
        <div id="error-banner" class="hidden bg-red-500/10 border border-red-500/50 text-red-400 px-4 py-3 rounded-xl text-sm flex items-center gap-2 mb-6">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
          </svg>
          <span id="error-text"></span>
        </div>

        <div class="space-y-5">

          <!-- Email -->
          <div>
            <label class="block text-sm font-bold text-slate-300 mb-2" for="email">
              Email
            </label>
            <input
              type="email"
              id="email"
              autocomplete="email"
              placeholder="admin@tudominio.com"
              class="w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 focus:border-red-500 focus:ring-2 focus:ring-red-500/20 transition-all outline-none text-white placeholder-slate-600"
            />
          </div>

          <!-- Contraseña -->
          <div>
            <label class="block text-sm font-bold text-slate-300 mb-2" for="password">
              Contraseña
            </label>
            <div class="relative">
              <input
                type="password"
                id="password"
                autocomplete="current-password"
                placeholder="••••••••"
                class="w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 focus:border-red-500 focus:ring-2 focus:ring-red-500/20 transition-all outline-none text-white placeholder-slate-600 pr-11"
              />
              <button
                type="button"
                id="toggle-pass"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-300 transition-colors"
                tabindex="-1"
              >
                <svg id="eye-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Botón -->
          <button
            id="btn-ingresar"
            type="button"
            class="w-full bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-red-500/20 hover:shadow-red-500/40 disabled:opacity-60 disabled:cursor-not-allowed text-base"
          >
            Ingresar al Dashboard
          </button>

        </div>

        <!-- Volver -->
        <div class="mt-6 pt-6 border-t border-slate-700/50 text-center">
          <a
            href="/auth/login"
            class="text-sm text-slate-400 hover:text-slate-300 transition-colors"
          >
            ← Volver al login de usuarios
          </a>
        </div>

      </div>

      <!-- Security badge -->
      <p class="text-center text-slate-500 text-xs mt-6">
        🔒 Conexión segura • Solo personal autorizado
      </p>

    </div>
  </div>

  <!-- Config -->
  <div
    id="app-config"
    data-url={import.meta.env.PUBLIC_SUPABASE_URL}
    data-anon={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    style="display:none"
  ></div>
</Layout>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25%       { transform: translateX(-4px); }
    75%       { transform: translateX(4px); }
  }
  .shake { animation: shake .3s ease; }
</style>

<script>
  import { createBrowserClient } from '@supabase/ssr'

  const cfg = document.getElementById('app-config')!
  const sb  = createBrowserClient(cfg.dataset.url!, cfg.dataset.anon!)

  const emailInput  = document.getElementById('email')          as HTMLInputElement
  const passInput   = document.getElementById('password')       as HTMLInputElement
  const btnIngresar = document.getElementById('btn-ingresar')   as HTMLButtonElement
  const errorBanner = document.getElementById('error-banner')   as HTMLDivElement
  const errorText   = document.getElementById('error-text')     as HTMLSpanElement
  const togglePass  = document.getElementById('toggle-pass')    as HTMLButtonElement

  function ocultarError() {
    errorBanner.classList.add('hidden')
    emailInput.classList.remove('border-red-500', 'shake')
    passInput.classList.remove('border-red-500', 'shake')
  }

  function mostrarError(msg: string) {
    errorText.textContent = msg
    errorBanner.classList.remove('hidden')
    emailInput.classList.add('border-red-500', 'shake')
    passInput.classList.add('border-red-500', 'shake')
    setTimeout(() => {
      emailInput.classList.remove('shake')
      passInput.classList.remove('shake')
    }, 300)
  }

  emailInput.addEventListener('input', ocultarError)
  passInput.addEventListener('input',  ocultarError)

  togglePass.addEventListener('click', () => {
    const mostrar = passInput.type === 'password'
    passInput.type = mostrar ? 'text' : 'password'
    document.getElementById('eye-icon')!.innerHTML = mostrar
      ? `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>`
      : `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`
  })

  ;[emailInput, passInput].forEach(el => {
    el.addEventListener('keydown', (e) => { if (e.key === 'Enter') btnIngresar.click() })
  })

  btnIngresar.addEventListener('click', async () => {
    const email    = emailInput.value.trim().toLowerCase()
    const password = passInput.value

    if (!email)    { mostrarError('Ingresa tu email.'); emailInput.focus(); return }
    if (!password) { mostrarError('Ingresa tu contraseña.'); passInput.focus(); return }

    btnIngresar.disabled    = true
    btnIngresar.textContent = 'Verificando...'
    ocultarError()

    const { error } = await sb.auth.signInWithPassword({ email, password })

    if (error) {
      const msg =
        error.message.includes('Invalid login')    ? 'Email o contraseña incorrectos.' :
        error.message.includes('Too many requests') ? 'Demasiados intentos. Espera un momento.' :
        'Error al ingresar. Intenta de nuevo.'
      mostrarError(msg)
      btnIngresar.disabled    = false
      btnIngresar.textContent = 'Ingresar al Dashboard'
      passInput.value = ''
      passInput.focus()
      return
    }

    // El middleware de /admin verifica isAdmin() — si no es admin lo bloquea
    btnIngresar.textContent = '✓ Accediendo...'
    window.location.href = '/admin'
  })
</script>