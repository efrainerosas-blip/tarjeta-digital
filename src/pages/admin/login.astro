---
// src/pages/admin/login.astro
export const prerender = false
import { createServerClient } from '@supabase/ssr'
import { isAdmin } from '../../lib/supabase-admin'

const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      getAll() {
        return (Astro.request.headers.get('Cookie') ?? '')
          .split(';').filter(Boolean)
          .map(c => { const [k,...v]=c.trim().split('='); return { name:k, value:v.join('=') } })
      },
      setAll(cs) { cs.forEach(({name,value,options}) => Astro.cookies.set(name,value,options)) },
    },
  }
)
const { data: { user } } = await supabase.auth.getUser()
if (user && await isAdmin(user.email)) return Astro.redirect('/admin')
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="supabase-url"  content={import.meta.env.PUBLIC_SUPABASE_URL} />
  <meta name="supabase-anon" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Admin Portal — CardVirtual</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'Geist', -apple-system, sans-serif;
      -webkit-font-smoothing: antialiased;
      background: #060b18;
      color: #f1f5f9;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      background-image:
        radial-gradient(ellipse at 20% 50%, rgba(0,212,255,.06) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 20%, rgba(75,108,247,.08) 0%, transparent 50%);
    }
    .login-wrap { width: 100%; max-width: 420px; }
    .login-header { text-align: center; margin-bottom: 32px; }
    .logo-container {
      width: 80px; height: 80px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 24px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px;
      box-shadow: 0 8px 32px rgba(0,0,0,.3), 0 0 0 1px rgba(0,212,255,.1);
      overflow: hidden; backdrop-filter: blur(8px);
    }
    .logo-container img { width: 58px; height: 58px; object-fit: contain; }
    .login-header h1 { font-size: 28px; font-weight: 800; color: #f1f5f9; letter-spacing: -.02em; line-height: 1.2; }
    .login-header p  { margin-top: 8px; font-size: 14px; color: #64748b; }
    .admin-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(0,212,255,.1); border: 1px solid rgba(0,212,255,.25);
      color: #00d4ff; font-size: 11px; font-weight: 700;
      letter-spacing: .08em; text-transform: uppercase;
      padding: 4px 12px; border-radius: 99px; margin-top: 12px;
    }
    .login-card {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 20px; padding: 32px;
      backdrop-filter: blur(12px);
      box-shadow: 0 0 0 1px rgba(0,212,255,.05), 0 24px 48px rgba(0,0,0,.4);
    }
    .error-banner {
      display: none; background: rgba(239,68,68,.1);
      border: 1px solid rgba(239,68,68,.3); color: #fca5a5;
      padding: 12px 16px; border-radius: 12px; font-size: 13px;
      align-items: center; gap: 8px; margin-bottom: 20px;
    }
    .error-banner.show { display: flex; }
    .field { margin-bottom: 20px; }
    .field label { display: block; font-size: 13px; font-weight: 600; color: #94a3b8; margin-bottom: 8px; }
    .field input {
      width: 100%; padding: 12px 14px;
      font-family: 'Geist', sans-serif; font-size: 14px;
      color: #f1f5f9; background: rgba(255,255,255,.06);
      border: 1.5px solid rgba(255,255,255,.1);
      border-radius: 12px; outline: none;
      transition: border-color .15s, box-shadow .15s, background .15s;
      -webkit-appearance: none;
    }
    .field input:hover { border-color: rgba(255,255,255,.2); }
    .field input:focus {
      border-color: #00d4ff;
      box-shadow: 0 0 0 3px rgba(0,212,255,.12);
      background: rgba(255,255,255,.08);
    }
    .field input::placeholder { color: #334155; }
    .field input:-webkit-autofill,
    .field input:-webkit-autofill:hover,
    .field input:-webkit-autofill:focus {
      -webkit-box-shadow: 0 0 0 1000px #0f1829 inset !important;
      -webkit-text-fill-color: #f1f5f9 !important;
      border-color: #00d4ff !important;
    }
    .pass-wrap { position: relative; }
    .pass-wrap input { padding-right: 44px; }
    .eye-btn {
      position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; color: #475569;
      padding: 4px; display: flex; transition: color .15s;
    }
    .eye-btn:hover { color: #00d4ff; }
    .btn-login {
      width: 100%; padding: 14px;
      background: linear-gradient(135deg, #4b6cf7, #00d4ff);
      color: #fff; font-family: 'Geist', sans-serif;
      font-size: 15px; font-weight: 700; border: none;
      border-radius: 12px; cursor: pointer;
      transition: opacity .15s, transform .15s, box-shadow .15s;
      box-shadow: 0 4px 20px rgba(0,212,255,.25);
      margin-top: 8px; letter-spacing: -.01em;
    }
    .btn-login:hover { opacity: .92; transform: translateY(-1px); box-shadow: 0 8px 28px rgba(0,212,255,.35); }
    .btn-login:active { transform: translateY(0); }
    .btn-login:disabled { opacity: .45; cursor: not-allowed; transform: none; box-shadow: none; }
    .card-footer { margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,.06); text-align: center; }
    .card-footer a { font-size: 13px; color: #475569; text-decoration: none; transition: color .15s; }
    .card-footer a:hover { color: #94a3b8; }
    .login-footer { text-align: center; margin-top: 24px; font-size: 12px; color: #1e293b; }
    @keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-4px)} 75%{transform:translateX(4px)} }
    .shake { animation: shake .3s ease; }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="login-header">
      <div class="logo-container">
        <img src="/CardVirtual.png" alt="CardVirtual"
          onerror="this.parentElement.innerHTML='<span style=\'font-size:36px\'>👑</span>'" />
      </div>
      <h1>Admin Portal</h1>
      <p>Panel de super administrador</p>
      <div class="admin-badge">
        <svg width="10" height="10" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        SUPER ADMIN
      </div>
    </div>
    <div class="login-card">
      <div class="error-banner" id="error-banner">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
        </svg>
        <span id="error-text"></span>
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" autocomplete="email" placeholder="admin@tudominio.com" />
      </div>
      <div class="field">
        <label for="password">Contraseña</label>
        <div class="pass-wrap">
          <input type="password" id="password" autocomplete="current-password" placeholder="••••••••" />
          <button type="button" class="eye-btn" id="toggle-pass" tabindex="-1">
            <svg id="eye-icon" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </button>
        </div>
      </div>
      <button class="btn-login" id="btn-ingresar" type="button">Ingresar al Dashboard</button>
      <div class="card-footer">
        <a href="/auth/login">← Volver al login de usuarios</a>
      </div>
    </div>
    <p class="login-footer">🔒 Conexión segura · Solo personal autorizado</p>
  </div>

  <div id="app-config"
    data-url={import.meta.env.PUBLIC_SUPABASE_URL}
    data-anon={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
    style="display:none"></div>

  <script>
    import { createBrowserClient } from '@supabase/ssr'
    const cfg = document.getElementById('app-config')!
    const sb  = createBrowserClient(cfg.dataset.url!, cfg.dataset.anon!)
    const emailEl   = document.getElementById('email')        as HTMLInputElement
    const passEl    = document.getElementById('password')     as HTMLInputElement
    const btnEl     = document.getElementById('btn-ingresar') as HTMLButtonElement
    const errorEl   = document.getElementById('error-banner') as HTMLDivElement
    const errorText = document.getElementById('error-text')   as HTMLSpanElement
    const toggleBtn = document.getElementById('toggle-pass')  as HTMLButtonElement
    function hideError() { errorEl.classList.remove('show') }
    function showError(msg: string) {
      errorText.textContent = msg
      errorEl.classList.add('show')
      emailEl.classList.add('shake'); passEl.classList.add('shake')
      setTimeout(() => { emailEl.classList.remove('shake'); passEl.classList.remove('shake') }, 300)
    }
    emailEl.addEventListener('input', hideError)
    passEl.addEventListener('input',  hideError)
    toggleBtn.addEventListener('click', () => {
      const show = passEl.type === 'password'
      passEl.type = show ? 'text' : 'password'
      document.getElementById('eye-icon')!.innerHTML = show
        ? `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/>`
        : `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`
    })
    ;[emailEl, passEl].forEach(el => el.addEventListener('keydown', e => { if (e.key === 'Enter') btnEl.click() }))
    btnEl.addEventListener('click', async () => {
      const email = emailEl.value.trim().toLowerCase()
      const password = passEl.value
      if (!email)    { showError('Ingresa tu email.'); emailEl.focus(); return }
      if (!password) { showError('Ingresa tu contraseña.'); passEl.focus(); return }
      btnEl.disabled = true; btnEl.textContent = 'Verificando...'
      hideError()
      const { error } = await sb.auth.signInWithPassword({ email, password })
      if (error) {
        const msg =
          error.message.includes('Invalid login')     ? 'Email o contraseña incorrectos.' :
          error.message.includes('Too many requests') ? 'Demasiados intentos. Espera un momento.' :
          'Error al ingresar. Intenta de nuevo.'
        showError(msg)
        btnEl.disabled = false; btnEl.textContent = 'Ingresar al Dashboard'
        passEl.value = ''; passEl.focus(); return
      }
      btnEl.textContent = '✓ Accediendo...'
      window.location.href = '/admin'
    })
  </script>
</body>
</html>