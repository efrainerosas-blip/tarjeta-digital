---
// src/pages/dashboard/analytics.astro
export const prerender = false
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import { createServerClient } from '@supabase/ssr'

const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      getAll() { return (Astro.request.headers.get('Cookie') ?? '').split(';').filter(Boolean).map(c => { const [k,...v]=c.trim().split('='); return { name: k, value: v.join('=') } }) },
      setAll(cs) { cs.forEach(({name,value,options}) => Astro.cookies.set(name,value,options)) },
    },
  }
)

const { data: { user }, error: authError } = await supabase.auth.getUser()
if (authError || !user) return Astro.redirect('/auth/login')

const { data: perfil } = await supabase.from('perfiles').select('id,slug,plan_id').eq('user_id', user.id).single()
const perfilId = perfil?.id
const plan = perfil?.plan_id ?? 'free'

// Métricas básicas (disponibles en free)
let totalVistas = 0, vistas7d = 0, vistas30d = 0
let eventosRecientes: any[] = []

if (perfilId) {
  const hace7d  = new Date(Date.now() - 7  * 86400000).toISOString()
  const hace30d = new Date(Date.now() - 30 * 86400000).toISOString()

  const [r1, r2, r3, r4] = await Promise.all([
    supabase.from('perfil_vistas').select('*', { count: 'exact', head: true }).eq('perfil_id', perfilId),
    supabase.from('perfil_vistas').select('*', { count: 'exact', head: true }).eq('perfil_id', perfilId).gte('visited_at', hace7d),
    supabase.from('perfil_vistas').select('*', { count: 'exact', head: true }).eq('perfil_id', perfilId).gte('visited_at', hace30d),
    supabase.from('eventos').select('tipo,metadata,created_at').eq('perfil_id', perfilId).order('created_at', { ascending: false }).limit(10),
  ])
  totalVistas = r1.count ?? 0
  vistas7d    = r2.count ?? 0
  vistas30d   = r3.count ?? 0
  eventosRecientes = r4.data ?? []
}

const tipoLabel: Record<string, string> = {
  click_red:       '🔗 Click en red social',
  click_servicio:  '⚡ Click en servicio',
  click_proyecto:  '📁 Click en proyecto',
  descarga_cv:     '📄 Descarga de CV',
  vista_seccion:   '👁 Vista de sección',
}
---

<DashboardLayout title="Analytics" tabActivo="analytics" user={{ email: user.email!, id: user.id }} slug={perfil?.slug}>

  <div class="page-header">
    <h1 class="page-title">Analytics</h1>
    <p class="page-desc">Métricas de visitas e interacciones en tu tarjeta digital.</p>
  </div>

  {!perfilId && (
    <div style="background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:12px;padding:14px 18px;margin-bottom:20px;font-size:13px;color:var(--warn)">
      ⚠ Primero crea tu <a href="/dashboard" style="color:var(--warn);text-decoration:underline">perfil básico</a> para ver tus métricas.
    </div>
  )}

  <!-- Stats cards -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:24px">
    {[
      { label: 'Vistas totales',    value: totalVistas, icon: '👁',  color: '#6366f1' },
      { label: 'Últimos 7 días',    value: vistas7d,    icon: '📅',  color: '#0ea5e9' },
      { label: 'Últimos 30 días',   value: vistas30d,   icon: '📊',  color: '#10b981' },
      { label: 'Eventos recientes', value: eventosRecientes.length, icon: '⚡', color: '#f59e0b' },
    ].map(stat => (
      <div style={`background:var(--bg-2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;position:relative;overflow:hidden`}>
        <div style={`position:absolute;top:-8px;right:-8px;width:48px;height:48px;border-radius:50%;background:${stat.color};opacity:.08`}></div>
        <div style="font-size:20px;margin-bottom:8px">{stat.icon}</div>
        <div style="font-size:28px;font-weight:700;color:var(--text-1);line-height:1">{stat.value.toLocaleString()}</div>
        <div style="font-size:12px;color:var(--text-3);margin-top:4px">{stat.label}</div>
      </div>
    ))}
  </div>

  <!-- Eventos recientes -->
  <div class="section-card">
    <div class="section-card-title">
      Actividad reciente
      {plan === 'free' && <span class="badge badge-free" style="margin-left:auto">Últimos 10</span>}
    </div>

    {eventosRecientes.length === 0 ? (
      <div style="text-align:center;padding:32px;color:var(--text-3)">
        <div style="font-size:28px;margin-bottom:8px">📭</div>
        <div style="font-size:13px">Sin actividad registrada aún. Comparte tu tarjeta para empezar a ver métricas.</div>
        {perfil?.slug && (
          <a href={`/${perfil.slug}`} target="_blank" class="btn btn-ghost" style="margin-top:12px;font-size:12px">
            Ver mi tarjeta →
          </a>
        )}
      </div>
    ) : (
      <div>
        {eventosRecientes.map(ev => (
          <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border)">
            <div style="font-size:18px;width:28px;text-align:center;flex-shrink:0">
              {tipoLabel[ev.tipo]?.split(' ')[0] ?? '·'}
            </div>
            <div style="flex:1;min-width:0">
              <div style="font-size:13px;color:var(--text-1)">{tipoLabel[ev.tipo]?.slice(2) ?? ev.tipo}</div>
              {ev.metadata && (
                <div style="font-size:11px;color:var(--text-3);font-family:var(--font-mono);margin-top:1px">
                  {JSON.stringify(ev.metadata)}
                </div>
              )}
            </div>
            <div style="font-size:11px;color:var(--text-3);flex-shrink:0">
              {new Date(ev.created_at).toLocaleDateString('es', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' })}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  {plan === 'free' && (
    <div style="margin-top:16px;background:linear-gradient(135deg,rgba(99,102,241,.1),rgba(139,92,246,.1));border:1px solid rgba(99,102,241,.2);border-radius:var(--radius-lg);padding:20px;text-align:center">
      <div style="font-size:20px;margin-bottom:8px">📈</div>
      <div style="font-weight:600;color:var(--text-1);margin-bottom:4px">Analytics avanzado en Pro</div>
      <div style="font-size:13px;color:var(--text-3);margin-bottom:16px">
        Historial ilimitado, gráficos de tendencias, fuentes de tráfico, países y más.
      </div>
      <a href="/dashboard/plan" class="btn btn-primary">Mejorar a Pro →</a>
    </div>
  )}

</DashboardLayout>