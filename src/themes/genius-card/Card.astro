---
// src/themes/genius-card/Card.astro
// THEME: Genius Card — Oscuro elegante con gradiente púrpura/violeta

import type { CardProps } from '../types'

const {
  perfil, experiencia, estudios, habilidades,
  servicios, proyectos, redes, logros, capacitaciones, referencias,
} = Astro.props as CardProps

const accent     = perfil.color_primario ?? '#7C3AED'
const nombre     = [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')
const fotoAvatar = perfil.foto_url || null

const ICONOS: Record<string, string> = {
