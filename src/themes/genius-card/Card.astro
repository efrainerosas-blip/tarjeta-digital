  Behance:     `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.938 4.503c.702 0 1.34.06 1.92.188.577.13 1.07.33 1.485.61.41.28.733.65.96 1.12.225.47.34 1.05.34 1.73 0 .74-.17 1.36-.507 1.86-.338.5-.837.9-1.502 1.22.906.26 1.576.72 2.022 1.37.448.66.665 1.45.665 2.36 0 .75-.13 1.39-.41 1.93-.28.55-.67 1-1.16 1.35-.49.36-1.065.62-1.72.78-.655.16-1.35.25-2.065.25H0V4.51h6.938v-.007zM16.94 16.665c.44.428 1.073.643 1.894.643.59 0 1.1-.148 1.53-.447.424-.29.68-.61.78-.94h2.588c-.403 1.28-1.048 2.2-1.92 2.75-.878.57-1.94.85-3.18.85-1.48 0-2.7-.48-3.654-1.43-.96-.95-1.43-2.28-1.43-3.97 0-1.64.49-2.95 1.46-3.93.97-.97 2.2-1.45 3.68-1.45 1.5 0 2.69.55 3.597 1.64.9 1.09 1.35 2.49 1.35 4.2H16.34c.04.86.26 1.508.7 1.936l-.1.097zm-9.975-6.34h-4.03v2.93h4.01c.547 0 1.006-.12 1.37-.38.36-.25.54-.66.54-1.23 0-.59-.18-1.01-.54-1.25-.36-.24-.81-.07-1.35-.07zm.536-4.55H2.934v2.58h4.01c.458 0 .82-.1 1.096-.3.27-.2.407-.54.407-1.02 0-.48-.143-.82-.43-1.02-.285-.19-.655-.24-1.11-.24h.01zm8.965 3.81c-.45.426-.7 1.056-.75 1.89h4.38c-.1-.85-.38-1.49-.86-1.9-.47-.42-1.05-.63-1.73-.63-.73 0-1.3.21-1.74.64h.7z"/></svg>`,
