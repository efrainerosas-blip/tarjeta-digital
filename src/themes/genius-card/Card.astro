---

<link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" slot="head" />

<style is:inline define:vars={{ accent }}>
  /* ── THEME: Genius Card — prefijo gc- ─────────────────────── */

  .gc-page {
    max-width: 420px;
    margin: 0 auto;
    min-height: 100vh;
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: #0E0B14;
    color: #fff;
    position: relative;
    overflow-x: hidden;
  }

  /* ── FONDO con gradiente púrpura igual que la imagen ─────── */
  .gc-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    max-width: 420px;
    margin: 0 auto;
  }
  .gc-bg::before {
    content: '';
    position: absolute;
    top: -60px; left: -60px;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124,58,237,0.55) 0%, rgba(109,40,217,0.3) 40%, transparent 70%);
    filter: blur(40px);
  }
  .gc-bg::after {
    content: '';
    position: absolute;
    top: 80px; right: -80px;
    width: 260px; height: 260px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(167,139,250,0.25) 0%, transparent 70%);
    filter: blur(50px);
  }
  .gc-bg-bottom {
    position: absolute;
    bottom: 0; left: 0; right: 0; height: 50%;
    background: linear-gradient(to top, #0E0B14 60%, transparent 100%);
  }

  /* ── HERO SUPERIOR ─────────────────────────────────────────── */
  .gc-hero {
    position: relative;
    z-index: 1;
    padding: 56px 24px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  /* Badge "GENIUS" o status pill */
  .gc-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(10px);
    border-radius: 99px;
    padding: 5px 14px 5px 8px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    animation: gc-fadeDown 0.5s ease-out both;
  }
  .gc-status-dot {
    width: 22px; height: 22px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #A78BFA);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px;
  }

  /* Avatar circular con glow y borde degradado */
  .gc-avatar-wrap {
    position: relative;
    animation: gc-fadeDown 0.5s ease-out 0.08s both;
  }
  .gc-avatar-ring {
    width: 128px; height: 128px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--accent), #A78BFA, #60A5FA);
    box-shadow:
      0 0 0 4px rgba(124,58,237,0.2),
      0 0 40px rgba(124,58,237,0.45),
      0 0 80px rgba(124,58,237,0.2);
  }
  .gc-avatar-inner {
    width: 100%; height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, #2D1B69, #1E1040);
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem; font-weight: 900; color: rgba(255,255,255,0.6);
  }
  .gc-avatar-inner img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  /* Nombre y título */
  .gc-name {
    font-size: clamp(2rem, 9vw, 2.6rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.05;
    letter-spacing: -0.03em;
    animation: gc-fadeUp 0.55s ease-out 0.14s both;
    text-shadow: 0 2px 20px rgba(124,58,237,0.4);
  }
  .gc-title {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.04em;
    margin-top: -8px;
    animation: gc-fadeUp 0.55s ease-out 0.18s both;
  }

  /* Redes sociales — fila de círculos con iconos */
  .gc-socials {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    animation: gc-fadeUp 0.55s ease-out 0.24s both;
  }
  .gc-social-btn {
    width: 46px; height: 46px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.16);
    backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .gc-social-btn svg { width: 18px; height: 18px; }
  .gc-social-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px) scale(1.08);
    box-shadow: 0 8px 20px rgba(124,58,237,0.45);
  }

  /* Botones de acción (CV / Contacto) */
  .gc-action-row {
    display: flex;
    gap: 10px;
    width: 100%;
    animation: gc-fadeUp 0.55s ease-out 0.3s both;
  }
  .gc-btn-primary {
    flex: 1;
    display: flex; align-items: center; justify-content: center; gap: 7px;
    padding: 13px 16px;
    background: linear-gradient(135deg, var(--accent), #6D28D9);
    color: #fff;
    border-radius: 14px;
    font-size: 13px; font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 8px 24px rgba(124,58,237,0.45);
  }
  .gc-btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
  .gc-btn-primary svg { width: 15px; height: 15px; }
  .gc-btn-secondary {
    flex: 1;
    display: flex; align-items: center; justify-content: center; gap: 7px;
    padding: 13px 16px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.16);
    color: rgba(255,255,255,0.85);
    border-radius: 14px;
    font-size: 13px; font-weight: 700;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .gc-btn-secondary:hover { background: rgba(255,255,255,0.14); transform: translateY(-1px); }
  .gc-btn-secondary svg { width: 15px; height: 15px; }

  /* Info rápida: ubicación, teléfono */
  .gc-info-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    animation: gc-fadeUp 0.55s ease-out 0.34s both;
  }
  .gc-info-item {
    display: flex; align-items: center; gap: 5px;
    font-size: 12px; color: rgba(255,255,255,0.42);
    text-decoration: none;
  }
  .gc-info-item svg { width: 12px; height: 12px; flex-shrink: 0; }
  .gc-info-item:hover { color: rgba(255,255,255,0.7); }

  /* ── DIVISOR ───────────────────────────────────────────────── */
  .gc-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    margin: 0 24px;
    position: relative; z-index: 1;
  }

  /* ── CONTENIDO (cards acordeón) ────────────────────────────── */
  .gc-content {
    position: relative; z-index: 1;
    padding: 20px 16px 60px;
    display: flex; flex-direction: column; gap: 10px;
  }

  /* Bio */
  .gc-bio {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px;
    padding: 18px 20px;
    font-size: 14px;
    color: rgba(255,255,255,0.72);
    line-height: 1.8;
  }

  /* Acordeón — mismo estilo de card oscura */
  .gc-acc {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .gc-acc:hover { border-color: rgba(124,58,237,0.3); }
  details.gc-acc[open] { border-color: rgba(124,58,237,0.35); }

  .gc-acc summary {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 18px;
    cursor: pointer; list-style: none; user-select: none;
    transition: background 0.15s;
  }
  .gc-acc summary:hover { background: rgba(255,255,255,0.03); }
  .gc-acc summary::-webkit-details-marker { display: none; }

  .gc-acc-left { display: flex; align-items: center; gap: 13px; }
  .gc-acc-icon {
    width: 38px; height: 38px; border-radius: 11px;
    background: linear-gradient(135deg, rgba(124,58,237,0.25), rgba(109,40,217,0.15));
    border: 1px solid rgba(124,58,237,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 17px; flex-shrink: 0;
  }
  .gc-acc-title { font-size: 14px; font-weight: 700; color: #fff; }
  .gc-acc-count { font-size: 11px; color: rgba(255,255,255,0.3); margin-top: 1px; }
  .gc-chevron {
    color: rgba(255,255,255,0.3);
    transition: transform 0.22s, color 0.15s;
    flex-shrink: 0;
  }
  details.gc-acc[open] .gc-chevron { transform: rotate(180deg); color: var(--accent); }

  .gc-acc-body {
    padding: 0 16px 16px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  /* Timeline (experiencia / educación) */
  .gc-timeline { display: flex; flex-direction: column; }
  .gc-tl {
    padding: 14px 0 14px 18px;
    border-left: 1.5px solid rgba(124,58,237,0.3);
    position: relative;
  }
  .gc-tl::before {
    content: '';
    position: absolute; left: -5px; top: 20px;
    width: 8px; height: 8px; border-radius: 50%;
    background: #0E0B14;
    border: 2px solid var(--accent);
    box-shadow: 0 0 6px var(--accent);
  }
  .gc-tl-title  { font-size: 13px; font-weight: 700; color: #fff; }
  .gc-tl-sub    { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 2px; }
  .gc-tl-period {
    display: inline-flex; font-size: 10px; color: rgba(255,255,255,0.28);
    background: rgba(255,255,255,0.06);
    padding: 2px 9px; border-radius: 99px; margin-top: 5px;
  }
  .gc-tl-badge {
    display: inline-flex; font-size: 9px; font-weight: 800;
    padding: 2px 8px; border-radius: 99px; margin-top: 4px;
    background: rgba(124,58,237,0.2);
    color: #A78BFA;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .gc-tl-desc   { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 5px; line-height: 1.6; }

  /* Skills — pills */
  .gc-skills { display: flex; flex-wrap: wrap; gap: 7px; padding-top: 14px; }
  .gc-skill {
    font-size: 11px; font-weight: 600;
    padding: 5px 13px; border-radius: 99px;
    background: rgba(124,58,237,0.15);
    color: #C4B5FD;
    border: 1px solid rgba(124,58,237,0.25);
    transition: background 0.15s, transform 0.15s;
  }
  .gc-skill:hover { background: rgba(124,58,237,0.3); transform: scale(1.03); }

  /* Servicios */
  .gc-services { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
  .gc-service {
    display: flex; gap: 13px;
    padding: 14px 15px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 13px;
    transition: border-color 0.15s;
  }
  .gc-service:hover { border-color: rgba(124,58,237,0.3); }
  .gc-service-ico  { font-size: 24px; flex-shrink: 0; line-height: 1; margin-top: 1px; }
  .gc-service-name { font-size: 13px; font-weight: 700; color: #fff; }
  .gc-service-desc { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 3px; line-height: 1.5; }
  .gc-service-price{ display: inline-flex; font-size: 12px; font-weight: 700; color: #A78BFA; margin-top: 6px; }

  /* Proyectos */
  .gc-projects { display: flex; flex-direction: column; gap: 11px; padding-top: 14px; }
  .gc-project {
    border-radius: 13px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.04);
    transition: border-color 0.15s;
  }
  .gc-project:hover { border-color: rgba(124,58,237,0.3); }
  .gc-project-img  { width: 100%; height: 152px; object-fit: cover; display: block; opacity: 0.82; }
  .gc-project-body { padding: 13px 14px; }
  .gc-project-title{ font-size: 13px; font-weight: 700; color: #fff; }
  .gc-project-desc { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 3px; line-height: 1.5; }
  .gc-project-link {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 700;
    color: #A78BFA; text-decoration: none; margin-top: 8px;
    transition: color 0.15s;
  }
  .gc-project-link:hover { color: #C4B5FD; }

  /* Logros */
  .gc-logros { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
  .gc-logro {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 14px 15px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 13px;
    transition: border-color 0.15s;
  }
  .gc-logro:hover { border-color: rgba(124,58,237,0.3); }
  .gc-logro-num {
    font-size: 1.8rem; font-weight: 900; line-height: 1;
    color: rgba(124,58,237,0.35); min-width: 28px; flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }
  .gc-logro-title { font-size: 13px; font-weight: 700; color: #fff; }
  .gc-logro-desc  { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 3px; line-height: 1.5; }
  .gc-logro-fecha { font-size: 10px; color: rgba(255,255,255,0.28); margin-top: 3px; }

  /* Capacitaciones */
  .gc-caps { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
  .gc-cap {
    display: flex; gap: 12px; align-items: flex-start;
    padding: 13px 15px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 13px;
    transition: border-color 0.15s;
  }
  .gc-cap:hover { border-color: rgba(124,58,237,0.3); }
  .gc-cap-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent); flex-shrink: 0; margin-top: 5px;
    box-shadow: 0 0 6px var(--accent);
  }
  .gc-cap-name  { font-size: 13px; font-weight: 700; color: #fff; }
  .gc-cap-inst  { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 2px; }
  .gc-cap-fecha { font-size: 10px; color: rgba(255,255,255,0.28); margin-top: 3px; }
  .gc-cap-cert  {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 700; color: #A78BFA;
    text-decoration: none; margin-top: 5px;
  }

  /* Referencias */
  .gc-refs { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
  .gc-ref {
    padding: 14px 15px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 13px;
    transition: border-color 0.15s;
  }
  .gc-ref:hover { border-color: rgba(124,58,237,0.3); }
  .gc-ref-name  { font-size: 13px; font-weight: 700; color: #fff; }
  .gc-ref-cargo { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 2px; }
  .gc-ref-obs   { font-size: 12px; color: rgba(255,255,255,0.38); margin-top: 5px; font-style: italic; line-height: 1.5; }
  .gc-ref-links { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px; }
  .gc-ref-link  {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 700; color: #A78BFA; text-decoration: none;
  }

  /* Footer */
  .gc-footer {
    text-align: center; padding: 16px 24px 36px;
    font-size: 11px; color: rgba(255,255,255,0.22);
    letter-spacing: 0.04em; position: relative; z-index: 1;
  }
  .gc-footer a { color: var(--accent); text-decoration: none; font-weight: 700; }

  /* Desktop container */
  @media (min-width: 480px) {
    body { padding: 32px 0 56px; background: #060408 !important; }
    .gc-page {
      border-radius: 36px;
      overflow: hidden;
      box-shadow:
        0 40px 100px rgba(0,0,0,0.7),
        0 0 0 1px rgba(255,255,255,0.06),
        inset 0 0 0 1px rgba(255,255,255,0.03);
    }
    .gc-bg { border-radius: 36px; }
  }

  /* Animaciones */
  @keyframes gc-fadeDown {
    from { opacity: 0; transform: translateY(-16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes gc-fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="gc-page">

  <!-- Fondo con orbes de color -->
  <div class="gc-bg">
    <div class="gc-bg-bottom"></div>
  </div>

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <div class="gc-hero">

    <!-- Badge status / rol -->
    <div class="gc-status-pill">
      <span class="gc-status-dot">✦</span>
      {perfil.status ?? perfil.titulo_profesional ?? 'Disponible'}
    </div>

    <!-- Avatar circular con glow -->
    <div class="gc-avatar-wrap">
      <div class="gc-avatar-ring">
        <div class="gc-avatar-inner">
          {fotoAvatar
            ? <img src={fotoAvatar} alt={nombre} />
            : nombre.charAt(0).toUpperCase()
          }
        </div>
      </div>
    </div>

    <!-- Nombre -->
    <div>
      <h1 class="gc-name">{nombre}</h1>
      {perfil.titulo_profesional && <p class="gc-title">{perfil.titulo_profesional}</p>}
    </div>

    <!-- Info rápida -->
    {(perfil.ubicacion || perfil.telefono) && (
      <div class="gc-info-row">
        {perfil.ubicacion && (
          <span class="gc-info-item">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
            {perfil.ubicacion}
          </span>
        )}
        {perfil.telefono && (
          <a href={`tel:${perfil.telefono.replace(/\s/g,'')}`} class="gc-info-item">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            {perfil.telefono}
          </a>
        )}
      </div>
    )}

    <!-- Redes sociales (iconos circulares) -->
    {redes.length > 0 && (
      <div class="gc-socials">
        {redes.map(red => (
          <a href={red.url} target="_blank" rel="noopener noreferrer"
             class="gc-social-btn track-red" data-plataforma={red.plataforma} title={red.plataforma}>
            <Fragment set:html={icon(red.plataforma)} />
          </a>
        ))}
      </div>
    )}

    <!-- Botones de acción -->
    <div class="gc-action-row">
      {perfil.cv_pdf_url && (
        <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer" class="gc-btn-primary track-cv">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Descargar CV
        </a>
      )}
      {perfil.email && (
        <a href={`mailto:${perfil.email}`} class="gc-btn-secondary">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Contactar
        </a>
      )}
    </div>

  </div>

  <div class="gc-divider"></div>

  <!-- ── CONTENIDO ─────────────────────────────────────────── -->
  <div class="gc-content">

    {perfil.bio && <div class="gc-bio">{perfil.bio}</div>}

    {servicios.length > 0 && (
      <details class="gc-acc">
        <summary>
          <div class="gc-acc-left">
            <div class="gc-acc-icon">⚡</div>
            <div>
              <div class="gc-acc-title">Servicios</div>
              <div class="gc-acc-count">{servicios.length} {servicios.length===1?'servicio':'servicios'}</div>
            </div>
          </div>
          <svg class="gc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="gc-acc-body">
          <div class="gc-services">
            {servicios.map(s => (
              <div class="gc-service">
                {s.icono && <div class="gc-service-ico">{s.icono}</div>}
                <div>
                  <div class="gc-service-name">{s.nombre}</div>
                  {s.descripcion && <p class="gc-service-desc">{s.descripcion}</p>}
                  {s.precio_referencial && <div class="gc-service-price">{s.precio_referencial}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {experiencia.length > 0 && (
      <details class="gc-acc">
        <summary>
          <div class="gc-acc-left">
            <div class="gc-acc-icon">💼</div>
            <div>
              <div class="gc-acc-title">Experiencia</div>
              <div class="gc-acc-count">{experiencia.length} {experiencia.length===1?'posición':'posiciones'}</div>
            </div>
          </div>
          <svg class="gc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="gc-acc-body">
          <div class="gc-timeline">
            {experiencia.map(exp => (
              <div class="gc-tl">
                <div class="gc-tl-title">{exp.cargo}</div>
                <div class="gc-tl-sub">{exp.empresa}</div>
                {exp.periodo && <div class="gc-tl-period">{exp.periodo}</div>}
                {exp.es_trabajo_actual && <div class="gc-tl-badge">Actual</div>}
                {exp.descripcion && <p class="gc-tl-desc">{exp.descripcion}</p>}
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {estudios.length > 0 && (
      <details class="gc-acc">
        <summary>
          <div class="gc-acc-left">
            <div class="gc-acc-icon">🎓</div>
            <div>
              <div class="gc-acc-title">Educación</div>
              <div class="gc-acc-count">{estudios.length} {estudios.length===1?'estudio':'estudios'}</div>
            </div>
          </div>
          <svg class="gc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="gc-acc-body">
          <div class="gc-timeline">
            {estudios.map(e => (
              <div class="gc-tl">
                <div class="gc-tl-title">{e.titulo_obtenido ?? e.nivel}</div>
                <div class="gc-tl-sub">{e.institucion}</div>
                {(e.fecha_inicio || e.fecha_fin) && (
                  <div class="gc-tl-period">{e.fecha_inicio ?? ''}{e.fecha_fin ? ` — ${e.fecha_fin}` : ''}</div>
                )}
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {habilidades.length > 0 && (
      <details class="gc-acc">
        <summary>
          <div class="gc-acc-left">
            <div class="gc-acc-icon">🧠</div>
            <div>
              <div class="gc-acc-title">Habilidades</div>
              <div class="gc-acc-count">{habilidades.length} habilidades</div>
            </div>
          </div>
          <svg class="gc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="gc-acc-body">
          <div class="gc-skills">
            {habilidades.map(h => <span class="gc-skill">{h.nombre}</span>)}
          </div>
        </div>
      </details>
    )}

    {proyectos.length > 0 && (
      <details class="gc-acc">
        <summary>
          <div class="gc-acc-left">
            <div class="gc-acc-icon">🗂</div>
            <div>
              <div class="gc-acc-title">Proyectos</div>
              <div class="gc-acc-count">{proyectos.length} {proyectos.length===1?'proyecto':'proyectos'}</div>
            </div>
          </div>
          <svg class="gc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="gc-acc-body">
          <div class="gc-projects">
            {proyectos.map(p => (
              <div class="gc-project">
                {p.imagen_url && <img src={p.imagen_url} alt={p.titulo} class="gc-project-img" loading="lazy" />}
                <div class="gc-project-body">
                  <div class="gc-project-title">{p.titulo}</div>
                  {p.descripcion && <p class="gc-project-desc">{p.descripcion}</p>}
                  {p.enlace_url && (
                    <a href={p.enlace_url} target="_blank" rel="noopener noreferrer"
                       class="gc-project-link track-proyecto" data-titulo={p.titulo}>
                      Ver proyecto →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {logros.length > 0 && (
      <details class="gc-acc">
        <summary>
          <div class="gc-acc-left">
            <div class="gc-acc-icon">🏆</div>
            <div>
              <div class="gc-acc-title">Logros</div>
              <div class="gc-acc-count">{logros.length} {logros.length===1?'logro':'logros'}</div>
            </div>
          </div>
          <svg class="gc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="gc-acc-body">
          <div class="gc-logros">
            {logros.map((l, i) => (
              <div class="gc-logro">
                <div class="gc-logro-num">0{i + 1}</div>
                <div>
                  <div class="gc-logro-title">{l.titulo}</div>
                  {l.descripcion && <p class="gc-logro-desc">{l.descripcion}</p>}
                  {l.fecha && <div class="gc-logro-fecha">{l.fecha}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {capacitaciones.length > 0 && (
      <details class="gc-acc">
        <summary>
          <div class="gc-acc-left">
            <div class="gc-acc-icon">📚</div>
            <div>
              <div class="gc-acc-title">Cursos</div>
              <div class="gc-acc-count">{capacitaciones.length} cursos</div>
            </div>
          </div>
          <svg class="gc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="gc-acc-body">
          <div class="gc-caps">
            {capacitaciones.map(c => (
              <div class="gc-cap">
                <div class="gc-cap-dot"></div>
                <div>
                  <div class="gc-cap-name">{c.nombre}</div>
                  {c.institucion && <div class="gc-cap-inst">{c.institucion}</div>}
                  {c.fecha && <div class="gc-cap-fecha">{c.fecha}</div>}
                  {c.certificado_url && (
                    <a href={c.certificado_url} target="_blank" rel="noopener noreferrer" class="gc-cap-cert">
                      Ver certificado →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {referencias && referencias.length > 0 && (
      <details class="gc-acc">
        <summary>
          <div class="gc-acc-left">
            <div class="gc-acc-icon">🤝</div>
            <div>
              <div class="gc-acc-title">Referencias</div>
              <div class="gc-acc-count">{referencias.length} {referencias.length===1?'contacto':'contactos'}</div>
            </div>
          </div>
          <svg class="gc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="gc-acc-body">
          <div class="gc-refs">
            {referencias.map(r => (
              <div class="gc-ref">
                <div class="gc-ref-name">{r.nombre}</div>
                {(r.cargo || r.empresa) && (
                  <div class="gc-ref-cargo">{r.cargo}{r.empresa ? ` · ${r.empresa}` : ''}</div>
                )}
                {r.observaciones && <p class="gc-ref-obs">"{r.observaciones}"</p>}
                <div class="gc-ref-links">
                  {r.telefono && (
                    <a href={`tel:${r.telefono.replace(/\s/g,'')}`} class="gc-ref-link">📞 Contactar</a>
                  )}
                  {r.email && (
                    <a href={`mailto:${r.email}`} class="gc-ref-link" style="color:#67E8F9;">✉️ Correo</a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

  </div>

  <footer class="gc-footer">
    Creado con <a href="/">CardVirtual</a>
  </footer>

</div>