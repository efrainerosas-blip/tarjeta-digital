function icon(p: string) {
  return ICONOS[p] ?? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`
}
---

<link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300&display=swap" rel="stylesheet" slot="head" />

<style is:inline define:vars={{ accent, accentText }}>

/* ── VARIABLES & RESET ────────────────────────────────────── */
.ios-page {
  --ios-bg1:      #ddeeff;
  --ios-bg2:      #eef5ff;
  --ios-glass:    rgba(255,255,255,0.72);
  --ios-glass2:   rgba(255,255,255,0.50);
  --ios-border:   rgba(255,255,255,0.80);
  --ios-border2:  rgba(0,0,0,0.07);
  --ios-text:     #0a0a0a;
  --ios-text2:    #3a3a3a;
  --ios-text3:    #8a8a9a;
  --ios-shadow:   0 8px 32px rgba(26,111,245,0.12);
  --ios-r:        20px;
  --ios-font:     'DM Sans', system-ui, -apple-system, sans-serif;

  max-width: 420px;
  margin: 0 auto;
  min-height: 100vh;
  font-family: var(--ios-font);
  background: linear-gradient(160deg, var(--ios-bg1) 0%, #f0f7ff 40%, #ffffff 100%);
  color: var(--ios-text);
  position: relative;
  overflow-x: hidden;
}

/* ── ESFERAS DE FONDO (efecto depth) ─────────────────────── */
.ios-orbs {
  position: fixed; inset: 0;
  pointer-events: none; z-index: 0;
  overflow: hidden;
}
.ios-orb {
  position: absolute; border-radius: 50%;
  filter: blur(60px); opacity: .35;
}
.ios-orb-1 {
  width: 340px; height: 340px;
  background: var(--accent);
  top: -80px; left: -80px;
  opacity: .18;
}
.ios-orb-2 {
  width: 260px; height: 260px;
  background: #a8d4ff;
  bottom: 20%; right: -60px;
  opacity: .28;
}
.ios-orb-3 {
  width: 180px; height: 180px;
  background: #c9e8ff;
  top: 45%; left: -40px;
  opacity: .22;
}

/* ── CONTENIDO PRINCIPAL ─────────────────────────────────── */
.ios-body {
  position: relative; z-index: 1;
  padding: 56px 20px 120px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

/* ── FOTO CIRCULAR ───────────────────────────────────────── */
.ios-photo-wrap {
  position: relative;
  width: 110px; height: 110px;
  margin-bottom: 22px;
  animation: ios-drop .6s cubic-bezier(.34,1.4,.64,1) both;
}
/* Glow difuminado detrás */
.ios-photo-wrap::before {
  content: '';
  position: absolute; inset: -10px;
  border-radius: 50%;
  background: var(--accent);
  opacity: .22;
  filter: blur(18px);
  animation: ios-pulse 4s ease-in-out infinite;
}
@keyframes ios-pulse {
  0%,100% { opacity: .18; transform: scale(1); }
  50%      { opacity: .30; transform: scale(1.08); }
}
.ios-photo-ring {
  position: relative; z-index: 1;
  width: 110px; height: 110px;
  border-radius: 50%;
  padding: 3px;
  background: linear-gradient(135deg, rgba(255,255,255,.9), rgba(255,255,255,.4));
  box-shadow:
    0 0 0 1px rgba(255,255,255,.6),
    0 12px 40px rgba(26,111,245,.2),
    inset 0 1px 0 rgba(255,255,255,.8);
}
.ios-photo {
  width: 100%; height: 100%;
  border-radius: 50%;
  object-fit: cover; object-position: center top;
  display: block;
}
.ios-photo-placeholder {
  width: 100%; height: 100%; border-radius: 50%;
  background: linear-gradient(135deg, rgba(26,111,245,.12), rgba(168,212,255,.3));
  display: flex; align-items: center; justify-content: center;
  font-size: 2.8rem;
}

/* ── IDENTIDAD ───────────────────────────────────────────── */
.ios-identity {
  text-align: center;
  margin-bottom: 28px;
  animation: ios-up .5s ease-out .1s both;
}
.ios-name {
  font-size: clamp(1.8rem, 8vw, 2.2rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--ios-text);
}
.ios-name-light { font-weight: 300; color: var(--ios-text2); }
.ios-title {
  font-size: 14px;
  font-weight: 400;
  color: var(--ios-text3);
  margin-top: 8px;
  letter-spacing: .01em;
}
.ios-location {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 12px; color: var(--ios-text3);
  margin-top: 6px;
}
.ios-location svg { width: 12px; height: 12px; opacity: .6; }

/* Status pill */
.ios-status {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,.7);
  border: 1px solid rgba(255,255,255,.9);
  backdrop-filter: blur(12px);
  padding: 5px 14px; border-radius: 99px;
  font-size: 11.5px; font-weight: 500;
  color: var(--ios-text2);
  margin-top: 10px;
  box-shadow: 0 2px 8px rgba(0,0,0,.06);
}
.ios-status-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #34c759; /* verde iOS */
  box-shadow: 0 0 5px rgba(52,199,89,.6);
  flex-shrink: 0;
}

/* ── BOTÓN CTA PRINCIPAL ─────────────────────────────────── */
.ios-cta-wrap {
  width: 100%; max-width: 280px;
  margin-bottom: 28px;
  animation: ios-up .5s ease-out .18s both;
}
.ios-cta {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%;
  padding: 15px 28px;
  background: var(--accent);
  color: var(--accentText);
  border: none; border-radius: 14px;
  font-family: var(--ios-font);
  font-size: 15px; font-weight: 600;
  letter-spacing: -.01em;
  cursor: pointer; text-decoration: none;
  box-shadow:
    0 6px 24px color-mix(in srgb, var(--accent) 40%, transparent),
    0 2px 6px rgba(0,0,0,.1),
    inset 0 1px 0 rgba(255,255,255,.2);
  transition: all .2s;
  -webkit-tap-highlight-color: transparent;
}
.ios-cta svg { width: 17px; height: 17px; flex-shrink: 0; }
.ios-cta:hover { transform: translateY(-2px); box-shadow: 0 10px 32px color-mix(in srgb, var(--accent) 50%, transparent); }
.ios-cta:active { transform: scale(.97); }

/* ── QUICK CONTACTS (fila de íconos) ─────────────────────── */
.ios-quick {
  display: flex; justify-content: center; gap: 14px;
  margin-bottom: 36px;
  animation: ios-up .5s ease-out .24s both;
}
.ios-quick-item {
  display: flex; flex-direction: column; align-items: center; gap: 5px;
}
.ios-quick-btn {
  width: 56px; height: 56px; border-radius: 16px;
  background: var(--ios-glass);
  border: 1px solid var(--ios-border);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  display: flex; align-items: center; justify-content: center;
  color: var(--accent);
  text-decoration: none;
  box-shadow:
    0 4px 16px rgba(0,0,0,.06),
    inset 0 1px 0 rgba(255,255,255,.8);
  transition: all .18s;
  -webkit-tap-highlight-color: transparent;
}
.ios-quick-btn svg { width: 22px; height: 22px; }
.ios-quick-btn:hover {
  background: var(--accent);
  color: var(--accentText);
  transform: translateY(-3px) scale(1.06);
  box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 30%, transparent);
}
.ios-quick-label {
  font-size: 10px; font-weight: 500;
  color: var(--ios-text3); letter-spacing: .02em;
}

/* ── BIO ─────────────────────────────────────────────────── */
.ios-bio-card {
  width: 100%;
  background: var(--ios-glass);
  border: 1px solid var(--ios-border);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--ios-r);
  padding: 18px 20px;
  margin-bottom: 12px;
  font-size: 14px;
  color: var(--ios-text2);
  line-height: 1.75;
  box-shadow: var(--ios-shadow), inset 0 1px 0 rgba(255,255,255,.8);
  animation: ios-up .45s ease-out .28s both;
}

/* ── REDES SOCIALES ──────────────────────────────────────── */
.ios-socials {
  width: 100%;
  background: var(--ios-glass);
  border: 1px solid var(--ios-border);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--ios-r);
  padding: 16px 20px;
  margin-bottom: 12px;
  box-shadow: var(--ios-shadow), inset 0 1px 0 rgba(255,255,255,.8);
  animation: ios-up .45s ease-out .32s both;
}
.ios-socials-label {
  font-size: 11px; font-weight: 600;
  color: var(--ios-text3); text-transform: uppercase;
  letter-spacing: .1em; margin-bottom: 12px;
}
.ios-socials-row {
  display: flex; flex-wrap: wrap; gap: 10px;
}
.ios-social-btn {
  width: 44px; height: 44px; border-radius: 13px;
  background: rgba(255,255,255,.6);
  border: 1px solid rgba(255,255,255,.9);
  display: flex; align-items: center; justify-content: center;
  color: var(--ios-text2); text-decoration: none;
  transition: all .18s;
  -webkit-tap-highlight-color: transparent;
}
.ios-social-btn svg { width: 20px; height: 20px; }
.ios-social-btn:hover {
  background: var(--accent); color: var(--accentText);
  transform: translateY(-2px);
  box-shadow: 0 4px 14px color-mix(in srgb, var(--accent) 35%, transparent);
}

/* ── SECCIONES ACORDEÓN (glass cards) ────────────────────── */
.ios-section {
  width: 100%;
  background: var(--ios-glass);
  border: 1px solid var(--ios-border);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--ios-r);
  overflow: hidden;
  margin-bottom: 10px;
  box-shadow: var(--ios-shadow), inset 0 1px 0 rgba(255,255,255,.8);
  transition: box-shadow .2s;
}
details.ios-section[open] {
  box-shadow:
    0 12px 40px color-mix(in srgb, var(--accent) 12%, transparent),
    inset 0 1px 0 rgba(255,255,255,.9);
}

.ios-section summary {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 18px;
  cursor: pointer; list-style: none; user-select: none;
  -webkit-tap-highlight-color: transparent;
}
.ios-section summary::-webkit-details-marker { display: none; }

.ios-sec-left { display: flex; align-items: center; gap: 13px; }
.ios-sec-icon {
  width: 38px; height: 38px; border-radius: 11px;
  background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 70%, #88bbff));
  display: flex; align-items: center; justify-content: center;
  font-size: 17px; flex-shrink: 0;
  box-shadow: 0 3px 10px color-mix(in srgb, var(--accent) 30%, transparent);
}
.ios-sec-title { font-size: 14px; font-weight: 600; color: var(--ios-text); letter-spacing: -.01em; }
.ios-sec-count { font-size: 11px; font-weight: 400; color: var(--ios-text3); margin-top: 1px; }

.ios-chevron {
  width: 26px; height: 26px; border-radius: 50%;
  background: rgba(0,0,0,.05);
  display: flex; align-items: center; justify-content: center;
  color: var(--ios-text3); flex-shrink: 0;
  transition: all .22s;
}
details.ios-section[open] .ios-chevron {
  transform: rotate(90deg);
  background: var(--accent);
  color: var(--accentText);
}
.ios-chevron svg { width: 12px; height: 12px; }

.ios-sec-body {
  padding: 0 18px 16px;
  border-top: 1px solid rgba(0,0,0,.05);
}

/* ── Timeline refinado ────────────────────────────────────── */
.ios-timeline { display: flex; flex-direction: column; }
.ios-tl {
  padding: 14px 0 14px 18px;
  border-left: 1.5px solid rgba(26,111,245,.15);
  position: relative; margin-left: 6px;
}
.ios-tl:last-child { border-left-color: transparent; }
.ios-tl::before {
  content: '';
  position: absolute; left: -6px; top: 20px;
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--ios-glass); border: 2px solid var(--accent);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 12%, transparent);
}
.ios-tl-title { font-size: 13px; font-weight: 600; color: var(--ios-text); }
.ios-tl-sub   { font-size: 12px; font-weight: 400; color: var(--ios-text3); margin-top: 2px; }
.ios-tl-period {
  display: inline-flex; font-size: 10px; font-weight: 500;
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  padding: 2px 9px; border-radius: 99px; margin-top: 5px;
}
.ios-tl-now {
  display: inline-flex; font-size: 9px; font-weight: 700;
  padding: 2px 8px; border-radius: 99px; margin-top: 4px; margin-left: 4px;
  background: rgba(52,199,89,.12); color: #1a9e40;
  text-transform: uppercase; letter-spacing: .06em;
}
.ios-tl-desc { font-size: 12px; color: var(--ios-text3); margin-top: 4px; line-height: 1.6; }

/* ── Skills ────────────────────────────────────────────────── */
.ios-skills { display: flex; flex-wrap: wrap; gap: 7px; padding-top: 14px; }
.ios-skill {
  font-size: 12px; font-weight: 500;
  padding: 5px 13px; border-radius: 99px;
  background: color-mix(in srgb, var(--accent) 8%, transparent);
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
  transition: all .15s;
}
.ios-skill:hover { background: var(--accent); color: var(--accentText); transform: scale(1.04); }

/* ── Servicios ─────────────────────────────────────────────── */
.ios-services { display: flex; flex-direction: column; gap: 9px; padding-top: 14px; }
.ios-service {
  display: flex; gap: 12px;
  padding: 12px 14px;
  background: rgba(255,255,255,.5);
  border: 1px solid rgba(255,255,255,.8);
  border-radius: 13px; transition: all .15s;
}
.ios-service:hover { background: rgba(255,255,255,.75); transform: translateX(3px); }
.ios-service-ico  { font-size: 22px; flex-shrink: 0; line-height: 1; margin-top: 2px; }
.ios-service-name { font-size: 13px; font-weight: 600; color: var(--ios-text); }
.ios-service-desc { font-size: 12px; color: var(--ios-text3); margin-top: 2px; line-height: 1.5; }
.ios-service-price {
  display: inline-flex; font-size: 11px; font-weight: 700;
  color: var(--accentText); background: var(--accent);
  padding: 2px 9px; border-radius: 99px; margin-top: 5px;
}

/* ── Proyectos ─────────────────────────────────────────────── */
.ios-projects { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
.ios-project  { border-radius: 13px; overflow: hidden; border: 1px solid rgba(255,255,255,.8); background: rgba(255,255,255,.5); transition: all .15s; }
.ios-project:hover { background: rgba(255,255,255,.75); box-shadow: 0 4px 16px rgba(0,0,0,.06); }
.ios-project-img  { width: 100%; height: 148px; object-fit: cover; display: block; }
.ios-project-body { padding: 12px 14px; }
.ios-project-title{ font-size: 13px; font-weight: 600; color: var(--ios-text); }
.ios-project-desc { font-size: 12px; color: var(--ios-text3); margin-top: 3px; line-height: 1.5; }
.ios-project-link {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; font-weight: 600; color: var(--accent);
  text-decoration: none; margin-top: 7px;
  padding: 4px 11px; border-radius: 99px;
  background: color-mix(in srgb, var(--accent) 8%, transparent);
  transition: all .15s;
}
.ios-project-link:hover { background: var(--accent); color: var(--accentText); }

/* ── Logros ────────────────────────────────────────────────── */
.ios-logros { display: flex; flex-direction: column; gap: 9px; padding-top: 14px; }
.ios-logro  {
  display: flex; gap: 13px;
  padding: 12px 14px;
  background: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.8);
  border-radius: 13px; transition: all .15s;
}
.ios-logro:hover { background: rgba(255,255,255,.75); transform: translateX(3px); }
.ios-logro-num   { font-size: 1.8rem; font-weight: 700; color: color-mix(in srgb, var(--accent) 18%, transparent); line-height: 1; min-width: 28px; flex-shrink: 0; }
.ios-logro-title { font-size: 13px; font-weight: 600; color: var(--ios-text); }
.ios-logro-desc  { font-size: 12px; color: var(--ios-text3); margin-top: 2px; line-height: 1.5; }
.ios-logro-fecha { font-size: 10px; color: var(--ios-text3); margin-top: 3px; opacity: .7; }

/* ── Capacitaciones ────────────────────────────────────────── */
.ios-caps { display: flex; flex-direction: column; gap: 9px; padding-top: 14px; }
.ios-cap  { display: flex; gap: 11px; padding: 12px 14px; background: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.8); border-radius: 13px; transition: all .15s; }
.ios-cap:hover { background: rgba(255,255,255,.75); }
.ios-cap-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--accent); flex-shrink: 0; margin-top: 4px; box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 14%, transparent); }
.ios-cap-name  { font-size: 13px; font-weight: 600; color: var(--ios-text); }
.ios-cap-inst  { font-size: 12px; color: var(--ios-text3); margin-top: 2px; }
.ios-cap-fecha { font-size: 10px; color: var(--ios-text3); margin-top: 2px; opacity: .7; }
.ios-cap-cert  { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; color: var(--accent); text-decoration: none; margin-top: 4px; padding: 3px 9px; border-radius: 99px; background: color-mix(in srgb, var(--accent) 8%, transparent); }

/* ── Referencias ───────────────────────────────────────────── */
.ios-refs { display: flex; flex-direction: column; gap: 9px; padding-top: 14px; }
.ios-ref  { padding: 12px 14px; background: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.8); border-radius: 13px; transition: all .15s; }
.ios-ref:hover { background: rgba(255,255,255,.75); }
.ios-ref-name  { font-size: 13px; font-weight: 600; color: var(--ios-text); }
.ios-ref-cargo { font-size: 12px; color: var(--ios-text3); margin-top: 2px; }
.ios-ref-obs   { font-size: 12px; color: var(--ios-text3); margin-top: 4px; font-style: italic; line-height: 1.5; opacity: .8; }
.ios-ref-links { display: flex; gap: 7px; flex-wrap: wrap; margin-top: 7px; }
.ios-ref-link  { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; color: var(--accent); text-decoration: none; padding: 3px 9px; border-radius: 99px; background: color-mix(in srgb, var(--accent) 8%, transparent); }

/* ── BARRA INFERIOR ──────────────────────────────────────── */
.ios-bar {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 420px;
  background: rgba(255,255,255,.82);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border-top: 1px solid rgba(255,255,255,.7);
  padding: 12px 20px;
  padding-bottom: max(12px, env(safe-area-inset-bottom, 12px));
  display: flex; gap: 10px;
  box-shadow: 0 -1px 0 rgba(0,0,0,.06), 0 -8px 32px rgba(26,111,245,.06);
  z-index: 50;
}
.ios-bar-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px;
  padding: 13px 10px; border-radius: 13px;
  font-family: var(--ios-font); font-size: 14px; font-weight: 600;
  text-decoration: none; border: none; cursor: pointer;
  transition: all .2s; letter-spacing: -.01em;
  -webkit-tap-highlight-color: transparent;
}
.ios-bar-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
.ios-bar-ghost {
  background: rgba(26,111,245,.08);
  color: var(--accent);
  border: 1px solid rgba(26,111,245,.12);
}
.ios-bar-ghost:hover { background: rgba(26,111,245,.14); }
.ios-bar-solid {
  background: var(--accent);
  color: var(--accentText);
  box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 38%, transparent);
}
.ios-bar-solid:hover { opacity: .92; transform: translateY(-1px); }
.ios-bar-solid:active { transform: scale(.97); }

/* ── FOOTER ──────────────────────────────────────────────── */
.ios-footer {
  text-align: center; padding: 12px 0 4px;
  font-size: 11px; color: var(--ios-text3);
  font-weight: 400; letter-spacing: .03em;
  width: 100%;
}
.ios-footer a { color: var(--accent); text-decoration: none; font-weight: 600; }

/* ── DESKTOP ─────────────────────────────────────────────── */
@media (min-width: 480px) {
  body { padding: 32px 0 56px; background: #ccdff5 !important; }
  .ios-page {
    border-radius: 44px;
    overflow: hidden;
    box-shadow:
      0 40px 100px rgba(26,111,245,.2),
      0 0 0 1px rgba(255,255,255,.4);
  }
  .ios-bar { border-radius: 0 0 44px 44px; }
  .ios-orbs { position: absolute; }
}

/* ── ANIMACIONES ─────────────────────────────────────────── */
@keyframes ios-drop {
  from { opacity: 0; transform: translateY(-20px) scale(.9); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
@keyframes ios-up {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Stagger animaciones de las secciones */
.ios-section:nth-child(1) { animation: ios-up .4s ease-out .36s both; }
.ios-section:nth-child(2) { animation: ios-up .4s ease-out .40s both; }
.ios-section:nth-child(3) { animation: ios-up .4s ease-out .44s both; }
.ios-section:nth-child(4) { animation: ios-up .4s ease-out .48s both; }
.ios-section:nth-child(5) { animation: ios-up .4s ease-out .52s both; }
.ios-section:nth-child(6) { animation: ios-up .4s ease-out .56s both; }
.ios-section:nth-child(7) { animation: ios-up .4s ease-out .60s both; }
.ios-section:nth-child(8) { animation: ios-up .4s ease-out .64s both; }
</style>

<div class="ios-page">

  <!-- Esferas de fondo -->
  <div class="ios-orbs" aria-hidden="true">
    <div class="ios-orb ios-orb-1"></div>
    <div class="ios-orb ios-orb-2"></div>
    <div class="ios-orb ios-orb-3"></div>
  </div>

  <div class="ios-body">

    <!-- ── FOTO ───────────────────────────────────────────── -->
    <div class="ios-photo-wrap">
      <div class="ios-photo-ring">
        {foto
          ? <img src={foto} alt={nombre} class="ios-photo" />
          : <div class="ios-photo-placeholder">👤</div>
        }
      </div>
    </div>

    <!-- ── IDENTIDAD ──────────────────────────────────────── -->
    <div class="ios-identity">
      <h1 class="ios-name">
        {parte1}
        {parte2 && <><br /><span class="ios-name-light">{parte2}</span></>}
      </h1>
      {perfil.titulo_profesional && (
        <div class="ios-title">{perfil.titulo_profesional}</div>
      )}
      {perfil.ubicacion && (
        <div class="ios-location">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          </svg>
          {perfil.ubicacion}
        </div>
      )}
      <div class="ios-status">
        <div class="ios-status-dot"></div>
        {perfil.status ?? 'Disponible'}
      </div>
    </div>

    <!-- ── CTA PRINCIPAL ──────────────────────────────────── -->
    {(perfil.email || perfil.telefono) && (
      <div class="ios-cta-wrap">
        <a
          href={perfil.email ? `mailto:${perfil.email}` : `tel:${perfil.telefono?.replace(/\s/g,'')}`}
          class="ios-cta"
        >
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          Contactar ahora
        </a>
      </div>
    )}

    <!-- ── CONTACTOS RÁPIDOS ───────────────────────────────── -->
    <div class="ios-quick">
      {perfil.telefono && (
        <div class="ios-quick-item">
          <a href={`tel:${perfil.telefono.replace(/\s/g,'')}`} class="ios-quick-btn" aria-label="Llamar">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </a>
          <span class="ios-quick-label">Llamar</span>
        </div>
      )}
      {perfil.telefono && (
        <div class="ios-quick-item">
          <a href={`https://wa.me/${perfil.telefono.replace(/[\s+\-]/g,'')}`}
             target="_blank" rel="noopener noreferrer"
             class="ios-quick-btn track-red" data-plataforma="WhatsApp" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <span class="ios-quick-label">WhatsApp</span>
        </div>
      )}
      {perfil.email && (
        <div class="ios-quick-item">
          <a href={`mailto:${perfil.email}`} class="ios-quick-btn" aria-label="Email">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
          <span class="ios-quick-label">Email</span>
        </div>
      )}
      {perfil.cv_pdf_url && (
        <div class="ios-quick-item">
          <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer"
             class="ios-quick-btn track-cv" aria-label="Curriculum">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </a>
          <span class="ios-quick-label">CV</span>
        </div>
      )}
    </div>

    <!-- ── BIO ────────────────────────────────────────────── -->
    {perfil.bio && <div class="ios-bio-card">{perfil.bio}</div>}

    <!-- ── REDES SOCIALES ─────────────────────────────────── -->
    {redes.length > 0 && (
      <div class="ios-socials">
        <div class="ios-socials-label">Redes</div>
        <div class="ios-socials-row">
          {redes.map(r => (
            <a href={r.url} target="_blank" rel="noopener noreferrer"
               class="ios-social-btn track-red" data-plataforma={r.plataforma}
               title={r.plataforma} aria-label={r.plataforma}>
              <Fragment set:html={icon(r.plataforma)} />
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- ── SECCIONES ──────────────────────────────────────── -->
    {servicios.length > 0 && (
      <details class="ios-section">
        <summary>
          <div class="ios-sec-left">
            <div class="ios-sec-icon">⚡</div>
            <div><div class="ios-sec-title">Servicios</div><div class="ios-sec-count">{servicios.length} {servicios.length===1?'servicio':'servicios'}</div></div>
          </div>
          <div class="ios-chevron"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
        </summary>
        <div class="ios-sec-body">
          <div class="ios-services">
            {servicios.map(s => (
              <div class="ios-service">
                {s.icono && <div class="ios-service-ico">{s.icono}</div>}
                <div>
                  <div class="ios-service-name">{s.nombre}</div>
                  {s.descripcion && <p class="ios-service-desc">{s.descripcion}</p>}
                  {s.precio_referencial && <div class="ios-service-price">{s.precio_referencial}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {experiencia.length > 0 && (
      <details class="ios-section">
        <summary>
          <div class="ios-sec-left">
            <div class="ios-sec-icon">💼</div>
            <div><div class="ios-sec-title">Experiencia</div><div class="ios-sec-count">{experiencia.length} {experiencia.length===1?'posición':'posiciones'}</div></div>
          </div>
          <div class="ios-chevron"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
        </summary>
        <div class="ios-sec-body">
          <div class="ios-timeline">
            {experiencia.map(e => (
              <div class="ios-tl">
                <div class="ios-tl-title">{e.cargo}</div>
                <div class="ios-tl-sub">{e.empresa}</div>
                {e.periodo && <div class="ios-tl-period">{e.periodo}</div>}
                {e.es_trabajo_actual && <span class="ios-tl-now">Actual</span>}
                {e.descripcion && <p class="ios-tl-desc">{e.descripcion}</p>}
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {estudios.length > 0 && (
      <details class="ios-section">
        <summary>
          <div class="ios-sec-left">
            <div class="ios-sec-icon">🎓</div>
            <div><div class="ios-sec-title">Educación</div><div class="ios-sec-count">{estudios.length} {estudios.length===1?'estudio':'estudios'}</div></div>
          </div>
          <div class="ios-chevron"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
        </summary>
        <div class="ios-sec-body">
          <div class="ios-timeline">
            {estudios.map(e => (
              <div class="ios-tl">
                <div class="ios-tl-title">{e.titulo_obtenido ?? e.nivel}</div>
                <div class="ios-tl-sub">{e.institucion}</div>
                {(e.fecha_inicio || e.fecha_fin) && (
                  <div class="ios-tl-period">{e.fecha_inicio ?? ''}{e.fecha_fin ? ` — ${e.fecha_fin}` : ''}</div>
                )}
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {habilidades.length > 0 && (
      <details class="ios-section">
        <summary>
          <div class="ios-sec-left">
            <div class="ios-sec-icon">🧠</div>
            <div><div class="ios-sec-title">Habilidades</div><div class="ios-sec-count">{habilidades.length} habilidades</div></div>
          </div>
          <div class="ios-chevron"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
        </summary>
        <div class="ios-sec-body">
          <div class="ios-skills">{habilidades.map(h => <span class="ios-skill">{h.nombre}</span>)}</div>
        </div>
      </details>
    )}

    {proyectos.length > 0 && (
      <details class="ios-section">
        <summary>
          <div class="ios-sec-left">
            <div class="ios-sec-icon">🗂</div>
            <div><div class="ios-sec-title">Proyectos</div><div class="ios-sec-count">{proyectos.length} {proyectos.length===1?'proyecto':'proyectos'}</div></div>
          </div>
          <div class="ios-chevron"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
        </summary>
        <div class="ios-sec-body">
          <div class="ios-projects">
            {proyectos.map(p => (
              <div class="ios-project">
                {p.imagen_url && <img src={p.imagen_url} alt={p.titulo} class="ios-project-img" loading="lazy" />}
                <div class="ios-project-body">
                  <div class="ios-project-title">{p.titulo}</div>
                  {p.descripcion && <p class="ios-project-desc">{p.descripcion}</p>}
                  {p.enlace_url && (
                    <a href={p.enlace_url} target="_blank" rel="noopener noreferrer"
                       class="ios-project-link track-proyecto" data-titulo={p.titulo}>
                      Ver proyecto →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {logros.length > 0 && (
      <details class="ios-section">
        <summary>
          <div class="ios-sec-left">
            <div class="ios-sec-icon">🏆</div>
            <div><div class="ios-sec-title">Logros</div><div class="ios-sec-count">{logros.length} {logros.length===1?'logro':'logros'}</div></div>
          </div>
          <div class="ios-chevron"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
        </summary>
        <div class="ios-sec-body">
          <div class="ios-logros">
            {logros.map((l, i) => (
              <div class="ios-logro">
                <div class="ios-logro-num">0{i+1}</div>
                <div>
                  <div class="ios-logro-title">{l.titulo}</div>
                  {l.descripcion && <p class="ios-logro-desc">{l.descripcion}</p>}
                  {l.fecha && <div class="ios-logro-fecha">{l.fecha}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {capacitaciones.length > 0 && (
      <details class="ios-section">
        <summary>
          <div class="ios-sec-left">
            <div class="ios-sec-icon">📚</div>
            <div><div class="ios-sec-title">Cursos</div><div class="ios-sec-count">{capacitaciones.length} cursos</div></div>
          </div>
          <div class="ios-chevron"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
        </summary>
        <div class="ios-sec-body">
          <div class="ios-caps">
            {capacitaciones.map(c => (
              <div class="ios-cap">
                <div class="ios-cap-dot"></div>
                <div>
                  <div class="ios-cap-name">{c.nombre}</div>
                  {c.institucion && <div class="ios-cap-inst">{c.institucion}</div>}
                  {c.fecha && <div class="ios-cap-fecha">{c.fecha}</div>}
                  {c.certificado_url && (
                    <a href={c.certificado_url} target="_blank" rel="noopener noreferrer" class="ios-cap-cert">
                      Ver certificado →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {referencias && referencias.length > 0 && (
      <details class="ios-section">
        <summary>
          <div class="ios-sec-left">
            <div class="ios-sec-icon">🤝</div>
            <div><div class="ios-sec-title">Referencias</div><div class="ios-sec-count">{referencias.length} {referencias.length===1?'contacto':'contactos'}</div></div>
          </div>
          <div class="ios-chevron"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
        </summary>
        <div class="ios-sec-body">
          <div class="ios-refs">
            {referencias.map(r => (
              <div class="ios-ref">
                <div class="ios-ref-name">{r.nombre}</div>
                {(r.cargo || r.empresa) && (
                  <div class="ios-ref-cargo">{r.cargo}{r.empresa ? ` · ${r.empresa}` : ''}</div>
                )}
                {r.observaciones && <p class="ios-ref-obs">"{r.observaciones}"</p>}
                <div class="ios-ref-links">
                  {r.telefono && <a href={`tel:${r.telefono.replace(/\s/g,'')}`} class="ios-ref-link">📞 Llamar</a>}
                  {r.email && <a href={`mailto:${r.email}`} class="ios-ref-link">✉️ Email</a>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    <div style="height:4px"></div>
    <footer class="ios-footer">Creado con <a href="/">CardVirtual</a></footer>

  </div><!-- /ios-body -->

  <!-- ── BARRA INFERIOR GLASS ───────────────────────────────── -->
  <div class="ios-bar">
    {perfil.cv_pdf_url && (
      <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer"
         class="ios-bar-btn ios-bar-ghost track-cv">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Descargar CV
      </a>
    )}
    {(perfil.email || perfil.telefono) && (
      <a
        href={perfil.email ? `mailto:${perfil.email}` : `tel:${perfil.telefono?.replace(/\s/g,'')}`}
        class="ios-bar-btn ios-bar-solid"
      >
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        Contactar
      </a>
    )}
  </div>

</div>