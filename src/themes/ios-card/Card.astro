---
// src/themes/ios-card/Card.astro
// THEME: iOS Card
// Estética Apple Wallet / iOS 17 — glassmorphism refinado,
// fondo degradado azul helado, foto circular con glow,

import type { CardProps } from '../types'

const {
  perfil, experiencia, estudios, habilidades,
  servicios, proyectos, redes, logros, capacitaciones, referencias,
} = Astro.props as CardProps

const accent  = perfil.color_primario ?? '#1A6FF5'
const nombre  = [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')
const foto    = perfil.foto_url || null

// Dividir nombre para el render
const partes   = nombre.trim().split(' ')
const mitad    = Math.ceil(partes.length / 2)
const parte1   = partes.slice(0, mitad).join(' ')
const parte2   = partes.slice(mitad).join(' ')

// Luminancia para contraste en botones
function lum(hex: string): number {
  const h = hex.replace('#', '')
  const r = parseInt(h.slice(0,2), 16)
  const g = parseInt(h.slice(2,4), 16)
  const b = parseInt(h.slice(4,6), 16)
  return (0.299*r + 0.587*g + 0.114*b) / 255
}
const accentText = lum(accent.startsWith('#') ? accent : '#1A6FF5') > 0.55 ? '#0a0a0a' : '#ffffff'

// Íconos redes
const ICONOS: Record<string, string> = {
