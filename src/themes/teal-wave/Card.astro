// Color derivados del accent para la ola y gradientes
---

<link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" slot="head" />

<style is:inline define:vars={{ accent }}>

  /* ── RESET & BASE ──────────────────────────────────────────── */
  .tw-page {
    max-width: 420px;
    margin: 0 auto;
    min-height: 100vh;
    font-family: 'Nunito', sans-serif;
    background: #F0F4F8;
    color: #1a2e35;
    position: relative;
    overflow-x: hidden;
  }

  /* ── HERO: zona teal con foto ──────────────────────────────── */
  .tw-hero {
    position: relative;
    width: 100%;
    background: var(--accent);
    overflow: hidden;
    /* Altura generosa para foto + datos */
    padding-bottom: 0;
  }

  /* Ruido sutil sobre el teal */
  .tw-hero::before {
    content: '';
    position: absolute; inset: 0; z-index: 1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 180px;
    pointer-events: none;
    opacity: .5;
  }

  /* Orbe de luz en esquina superior derecha */
  .tw-hero::after {
    content: '';
    position: absolute; top: -60px; right: -60px; z-index: 0;
    width: 240px; height: 240px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Foto hero — ocupa todo el ancho, centrada */
  .tw-photo-wrap {
    position: relative; z-index: 2;
    width: 100%;
    height: 340px;
    overflow: hidden;
    display: flex; align-items: flex-end; justify-content: center;
  }
  .tw-photo {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    /* Fade sutil en la parte inferior para que se mezcle con la ola */
    mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
  }
  /* Placeholder si no hay foto */
  .tw-photo-placeholder {
    width: 100%; height: 340px;
    display: flex; align-items: center; justify-content: center;
    font-size: 6rem; opacity: .25;
    background: linear-gradient(160deg, rgba(255,255,255,0.08), transparent);
    position: relative; z-index: 2;
  }

  /* Logo/icono circular superpuesto sobre la foto */
  .tw-badge-icon {
    position: absolute;
    left: 20px; bottom: -22px;
    z-index: 10;
    width: 58px; height: 58px; border-radius: 50%;
    background: #fff;
    border: 3px solid var(--accent);
    box-shadow: 0 4px 20px rgba(0,0,0,0.18);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem;
    animation: tw-popIn 0.5s cubic-bezier(0.34,1.56,0.64,1) 0.3s both;
  }

  /* ── OLA SVG ── */
  .tw-wave-wrap {
    position: relative; z-index: 3;
    margin-top: -2px; /* evita gap blanco */
    line-height: 0;
  }
  .tw-wave-wrap svg {
    width: 100%; height: auto; display: block;
  }

  /* ── DATOS DEL PERFIL (sobre la ola, fondo teal) ─────────── */
  .tw-identity {
    position: relative; z-index: 5;
    /* Fondo teal continúa debajo de la ola */
    background: var(--accent);
    padding: 28px 20px 0 20px;
    margin-top: -120px; /* sube el bloque de texto debajo de la foto */
    padding-top: 16px;
  }
  .tw-name {
    font-size: clamp(1.8rem, 7vw, 2.2rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 12px rgba(0,0,0,0.2);
    animation: tw-fadeUp 0.5s ease-out 0.1s both;
  }
  .tw-role {
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.75);
    margin-top: 4px;
    animation: tw-fadeUp 0.5s ease-out 0.16s both;
  }
  .tw-company {
    font-size: 12px; font-weight: 500;
    color: rgba(255,255,255,0.5);
    margin-top: 2px;
    display: flex; align-items: center; gap: 4px;
    animation: tw-fadeUp 0.5s ease-out 0.2s both;
  }
  .tw-company svg { width: 11px; height: 11px; flex-shrink: 0; }

  /* Fila de contacto rápido (iconos circulares blancos) */
  .tw-contacts {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding-bottom: 24px;
    animation: tw-fadeUp 0.5s ease-out 0.26s both;
  }
  .tw-contact-btn {
    width: 46px; height: 46px; border-radius: 50%;
    background: rgba(255,255,255,0.95);
    box-shadow: 0 4px 14px rgba(0,0,0,0.15);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    flex-shrink: 0;
  }
  .tw-contact-btn svg { width: 20px; height: 20px; }
  .tw-contact-btn:hover {
    transform: translateY(-3px) scale(1.08);
    box-shadow: 0 8px 22px rgba(0,0,0,0.22);
    background: #fff;
  }

  /* ── OLA INFERIOR — transición a blanco ─────────────────── */
  .tw-wave-bottom {
    position: relative; z-index: 4;
    background: var(--accent);
    line-height: 0;
    margin-bottom: -1px;
  }
  .tw-wave-bottom svg { width: 100%; height: auto; display: block; }

  /* ── CONTENIDO (zona blanca/gris claro) ─────────────────── */
  .tw-content {
    background: #F0F4F8;
    padding: 20px 16px 60px;
    display: flex; flex-direction: column; gap: 12px;
    position: relative; z-index: 5;
  }

  /* Bio */
  .tw-bio {
    background: #fff;
    border-radius: 18px;
    padding: 18px 20px;
    font-size: 14px;
    color: #3d5a5f;
    line-height: 1.8;
    box-shadow: 0 2px 16px rgba(10,112,117,0.07);
    border-left: 4px solid var(--accent);
  }

  /* Card de sección genérica */
  .tw-card {
    background: #fff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(10,112,117,0.07);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .tw-card:hover {
    box-shadow: 0 8px 30px rgba(10,112,117,0.14);
    transform: translateY(-1px);
  }

  /* Header de card (acordeón) */
  .tw-card summary {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 18px;
    cursor: pointer; list-style: none; user-select: none;
    transition: background 0.15s;
  }
  .tw-card summary:hover { background: rgba(10,112,117,0.04); }
  .tw-card summary::-webkit-details-marker { display: none; }

  .tw-card-left { display: flex; align-items: center; gap: 14px; }
  .tw-card-icon {
    width: 42px; height: 42px; border-radius: 13px;
    background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 60%, #00c896));
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(10,112,117,0.3);
  }
  .tw-card-title { font-size: 15px; font-weight: 800; color: #1a2e35; }
  .tw-card-count { font-size: 11px; font-weight: 600; color: #8faab0; margin-top: 1px; }

  .tw-chevron {
    width: 32px; height: 32px; border-radius: 50%;
    background: #F0F4F8;
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); flex-shrink: 0;
    transition: transform 0.22s, background 0.15s;
  }
  details.tw-card[open] .tw-chevron {
    transform: rotate(180deg);
    background: var(--accent);
    color: #fff;
  }
  .tw-chevron svg { width: 14px; height: 14px; }

  .tw-card-body {
    padding: 0 16px 16px;
    border-top: 1px solid rgba(10,112,117,0.08);
  }

  /* Timeline */
  .tw-timeline { display: flex; flex-direction: column; }
  .tw-tl {
    padding: 14px 0 14px 20px;
    border-left: 2px solid rgba(10,112,117,0.2);
    position: relative;
    margin-left: 4px;
  }
  .tw-tl::before {
    content: '';
    position: absolute; left: -6px; top: 20px;
    width: 10px; height: 10px; border-radius: 50%;
    background: #fff;
    border: 2.5px solid var(--accent);
    box-shadow: 0 0 0 3px rgba(10,112,117,0.12);
  }
  .tw-tl-title  { font-size: 13px; font-weight: 800; color: #1a2e35; }
  .tw-tl-sub    { font-size: 12px; font-weight: 600; color: #8faab0; margin-top: 2px; }
  .tw-tl-period {
    display: inline-flex; font-size: 10px; font-weight: 700;
    color: var(--accent);
    background: rgba(10,112,117,0.08);
    padding: 2px 9px; border-radius: 99px; margin-top: 5px;
  }
  .tw-tl-badge {
    display: inline-flex; font-size: 9px; font-weight: 800;
    padding: 2px 9px; border-radius: 99px; margin-top: 4px;
    background: rgba(10,112,117,0.12); color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .tw-tl-desc { font-size: 12px; color: #6a8a90; margin-top: 5px; line-height: 1.6; }

  /* Skills */
  .tw-skills { display: flex; flex-wrap: wrap; gap: 8px; padding-top: 14px; }
  .tw-skill {
    font-size: 12px; font-weight: 700;
    padding: 6px 14px; border-radius: 99px;
    background: rgba(10,112,117,0.08);
    color: var(--accent);
    border: 1.5px solid rgba(10,112,117,0.18);
    transition: all 0.15s;
  }
  .tw-skill:hover {
    background: var(--accent); color: #fff;
    transform: scale(1.05);
  }

  /* Servicios */
  .tw-services { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
  .tw-service {
    display: flex; gap: 13px; align-items: flex-start;
    padding: 14px 15px;
    background: #F8FBFC;
    border: 1.5px solid rgba(10,112,117,0.1);
    border-radius: 14px;
    transition: border-color 0.15s, transform 0.15s;
  }
  .tw-service:hover { border-color: var(--accent); transform: translateX(3px); }
  .tw-service-ico  { font-size: 26px; flex-shrink: 0; line-height: 1; }
  .tw-service-name { font-size: 13px; font-weight: 800; color: #1a2e35; }
  .tw-service-desc { font-size: 12px; color: #6a8a90; margin-top: 3px; line-height: 1.5; }
  .tw-service-price{
    display: inline-flex; font-size: 12px; font-weight: 800;
    color: #fff; background: var(--accent);
    padding: 2px 10px; border-radius: 99px; margin-top: 6px;
  }

  /* Proyectos */
  .tw-projects { display: flex; flex-direction: column; gap: 12px; padding-top: 14px; }
  .tw-project {
    border-radius: 14px; overflow: hidden;
    border: 1.5px solid rgba(10,112,117,0.1);
    background: #F8FBFC;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .tw-project:hover { border-color: var(--accent); box-shadow: 0 4px 16px rgba(10,112,117,0.12); }
  .tw-project-img  { width: 100%; height: 152px; object-fit: cover; display: block; }
  .tw-project-body { padding: 13px 14px; }
  .tw-project-title{ font-size: 13px; font-weight: 800; color: #1a2e35; }
  .tw-project-desc { font-size: 12px; color: #6a8a90; margin-top: 3px; line-height: 1.5; }
  .tw-project-link {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 800; color: var(--accent);
    text-decoration: none; margin-top: 8px;
    padding: 4px 12px; border-radius: 99px;
    background: rgba(10,112,117,0.08);
    transition: background 0.15s;
  }
  .tw-project-link:hover { background: var(--accent); color: #fff; }

  /* Logros */
  .tw-logros { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
  .tw-logro {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 14px 15px;
    background: #F8FBFC;
    border: 1.5px solid rgba(10,112,117,0.1);
    border-radius: 14px;
    transition: border-color 0.15s, transform 0.15s;
  }
  .tw-logro:hover { border-color: var(--accent); transform: translateX(3px); }
  .tw-logro-num {
    font-size: 2rem; font-weight: 900; line-height: 1;
    color: rgba(10,112,117,0.2); min-width: 28px; flex-shrink: 0;
  }
  .tw-logro-title { font-size: 13px; font-weight: 800; color: #1a2e35; }
  .tw-logro-desc  { font-size: 12px; color: #6a8a90; margin-top: 3px; line-height: 1.5; }
  .tw-logro-fecha { font-size: 10px; color: #8faab0; margin-top: 3px; }

  /* Capacitaciones */
  .tw-caps { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
  .tw-cap {
    display: flex; gap: 12px; align-items: flex-start;
    padding: 13px 15px;
    background: #F8FBFC;
    border: 1.5px solid rgba(10,112,117,0.1);
    border-radius: 14px;
    transition: border-color 0.15s;
  }
  .tw-cap:hover { border-color: var(--accent); }
  .tw-cap-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--accent); flex-shrink: 0; margin-top: 4px;
    box-shadow: 0 0 0 3px rgba(10,112,117,0.15);
  }
  .tw-cap-name  { font-size: 13px; font-weight: 800; color: #1a2e35; }
  .tw-cap-inst  { font-size: 12px; color: #6a8a90; margin-top: 2px; }
  .tw-cap-fecha { font-size: 10px; color: #8faab0; margin-top: 3px; }
  .tw-cap-cert  {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 700; color: var(--accent);
    text-decoration: none; margin-top: 5px;
    padding: 3px 10px; border-radius: 99px;
    background: rgba(10,112,117,0.08);
  }

  /* Referencias */
  .tw-refs { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
  .tw-ref {
    padding: 14px 15px;
    background: #F8FBFC;
    border: 1.5px solid rgba(10,112,117,0.1);
    border-radius: 14px;
    transition: border-color 0.15s;
  }
  .tw-ref:hover { border-color: var(--accent); }
  .tw-ref-name  { font-size: 13px; font-weight: 800; color: #1a2e35; }
  .tw-ref-cargo { font-size: 12px; color: #6a8a90; margin-top: 2px; }
  .tw-ref-obs   { font-size: 12px; color: #8faab0; margin-top: 5px; font-style: italic; line-height: 1.5; }
  .tw-ref-links { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 8px; }
  .tw-ref-link  {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 700; color: var(--accent);
    text-decoration: none; padding: 4px 10px; border-radius: 99px;
    background: rgba(10,112,117,0.08);
  }

  /* ── BARRA INFERIOR FIJA ────────────────────────────────── */
  .tw-bottom-bar {
    position: fixed; bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 100%; max-width: 420px;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(16px);
    border-top: 1px solid rgba(10,112,117,0.12);
    padding: 12px 20px 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    z-index: 100;
    box-shadow: 0 -4px 24px rgba(10,112,117,0.1);
  }
  .tw-bar-btn {
    flex: 1;
    display: flex; align-items: center; justify-content: center; gap: 7px;
    padding: 12px 10px;
    border-radius: 13px;
    font-family: 'Nunito', sans-serif;
    font-size: 13px; font-weight: 800;
    text-decoration: none; border: none; cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s;
  }
  .tw-bar-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
  .tw-bar-btn-ghost {
    background: #F0F4F8;
    color: var(--accent);
    border: 1.5px solid rgba(10,112,117,0.15);
  }
  .tw-bar-btn-ghost:hover { background: rgba(10,112,117,0.08); transform: translateY(-1px); }
  .tw-bar-btn-solid {
    background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 70%, #00a878));
    color: #fff;
    box-shadow: 0 6px 20px rgba(10,112,117,0.4);
  }
  .tw-bar-btn-solid:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 8px 26px rgba(10,112,117,0.5); }

  /* Footer */
  .tw-footer {
    text-align: center; padding: 16px 24px 90px;
    font-size: 11px; color: #8faab0; letter-spacing: 0.04em;
    font-weight: 600;
  }
  .tw-footer a { color: var(--accent); text-decoration: none; font-weight: 800; }

  /* Desktop */
  @media (min-width: 480px) {
    body { padding: 32px 0 56px; background: #d8e8ea !important; }
    .tw-page {
      border-radius: 40px;
      overflow: hidden;
      box-shadow: 0 40px 100px rgba(10,112,117,0.25), 0 0 0 1px rgba(10,112,117,0.1);
    }
    .tw-bottom-bar { border-radius: 0 0 40px 40px; }
  }

  /* Animaciones */
  @keyframes tw-fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes tw-popIn {
    from { opacity: 0; transform: scale(0.5); }
    to   { opacity: 1; transform: scale(1); }
  }
</style>

<div class="tw-page">

  <!-- ── HERO TEAL ─────────────────────────────────────────── -->
  <div class="tw-hero">
    <!-- Foto de perfil (ocupa todo el ancho) -->
    <div class="tw-photo-wrap">
      {foto
        ? <img src={foto} alt={nombre} class="tw-photo" />
        : <div class="tw-photo-placeholder">👤</div>
      }
    </div>

    <!-- Badge/icono circular sobre la foto -->
    <div class="tw-badge-icon">
      {perfil.icono_profesion ?? '⭐'}
    </div>
  </div>

  <!-- Ola SVG: teal → datos de identidad -->
  <div class="tw-wave-wrap" style="background:#F0F4F8;">
    <svg viewBox="0 0 420 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 L420,0 L420,40 Q330,80 210,60 Q90,40 0,70 Z" fill="var(--accent)"/>
    </svg>
  </div>

  <!-- Datos de identidad: nombre, rol, empresa, contactos -->
  <!-- Este bloque va ANTES de la ola visualmente, pegado al teal -->
  <div style="background:var(--accent); margin-top:-82px; position:relative; z-index:3; padding: 0 20px 28px 20px;">

    <!-- Nombre y datos -->
    <div style="padding-top: 10px;">
      <h1 class="tw-name">{nombre}</h1>
      {perfil.titulo_profesional && <p class="tw-role">{perfil.titulo_profesional}</p>}
      {perfil.empresa && (
        <p class="tw-company">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          {perfil.empresa}
        </p>
      )}
      {perfil.ubicacion && (
        <p class="tw-company" style="margin-top:3px;">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          </svg>
          {perfil.ubicacion}
        </p>
      )}
    </div>

    <!-- Iconos de contacto / redes (círculos blancos) -->
    <div class="tw-contacts">
      {perfil.email && (
        <a href={`mailto:${perfil.email}`} class="tw-contact-btn" title="Email">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </a>
      )}
      {perfil.telefono && (
        <a href={`tel:${perfil.telefono.replace(/\s/g,'')}`} class="tw-contact-btn" title="Teléfono">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </a>
      )}
      {redes.map(red => (
        <a href={red.url} target="_blank" rel="noopener noreferrer"
           class="tw-contact-btn track-red" data-plataforma={red.plataforma} title={red.plataforma}>
          <Fragment set:html={icon(red.plataforma)} />
        </a>
      ))}
    </div>
  </div>

  <!-- Segunda ola: teal → fondo gris claro del contenido -->
  <div class="tw-wave-bottom">
    <svg viewBox="0 0 420 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 Q105,70 210,40 Q315,10 420,50 L420,70 L0,70 Z" fill="#F0F4F8"/>
    </svg>
  </div>

  <!-- ── CONTENIDO (zona clara) ────────────────────────────── -->
  <div class="tw-content">

    {perfil.bio && <div class="tw-bio">{perfil.bio}</div>}

    {servicios.length > 0 && (
      <details class="tw-card">
        <summary>
          <div class="tw-card-left">
            <div class="tw-card-icon">⚡</div>
            <div>
              <div class="tw-card-title">Servicios</div>
              <div class="tw-card-count">{servicios.length} {servicios.length===1?'servicio':'servicios'}</div>
            </div>
          </div>
          <div class="tw-chevron">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="tw-card-body">
          <div class="tw-services">
            {servicios.map(s => (
              <div class="tw-service">
                {s.icono && <div class="tw-service-ico">{s.icono}</div>}
                <div>
                  <div class="tw-service-name">{s.nombre}</div>
                  {s.descripcion && <p class="tw-service-desc">{s.descripcion}</p>}
                  {s.precio_referencial && <div class="tw-service-price">{s.precio_referencial}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {experiencia.length > 0 && (
      <details class="tw-card">
        <summary>
          <div class="tw-card-left">
            <div class="tw-card-icon">💼</div>
            <div>
              <div class="tw-card-title">Experiencia</div>
              <div class="tw-card-count">{experiencia.length} {experiencia.length===1?'posición':'posiciones'}</div>
            </div>
          </div>
          <div class="tw-chevron">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="tw-card-body">
          <div class="tw-timeline">
            {experiencia.map(exp => (
              <div class="tw-tl">
                <div class="tw-tl-title">{exp.cargo}</div>
                <div class="tw-tl-sub">{exp.empresa}</div>
                {exp.periodo && <div class="tw-tl-period">{exp.periodo}</div>}
                {exp.es_trabajo_actual && <div class="tw-tl-badge">Actual</div>}
                {exp.descripcion && <p class="tw-tl-desc">{exp.descripcion}</p>}
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {estudios.length > 0 && (
      <details class="tw-card">
        <summary>
          <div class="tw-card-left">
            <div class="tw-card-icon">🎓</div>
            <div>
              <div class="tw-card-title">Educación</div>
              <div class="tw-card-count">{estudios.length} {estudios.length===1?'estudio':'estudios'}</div>
            </div>
          </div>
          <div class="tw-chevron">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="tw-card-body">
          <div class="tw-timeline">
            {estudios.map(e => (
              <div class="tw-tl">
                <div class="tw-tl-title">{e.titulo_obtenido ?? e.nivel}</div>
                <div class="tw-tl-sub">{e.institucion}</div>
                {(e.fecha_inicio || e.fecha_fin) && (
                  <div class="tw-tl-period">{e.fecha_inicio ?? ''}{e.fecha_fin ? ` — ${e.fecha_fin}` : ''}</div>
                )}
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {habilidades.length > 0 && (
      <details class="tw-card">
        <summary>
          <div class="tw-card-left">
            <div class="tw-card-icon">🧠</div>
            <div>
              <div class="tw-card-title">Habilidades</div>
              <div class="tw-card-count">{habilidades.length} habilidades</div>
            </div>
          </div>
          <div class="tw-chevron">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="tw-card-body">
          <div class="tw-skills">
            {habilidades.map(h => <span class="tw-skill">{h.nombre}</span>)}
          </div>
        </div>
      </details>
    )}

    {proyectos.length > 0 && (
      <details class="tw-card">
        <summary>
          <div class="tw-card-left">
            <div class="tw-card-icon">🗂</div>
            <div>
              <div class="tw-card-title">Proyectos</div>
              <div class="tw-card-count">{proyectos.length} {proyectos.length===1?'proyecto':'proyectos'}</div>
            </div>
          </div>
          <div class="tw-chevron">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="tw-card-body">
          <div class="tw-projects">
            {proyectos.map(p => (
              <div class="tw-project">
                {p.imagen_url && <img src={p.imagen_url} alt={p.titulo} class="tw-project-img" loading="lazy"/>}
                <div class="tw-project-body">
                  <div class="tw-project-title">{p.titulo}</div>
                  {p.descripcion && <p class="tw-project-desc">{p.descripcion}</p>}
                  {p.enlace_url && (
                    <a href={p.enlace_url} target="_blank" rel="noopener noreferrer"
                       class="tw-project-link track-proyecto" data-titulo={p.titulo}>
                      Ver proyecto →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {logros.length > 0 && (
      <details class="tw-card">
        <summary>
          <div class="tw-card-left">
            <div class="tw-card-icon">🏆</div>
            <div>
              <div class="tw-card-title">Logros</div>
              <div class="tw-card-count">{logros.length} {logros.length===1?'logro':'logros'}</div>
            </div>
          </div>
          <div class="tw-chevron">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="tw-card-body">
          <div class="tw-logros">
            {logros.map((l, i) => (
              <div class="tw-logro">
                <div class="tw-logro-num">0{i+1}</div>
                <div>
                  <div class="tw-logro-title">{l.titulo}</div>
                  {l.descripcion && <p class="tw-logro-desc">{l.descripcion}</p>}
                  {l.fecha && <div class="tw-logro-fecha">{l.fecha}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {capacitaciones.length > 0 && (
      <details class="tw-card">
        <summary>
          <div class="tw-card-left">
            <div class="tw-card-icon">📚</div>
            <div>
              <div class="tw-card-title">Cursos</div>
              <div class="tw-card-count">{capacitaciones.length} cursos</div>
            </div>
          </div>
          <div class="tw-chevron">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="tw-card-body">
          <div class="tw-caps">
            {capacitaciones.map(c => (
              <div class="tw-cap">
                <div class="tw-cap-dot"></div>
                <div>
                  <div class="tw-cap-name">{c.nombre}</div>
                  {c.institucion && <div class="tw-cap-inst">{c.institucion}</div>}
                  {c.fecha && <div class="tw-cap-fecha">{c.fecha}</div>}
                  {c.certificado_url && (
                    <a href={c.certificado_url} target="_blank" rel="noopener noreferrer" class="tw-cap-cert">
                      Ver certificado →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    {referencias && referencias.length > 0 && (
      <details class="tw-card">
        <summary>
          <div class="tw-card-left">
            <div class="tw-card-icon">🤝</div>
            <div>
              <div class="tw-card-title">Referencias</div>
              <div class="tw-card-count">{referencias.length} {referencias.length===1?'contacto':'contactos'}</div>
            </div>
          </div>
          <div class="tw-chevron">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </summary>
        <div class="tw-card-body">
          <div class="tw-refs">
            {referencias.map(r => (
              <div class="tw-ref">
                <div class="tw-ref-name">{r.nombre}</div>
                {(r.cargo || r.empresa) && (
                  <div class="tw-ref-cargo">{r.cargo}{r.empresa ? ` · ${r.empresa}` : ''}</div>
                )}
                {r.observaciones && <p class="tw-ref-obs">"{r.observaciones}"</p>}
                <div class="tw-ref-links">
                  {r.telefono && (
                    <a href={`tel:${r.telefono.replace(/\s/g,'')}`} class="tw-ref-link">📞 Llamar</a>
                  )}
                  {r.email && (
                    <a href={`mailto:${r.email}`} class="tw-ref-link">✉️ Email</a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

  </div>

  <footer class="tw-footer">
    Creado con <a href="/">CardVirtual</a>
  </footer>

  <!-- ── BARRA INFERIOR FIJA ─────────────────────────────── -->
  <div class="tw-bottom-bar">
    {perfil.cv_pdf_url && (
      <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer"
         class="tw-bar-btn tw-bar-btn-ghost track-cv">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Descargar CV
      </a>
    )}
    {perfil.email && (
      <a href={`mailto:${perfil.email}`} class="tw-bar-btn tw-bar-btn-solid">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Contactar
      </a>
    )}
    {!perfil.email && perfil.telefono && (
      <a href={`tel:${perfil.telefono.replace(/\s/g,'')}`} class="tw-bar-btn tw-bar-btn-solid">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Llamar
      </a>
    )}
  </div>

</div>