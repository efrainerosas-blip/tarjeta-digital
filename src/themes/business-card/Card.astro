<div id="track-data" data-perfil-id={perfil.id} style="display:none"></div>

<script>
  const card  = document.getElementById('bc-card')!
  const label = document.getElementById('bc-flip-label')!
  let flipped = false

  ;(window as any).bcFlip = function() {
    flipped = !flipped
    card.classList.toggle('flipped', flipped)
    label.textContent = flipped ? 'Ver frente' : 'Ver reverso'
  }

  // Swipe horizontal
  let touchX = 0
  const scene = document.getElementById('bc-scene')!
  scene.addEventListener('touchstart', e => { touchX = e.touches[0].clientX }, { passive: true })
  scene.addEventListener('touchend', e => {
    if (Math.abs(e.changedTouches[0].clientX - touchX) > 50) (window as any).bcFlip()
  }, { passive: true })

  // Tracking
  const perfilId = document.getElementById('track-data')?.dataset.perfilId
  if (perfilId) fetch('/api/track', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ perfil_id: perfilId }),
  })
</script>