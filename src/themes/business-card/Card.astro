---
// src/themes/business-card/Card.astro
// THEME: Business Card Premium — Pantalla completa, flip por swipe
//
// CARA FRONTAL: Fondo blanco + forma decorativa acento inf-der
//               Logo grande centrado, nombre, tagline, web/email, redes
//
// CARA TRASERA: Header navy ~55% con corte diagonal + fondo blanco
//               Logo pequeño + nombre en header, datos de contacto,
//               mapa Google Maps embed
//
// Sin botones de flip — solo swipe horizontal o clic en la tarjeta

import type { CardProps } from '../types'

const { perfil, servicios, redes } = Astro.props as CardProps

const accent  = perfil.color_primario   ?? '#f97316'
const accent2 = perfil.color_secundario ?? '#ea580c'
const nombre  = perfil.nombre_negocio   ?? perfil.nombre ?? 'Mi Negocio'
const tagline = perfil.tagline          ?? perfil.categoria_negocio ?? ''
const logo    = perfil.foto_url         ?? null
const tel     = perfil.telefono         ?? perfil.whatsapp_pedidos  ?? null
const email   = perfil.email_negocio    ?? perfil.email             ?? null
const dir     = perfil.direccion        ?? null
const web     = perfil.sitio_web        ?? null
const wa      = perfil.whatsapp_pedidos ?? perfil.telefono          ?? null
const slug    = perfil.slug             ?? ''
const resp    = [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')

// Contraste texto sobre acento
function lum(hex: string): number {
  const h = hex.replace('#','')
  const r = parseInt(h.slice(0,2),16)
  const g = parseInt(h.slice(2,4),16)
  const b = parseInt(h.slice(4,6),16)
  return (0.299*r + 0.587*g + 0.114*b)/255
}
const onAccent = lum(accent.startsWith('#') ? accent : '#f97316') > 0.55 ? '#0a0a0a' : '#ffffff'

// Google Maps embed URL (si hay dirección)
const mapsQuery = dir ? encodeURIComponent(dir) : null
const mapsEmbed = mapsQuery
  ? `https://www.google.com/maps/embed/v1/place?key=AIzaSyD-9tSrke72PouQMnMX-a7eZSW0jkFMBWY&q=${mapsQuery}`
  : null
const mapsLink = mapsQuery
  ? `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`
  : null

const ICONOS: Record<string,string> = {
  LinkedIn:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  Instagram:   `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  Facebook:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  WhatsApp:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  TikTok:      `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`,
  YouTube:     `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>`,
  'Twitter/X': `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  Telegram:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`,
}
function icon(p: string) {
  return ICONOS[p] ?? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>`
}
---

<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;600;700;800;900&family=Open+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" slot="head"/>

<style is:inline define:vars={{ accent, accent2, onAccent }}>

/* ── ROOT — variables del theme ─────────────────────────────── */
:root {
  --bc-navy:      #1a2238;
  --bc-navy2:     #111827;
  --bc-fh:        'Raleway', sans-serif;
  --bc-fb:        'Open Sans', sans-serif;
  --bc-white:     #ffffff;
  --bc-off:       #f8f9fc;
  --bc-text:      #1a2238;
  --bc-muted:     #6b7280;
  --bc-line:      #e5e7eb;
}

/* ── CONTENEDOR PRINCIPAL ───────────────────────────────────── */
.bc-root {
  position: fixed;
  inset: 0;
  overflow: hidden;
  background: var(--bc-navy2);
  font-family: var(--bc-fb);
  touch-action: pan-y;
}

/* ── FLIPPER ────────────────────────────────────────────────── */
.bc-flipper {
  position: absolute;
  inset: 0;
  transform-style: preserve-3d;
  transition: transform .7s cubic-bezier(.4,.2,.2,1);
  will-change: transform;
}
.bc-flipper.flipped {
  transform: rotateY(180deg);
}

/* ── CARA GENÉRICA ──────────────────────────────────────────── */
.bc-face {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
}

/* ══════════════════════════════════════════════════════════════
   CARA FRONTAL
   Fondo blanco, forma decorativa color en esquina inf-der,
   logo grande centrado, nombre, tagline, web/email, redes.
   Fiel a la imagen derecha de la referencia.
   ══════════════════════════════════════════════════════════════ */
.bc-front {
  background: var(--bc-white);
  display: flex;
  flex-direction: column;
  min-height: 100%;
}

/* Forma decorativa esquina superior izquierda */
.bc-front-deco-tl {
  position: absolute;
  top: 0; left: 0;
  width: 48%;
  height: 38%;
  pointer-events: none;
  overflow: hidden;
}
.bc-front-deco-tl svg {
  width: 100%; height: 100%;
}

/* Forma decorativa esquina inferior derecha */
.bc-front-deco-br {
  position: absolute;
  bottom: 0; right: 0;
  width: 42%;
  height: 32%;
  pointer-events: none;
  overflow: hidden;
}
.bc-front-deco-br svg {
  width: 100%; height: 100%;
}

/* Contenido centrado de la cara frontal */
.bc-front-content {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 40px 80px;
  gap: 0;
}

/* Logo */
.bc-front-logo {
  width: 110px;
  height: 110px;
  border-radius: 20px;
  overflow: hidden;
  margin-bottom: 28px;
  box-shadow:
    0 8px 32px rgba(0,0,0,.12),
    0 0 0 1px rgba(0,0,0,.06);
}
.bc-front-logo img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  display: block;
}
.bc-front-logo-ph {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  font-size: 3rem;
}

/* Nombre del negocio */
.bc-front-name {
  font-family: var(--bc-fh);
  font-size: clamp(1.6rem, 5vw, 2.2rem);
  font-weight: 800;
  color: var(--bc-text);
  letter-spacing: -.03em;
  line-height: 1.1;
  text-align: center;
  margin-bottom: 8px;
}

/* Tagline */
.bc-front-tag {
  font-family: var(--bc-fh);
  font-size: clamp(10px, 2.5vw, 12px);
  font-weight: 600;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: .22em;
  text-align: center;
  margin-bottom: 36px;
}

/* Divisor */
.bc-front-divider {
  width: 48px; height: 3px;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  border-radius: 99px;
  margin-bottom: 36px;
}

/* Web / Email */
.bc-front-web {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: clamp(12px, 3vw, 14px);
  font-weight: 500;
  color: var(--bc-muted);
  text-decoration: none;
  margin-bottom: 36px;
  transition: color .15s;
}
.bc-front-web:hover { color: var(--accent); }
.bc-front-web svg { width: 16px; height: 16px; flex-shrink: 0; opacity: .6; }

/* Redes sociales */
.bc-front-socials {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
}
.bc-front-social {
  width: 44px; height: 44px;
  border-radius: 12px;
  background: var(--bc-off);
  border: 1px solid var(--bc-line);
  display: flex; align-items: center; justify-content: center;
  color: var(--bc-muted);
  text-decoration: none;
  transition: all .18s;
}
.bc-front-social svg { width: 20px; height: 20px; }
.bc-front-social:hover {
  background: var(--accent);
  color: var(--onAccent);
  border-color: var(--accent);
  transform: translateY(-2px);
}

/* Hint swipe inferior */
.bc-swipe-hint {
  position: absolute;
  bottom: 24px;
  left: 0; right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 10px;
  font-weight: 600;
  color: var(--bc-muted);
  opacity: .5;
  letter-spacing: .1em;
  text-transform: uppercase;
  animation: bc-hint 3s ease-in-out infinite 2s;
  pointer-events: none;
}
.bc-swipe-hint svg { width: 14px; height: 14px; }
@keyframes bc-hint { 0%,100%{opacity:.3} 50%{opacity:.7} }

/* ══════════════════════════════════════════════════════════════
   CARA TRASERA
   Header navy con corte diagonal (~55% superior),
   fondo blanco inferior con datos de contacto y mapa.
   Fiel a la imagen izquierda de la referencia.
   ══════════════════════════════════════════════════════════════ */
.bc-back {
  background: var(--bc-white);
  transform: rotateY(180deg);
  display: flex;
  flex-direction: column;
  min-height: 100%;
}

/* Header navy con SVG diagonal */
.bc-back-header {
  position: relative;
  background: var(--bc-navy);
  flex-shrink: 0;
  /* La altura la da el contenido + el SVG */
}

/* SVG corte diagonal inferior del header */
.bc-back-header-cut {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  height: 60px;
  pointer-events: none;
}
.bc-back-header-cut svg {
  width: 100%; height: 100%;
}

/* Contenido del header */
.bc-back-header-content {
  position: relative;
  z-index: 1;
  padding: 48px 32px 72px;
  display: flex;
  align-items: center;
  gap: 20px;
}

/* Logo pequeño en header */
.bc-back-logo-sm {
  width: 64px; height: 64px;
  border-radius: 14px;
  overflow: hidden;
  flex-shrink: 0;
  border: 2px solid rgba(255,255,255,.2);
  box-shadow: 0 4px 16px rgba(0,0,0,.3);
}
.bc-back-logo-sm img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.bc-back-logo-sm-ph {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem;
}

/* Nombre en header */
.bc-back-header-text {}
.bc-back-header-name {
  font-family: var(--bc-fh);
  font-size: clamp(1.2rem, 4vw, 1.6rem);
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -.02em;
  line-height: 1.1;
}
.bc-back-header-tag {
  font-size: 11px;
  font-weight: 400;
  color: rgba(255,255,255,.55);
  margin-top: 4px;
  text-transform: uppercase;
  letter-spacing: .14em;
}

/* Acento de color esquina superior derecha del header */
.bc-back-header-accent {
  position: absolute;
  top: 0; right: 0;
  width: 80px; height: 80px;
  overflow: hidden;
  pointer-events: none;
}
.bc-back-header-accent svg {
  width: 100%; height: 100%;
}

/* Cuerpo del dorso — datos de contacto + mapa */
.bc-back-body {
  flex: 1;
  padding: 32px 28px 40px;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* Fila de contacto */
.bc-contact-row {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 0;
  border-bottom: 1px solid var(--bc-line);
  text-decoration: none;
  transition: all .15s;
}
.bc-contact-row:last-of-type { border-bottom: none; }
.bc-contact-row:hover .bc-contact-ico { background: var(--accent); color: var(--onAccent); }

.bc-contact-ico {
  width: 38px; height: 38px;
  border-radius: 10px;
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  color: var(--accent);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: all .15s;
}
.bc-contact-ico svg { width: 17px; height: 17px; }

.bc-contact-info { min-width: 0; }
.bc-contact-label {
  font-size: 9px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .12em;
  color: var(--bc-muted); line-height: 1;
  margin-bottom: 3px;
}
.bc-contact-value {
  font-size: 13.5px; font-weight: 500;
  color: var(--bc-text);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: calc(100vw - 120px);
}

/* Mapa Google Maps */
.bc-map-wrap {
  margin-top: 24px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--bc-line);
  box-shadow: 0 2px 16px rgba(0,0,0,.08);
  position: relative;
}
.bc-map-wrap iframe {
  width: 100%;
  height: 200px;
  border: none;
  display: block;
}
/* Overlay que abre Google Maps al tocar (evita que el iframe capture el swipe) */
.bc-map-overlay {
  position: absolute;
  inset: 0;
  cursor: pointer;
  background: transparent;
  -webkit-tap-highlight-color: transparent;
}

/* Dirección sin mapa (fallback si no hay embed) */
.bc-map-fallback {
  margin-top: 24px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  background: var(--bc-off);
  border-radius: 12px;
  border: 1px solid var(--bc-line);
  text-decoration: none;
  color: var(--bc-text);
  font-size: 13px;
  font-weight: 500;
  transition: all .15s;
}
.bc-map-fallback:hover { border-color: var(--accent); }
.bc-map-fallback svg { width: 18px; height: 18px; color: var(--accent); flex-shrink: 0; }

/* Footer */
.bc-back-footer {
  padding: 20px 28px 28px;
  text-align: center;
  font-size: 11px;
  color: var(--bc-muted);
  border-top: 1px solid var(--bc-line);
  margin-top: auto;
}
.bc-back-footer a {
  color: var(--accent);
  text-decoration: none;
  font-weight: 700;
}

/* ── Barra de acción inferior (fija) ────────────────────────── */
.bc-action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  gap: 10px;
  padding: 12px 20px;
  padding-bottom: max(12px, env(safe-area-inset-bottom, 12px));
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-top: 1px solid rgba(0,0,0,.07);
}
.bc-action-btn {
  flex: 1;
  display: flex; align-items: center; justify-content: center; gap: 7px;
  padding: 13px 10px;
  border-radius: 12px;
  font-family: var(--bc-fb);
  font-size: 13.5px; font-weight: 700;
  text-decoration: none; border: none; cursor: pointer;
  transition: all .2s; letter-spacing: -.01em;
  -webkit-tap-highlight-color: transparent;
}
.bc-action-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
.bc-btn-wa {
  background: #25D366; color: #fff;
  box-shadow: 0 4px 16px rgba(37,211,102,.3);
}
.bc-btn-wa:hover { opacity: .9; transform: translateY(-1px); }
.bc-btn-acc {
  background: var(--accent); color: var(--onAccent);
  box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 35%, transparent);
}
.bc-btn-acc:hover { opacity: .9; transform: translateY(-1px); }

/* ── Indicador de cara activa (dots) ────────────────────────── */
.bc-dots {
  position: fixed;
  bottom: calc(64px + max(12px, env(safe-area-inset-bottom, 12px)) + 8px);
  left: 50%;
  transform: translateX(-50%);
  display: flex; gap: 6px; z-index: 101;
  pointer-events: none;
}
.bc-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(0,0,0,.2);
  transition: all .3s;
}
.bc-dot.active {
  background: var(--accent);
  width: 18px;
  border-radius: 99px;
}

</style>

