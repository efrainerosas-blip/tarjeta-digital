---
// src/themes/business-card/Card.astro
// THEME: Business Card
// Tarjeta de presentación física digitalizada.
// Flip 3D CSS puro — cara frontal y cara trasera.
// Diseño premium: fondo oscuro, acento del negocio,
// tipografía editorial Playfair + DM Sans.
// Solo consume datos de perfiles_negocios (via vista).

import type { CardProps } from '../types'

const { perfil, servicios, redes } = Astro.props as CardProps

const accent  = perfil.color_primario  ?? '#C41E3A'
const accent2 = perfil.color_secundario ?? '#8B0000'
const nombre  = perfil.nombre_negocio  ?? perfil.nombre ?? 'Mi Negocio'
const tagline = perfil.tagline         ?? perfil.categoria_negocio ?? ''
const logo    = perfil.foto_url        ?? null
const tel     = perfil.telefono        ?? perfil.whatsapp_pedidos  ?? null
const email   = perfil.email_negocio   ?? null
const dir     = perfil.direccion       ?? null
const web     = perfil.sitio_web       ?? null
const wa      = perfil.whatsapp_pedidos ?? perfil.telefono ?? null
const slug    = perfil.slug            ?? ''

// Luminancia para color de texto sobre el acento
function lum(hex: string): number {
  const h = hex.replace('#','')
  const r = parseInt(h.slice(0,2),16)
  const g = parseInt(h.slice(2,4),16)
  const b = parseInt(h.slice(4,6),16)
  return (0.299*r + 0.587*g + 0.114*b)/255
}
const accentText = lum(accent.startsWith('#') ? accent : '#C41E3A') > 0.55
  ? '#0a0a0a' : '#ffffff'

// Íconos redes (mismos que ios-card)
const ICONOS: Record<string,string> = {
