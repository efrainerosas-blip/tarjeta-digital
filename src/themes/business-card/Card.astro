---
// src/themes/business-card/Card.astro
// THEME: Business Card — Flip 3D
// Cara FRONTAL: fondo blanco/crema, ondas de color en esquinas,
//               logo centrado, nombre, tagline, datos de contacto.
// Cara TRASERA: fondo oscuro azul/navy, redes, web, QR hint.
// Inspirado en tarjeta de presentación física clásica.

import type { CardProps } from '../types'

const { perfil, servicios, redes } = Astro.props as CardProps

const accent  = perfil.color_primario   ?? '#1a56db'
const accent2 = perfil.color_secundario ?? '#1e3a8a'
const nombre  = perfil.nombre_negocio   ?? perfil.nombre ?? 'Mi Negocio'
const tagline = perfil.tagline          ?? perfil.categoria_negocio ?? ''
const logo    = perfil.foto_url         ?? null
const tel     = perfil.telefono         ?? perfil.whatsapp_pedidos  ?? null
const email   = perfil.email_negocio    ?? null
const dir     = perfil.direccion        ?? null
const web     = perfil.sitio_web        ?? null
const wa      = perfil.whatsapp_pedidos ?? perfil.telefono          ?? null
const slug    = perfil.slug             ?? ''

function lum(hex: string): number {
  const h = hex.replace('#','')
  const r = parseInt(h.slice(0,2),16)
  const g = parseInt(h.slice(2,4),16)
  const b = parseInt(h.slice(4,6),16)
  return (0.299*r + 0.587*g + 0.114*b)/255
}
const accentText = lum(accent.startsWith('#') ? accent : '#1a56db') > 0.55 ? '#0a0a0a' : '#ffffff'

const ICONOS: Record<string,string> = {
  LinkedIn:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  Instagram:   `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  Facebook:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  WhatsApp:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  TikTok:      `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`,
  YouTube:     `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>`,
  'Twitter/X': `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  Telegram:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`,
}
function icon(p: string) {
  return ICONOS[p] ?? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`
}
---

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" slot="head" />

<style is:inline define:vars={{ accent, accent2, accentText }}>

:root {
  --bc-ff-head: 'Montserrat', sans-serif;
  --bc-ff-body: 'Open Sans', sans-serif;
  --bc-front-bg:   #f7f9fc;
  --bc-front-bg2:  #ffffff;
  --bc-front-text: #1a1f36;
  --bc-front-muted:#6b7280;
  --bc-front-line: #e5e9f0;
  --bc-back-bg:    #0d1b3e;
  --bc-back-bg2:   #112250;
  --bc-back-text:  #e8edf8;
  --bc-back-muted: rgba(232,237,248,.5);
  --bc-w: 360px;
  --bc-h: 620px;
  --bc-r: 18px;
}

.bc-page {

  min-height: 100vh;
  font-family: var(--bc-ff-body);
  /* Fondo neutro claro — resalta la tarjeta */
  background: linear-gradient(160deg, #e8edf8 0%, #d4daf0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 16px 110px;
  position: relative;
}

/* Textura sutil de fondo */
.bc-page::before {
  content: '';
  position: fixed; inset: 0;
  background-image: radial-gradient(circle at 20% 20%, rgba(255,255,255,.6) 0%, transparent 50%),
                    radial-gradient(circle at 80% 80%, color-mix(in srgb, var(--accent) 12%, transparent) 0%, transparent 50%);
  pointer-events: none; z-index: 0;
}

/* ── ESCENA 3D ─────────────────────────────────────────────── */
.bc-scene {
  position: relative; z-index: 1;
  width: min(var(--bc-w), calc(100vw - 32px));
  height: min(var(--bc-h), calc((100vw - 32px) * 1.72));
  perspective: 1400px;
  cursor: pointer;
  margin-bottom: 20px;
  animation: bc-appear .65s cubic-bezier(.34,1.4,.64,1) both;
  /* Sombra realista de tarjeta */
  /* filter removido — rompe preserve-3d en todos los navegadores */
}

@keyframes bc-appear {
  from { opacity:0; transform: translateY(28px) scale(.97); }
  to   { opacity:1; transform: translateY(0) scale(1); }
}

.bc-card {
  width: 100%; height: 100%;
  position: relative;
  transform-style: preserve-3d;
  box-shadow: 0 20px 50px rgba(13,27,62,.35), 0 4px 12px rgba(13,27,62,.2);
  transition: transform .75s cubic-bezier(.4,.2,.2,1);
}
.bc-card.flipped { transform: rotateY(180deg); }

.bc-face {
  position: absolute; inset: 0;
  border-radius: var(--bc-r);
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  overflow: hidden;
}

/* ════════════════════════════════════════════════════════════
   CARA FRONTAL — BLANCA con ondas de color
   ════════════════════════════════════════════════════════════ */
.bc-front {
  background: var(--bc-front-bg);
  display: flex;
  flex-direction: column;
}

/* Onda decorativa superior — color del acento */
.bc-front-wave-top {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 220px;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}
.bc-front-wave-top svg {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%;
}

/* Onda decorativa inferior derecha */
.bc-front-wave-bottom {
  position: absolute;
  bottom: 0; right: 0;
  width: 180px; height: 180px;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}
.bc-front-wave-bottom svg {
  position: absolute; bottom: 0; right: 0;
  width: 100%; height: 100%;
}

/* Logo centrado encima de la ola */
.bc-front-logo-wrap {
  position: relative; z-index: 2;
  display: flex; justify-content: center;
  padding-top: 32px;
}
.bc-front-logo-ring {
  width: 90px; height: 90px;
  border-radius: 50%;
  padding: 4px;
  background: white;
  box-shadow: 0 4px 24px rgba(0,0,0,.18), 0 0 0 3px var(--accent);
}
.bc-front-logo-ring img,
.bc-front-logo-ring .bc-logo-ph {
  width: 100%; height: 100%;
  border-radius: 50%;
  object-fit: cover; object-position: center;
  display: block;
}
.bc-logo-ph {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  font-size: 2.2rem;
}

/* Cuerpo frontal */
.bc-front-body {
  position: relative; z-index: 1;
  flex: 1;
  display: flex; flex-direction: column;
  align-items: center;
  padding: 20px 28px 24px;
  text-align: center;
}

.bc-biz-name {
  font-family: var(--bc-ff-head);
  font-size: 1.6rem; font-weight: 800;
  color: var(--bc-front-text);
  letter-spacing: -.03em;
  line-height: 1.1;
  margin-bottom: 4px;
}
.bc-biz-tagline {
  font-family: var(--bc-ff-head);
  font-size: 11px; font-weight: 600;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: .2em;
  margin-bottom: 20px;
}

/* Línea divisoria ornamental */
.bc-sep {
  display: flex; align-items: center; gap: 8px;
  width: 100%; margin-bottom: 20px;
}
.bc-sep-line { flex: 1; height: 1px; background: var(--bc-front-line); }
.bc-sep-ico  {
  width: 26px; height: 26px; border-radius: 50%;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.bc-sep-ico svg { width: 12px; height: 12px; fill: var(--accentText); }

/* Lista de contactos */
.bc-contacts {
  width: 100%;
  display: flex; flex-direction: column; gap: 10px;
}
.bc-contact-row {
  display: flex; align-items: center; gap: 12px;
  text-decoration: none;
  padding: 9px 12px;
  border-radius: 10px;
  background: var(--bc-front-bg2);
  border: 1px solid var(--bc-front-line);
  transition: all .15s;
}
.bc-contact-row:hover {
  border-color: var(--accent);
  box-shadow: 0 2px 12px color-mix(in srgb, var(--accent) 15%, transparent);
  transform: translateX(2px);
}
.bc-contact-icon {
  width: 32px; height: 32px; border-radius: 8px;
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  display: flex; align-items: center; justify-content: center;
  color: var(--accent); flex-shrink: 0;
}
.bc-contact-icon svg { width: 15px; height: 15px; }
.bc-contact-info { text-align: left; min-width: 0; }
.bc-contact-label { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: .1em; color: var(--bc-front-muted); line-height: 1; }
.bc-contact-val   { font-size: 12.5px; font-weight: 500; color: var(--bc-front-text); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* Status */
.bc-status-wrap {
  margin-top: auto; padding-top: 16px;
  display: flex; align-items: center; gap: 6px;
  font-size: 10px; font-weight: 600; text-transform: uppercase;
  letter-spacing: .08em; color: var(--bc-front-muted);
}
.bc-status-dot {
  width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
}
.bc-status-dot.open   { background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,.5); }
.bc-status-dot.closed { background: #ef4444; }
.bc-status-dot.other  { background: #f59e0b; }

/* ════════════════════════════════════════════════════════════
   CARA TRASERA — NAVY OSCURO con info del responsable + redes
   ════════════════════════════════════════════════════════════ */
.bc-back {
  background: linear-gradient(160deg, var(--bc-back-bg) 0%, var(--bc-back-bg2) 100%);
  transform: rotateY(180deg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: space-between;
  padding: 44px 28px 36px;
  position: relative; overflow: hidden;
}

/* Onda decorativa en la trasera (espejo del frente) */
.bc-back-wave {
  position: absolute; top: 0; left: 0; right: 0; height: 160px;
  pointer-events: none; overflow: hidden;
}
.bc-back-wave svg { width: 100%; height: 100%; }

/* Círculo decorativo trasero */
.bc-back-circle {
  position: absolute; bottom: -60px; right: -60px;
  width: 220px; height: 220px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,.05);
  pointer-events: none;
}
.bc-back-circle::after {
  content: '';
  position: absolute; inset: 20px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,.04);
}

/* Sección superior: nombre del responsable */
.bc-back-top {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  text-align: center;
}
.bc-back-resp-label {
  font-size: 9px; font-weight: 600; text-transform: uppercase;
  letter-spacing: .18em; color: var(--bc-back-muted);
}
.bc-back-resp-name {
  font-family: var(--bc-ff-head);
  font-size: 1.4rem; font-weight: 700;
  color: var(--bc-back-text);
  letter-spacing: -.02em; line-height: 1.15;
}
.bc-back-resp-title {
  font-size: 11px; font-weight: 400;
  color: var(--bc-back-muted);
  letter-spacing: .06em;
}

/* Línea divisoria central (idéntica a la imagen 2) */
.bc-back-divider {
  position: relative; z-index: 1;
  width: 100%;
  display: flex; align-items: center; gap: 12px;
}
.bc-back-divider-line { flex: 1; height: 1px; background: rgba(255,255,255,.1); }
.bc-back-divider-logo {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
}
.bc-back-logo-img,
.bc-back-logo-ph {
  width: 56px; height: 56px; border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(255,255,255,.15);
  box-shadow: 0 0 24px color-mix(in srgb, var(--accent) 25%, transparent);
}
.bc-back-logo-ph {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem;
}
.bc-back-biz-name {
  font-family: var(--bc-ff-head);
  font-size: 13px; font-weight: 700;
  color: rgba(255,255,255,.9);
  text-align: center; letter-spacing: -.01em;
}

/* Lista de datos de contacto en la trasera */
.bc-back-contacts {
  position: relative; z-index: 1;
  width: 100%; display: flex; flex-direction: column; gap: 10px;
}
.bc-back-contact-row {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.bc-back-contact-ico {
  width: 30px; height: 30px; border-radius: 8px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.1);
  display: flex; align-items: center; justify-content: center;
  color: var(--accent); flex-shrink: 0;
}
.bc-back-contact-ico svg { width: 14px; height: 14px; }
.bc-back-contact-txt {
  font-size: 12px; font-weight: 400;
  color: rgba(255,255,255,.75);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* Redes sociales en la trasera */
.bc-socials {
  position: relative; z-index: 1;
  display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;
}
.bc-social-btn {
  width: 42px; height: 42px; border-radius: 10px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.1);
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,.65);
  text-decoration: none;
  transition: all .18s;
}
.bc-social-btn svg { width: 18px; height: 18px; }
.bc-social-btn:hover {
  background: var(--accent); color: var(--accentText);
  border-color: var(--accent); transform: translateY(-2px);
}

/* Hint flip en la trasera */
.bc-back-hint {
  position: relative; z-index: 1;
  display: flex; align-items: center; gap: 6px;
  font-size: 10px; color: rgba(255,255,255,.25);
  animation: bc-pulse 3s ease-in-out infinite 2s;
}
.bc-back-hint svg { width: 12px; height: 12px; }
@keyframes bc-pulse { 0%,100%{opacity:.4} 50%{opacity:.8} }

/* ── BOTÓN FLIP ────────────────────────────────────────────── */
.bc-flip-btn {
  position: relative; z-index: 2;
  display: flex; align-items: center; gap: 8px;
  background: white;
  border: 1.5px solid var(--bc-front-line);
  border-radius: 99px;
  padding: 10px 22px;
  font-family: var(--bc-ff-body);
  font-size: 12.5px; font-weight: 600;
  color: var(--bc-front-text);
  cursor: pointer;
  transition: all .2s;
  box-shadow: 0 2px 12px rgba(0,0,0,.1);
}
.bc-flip-btn:hover {
  background: var(--accent);
  color: var(--accentText);
  border-color: var(--accent);
  box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 35%, transparent);
}
.bc-flip-btn svg { width: 14px; height: 14px; }

/* ── CATÁLOGO ──────────────────────────────────────────────── */
.bc-catalog-section {
  width: 100%; max-width: var(--bc-w);
  position: relative; z-index: 1;
  margin-top: 12px;
}
.bc-catalog-title {
  font-family: var(--bc-ff-head);
  font-size: 16px; font-weight: 700;
  color: var(--bc-front-text);
  margin-bottom: 12px;
  display: flex; align-items: center; gap: 10px;
  padding: 0 2px;
}
.bc-catalog-title::after {
  content: ''; flex: 1; height: 2px;
  background: linear-gradient(90deg, var(--accent), transparent);
  border-radius: 99px;
}
.bc-catalog-grid { display: flex; flex-direction: column; gap: 8px; }
.bc-catalog-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px;
  background: white;
  border: 1px solid var(--bc-front-line);
  border-radius: 12px;
  transition: all .15s;
  text-decoration: none;
  box-shadow: 0 1px 4px rgba(0,0,0,.06);
}
.bc-catalog-item:hover { border-color: var(--accent); transform: translateX(2px); }
.bc-catalog-ico { font-size: 20px; flex-shrink: 0; }
.bc-catalog-name { font-size: 13px; font-weight: 600; color: var(--bc-front-text); }
.bc-catalog-desc { font-size: 11px; color: var(--bc-front-muted); margin-top: 1px; }
.bc-catalog-price {
  margin-left: auto; flex-shrink: 0;
  font-size: 12px; font-weight: 700;
  color: var(--accentText);
  background: var(--accent);
  padding: 3px 10px; border-radius: 99px;
}

/* ── BARRA INFERIOR ─────────────────────────────────────────── */
.bc-bar {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 420px;
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-top: 1px solid rgba(0,0,0,.08);
  padding: 12px 20px;
  padding-bottom: max(12px, env(safe-area-inset-bottom, 12px));
  display: flex; gap: 10px;
  z-index: 50;
}
.bc-bar-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px;
  padding: 13px 10px; border-radius: 12px;
  font-family: var(--bc-ff-body); font-size: 13.5px; font-weight: 600;
  text-decoration: none; border: none; cursor: pointer;
  transition: all .2s; letter-spacing: -.01em;
  -webkit-tap-highlight-color: transparent;
}
.bc-bar-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
.bc-bar-wa {
  background: #25D366; color: #fff;
  box-shadow: 0 4px 16px rgba(37,211,102,.3);
}
.bc-bar-wa:hover { opacity: .9; transform: translateY(-1px); }
.bc-bar-solid {
  background: var(--accent); color: var(--accentText);
  box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 35%, transparent);
}
.bc-bar-solid:hover { opacity: .92; transform: translateY(-1px); }

/* ── FOOTER ─────────────────────────────────────────────────── */
.bc-footer {
  position: relative; z-index: 1;
  text-align: center; padding: 20px 0 6px;
  font-size: 11px; color: var(--bc-front-muted);
}
.bc-footer a { color: var(--accent); text-decoration: none; font-weight: 600; }

@media (min-width: 480px) {
  .bc-page { padding-top: 60px; }
}

</style>

