<div id="bc-track" data-perfil-id={perfil.id} style="display:none"></div>

<script>
  const flipper = document.getElementById('bc-flipper')!
  const dot0    = document.getElementById('bc-dot-0')!
  const dot1    = document.getElementById('bc-dot-1')!
  let flipped   = false
  let touchStartX = 0
  let touchStartY = 0

  function flip(to?: boolean) {
    flipped = to !== undefined ? to : !flipped
    flipper.classList.toggle('flipped', flipped)
    dot0.classList.toggle('active', !flipped)
    dot1.classList.toggle('active', flipped)
  }

  // Swipe horizontal en el contenedor raíz
  const root = document.getElementById('bc-root')!

  root.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX
    touchStartY = e.touches[0].clientY
  }, { passive: true })

  root.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX
    const dy = Math.abs(e.changedTouches[0].clientY - touchStartY)
    // Solo flip si es un swipe mayormente horizontal (no scroll vertical)
    if (Math.abs(dx) > 60 && dy < 80) {
      if (dx < 0 && !flipped) flip(true)   // swipe izq → ver dorso
      if (dx > 0 && flipped)  flip(false)  // swipe der → ver frente
    }
  }, { passive: true })

  // También clic/tap en la cara (no en links ni iframe)
  ;['bc-front', 'bc-back'].forEach(id => {
    document.getElementById(id)?.addEventListener('click', e => {
      const t = e.target as HTMLElement
      if (t.closest('a') || t.closest('iframe') || t.closest('.bc-map-overlay')) return
      flip()
    })
  })

  // Teclado: flechas izq/der
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' && !flipped) flip(true)
    if (e.key === 'ArrowLeft'  && flipped)  flip(false)
  })

  // Tracking
  const pid = document.getElementById('bc-track')?.dataset.perfilId
  if (pid) fetch('/api/track', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ perfil_id: pid }),
  })
</script>