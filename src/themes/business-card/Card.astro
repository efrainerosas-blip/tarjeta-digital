      </svg>
      Llamar
    </a>
  )}
  <a href={`/${slug}`} class="bc-bar-btn bc-bar-acc">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    Contactar
  </a>
</div>

<div id="track-data" data-perfil-id={perfil.id} style="display:none"></div>

<script>
  const card  = document.getElementById('bc-card')!
  const label = document.getElementById('bc-flip-label')!
  let flipped = false

  ;(window as any).bcFlip = function() {
    flipped = !flipped
    card.classList.toggle('flipped', flipped)
    label.textContent = flipped ? 'Ver frente' : 'Ver reverso'
  }

  // Swipe horizontal para flip
  let tx = 0
  const scene = document.getElementById('bc-scene')!
  scene.addEventListener('touchstart', e => { tx = e.touches[0].clientX }, { passive: true })
  scene.addEventListener('touchend',   e => {
    if (Math.abs(e.changedTouches[0].clientX - tx) > 50) (window as any).bcFlip()
  }, { passive: true })

  // Tracking
  const pid = document.getElementById('track-data')?.dataset.perfilId
  if (pid) fetch('/api/track', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ perfil_id: pid }),
  })
</script>