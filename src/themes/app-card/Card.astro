---
// src/themes/app-card/Card.astro
// THEME: App Card — Cinematográfico
// Foto a pantalla completa con Ken Burns, gradiente oscuro,
// grain overlay, nombre con fadeUp. Secciones dark glass.

import type { CardProps } from '../types'

const {
  perfil, experiencia, estudios, habilidades,
  servicios, proyectos, redes, logros, capacitaciones,
} = Astro.props as CardProps

const accent  = perfil.color_primario ?? '#2563eb'
const nombre  = [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')

