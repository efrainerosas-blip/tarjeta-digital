}

// Usa foto de portada si hay, si no la foto de perfil, si no nada
const fotoHero = perfil.foto_portada_url || perfil.foto_url || null
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={perfil.bio ?? `Tarjeta digital de ${nombre}`} />
  <meta property="og:title" content={nombre} />
  {perfil.foto_url && <meta property="og:image" content={perfil.foto_url} />}
  <title>{nombre}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style define:vars={{ accent }}>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --accent:  var(--accent);
      --bg:      #0a0508;
      --glass:   rgba(255,255,255,.05);
      --glass-b: rgba(255,255,255,.09);
      --t1:      #ffffff;
      --t2:      rgba(255,255,255,.78);
      --t3:      rgba(255,255,255,.48);
      --t4:      rgba(255,255,255,.28);
      --font:    'Outfit', sans-serif;
      --max-w:   480px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--t2);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    .page {
      max-width: var(--max-w);
      margin: 0 auto;
      min-height: 100vh;
    }

    /* ══ HERO ══ */
    .hero {
      position: relative;
      width: 100%;
      height: 100svh;
      max-height: 700px;
      overflow: hidden;
      background: var(--bg);
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center top;
      animation: kenBurns 14s ease-out forwards;
      will-change: transform;
    }

    .hero-bg-placeholder {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        160deg,
        color-mix(in srgb, var(--accent) 80%, #000) 0%,
        color-mix(in srgb, var(--accent) 30%, #000) 55%,
        #0a0508 100%
      );
    }

    /* Gradiente igual al HeroBanner */
    .hero-gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(10,5,8,.97) 0%,
        rgba(10,5,8,.62) 42%,
        rgba(10,5,8,.12) 100%
      );
      pointer-events: none;
      z-index: 2;
    }

    /* Grain overlay sutil */
    .hero-grain {
      position: absolute;
      inset: 0;
      opacity: .045;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 128px;
      pointer-events: none;
      z-index: 3;
    }

    /* Contenido anclado al fondo del hero */
    .hero-content {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2rem 1.5rem 2.5rem;
      z-index: 10;
      display: flex;
      flex-direction: column;
      gap: .9rem;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 5px 13px;
      border-radius: 99px;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.2);
      color: #fff;
      backdrop-filter: blur(8px);
      width: fit-content;
      animation: fadeUp .5s ease-out both;
    }
    .status-badge::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 6px var(--accent);
    }

    .hero-name {
      font-size: clamp(2rem, 9vw, 3rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.05;
      letter-spacing: -.03em;
      text-shadow: 0 4px 24px rgba(0,0,0,.8);
      animation: fadeUp .55s ease-out .08s both;
    }

    .hero-title {
      font-size: 13px;
      font-weight: 500;
      color: var(--t3);
      letter-spacing: .04em;
      margin-top: -2px;
      animation: fadeUp .55s ease-out .14s both;
    }

    .hero-location {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      color: var(--t3);
      animation: fadeUp .55s ease-out .18s both;
    }

    /* Íconos circulares sin texto */
    .hero-redes {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      animation: fadeUp .55s ease-out .22s both;
    }

    .red-icon {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.2);
      backdrop-filter: blur(8px);
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      text-decoration: none;
      transition: background .15s, transform .15s;
      flex-shrink: 0;
    }
    .red-icon svg { width: 18px; height: 18px; }
    .red-icon:hover { background: var(--accent); border-color: var(--accent); transform: scale(1.08); }

    .hero-footer {
      display: flex;
      align-items: center;
      gap: 14px;
      animation: fadeUp .55s ease-out .28s both;
    }

    .cv-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 11px 22px;
      background: var(--accent);
      color: #fff;
      border-radius: 12px;
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      transition: opacity .15s, transform .15s;
      box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 55%, transparent);
    }
    .cv-btn:hover { opacity: .88; transform: translateY(-1px); }
    .cv-btn svg { width: 16px; height: 16px; }

    .scroll-hint {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      color: var(--t4);
      letter-spacing: .04em;
    }
    .scroll-hint svg { animation: bounce 1.8s ease-in-out infinite; }

    /* ══ CONTENIDO DARK GLASS ══ */
    .content { padding: 8px 14px 48px; }

    .bio-strip {
      background: var(--glass);
      border: 1px solid var(--glass-b);
      border-radius: 16px;
      padding: 16px 18px;
      margin-bottom: 8px;
      font-size: 14px;
      color: var(--t2);
      line-height: 1.8;
    }

    .acc {
      margin-bottom: 8px;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid var(--glass-b);
      background: var(--glass);
    }

    .acc summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 16px;
      cursor: pointer;
      list-style: none;
      user-select: none;
      transition: background .15s;
    }
    .acc summary:hover { background: rgba(255,255,255,.04); }
    .acc summary::-webkit-details-marker { display: none; }

    .acc-left { display: flex; align-items: center; gap: 12px; }

    .acc-emoji {
      width: 36px; height: 36px;
      border-radius: 10px;
      background: color-mix(in srgb, var(--accent) 18%, transparent);
      display: flex; align-items: center; justify-content: center;
      font-size: 17px; flex-shrink: 0;
    }

    .acc-title { font-size: 14px; font-weight: 700; color: var(--t1); }
    .acc-count { font-size: 11px; color: var(--t4); margin-top: 1px; }

    .acc-chevron { color: var(--t4); transition: transform .2s; flex-shrink: 0; }
    details[open] .acc-chevron { transform: rotate(180deg); }

    .acc-body {
      padding: 0 14px 14px;
      border-top: 1px solid var(--glass-b);
    }

    /* Timeline */
    .timeline { display: flex; flex-direction: column; }
    .tl-item {
      padding: 13px 0 13px 16px;
      border-left: 1px solid rgba(255,255,255,.12);
      position: relative;
    }
    .tl-item::before {
      content: '';
      position: absolute;
      left: -4px; top: 19px;
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--bg);
      border: 1.5px solid var(--accent);
    }
    .tl-title  { font-size: 13px; font-weight: 700; color: var(--t1); }
    .tl-sub    { font-size: 12px; color: var(--t3); margin-top: 2px; }
    .tl-period {
      display: inline-flex;
      font-size: 10px; color: var(--t4);
      background: rgba(255,255,255,.06);
      padding: 2px 8px; border-radius: 99px; margin-top: 4px;
    }
    .tl-desc   { font-size: 12px; color: var(--t3); margin-top: 5px; line-height: 1.6; }
    .badge-actual {
      display: inline-flex;
      font-size: 9px; font-weight: 800;
      padding: 2px 8px; border-radius: 99px;
      background: color-mix(in srgb, var(--accent) 20%, transparent);
      color: var(--accent);
      text-transform: uppercase; letter-spacing: .08em; margin-top: 4px;
    }

    .skills { display: flex; flex-wrap: wrap; gap: 7px; padding-top: 13px; }
    .skill-tag {
      font-size: 11px; font-weight: 600;
      padding: 5px 12px; border-radius: 99px;
      background: rgba(255,255,255,.07);
      color: var(--t2);
      border: 1px solid rgba(255,255,255,.1);
    }

    .services { display: flex; flex-direction: column; gap: 9px; padding-top: 13px; }
    .service-item {
      display: flex; gap: 12px;
      padding: 12px 13px;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 12px;
    }
    .service-emoji { font-size: 22px; flex-shrink: 0; line-height: 1; margin-top: 1px; }
    .service-name  { font-size: 13px; font-weight: 700; color: var(--t1); }
    .service-desc  { font-size: 12px; color: var(--t3); margin-top: 3px; line-height: 1.5; }
    .service-price { display: inline-flex; font-size: 12px; font-weight: 700; color: var(--accent); margin-top: 5px; }

    .projects { display: flex; flex-direction: column; gap: 10px; padding-top: 13px; }
    .project-item {
      border-radius: 12px; overflow: hidden;
      border: 1px solid rgba(255,255,255,.07);
      background: rgba(255,255,255,.04);
    }
    .project-img   { width: 100%; height: 148px; object-fit: cover; display: block; opacity: .85; }
    .project-body  { padding: 12px; }
    .project-title { font-size: 13px; font-weight: 700; color: var(--t1); }
    .project-desc  { font-size: 12px; color: var(--t3); margin-top: 3px; line-height: 1.5; }
    .project-link  {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 700;
      color: var(--accent); text-decoration: none; margin-top: 7px;
    }

    .logros { display: flex; flex-direction: column; gap: 9px; padding-top: 13px; }
    .logro-item {
      display: flex; gap: 12px;
      padding: 12px 13px;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 12px;
    }
    .logro-num   { font-size: 20px; font-weight: 900; color: color-mix(in srgb, var(--accent) 30%, transparent); line-height: 1; min-width: 26px; }
    .logro-title { font-size: 13px; font-weight: 700; color: var(--t1); }
    .logro-desc  { font-size: 12px; color: var(--t3); margin-top: 2px; }
    .logro-fecha { font-size: 10px; color: var(--t4); margin-top: 3px; }

    .caps { display: flex; flex-direction: column; gap: 9px; padding-top: 13px; }
    .cap-item {
      display: flex; gap: 10px;
      padding: 12px 13px;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 12px;
    }
    .cap-dot   { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); flex-shrink: 0; margin-top: 5px; box-shadow: 0 0 5px var(--accent); }
    .cap-name  { font-size: 13px; font-weight: 700; color: var(--t1); }
    .cap-inst  { font-size: 12px; color: var(--t3); margin-top: 1px; }
    .cap-fecha { font-size: 10px; color: var(--t4); margin-top: 2px; }
    .cap-cert  { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; color: var(--accent); text-decoration: none; margin-top: 4px; }

    .card-footer {
      text-align: center;
      padding: 16px 24px 32px;
      font-size: 11px;
      color: var(--t4);
      letter-spacing: .04em;
    }
    .card-footer a { color: var(--accent); text-decoration: none; font-weight: 700; }

    /* ══ ANIMACIONES ══ */
    @keyframes kenBurns {
      0%   { transform: scale(1);    }
      100% { transform: scale(1.07); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0);    }
    }
    @keyframes bounce {
      0%,100% { transform: translateY(0);   }
      50%      { transform: translateY(4px); }
    }

    /* ══ RESPONSIVE ══ */
    @media (min-width: 480px) {
      body { padding: 24px 0 48px; background: #111; }
      .page { border-radius: 32px; overflow: hidden; box-shadow: 0 32px 80px rgba(0,0,0,.6); }
    }
  </style>
</head>

<body>
  <div class="page">

    <!-- HERO -->
    <section class="hero">
      {fotoHero
        ? <div class="hero-bg" style={`background-image:url('${fotoHero}')`}></div>
        : <div class="hero-bg-placeholder"></div>
      }
      <div class="hero-gradient"></div>
      <div class="hero-grain"></div>

      <div class="hero-content">
        <span class="status-badge">{perfil.status ?? 'Disponible'}</span>

        <div>
          <h1 class="hero-name">{nombre}</h1>
          {perfil.titulo_profesional && <p class="hero-title">{perfil.titulo_profesional}</p>}
          {perfil.ubicacion && (
            <p class="hero-location">
              <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              </svg>
              {perfil.ubicacion}
            </p>
          )}
          {perfil.telefono && (
            <a href={`tel:${perfil.telefono.replace(/\s/g,'')}`} class="hero-location" style="text-decoration:none;color:var(--t3)">
              <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {perfil.telefono}
            </a>
          )}
        </div>

        {redes.length > 0 && (
          <div class="hero-redes">
            {redes.map(red => (
              <a href={red.url} target="_blank" rel="noopener noreferrer"
                class="red-icon track-red" data-plataforma={red.plataforma} title={red.plataforma}>
                <Fragment set:html={icon(red.plataforma)} />
              </a>
            ))}
          </div>
        )}

        <div class="hero-footer">
          {perfil.cv_pdf_url && (
            <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer" class="cv-btn track-cv">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Descargar CV
            </a>
          )}
          <div class="scroll-hint">
            <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
            Ver más
          </div>
        </div>
      </div>
    </section>

    <!-- CONTENIDO -->
    <div class="content">

      {perfil.bio && <div class="bio-strip">{perfil.bio}</div>}

      {servicios.length > 0 && (
        <details class="acc" open>
          <summary>
            <div class="acc-left">
              <div class="acc-emoji">⚡</div>
              <div><div class="acc-title">Servicios</div><div class="acc-count">{servicios.length} {servicios.length === 1 ? 'servicio' : 'servicios'}</div></div>
            </div>
            <svg class="acc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="acc-body">
            <div class="services">
              {servicios.map(s => (
                <div class="service-item">
                  {s.icono && <div class="service-emoji">{s.icono}</div>}
                  <div>
                    <div class="service-name">{s.nombre}</div>
                    {s.descripcion && <p class="service-desc">{s.descripcion}</p>}
                    {s.precio_referencial && <div class="service-price">{s.precio_referencial}</div>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </details>
      )}

      {experiencia.length > 0 && (
        <details class="acc">
          <summary>
            <div class="acc-left">
              <div class="acc-emoji">💼</div>
              <div><div class="acc-title">Experiencia</div><div class="acc-count">{experiencia.length} {experiencia.length === 1 ? 'posición' : 'posiciones'}</div></div>
            </div>
            <svg class="acc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="acc-body">
            <div class="timeline">
              {experiencia.map(exp => (
                <div class="tl-item">
                  <div class="tl-title">{exp.cargo}</div>
                  <div class="tl-sub">{exp.empresa}</div>
                  {exp.periodo && <div class="tl-period">{exp.periodo}</div>}
                  {exp.es_trabajo_actual && <div class="badge-actual">Actual</div>}
                  {exp.descripcion && <p class="tl-desc">{exp.descripcion}</p>}
                </div>
              ))}
            </div>
          </div>
        </details>
      )}

      {estudios.length > 0 && (
        <details class="acc">
          <summary>
            <div class="acc-left">
              <div class="acc-emoji">🎓</div>
              <div><div class="acc-title">Educación</div><div class="acc-count">{estudios.length} {estudios.length === 1 ? 'estudio' : 'estudios'}</div></div>
            </div>
            <svg class="acc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="acc-body">
            <div class="timeline">
              {estudios.map(e => (
                <div class="tl-item">
                  <div class="tl-title">{e.titulo_obtenido ?? e.nivel}</div>
                  <div class="tl-sub">{e.institucion}</div>
                  {(e.fecha_inicio || e.fecha_fin) && (
                    <div class="tl-period">{e.fecha_inicio ?? ''}{e.fecha_fin ? ` — ${e.fecha_fin}` : ''}</div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </details>
      )}

      {habilidades.length > 0 && (
        <details class="acc">
          <summary>
            <div class="acc-left">
              <div class="acc-emoji">🧠</div>
              <div><div class="acc-title">Habilidades</div><div class="acc-count">{habilidades.length} habilidades</div></div>
            </div>
            <svg class="acc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="acc-body">
            <div class="skills">{habilidades.map(h => <span class="skill-tag">{h.nombre}</span>)}</div>
          </div>
        </details>
      )}

      {proyectos.length > 0 && (
        <details class="acc">
          <summary>
            <div class="acc-left">
              <div class="acc-emoji">🗂</div>
              <div><div class="acc-title">Proyectos</div><div class="acc-count">{proyectos.length} {proyectos.length === 1 ? 'proyecto' : 'proyectos'}</div></div>
            </div>
            <svg class="acc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="acc-body">
            <div class="projects">
              {proyectos.map(p => (
                <div class="project-item">
                  {p.imagen_url && <img src={p.imagen_url} alt={p.titulo} class="project-img" loading="lazy" />}
                  <div class="project-body">
                    <div class="project-title">{p.titulo}</div>
                    {p.descripcion && <p class="project-desc">{p.descripcion}</p>}
                    {p.enlace_url && (
                      <a href={p.enlace_url} target="_blank" rel="noopener noreferrer"
                         class="project-link track-proyecto" data-titulo={p.titulo}>Ver proyecto →</a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </details>
      )}

      {logros.length > 0 && (
        <details class="acc">
          <summary>
            <div class="acc-left">
              <div class="acc-emoji">🏆</div>
              <div><div class="acc-title">Logros</div><div class="acc-count">{logros.length} {logros.length === 1 ? 'logro' : 'logros'}</div></div>
            </div>
            <svg class="acc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="acc-body">
            <div class="logros">
              {logros.map((l, i) => (
                <div class="logro-item">
                  <div class="logro-num">0{i + 1}</div>
                  <div>
                    <div class="logro-title">{l.titulo}</div>
                    {l.descripcion && <p class="logro-desc">{l.descripcion}</p>}
                    {l.fecha && <div class="logro-fecha">{l.fecha}</div>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </details>
      )}

      {capacitaciones.length > 0 && (
        <details class="acc">
          <summary>
            <div class="acc-left">
              <div class="acc-emoji">📚</div>
              <div><div class="acc-title">Cursos</div><div class="acc-count">{capacitaciones.length} cursos</div></div>
            </div>
            <svg class="acc-chevron" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="acc-body">
            <div class="caps">
              {capacitaciones.map(c => (
                <div class="cap-item">
                  <div class="cap-dot"></div>
                  <div>
                    <div class="cap-name">{c.nombre}</div>
                    {c.institucion && <div class="cap-inst">{c.institucion}</div>}
                    {c.fecha && <div class="cap-fecha">{c.fecha}</div>}
                    {c.certificado_url && (
                      <a href={c.certificado_url} target="_blank" rel="noopener noreferrer" class="cap-cert">Ver certificado →</a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </details>
      )}

    </div>

    <footer class="card-footer">Creado con <a href="/">TarjetaDigital</a></footer>
  </div>
</body>
</html>