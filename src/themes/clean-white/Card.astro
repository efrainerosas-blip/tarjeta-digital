---
// src/themes/clean-white/Card.astro
// THEME: Clean White
// Foto hero rectangular con borde inferior ondulado,
// íconos circulares con colores oficiales de cada red,
// tarjetas blancas con sombra suave sobre fondo gris claro.

import type { CardProps } from '../types'

const {
  perfil, experiencia, estudios, habilidades,
  servicios, proyectos, redes, logros, capacitaciones, referencias
} = Astro.props as CardProps

const nombre = [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')

// Colores oficiales de cada red social
const RED_COLORS: Record<string, string> = {
  LinkedIn:    '#0A66C2',
  GitHub:      '#181717',
  'Twitter/X': '#000000',
  Instagram:   '#E1306C',
  Facebook:    '#1877F2',
  YouTube:     '#FF0000',
  TikTok:      '#010101',
  WhatsApp:    '#25D366',
  Telegram:    '#2AABEE',
  Behance:     '#1769FF',
  Dribbble:    '#EA4C89',
  Pinterest:   '#E60023',
  Snapchat:    '#FFFC00',
}

function redColor(plataforma: string): string {
  return RED_COLORS[plataforma] ?? '#6366f1'
}

const ICONOS: Record<string, string> = {
