  Telegram:    `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`,
}

function icon(p: string): string {
  return ICONOS[p] ?? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`
}

// Nombre de handle/descripción para cada red
function redLabel(red: { plataforma: string; url: string }): string {
  try {
    const url  = new URL(red.url)
    const path = url.pathname.replace(/\/$/, '').split('/').pop() ?? ''
    return path ? `@${path}` : red.plataforma
  } catch {
    return red.plataforma
  }
}
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={perfil.bio ?? `Tarjeta digital de ${nombre}`} />
  <title>{nombre}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #f2f4f7;   /* fondo gris muy claro */
      --white:    #ffffff;
      --text-1:   #1a1a2e;   /* casi negro */
      --text-2:   #4a5568;   /* gris medio */
      --text-3:   #9aa5b4;   /* gris claro */
      --shadow:   0 2px 12px rgba(0,0,0,.08);
      --shadow-lg: 0 8px 32px rgba(0,0,0,.12);
      --radius:   18px;
      --font:     'Nunito', sans-serif;
      --max-w:    420px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text-1);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    @media (min-width: 480px) {
      body {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 32px 0 64px;
        background: #e2e5eb;
      }
    }

    /* ── Página completa ─────────────────────────────────────── */
    .page {
      width: 100%;
      max-width: var(--max-w);
      min-height: 100vh;
      background: var(--bg);
      overflow: hidden;
    }

    @media (min-width: 480px) {
      .page {
        min-height: auto;
        border-radius: 40px;
        box-shadow: 0 40px 100px rgba(0,0,0,.25);
        overflow: hidden;
      }
    }

    /* ══ HERO — foto grande con ola inferior ════════════════════ */
    .hero {
      position: relative;
      width: 100%;
      background: var(--bg);
    }

    /* Foto rectangular que ocupa casi la mitad de la pantalla */
    .hero-foto-wrap {
      position: relative;
      width: 100%;
      height: 280px;
      overflow: hidden;
    }

    .hero-foto {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
    }

    /* Placeholder sin foto */
    .hero-foto-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(160deg, #c8d6e8 0%, #a8bdd4 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-foto-placeholder svg {
      width: 72px;
      height: 72px;
      color: rgba(255,255,255,.5);
    }

    /* ── Ola SVG — borde inferior ondulado de la foto ────────── */
    /* Este SVG crea la curva que "abraza" la foto desde abajo  */
    .hero-wave {
      display: block;
      width: 100%;
      height: 48px;
      margin-top: -48px;
      position: relative;
      z-index: 2;
      background: transparent;
    }
    .hero-wave path {
      fill: var(--bg); /* mismo color que el fondo de la página */
    }

    /* Nombre y título — debajo de la ola */
    .hero-info {
      text-align: center;
      padding: 4px 24px 20px;
    }

    .hero-name {
      font-size: 24px;
      font-weight: 900;
      color: var(--text-1);
      letter-spacing: -.02em;
      line-height: 1.1;
    }

    .hero-title {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-2);
      margin-top: 4px;
      letter-spacing: .01em;
    }

    .hero-location {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      font-size: 12px;
      color: var(--text-3);
      margin-top: 6px;
    }

    /* ══ ÍCONOS DE REDES — círculos con color oficial ═══════════ */
    .redes-row {
      display: flex;
      justify-content: center;
      gap: 12px;
      padding: 0 24px 24px;
      flex-wrap: wrap;
    }

    .red-circle {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      text-decoration: none;
      transition: transform .15s, box-shadow .15s;
      flex-shrink: 0;
      box-shadow: 0 4px 12px rgba(0,0,0,.15);
    }
    .red-circle svg { width: 20px; height: 20px; }
    .red-circle:hover {
      transform: translateY(-2px) scale(1.08);
      box-shadow: 0 8px 20px rgba(0,0,0,.2);
    }

    /* ══ TARJETAS DE REDES — lista debajo de los íconos ════════ */
    .redes-list {
      padding: 0 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 16px;
    }

    .red-card {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      text-decoration: none;
      transition: transform .15s, box-shadow .15s;
    }
    .red-card:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-lg);
    }

    /* Ícono cuadrado redondeado con color de la red */
    .red-card-icon {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      flex-shrink: 0;
    }
    .red-card-icon svg { width: 20px; height: 20px; }

    .red-card-info { flex: 1; min-width: 0; }
    .red-card-name {
      font-size: 14px;
      font-weight: 700;
      color: var(--text-1);
      line-height: 1.2;
    }
    .red-card-handle {
      font-size: 12px;
      color: var(--text-3);
      margin-top: 2px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .red-card-arrow {
      color: var(--text-3);
      flex-shrink: 0;
    }

    /* ══ SECCIONES DE CONTENIDO ══════════════════════════════════ */
    .sections {
      padding: 0 16px 48px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    /* Tarjeta blanca con sombra */
    .card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 18px 18px;
      box-shadow: var(--shadow);
    }

    .card-title {
      font-size: 15px;
      font-weight: 800;
      color: var(--text-1);
      margin-bottom: 12px;
      letter-spacing: -.01em;
    }

    .card-text {
      font-size: 13px;
      color: var(--text-2);
      line-height: 1.7;
    }

    /* ── Timeline ───────────────────────────────────────────── */
    .timeline { display: flex; flex-direction: column; gap: 14px; }
    .tl-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }
    .tl-dot-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
      padding-top: 4px;
    }
    .tl-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #6366f1;
      flex-shrink: 0;
    }
    .tl-line {
      width: 1.5px;
      flex: 1;
      background: #e5e7eb;
      min-height: 20px;
      margin-top: 4px;
    }
    .tl-item:last-child .tl-line { display: none; }
    .tl-name   { font-size: 13px; font-weight: 700; color: var(--text-1); line-height: 1.3; }
    .tl-sub    { font-size: 12px; color: var(--text-2); margin-top: 2px; }
    .tl-period { font-size: 11px; color: var(--text-3); margin-top: 2px; }
    .tl-desc   { font-size: 12px; color: var(--text-2); margin-top: 4px; line-height: 1.5; }

    /* ── Skills ─────────────────────────────────────────────── */
    .skills { display: flex; flex-wrap: wrap; gap: 8px; }
    .skill-tag {
      font-size: 12px;
      font-weight: 600;
      padding: 5px 13px;
      border-radius: 99px;
      background: #f0f1ff;
      color: #4f46e5;
      border: 1px solid #e0e2ff;
    }

    /* ── Servicios ──────────────────────────────────────────── */
    .services { display: flex; flex-direction: column; gap: 10px; }
    .service-item {
      display: flex;
      gap: 12px;
      padding: 12px 14px;
      background: #f8f9fb;
      border-radius: 14px;
      border: 1px solid #edf0f4;
    }
    .service-emoji { font-size: 24px; flex-shrink: 0; line-height: 1; }
    .service-name  { font-size: 13px; font-weight: 700; color: var(--text-1); }
    .service-desc  { font-size: 12px; color: var(--text-2); margin-top: 2px; line-height: 1.5; }
    .service-price { font-size: 12px; font-weight: 700; color: #4f46e5; margin-top: 4px; display: inline-block; }

    /* ── Proyectos ──────────────────────────────────────────── */
    .projects { display: flex; flex-direction: column; gap: 12px; }
    .project-item {
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid #edf0f4;
      background: #f8f9fb;
    }
    .project-img   { width: 100%; height: 140px; object-fit: cover; display: block; }
    .project-body  { padding: 12px; }
    .project-name  { font-size: 13px; font-weight: 700; color: var(--text-1); }
    .project-desc  { font-size: 12px; color: var(--text-2); margin-top: 3px; line-height: 1.5; }
    .project-link  {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 700; color: #4f46e5;
      text-decoration: none; margin-top: 6px;
    }

    /* ── Logros ─────────────────────────────────────────────── */
    .logros { display: flex; flex-direction: column; gap: 10px; }
    .logro-item {
      display: flex; gap: 12px;
      padding: 12px 14px;
      background: #f8f9fb;
      border-radius: 14px;
      border: 1px solid #edf0f4;
    }
    .logro-num  { font-size: 20px; font-weight: 900; color: #e5e7eb; min-width: 28px; line-height: 1; }
    .logro-name { font-size: 13px; font-weight: 700; color: var(--text-1); }
    .logro-desc { font-size: 12px; color: var(--text-2); margin-top: 2px; }
    .logro-fecha{ font-size: 10px; color: var(--text-3); margin-top: 2px; }

    /* ── Capacitaciones ─────────────────────────────────────── */
    .caps { display: flex; flex-direction: column; gap: 10px; }
    .cap-item {
      display: flex; gap: 10px;
      padding: 12px 14px;
      background: #f8f9fb;
      border-radius: 14px;
      border: 1px solid #edf0f4;
    }
    .cap-dot   { width: 8px; height: 8px; border-radius: 50%; background: #6366f1; flex-shrink: 0; margin-top: 4px; }
    .cap-name  { font-size: 13px; font-weight: 700; color: var(--text-1); }
    .cap-inst  { font-size: 12px; color: var(--text-2); margin-top: 1px; }
    .cap-fecha { font-size: 10px; color: var(--text-3); margin-top: 2px; }
    .cap-cert  {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 600; color: #4f46e5;
      text-decoration: none; margin-top: 4px;
    }

    /* ── CV button ──────────────────────────────────────────── */
    .cv-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 14px 20px;
      background: #4f46e5;
      color: var(--white);
      border-radius: var(--radius);
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
      box-shadow: 0 4px 16px rgba(79,70,229,.3);
      transition: background .15s, transform .1s;
      margin: 0 16px;
    }
    .cv-btn:hover { background: #4338ca; transform: translateY(-1px); }
    .cv-btn svg { width: 18px; height: 18px; }

    /* ── Footer ─────────────────────────────────────────────── */
    .footer {
      text-align: center;
      padding: 24px 24px 40px;
      font-size: 11px;
      color: var(--text-3);
      letter-spacing: .04em;
    }
    .footer a { color: #6366f1; text-decoration: none; font-weight: 700; }

    /* ── Animación de entrada ────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-info  { animation: fadeUp .45s ease-out .05s both; }
    .redes-row  { animation: fadeUp .45s ease-out .12s both; }
    .redes-list { animation: fadeUp .45s ease-out .18s both; }
    .sections   { animation: fadeUp .45s ease-out .24s both; }
  </style>
</head>

<body>
<div class="page">

  <!-- ══ HERO ═══════════════════════════════════════════════════ -->
  <div class="hero">

    <!-- Foto grande rectangular -->
    <div class="hero-foto-wrap">
      {perfil.foto_url
        ? <img src={perfil.foto_url} alt={nombre} class="hero-foto" />
        : (
          <div class="hero-foto-placeholder">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/>
            </svg>
          </div>
        )
      }
    </div>

    <!-- Ola SVG — borde inferior ondulado -->
    <!-- La ola "abraza" la foto desde abajo con curvas suaves -->
    <svg
      class="hero-wave"
      viewBox="0 0 420 48"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
    >
      <path d="M0,48 L0,24 Q52,0 105,20 Q158,40 210,16 Q262,-8 315,20 Q368,48 420,24 L420,48 Z" />
    </svg>

    <!-- Nombre y título -->
    <div class="hero-info">
      <h1 class="hero-name">{nombre}</h1>
      {perfil.titulo_profesional && <p class="hero-title">{perfil.titulo_profesional}</p>}
      {perfil.ubicacion && (
        <p class="hero-location">
          <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          </svg>
          {perfil.ubicacion}
        </p>
      )}
    </div>

  </div>

  <!-- ══ ÍCONOS CIRCULARES DE REDES ══════════════════════════════ -->
  {redes.length > 0 && (
    <div class="redes-row">
      {redes.slice(0, 5).map(red => (
        <a
          href={red.url}
          target="_blank"
          rel="noopener noreferrer"
          class="red-circle track-red"
          data-plataforma={red.plataforma}
          title={red.plataforma}
          style={`background-color: ${redColor(red.plataforma)}`}
        >
          <Fragment set:html={icon(red.plataforma)} />
        </a>
      ))}
    </div>
  )}

  <!-- ══ TARJETAS DE REDES — lista con ícono + handle ═══════════ -->
  {redes.length > 0 && (
    <div class="redes-list">
      {redes.map(red => (
        <a
          href={red.url}
          target="_blank"
          rel="noopener noreferrer"
          class="red-card track-red"
          data-plataforma={red.plataforma}
        >
          <!-- Ícono cuadrado con color oficial -->
          <div
            class="red-card-icon"
            style={`background-color: ${redColor(red.plataforma)}`}
          >
            <Fragment set:html={icon(red.plataforma)} />
          </div>

          <!-- Nombre + handle -->
          <div class="red-card-info">
            <div class="red-card-name">{red.plataforma}</div>
            <div class="red-card-handle">{redLabel(red)}</div>
          </div>

          <!-- Flecha -->
          <svg class="red-card-arrow" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>
  )}

  <!-- ══ SECCIONES DE CONTENIDO ══════════════════════════════════ -->
  <div class="sections">

    <!-- Bio -->
    {perfil.bio && (
      <div class="card">
        <div class="card-title">Sobre mí</div>
        <p class="card-text">{perfil.bio}</p>
      </div>
    )}

    <!-- CV -->
    {perfil.cv_pdf_url && (
      <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer" class="cv-btn track-cv">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Descargar CV
      </a>
    )}

    <!-- Servicios -->
    {servicios.length > 0 && (
      <div class="card">
        <div class="card-title">Servicios</div>
        <div class="services">
          {servicios.map(s => (
            <div class="service-item">
              {s.icono && <div class="service-emoji">{s.icono}</div>}
              <div>
                <div class="service-name">{s.nombre}</div>
                {s.descripcion && <p class="service-desc">{s.descripcion}</p>}
                {s.precio_referencial && <span class="service-price">{s.precio_referencial}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Experiencia -->
    {experiencia.length > 0 && (
      <div class="card">
        <div class="card-title">Experiencia</div>
        <div class="timeline">
          {experiencia.map(exp => (
            <div class="tl-item">
              <div class="tl-dot-wrap">
                <div class="tl-dot"></div>
                <div class="tl-line"></div>
              </div>
              <div style="flex:1;padding-bottom:8px">
                <div class="tl-name">{exp.cargo}</div>
                <div class="tl-sub">{exp.empresa}</div>
                {exp.periodo && <div class="tl-period">{exp.periodo}</div>}
                {exp.descripcion && <p class="tl-desc">{exp.descripcion}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Educación -->
    {estudios.length > 0 && (
      <div class="card">
        <div class="card-title">Educación</div>
        <div class="timeline">
          {estudios.map(e => (
            <div class="tl-item">
              <div class="tl-dot-wrap">
                <div class="tl-dot"></div>
                <div class="tl-line"></div>
              </div>
              <div style="flex:1;padding-bottom:8px">
                <div class="tl-name">{e.titulo_obtenido ?? e.nivel}</div>
                <div class="tl-sub">{e.institucion}</div>
                {(e.fecha_inicio || e.fecha_fin) && (
                  <div class="tl-period">
                    {e.fecha_inicio ?? ''}{e.fecha_fin ? ` — ${e.fecha_fin}` : ''}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Habilidades -->
    {habilidades.length > 0 && (
      <div class="card">
        <div class="card-title">Habilidades</div>
        <div class="skills">
          {habilidades.map(h => <span class="skill-tag">{h.nombre}</span>)}
        </div>
      </div>
    )}

    <!-- Proyectos -->
    {proyectos.length > 0 && (
      <div class="card">
        <div class="card-title">Proyectos</div>
        <div class="projects">
          {proyectos.map(p => (
            <div class="project-item">
              {p.imagen_url && <img src={p.imagen_url} alt={p.titulo} class="project-img" loading="lazy" />}
              <div class="project-body">
                <div class="project-name">{p.titulo}</div>
                {p.descripcion && <p class="project-desc">{p.descripcion}</p>}
                {p.enlace_url && (
                  <a href={p.enlace_url} target="_blank" rel="noopener noreferrer"
                     class="project-link track-proyecto" data-titulo={p.titulo}>
                    Ver proyecto →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Logros -->
    {logros.length > 0 && (
      <div class="card">
        <div class="card-title">Logros</div>
        <div class="logros">
          {logros.map((l, i) => (
            <div class="logro-item">
              <div class="logro-num">0{i + 1}</div>
              <div>
                <div class="logro-name">{l.titulo}</div>
                {l.descripcion && <p class="logro-desc">{l.descripcion}</p>}
                {l.fecha && <div class="logro-fecha">{l.fecha}</div>}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Capacitaciones -->
    {capacitaciones.length > 0 && (
      <div class="card">
        <div class="card-title">Cursos & Certificados</div>
        <div class="caps">
          {capacitaciones.map(c => (
            <div class="cap-item">
              <div class="cap-dot"></div>
              <div>
                <div class="cap-name">{c.nombre}</div>
                {c.institucion && <div class="cap-inst">{c.institucion}</div>}
                {c.fecha && <div class="cap-fecha">{c.fecha}</div>}
                {c.certificado_url && (
                  <a href={c.certificado_url} target="_blank" rel="noopener noreferrer" class="cap-cert">
                    Ver certificado →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>

  {referencias && referencias.length > 0 && (
    <div class="card">
      <div class="card-title">Referencias Profesionales</div>
      <div class="caps">
        {referencias.map(r => (
          <div class="cap-item">
            <div class="cap-dot" style="background: #10b981; margin-top: 6px;"></div> 
            <div style="flex:1;">
              <div class="cap-name">{r.nombre}</div>
              {(r.cargo || r.empresa) && <div class="cap-inst">{r.cargo} {r.empresa ? `en ${r.empresa}` : ''}</div>}
              {r.observaciones && <div class="tl-desc" style="font-style: italic;">"{r.observaciones}"</div>}
              
              <div style="display:flex; gap:12px; margin-top:8px; flex-wrap:wrap;">
                {r.telefono && (
                  <a href={`tel:${r.telefono.replace(/\s/g, '')}`} class="cap-cert" style="color: #10b981;">
                    📞 {r.telefono}
                  </a>
                )}
                {r.email && (
                  <a href={`mailto:${r.email}`} class="cap-cert" style="color: #6366f1;">
                    ✉️ Correo
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

</div>

<footer class="footer">Creado con <a href="/">TarjetaDigital</a></footer>
</body>
</html>