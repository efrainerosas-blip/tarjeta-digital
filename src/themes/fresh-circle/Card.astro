function icon(p: string) {
  return ICONOS[p] ?? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`
}

// ¿Hay email WhatsApp entre las redes?
const redWhatsApp = redes.find(r => r.plataforma === 'WhatsApp')
const redesSinContacto = redes.filter(r => r.plataforma !== 'WhatsApp')
---

<link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" slot="head" />

<style is:inline define:vars={{ accent, accentText }}>

/* ── BASE ──────────────────────────────────────────────────── */
.fc-page {
  max-width: 420px;
  margin: 0 auto;
  min-height: 100vh;
  font-family: 'Poppins', sans-serif;
  background: #ffffff;
  color: #1a1a2e;
  position: relative;
  overflow-x: hidden;
}

/* ── BANNER SUPERIOR ────────────────────────────────────────── */
.fc-banner {
  width: 100%;
  height: 160px;
  position: relative;
  overflow: hidden;
  background: var(--accent);
}
/* Degradado de fondo + patrón */
.fc-banner::before {
  content: '';
  position: absolute; inset: 0; z-index: 0;
  background:
    linear-gradient(135deg,
      color-mix(in srgb, var(--accent) 80%, #000) 0%,
      var(--accent) 50%,
      color-mix(in srgb, var(--accent) 70%, #fff) 100%
    );
}
/* Ondas decorativas en el banner */
.fc-banner::after {
  content: '';
  position: absolute; inset: 0; z-index: 1;
  background-image:
    radial-gradient(ellipse at 20% 50%, rgba(255,255,255,0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.1) 0%, transparent 40%),
    radial-gradient(ellipse at 50% 100%, rgba(0,0,0,0.1) 0%, transparent 40%);
}
/* Texto del banner */
.fc-banner-content {
  position: relative; z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 20px;
  text-align: center;
}
.fc-banner-brand {
  font-size: 22px;
  font-weight: 900;
  color: rgba(255,255,255,0.95);
  letter-spacing: -0.01em;
  line-height: 1.1;
}
.fc-banner-brand span {
  color: rgba(255,255,255,0.6);
  font-weight: 400;
  font-size: 16px;
}
.fc-banner-tagline {
  font-size: 10px;
  font-weight: 600;
  color: rgba(255,255,255,0.55);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-top: 4px;
}
/* Línea decorativa bajo el banner */
.fc-banner-bar {
  height: 4px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
  position: absolute;
  bottom: 0; left: 0; right: 0; z-index: 3;
}

/* ── FOTO CIRCULAR CENTRADA ──────────────────────────────────── */
.fc-photo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -64px;
  position: relative;
  z-index: 10;
}
.fc-photo-outer {
  width: 130px;
  height: 130px;
  border-radius: 50%;
  padding: 4px;
  background: #fff;
  box-shadow: 0 8px 32px rgba(0,0,0,0.18);
  position: relative;
}
/* Anillo de color acento */
.fc-photo-outer::before {
  content: '';
  position: absolute; inset: -3px;
  border-radius: 50%;
  background: conic-gradient(var(--accent) 0deg, transparent 180deg, var(--accent) 360deg);
  opacity: 0.5;
  animation: fc-ring-spin 6s linear infinite;
}
@keyframes fc-ring-spin { to { transform: rotate(360deg); } }
.fc-photo-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  background: #f0f0f0;
}
.fc-photo-img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}
.fc-photo-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 3.5rem;
  background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
}

/* ── IDENTIDAD ───────────────────────────────────────────────── */
.fc-identity {
  text-align: center;
  padding: 16px 24px 0;
}
.fc-name {
  font-size: clamp(1.7rem, 7.5vw, 2.1rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: #1a1a2e;
  margin-top: 12px;
}
.fc-name-accent { color: var(--accent); }
.fc-title {
  font-size: 13px;
  font-weight: 600;
  color: #6b7280;
  margin-top: 6px;
}
.fc-empresa {
  font-size: 14px;
  font-weight: 800;
  color: #374151;
  margin-top: 2px;
}
.fc-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 8px;
  flex-wrap: wrap;
}
.fc-meta-chip {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; font-weight: 600;
  color: #9ca3af;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  padding: 3px 10px;
  border-radius: 99px;
}
.fc-meta-chip svg { width: 10px; height: 10px; }

/* Status badge */
.fc-status {
  display: inline-flex; align-items: center; gap: 6px;
  background: color-mix(in srgb, var(--accent) 8%, transparent);
  border: 1.5px solid color-mix(in srgb, var(--accent) 20%, transparent);
  color: var(--accent);
  font-size: 11px; font-weight: 700;
  padding: 4px 14px; border-radius: 99px;
  margin-top: 10px;
  letter-spacing: 0.04em;
}
.fc-status-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 6px #4ade80;
  flex-shrink: 0;
}

/* ── BOTONES DE CONTACTO CIRCULARES ────────────────────────── */
.fc-contacts {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin: 24px 24px 0;
}
.fc-contact-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.fc-contact-btn {
  width: 62px; height: 62px;
  border-radius: 50%;
  background: var(--accent);
  color: var(--accentText);
  display: flex; align-items: center; justify-content: center;
  text-decoration: none;
  box-shadow:
    0 6px 20px color-mix(in srgb, var(--accent) 35%, transparent),
    0 2px 6px rgba(0,0,0,0.1);
  transition: transform 0.2s, box-shadow 0.2s;
  flex-shrink: 0;
  border: none; cursor: pointer;
  font-family: inherit;
}
.fc-contact-btn svg { width: 26px; height: 26px; }
.fc-contact-btn:hover {
  transform: translateY(-4px) scale(1.07);
  box-shadow:
    0 12px 28px color-mix(in srgb, var(--accent) 45%, transparent),
    0 4px 10px rgba(0,0,0,0.14);
}
.fc-contact-btn:active { transform: scale(0.95); }
.fc-contact-label {
  font-size: 10px;
  font-weight: 700;
  color: #9ca3af;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* ── BOTÓN CTA PRINCIPAL ─────────────────────────────────────── */
.fc-cta-wrap {
  padding: 20px 24px 0;
}
.fc-cta {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%;
  padding: 15px 20px;
  background: var(--accent);
  color: var(--accentText);
  border: none; border-radius: 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 15px; font-weight: 800;
  cursor: pointer; text-decoration: none;
  box-shadow:
    0 6px 20px color-mix(in srgb, var(--accent) 40%, transparent),
    0 2px 6px rgba(0,0,0,0.1);
  transition: all 0.2s;
  letter-spacing: -0.01em;
}
.fc-cta svg { width: 18px; height: 18px; }
.fc-cta:hover { opacity: 0.92; transform: translateY(-2px); }
.fc-cta:active { transform: translateY(0) scale(0.98); }

/* ── REDES SOCIALES PLANAS ───────────────────────────────────── */
.fc-social-wrap {
  padding: 20px 24px 0;
}
.fc-social-row {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}
.fc-social-btn {
  width: 48px; height: 48px;
  border-radius: 12px;
  background: #f3f4f6;
  display: flex; align-items: center; justify-content: center;
  color: #374151;
  text-decoration: none;
  transition: all 0.18s;
  flex-shrink: 0;
}
.fc-social-btn svg { width: 22px; height: 22px; }
.fc-social-btn:hover {
  background: var(--accent);
  color: var(--accentText);
  transform: translateY(-3px);
  box-shadow: 0 6px 16px color-mix(in srgb, var(--accent) 35%, transparent);
}

/* ── DIVISOR ─────────────────────────────────────────────────── */
.fc-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, #e5e7eb, transparent);
  margin: 24px 24px 0;
}

/* ── BIO ─────────────────────────────────────────────────────── */
.fc-bio {
  margin: 20px 16px 0;
  background: #f9fafb;
  border-left: 3px solid var(--accent);
  border-radius: 0 12px 12px 0;
  padding: 14px 16px;
  font-size: 13.5px;
  color: #4b5563;
  line-height: 1.8;
}

/* ── SECCIONES ACORDEÓN ──────────────────────────────────────── */
.fc-section {
  margin: 10px 16px 0;
  border-radius: 14px;
  overflow: hidden;
  border: 1.5px solid #e5e7eb;
  background: #fff;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.fc-section:hover {
  border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  box-shadow: 0 4px 16px rgba(0,0,0,0.06);
}
details.fc-section[open] {
  border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 10%, transparent);
}

.fc-section summary {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 16px;
  cursor: pointer; list-style: none; user-select: none;
  -webkit-tap-highlight-color: transparent;
  transition: background 0.15s;
}
.fc-section summary::-webkit-details-marker { display: none; }
.fc-section summary:hover { background: #fafafa; }

.fc-sec-left { display: flex; align-items: center; gap: 12px; }
.fc-sec-icon {
  width: 40px; height: 40px; border-radius: 12px;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex-shrink: 0;
  box-shadow: 0 3px 10px color-mix(in srgb, var(--accent) 30%, transparent);
}
.fc-sec-title { font-size: 14px; font-weight: 800; color: #1a1a2e; }
.fc-sec-count { font-size: 11px; font-weight: 500; color: #9ca3af; margin-top: 1px; }

.fc-chevron {
  width: 28px; height: 28px; border-radius: 50%;
  background: #f3f4f6;
  display: flex; align-items: center; justify-content: center;
  color: #9ca3af; flex-shrink: 0;
  transition: all 0.2s;
}
details.fc-section[open] .fc-chevron {
  transform: rotate(180deg);
  background: var(--accent);
  color: var(--accentText);
}
.fc-chevron svg { width: 13px; height: 13px; }

.fc-sec-body {
  padding: 0 16px 16px;
  border-top: 1px solid #f3f4f6;
}

/* ── Timeline ─────────────────────────────────────────────────── */
.fc-timeline { display: flex; flex-direction: column; }
.fc-tl {
  padding: 14px 0 14px 18px;
  border-left: 2px solid #e5e7eb;
  position: relative; margin-left: 6px;
}
.fc-tl:last-child { border-left-color: transparent; }
.fc-tl::before {
  content: '';
  position: absolute; left: -7px; top: 19px;
  width: 12px; height: 12px; border-radius: 50%;
  background: #fff; border: 2.5px solid var(--accent);
}
.fc-tl-title { font-size: 13px; font-weight: 800; color: #1a1a2e; }
.fc-tl-sub   { font-size: 12px; font-weight: 600; color: #6b7280; margin-top: 2px; }
.fc-tl-period {
  display: inline-flex; font-size: 10px; font-weight: 700;
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 10%, transparent);
  padding: 2px 9px; border-radius: 99px; margin-top: 5px;
}
.fc-tl-actual {
  display: inline-flex; font-size: 9px; font-weight: 800;
  padding: 2px 8px; border-radius: 99px; margin-top: 4px; margin-left: 4px;
  background: rgba(74,222,128,0.12); color: #16a34a;
  text-transform: uppercase; letter-spacing: 0.06em;
}
.fc-tl-desc { font-size: 12px; color: #6b7280; margin-top: 5px; line-height: 1.6; }

/* ── Skills ───────────────────────────────────────────────────── */
.fc-skills { display: flex; flex-wrap: wrap; gap: 7px; padding-top: 14px; }
.fc-skill {
  font-size: 12px; font-weight: 700;
  padding: 5px 13px; border-radius: 99px;
  background: color-mix(in srgb, var(--accent) 8%, transparent);
  color: var(--accent);
  border: 1.5px solid color-mix(in srgb, var(--accent) 20%, transparent);
  transition: all 0.15s;
}
.fc-skill:hover { background: var(--accent); color: var(--accentText); transform: scale(1.04); }

/* ── Servicios ────────────────────────────────────────────────── */
.fc-services { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
.fc-service {
  display: flex; gap: 12px;
  padding: 13px 14px;
  background: #fafafa; border: 1.5px solid #f3f4f6;
  border-radius: 12px; transition: all 0.15s;
}
.fc-service:hover { border-color: var(--accent); transform: translateX(3px); }
.fc-service-ico  { font-size: 24px; flex-shrink: 0; line-height: 1; margin-top: 2px; }
.fc-service-name { font-size: 13px; font-weight: 800; color: #1a1a2e; }
.fc-service-desc { font-size: 12px; color: #6b7280; margin-top: 3px; line-height: 1.5; }
.fc-service-price {
  display: inline-flex; font-size: 12px; font-weight: 800;
  color: var(--accentText); background: var(--accent);
  padding: 2px 10px; border-radius: 99px; margin-top: 6px;
}

/* ── Proyectos ────────────────────────────────────────────────── */
.fc-projects { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
.fc-project  { border-radius: 12px; overflow: hidden; border: 1.5px solid #f3f4f6; transition: all 0.15s; }
.fc-project:hover { border-color: var(--accent); box-shadow: 0 4px 14px rgba(0,0,0,0.08); }
.fc-project-img   { width: 100%; height: 148px; object-fit: cover; display: block; }
.fc-project-body  { padding: 12px 13px; }
.fc-project-title { font-size: 13px; font-weight: 800; color: #1a1a2e; }
.fc-project-desc  { font-size: 12px; color: #6b7280; margin-top: 3px; line-height: 1.5; }
.fc-project-link  {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; font-weight: 800;
  color: var(--accentText); background: var(--accent);
  padding: 4px 12px; border-radius: 99px; margin-top: 8px;
  text-decoration: none; transition: opacity 0.15s;
}
.fc-project-link:hover { opacity: 0.85; }

/* ── Logros ───────────────────────────────────────────────────── */
.fc-logros { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
.fc-logro  {
  display: flex; gap: 14px;
  padding: 13px 14px; background: #fafafa;
  border: 1.5px solid #f3f4f6; border-radius: 12px; transition: all 0.15s;
}
.fc-logro:hover { border-color: var(--accent); transform: translateX(3px); }
.fc-logro-num   { font-size: 1.9rem; font-weight: 900; color: color-mix(in srgb, var(--accent) 18%, transparent); line-height: 1; min-width: 28px; flex-shrink: 0; }
.fc-logro-title { font-size: 13px; font-weight: 800; color: #1a1a2e; }
.fc-logro-desc  { font-size: 12px; color: #6b7280; margin-top: 3px; line-height: 1.5; }
.fc-logro-fecha { font-size: 10px; color: #9ca3af; margin-top: 3px; }

/* ── Capacitaciones ───────────────────────────────────────────── */
.fc-caps { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
.fc-cap  {
  display: flex; gap: 12px; padding: 12px 14px;
  background: #fafafa; border: 1.5px solid #f3f4f6;
  border-radius: 12px; transition: border-color 0.15s;
}
.fc-cap:hover { border-color: var(--accent); }
.fc-cap-dot   { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); flex-shrink: 0; margin-top: 4px; box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 15%, transparent); }
.fc-cap-name  { font-size: 13px; font-weight: 800; color: #1a1a2e; }
.fc-cap-inst  { font-size: 12px; color: #6b7280; margin-top: 2px; }
.fc-cap-fecha { font-size: 10px; color: #9ca3af; margin-top: 3px; }
.fc-cap-cert  {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; font-weight: 700; color: var(--accent);
  text-decoration: none; margin-top: 5px;
  padding: 3px 10px; border-radius: 99px;
  background: color-mix(in srgb, var(--accent) 8%, transparent);
}

/* ── Referencias ──────────────────────────────────────────────── */
.fc-refs { display: flex; flex-direction: column; gap: 10px; padding-top: 14px; }
.fc-ref  { padding: 13px 14px; background: #fafafa; border: 1.5px solid #f3f4f6; border-radius: 12px; transition: border-color 0.15s; }
.fc-ref:hover { border-color: var(--accent); }
.fc-ref-name  { font-size: 13px; font-weight: 800; color: #1a1a2e; }
.fc-ref-cargo { font-size: 12px; color: #6b7280; margin-top: 2px; }
.fc-ref-obs   { font-size: 12px; color: #9ca3af; margin-top: 5px; font-style: italic; line-height: 1.5; }
.fc-ref-links { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px; }
.fc-ref-link  { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 700; color: var(--accent); text-decoration: none; padding: 4px 10px; border-radius: 99px; background: color-mix(in srgb, var(--accent) 8%, transparent); }

/* ── BOTTOM NAV FIJO ──────────────────────────────────────────── */
.fc-bottom {
  position: sticky; bottom: 0;
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 2px solid var(--accent);
  padding: 10px 16px env(safe-area-inset-bottom, 10px);
  display: flex; gap: 0;
  box-shadow: 0 -4px 24px rgba(0,0,0,0.08);
  z-index: 50;
}
.fc-bottom-item {
  flex: 1;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 3px;
  font-size: 9px; font-weight: 700;
  color: #9ca3af;
  text-decoration: none;
  transition: color 0.15s;
  padding: 4px;
  -webkit-tap-highlight-color: transparent;
}
.fc-bottom-item svg { width: 22px; height: 22px; }
.fc-bottom-item.active,
.fc-bottom-item:hover { color: var(--accent); }
.fc-bottom-item.fc-bottom-cta {
  background: var(--accent);
  border-radius: 12px;
  color: var(--accentText);
  margin: -2px 4px;
  padding: 8px 4px;
  box-shadow: 0 4px 14px color-mix(in srgb, var(--accent) 40%, transparent);
}

/* ── FOOTER ────────────────────────────────────────────────────── */
.fc-footer {
  text-align: center; padding: 20px 20px 8px;
  font-size: 11px; color: #9ca3af; font-weight: 600; letter-spacing: 0.04em;
}
.fc-footer a { color: var(--accent); text-decoration: none; font-weight: 800; }

/* ── DESKTOP ───────────────────────────────────────────────────── */
@media (min-width: 480px) {
  body { padding: 28px 0 48px; background: #dde4ee !important; }
  .fc-page {
    border-radius: 36px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.18), 0 0 0 1px rgba(0,0,0,0.06);
  }
  .fc-bottom { border-radius: 0 0 36px 36px; }
}

/* ── ANIMACIONES ───────────────────────────────────────────────── */
@keyframes fc-up {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
.fc-photo-section { animation: fc-up 0.4s ease-out 0.05s both; }
.fc-identity      { animation: fc-up 0.4s ease-out 0.12s both; }
.fc-contacts      { animation: fc-up 0.4s ease-out 0.18s both; }
.fc-cta-wrap      { animation: fc-up 0.4s ease-out 0.22s both; }
.fc-social-wrap   { animation: fc-up 0.4s ease-out 0.26s both; }

</style>

<div class="fc-page">

  <!-- ── BANNER SUPERIOR ──────────────────────────────────────── -->
  <div class="fc-banner">
    <div class="fc-banner-content">
      {perfil.empresa
        ? <>
            <div class="fc-banner-brand">{perfil.empresa}</div>
            <div class="fc-banner-tagline">Tarjeta digital profesional</div>
          </>
        : <>
            <div class="fc-banner-brand">
              {perfil.titulo_profesional
                ? perfil.titulo_profesional.split('·')[0].trim()
                : 'CardVirtual'
              }
            </div>
            <div class="fc-banner-tagline">Tarjeta personal digital</div>
          </>
      }
    </div>
    <div class="fc-banner-bar"></div>
  </div>

  <!-- ── FOTO CIRCULAR ────────────────────────────────────────── -->
  <div class="fc-photo-section">
    <div class="fc-photo-outer">
      <div class="fc-photo-inner">
        {foto
          ? <img src={foto} alt={nombre} class="fc-photo-img" />
          : <div class="fc-photo-placeholder">👤</div>
        }
      </div>
    </div>
  </div>

  <!-- ── IDENTIDAD ─────────────────────────────────────────────── -->
  <div class="fc-identity">
    <h1 class="fc-name">
      {primerParte}{segundaParte && <> <span class="fc-name-accent">{segundaParte}</span></>}
    </h1>

    {perfil.titulo_profesional && (
      <div class="fc-title">{perfil.titulo_profesional}</div>
    )}
    {perfil.empresa && (
      <div class="fc-empresa">{perfil.empresa}</div>
    )}

    <div class="fc-meta">
      {perfil.ubicacion && (
        <div class="fc-meta-chip">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          </svg>
          {perfil.ubicacion}
        </div>
      )}
      <div class="fc-status">
        <div class="fc-status-dot"></div>
        {perfil.status ?? 'Disponible'}
      </div>
    </div>
  </div>

  <!-- ── CONTACTOS CIRCULARES GRANDES ─────────────────────────── -->
  <div class="fc-contacts">
    {perfil.telefono && (
      <div class="fc-contact-item">
        <a href={`tel:${perfil.telefono.replace(/\s/g,'')}`} class="fc-contact-btn" aria-label="Llamar">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </a>
        <span class="fc-contact-label">Llamar</span>
      </div>
    )}

    {(redWhatsApp || perfil.telefono) && (
      <div class="fc-contact-item">
        <a
          href={redWhatsApp
            ? redWhatsApp.url
            : `https://wa.me/${perfil.telefono?.replace(/[\s+\-]/g,'')}`
          }
          target="_blank" rel="noopener noreferrer"
          class="fc-contact-btn track-red"
          data-plataforma="WhatsApp"
          aria-label="WhatsApp"
          style="background:color-mix(in srgb, var(--accent) 80%, #25d366 30%)"
        >
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
        <span class="fc-contact-label">WhatsApp</span>
      </div>
    )}

    {perfil.email && (
      <div class="fc-contact-item">
        <a href={`mailto:${perfil.email}`} class="fc-contact-btn" aria-label="Email"
           style="background:color-mix(in srgb, var(--accent) 80%, #c0392b 25%)">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </a>
        <span class="fc-contact-label">Email</span>
      </div>
    )}

    {perfil.cv_pdf_url && (
      <div class="fc-contact-item">
        <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer"
           class="fc-contact-btn track-cv" aria-label="Descargar CV"
           style="background:color-mix(in srgb, var(--accent) 80%, #7c3aed 25%)">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </a>
        <span class="fc-contact-label">CV</span>
      </div>
    )}
  </div>

  <!-- ── CTA CENTRAL ───────────────────────────────────────────── -->
  <div class="fc-cta-wrap">
    {perfil.email
      ? <a href={`mailto:${perfil.email}`} class="fc-cta">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          Contáctame ahora
        </a>
      : perfil.telefono
        ? <a href={`tel:${perfil.telefono.replace(/\s/g,'')}`} class="fc-cta">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            Contactar ahora
          </a>
        : null
    }
  </div>

  <!-- ── REDES SOCIALES ─────────────────────────────────────────── -->
  {redesSinContacto.length > 0 && (
    <div class="fc-social-wrap">
      <div class="fc-social-row">
        {redesSinContacto.map(red => (
          <a href={red.url} target="_blank" rel="noopener noreferrer"
             class="fc-social-btn track-red" data-plataforma={red.plataforma}
             title={red.plataforma} aria-label={red.plataforma}>
            <Fragment set:html={icon(red.plataforma)} />
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="fc-divider"></div>

  <!-- ── BIO ───────────────────────────────────────────────────── -->
  {perfil.bio && <div class="fc-bio">{perfil.bio}</div>}

  <!-- ── SECCIONES ─────────────────────────────────────────────── -->
  {servicios.length > 0 && (
    <details class="fc-section">
      <summary>
        <div class="fc-sec-left">
          <div class="fc-sec-icon">⚡</div>
          <div>
