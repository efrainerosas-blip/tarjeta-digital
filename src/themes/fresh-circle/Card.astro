---
// src/themes/fresh-circle/Card.astro
// THEME: Fresh Circle
// banner superior, foto circular centrada, nombre con acento en apellido,
// contactos grandes, CTA ancho, redes planas, bottom nav.

import type { CardProps } from '../types'

const {
  perfil, experiencia, estudios, habilidades,
  servicios, proyectos, redes, logros, capacitaciones, referencias,
} = Astro.props as CardProps

const accent  = perfil.color_primario ?? '#0078D7'
const nombre  = [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')
const foto    = perfil.foto_url || null

// Partir nombre / apellidos para colorear
const palabras    = nombre.trim().split(' ')
const mitad       = Math.ceil(palabras.length / 2)
const primerParte = palabras.slice(0, mitad).join(' ')
const segundaParte= palabras.slice(mitad).join(' ')

// Luminancia para elegir texto sobre el acento
function luminance(hex: string): number {
  const h = hex.replace('#','')
  const r = parseInt(h.slice(0,2),16)
  const g = parseInt(h.slice(2,4),16)
  const b = parseInt(h.slice(4,6),16)
  return (0.299*r + 0.587*g + 0.114*b) / 255
}
const accentText = luminance(accent.startsWith('#') ? accent : '#0078D7') > 0.6 ? '#111' : '#fff'

// Iconos de redes sociales
const ICONOS: Record<string, string> = {
