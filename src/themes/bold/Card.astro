---
// src/themes/bold/Card.astro
//
// THEME: Bold
// Estética: bloques de color grandes, tipografía con carácter,
// layouts asimétricos. Ideal para diseñadores, creativos,
// fotógrafos, marketers y cualquier profesión visual.

import type { CardProps } from '../types'

const {
  perfil, experiencia, estudios, habilidades,
  servicios, proyectos, redes, logros, capacitaciones,
} = Astro.props as CardProps

const accent   = perfil.color_primario ?? '#f97316'
const nombre   = [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')
const inicial  = perfil.nombre[0]?.toUpperCase() ?? '?'

const redIconos: Record<string, string> = {
