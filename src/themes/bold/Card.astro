}
function getIcon(p: string) {
  return redIconos[p] ?? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`
}
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={perfil.bio ?? `Tarjeta digital de ${nombre}`} />
  <meta property="og:title" content={nombre} />
  {perfil.foto_url && <meta property="og:image" content={perfil.foto_url} />}
  <title>{nombre}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style define:vars={{ accent }}>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --accent:  var(--accent);
      --bg:      #fafaf9;
      --bg-2:    #ffffff;
      --border:  #e7e5e4;
      --text-1:  #1c1917;
      --text-2:  #44403c;
      --text-3:  #78716c;
      --text-4:  #a8a29e;
      --font:    'Plus Jakarta Sans', sans-serif;
      --max-w:   700px;
      --radius:  12px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text-2);
      font-size: 14px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    .card-shell {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 0 64px;
    }

    /* ── HERO — bloque de color a full width ── */
    .hero {
      background: var(--accent);
      color: #fff;
      padding: 40px 24px 32px;
      position: relative;
      overflow: hidden;
    }

    /* Forma decorativa de fondo */
    .hero::before {
      content: '';
      position: absolute;
      bottom: -60px; right: -60px;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: rgba(255,255,255,.08);
    }
    .hero::after {
      content: '';
      position: absolute;
      top: -40px; left: 40%;
      width: 160px; height: 160px;
      border-radius: 50%;
      background: rgba(255,255,255,.06);
    }

    .hero-inner {
      position: relative; z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .hero-identity { display: flex; gap: 18px; align-items: center; }

    .avatar {
      width: 80px; height: 80px;
      border-radius: 16px;
      object-fit: cover;
      border: 3px solid rgba(255,255,255,.4);
      flex-shrink: 0;
    }
    .avatar-placeholder {
      width: 80px; height: 80px;
      border-radius: 16px;
      background: rgba(255,255,255,.2);
      border: 3px solid rgba(255,255,255,.4);
      display: flex; align-items: center; justify-content: center;
      font-size: 32px; font-weight: 800;
      color: #fff; flex-shrink: 0;
    }

    .hero-name {
      font-size: clamp(22px, 6vw, 34px);
      font-weight: 800;
      color: #fff;
      line-height: 1.1;
      letter-spacing: -.02em;
    }
    .hero-title {
      font-size: 13px;
      font-weight: 500;
      color: rgba(255,255,255,.8);
      margin-top: 4px;
    }
    .hero-location {
      font-size: 12px;
      color: rgba(255,255,255,.7);
      display: flex; align-items: center; gap: 4px;
      margin-top: 4px;
    }

    .status-badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 700;
      padding: 5px 12px; border-radius: 99px;
      background: rgba(255,255,255,.2);
      color: #fff;
      backdrop-filter: blur(4px);
      text-transform: uppercase; letter-spacing: .06em;
    }
    .status-badge::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #fff;
    }

    .hero-bio {
      font-size: 14px;
      color: rgba(255,255,255,.85);
      line-height: 1.7;
      max-width: 500px;
    }

    /* ── Redes en hero ── */
    .redes {
      display: flex; flex-wrap: wrap; gap: 8px;
    }
    .red-btn {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 7px 14px;
      border-radius: 99px;
      background: rgba(255,255,255,.15);
      border: 1px solid rgba(255,255,255,.25);
      color: #fff;
      text-decoration: none;
      font-size: 12px; font-weight: 600;
      transition: background .15s;
      backdrop-filter: blur(4px);
    }
    .red-btn:hover { background: rgba(255,255,255,.25); }
    .red-btn svg { width: 14px; height: 14px; }

    .cv-btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px;
      background: #fff;
      color: var(--accent);
      border-radius: var(--radius);
      font-size: 13px; font-weight: 700;
      text-decoration: none;
      transition: transform .15s, box-shadow .15s;
    }
    .cv-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,0,0,.15);
    }
    .cv-btn svg { width: 14px; height: 14px; }

    /* ── Contenido ── */
    .content { padding: 32px 24px; }

    /* ── Secciones ── */
    .section { margin-bottom: 40px; }

    .section-header {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 18px;
    }
    .section-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }
    .section-title {
      font-size: 16px; font-weight: 800;
      color: var(--text-1);
      letter-spacing: -.02em;
    }

    /* ── Experiencia / Estudios ── */
    .timeline { display: flex; flex-direction: column; gap: 0; }
    .timeline-item {
      padding: 16px 0 16px 20px;
      border-left: 2px solid var(--border);
      position: relative;
    }
    .timeline-item::before {
      content: '';
      position: absolute;
      left: -5px; top: 22px;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--bg);
      border: 2px solid var(--accent);
    }
    .timeline-header {
      display: flex; justify-content: space-between;
      align-items: flex-start; gap: 8px; flex-wrap: wrap;
    }
    .timeline-title { font-size: 14px; font-weight: 700; color: var(--text-1); }
    .timeline-sub   { font-size: 12px; color: var(--text-3); margin-top: 2px; }
    .timeline-period {
      font-size: 11px; color: var(--text-4);
      white-space: nowrap; flex-shrink: 0;
      background: var(--border);
      padding: 2px 8px; border-radius: 99px;
    }
    .timeline-desc { font-size: 13px; color: var(--text-3); margin-top: 6px; line-height: 1.6; }
    .badge-actual {
      font-size: 10px; font-weight: 700;
      padding: 2px 8px; border-radius: 99px;
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      color: var(--accent);
      text-transform: uppercase; letter-spacing: .06em;
    }

    /* ── Habilidades ── */
    .skills { display: flex; flex-wrap: wrap; gap: 8px; }
    .skill-tag {
      font-size: 12px; font-weight: 600;
      padding: 6px 14px;
      border-radius: 99px;
      background: var(--bg-2);
      color: var(--text-2);
      border: 2px solid var(--border);
      transition: border-color .15s, color .15s;
    }
    .skill-tag:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* ── Servicios ── */
    .services { display: grid; grid-template-columns: 1fr; gap: 12px; }
    .service-card {
      padding: 18px;
      background: var(--bg-2);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      transition: border-color .15s, transform .15s;
    }
    .service-card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
    }
    .service-icon { font-size: 28px; margin-bottom: 10px; line-height: 1; }
    .service-name { font-size: 15px; font-weight: 700; color: var(--text-1); }
    .service-desc { font-size: 13px; color: var(--text-3); margin-top: 4px; line-height: 1.5; }
    .service-price {
      display: inline-flex; align-items: center;
      font-size: 13px; font-weight: 700;
      color: var(--accent); margin-top: 10px;
      background: color-mix(in srgb, var(--accent) 10%, transparent);
      padding: 3px 10px; border-radius: 99px;
    }

    /* ── Proyectos ── */
    .projects { display: grid; grid-template-columns: 1fr; gap: 16px; }
    .project-card {
      background: var(--bg-2);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: border-color .15s, transform .15s;
    }
    .project-card:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
    }
    .project-img { width: 100%; height: 160px; object-fit: cover; display: block; }
    .project-body { padding: 16px; }
    .project-title { font-size: 14px; font-weight: 700; color: var(--text-1); }
    .project-desc  { font-size: 13px; color: var(--text-3); margin-top: 4px; line-height: 1.5; }
    .project-link {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 12px; font-weight: 700;
      color: #fff; background: var(--accent);
      text-decoration: none; margin-top: 12px;
      padding: 6px 14px; border-radius: 99px;
      transition: opacity .15s;
    }
    .project-link:hover { opacity: .85; }

    /* ── Logros ── */
    .logros { display: flex; flex-direction: column; gap: 12px; }
    .logro-item {
      display: flex; gap: 12px;
      padding: 14px 16px;
      background: var(--bg-2);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      transition: border-color .15s;
    }
    .logro-item:hover { border-color: var(--accent); }
    .logro-num {
      font-size: 24px; font-weight: 800;
      color: color-mix(in srgb, var(--accent) 20%, transparent);
      line-height: 1; flex-shrink: 0;
      min-width: 32px; text-align: right;
    }
    .logro-title { font-size: 14px; font-weight: 700; color: var(--text-1); }
    .logro-desc  { font-size: 13px; color: var(--text-3); margin-top: 2px; }
    .logro-fecha { font-size: 11px; color: var(--text-4); margin-top: 4px; }

    /* ── Capacitaciones ── */
    .capacitaciones { display: flex; flex-direction: column; gap: 10px; }
    .cap-item {
      display: flex; gap: 10px;
      padding: 12px 14px;
      background: var(--bg-2);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      align-items: flex-start;
      transition: border-color .15s;
    }
    .cap-item:hover { border-color: var(--accent); }
    .cap-icon {
      width: 32px; height: 32px;
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; font-size: 16px;
    }
    .cap-name  { font-size: 13px; font-weight: 700; color: var(--text-1); }
    .cap-inst  { font-size: 12px; color: var(--text-3); }
    .cap-fecha { font-size: 11px; color: var(--text-4); margin-top: 2px; }
    .cap-cert  {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 600;
      color: var(--accent); text-decoration: none;
      margin-top: 4px;
    }

    /* ── Footer ── */
    .card-footer {
      text-align: center; padding: 24px 24px 8px;
      font-size: 12px; color: var(--text-4);
    }
    .card-footer a { color: var(--accent); text-decoration: none; font-weight: 700; }

    /* ── Responsive ── */
    @media (min-width: 480px) {
      .services { grid-template-columns: 1fr 1fr; }
      .projects { grid-template-columns: 1fr 1fr; }
      .hero { padding: 48px 32px 40px; }
      .content { padding: 36px 32px; }
    }

    @media (min-width: 600px) {
      .hero-inner { flex-direction: row; align-items: flex-start; }
      .hero-identity { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>

<body>
  <div class="card-shell">

    <!-- HERO — bloque de color total -->
    <header class="hero">
      <div class="hero-inner">
        <div class="hero-identity">
          {perfil.foto_url
            ? <img src={perfil.foto_url} alt={nombre} class="avatar" loading="eager" />
            : <div class="avatar-placeholder">{inicial}</div>
          }
        </div>

        <div style="flex:1;min-width:0">
          <h1 class="hero-name">{nombre}</h1>
          {perfil.titulo_profesional && (
            <p class="hero-title">{perfil.titulo_profesional}</p>
          )}
          {perfil.ubicacion && (
            <p class="hero-location">
              <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              </svg>
              {perfil.ubicacion}
            </p>
          )}

          <div style="display:flex;flex-wrap:wrap;align-items:center;gap:10px;margin-top:14px">
            <span class="status-badge">{perfil.status ?? 'Disponible'}</span>
            {perfil.cv_pdf_url && (
              <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer"
                 class="cv-btn track-cv">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Descargar CV
              </a>
            )}
          </div>

          {perfil.bio && <p class="hero-bio" style="margin-top:16px">{perfil.bio}</p>}

          {redes.length > 0 && (
            <div class="redes" style="margin-top:16px">
              {redes.map(red => (
                <a href={red.url} target="_blank" rel="noopener noreferrer"
                   class="red-btn track-red" data-plataforma={red.plataforma}>
                  <span set:html={getIcon(red.plataforma)} />
                  {red.plataforma}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- CONTENIDO -->
    <div class="content">

      {servicios.length > 0 && (
        <section class="section">
          <div class="section-header">
            <div class="section-dot"></div>
            <h2 class="section-title">Servicios</h2>
          </div>
          <div class="services">
            {servicios.map(s => (
              <div class="service-card">
                {s.icono && <div class="service-icon">{s.icono}</div>}
                <div class="service-name">{s.nombre}</div>
                {s.descripcion && <p class="service-desc">{s.descripcion}</p>}
                {s.precio_referencial && (
                  <div class="service-price">{s.precio_referencial}</div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {experiencia.length > 0 && (
        <section class="section">
          <div class="section-header">
            <div class="section-dot"></div>
            <h2 class="section-title">Experiencia</h2>
          </div>
          <div class="timeline">
            {experiencia.map(exp => (
              <div class="timeline-item">
                <div class="timeline-header">
                  <div>
                    <div class="timeline-title">{exp.cargo}</div>
                    <div class="timeline-sub">{exp.empresa}</div>
                  </div>
                  <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px">
                    {exp.periodo && <span class="timeline-period">{exp.periodo}</span>}
                    {exp.es_trabajo_actual && <span class="badge-actual">Actual</span>}
                  </div>
                </div>
                {exp.descripcion && <p class="timeline-desc">{exp.descripcion}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

      {estudios.length > 0 && (
        <section class="section">
          <div class="section-header">
            <div class="section-dot"></div>
            <h2 class="section-title">Educación</h2>
          </div>
          <div class="timeline">
            {estudios.map(e => (
              <div class="timeline-item">
                <div class="timeline-header">
                  <div>
                    <div class="timeline-title">{e.titulo_obtenido ?? e.nivel}</div>
                    <div class="timeline-sub">{e.institucion}</div>
                  </div>
                  {(e.fecha_inicio || e.fecha_fin) && (
                    <span class="timeline-period">
                      {e.fecha_inicio ?? ''}{e.fecha_fin ? ` — ${e.fecha_fin}` : ''}
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {habilidades.length > 0 && (
        <section class="section">
          <div class="section-header">
            <div class="section-dot"></div>
            <h2 class="section-title">Habilidades</h2>
          </div>
          <div class="skills">
            {habilidades.map(h => <span class="skill-tag">{h.nombre}</span>)}
          </div>
        </section>
      )}

      {proyectos.length > 0 && (
        <section class="section">
          <div class="section-header">
            <div class="section-dot"></div>
            <h2 class="section-title">Proyectos</h2>
          </div>
          <div class="projects">
            {proyectos.map(p => (
              <div class="project-card">
                {p.imagen_url && (
                  <img src={p.imagen_url} alt={p.titulo} class="project-img" loading="lazy" />
                )}
                <div class="project-body">
                  <div class="project-title">{p.titulo}</div>
                  {p.descripcion && <p class="project-desc">{p.descripcion}</p>}
                  {p.enlace_url && (
                    <a href={p.enlace_url} target="_blank" rel="noopener noreferrer"
                       class="project-link track-proyecto" data-titulo={p.titulo}>
                      Ver proyecto →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {logros.length > 0 && (
        <section class="section">
          <div class="section-header">
            <div class="section-dot"></div>
            <h2 class="section-title">Logros</h2>
          </div>
          <div class="logros">
            {logros.map((l, i) => (
              <div class="logro-item">
                <div class="logro-num">0{i + 1}</div>
                <div>
                  <div class="logro-title">{l.titulo}</div>
                  {l.descripcion && <p class="logro-desc">{l.descripcion}</p>}
                  {l.fecha && <div class="logro-fecha">{l.fecha}</div>}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {capacitaciones.length > 0 && (
        <section class="section">
          <div class="section-header">
            <div class="section-dot"></div>
            <h2 class="section-title">Cursos</h2>
          </div>
          <div class="capacitaciones">
            {capacitaciones.map(c => (
              <div class="cap-item">
                <div class="cap-icon">📚</div>
                <div>
                  <div class="cap-name">{c.nombre}</div>
                  {c.institucion && <div class="cap-inst">{c.institucion}</div>}
                  {c.fecha && <div class="cap-fecha">{c.fecha}</div>}
                  {c.certificado_url && (
                    <a href={c.certificado_url} target="_blank" rel="noopener noreferrer" class="cap-cert">
                      Ver certificado →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

    </div>

    <footer class="card-footer">
      Creado con <a href="/">TarjetaDigital</a>
    </footer>
  </div>
</body>
</html>