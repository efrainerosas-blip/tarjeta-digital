function icon(p: string) {
  return ICONOS[p] ?? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`
}
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={perfil.bio ?? `Tarjeta digital de ${nombre}`} />
  <title>{nombre}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Azules exactos de la imagen de referencia */
      --blue-deep:   #1a4fa0;   /* azul más oscuro, parte inferior */
      --blue-mid:    #1e6dd8;   /* azul medio del degradado */
      --blue-hero:   #2a7de1;   /* azul del área de la foto */
      --blue-card:   #2878d4;   /* fondo de las tarjetas */
      --blue-card2:  #1f6cc8;   /* tarjetas ligeramente más oscuras */
      --white:       #ffffff;
      --white-90:    rgba(255,255,255,.90);
      --white-70:    rgba(255,255,255,.70);
      --white-50:    rgba(255,255,255,.50);
      --white-20:    rgba(255,255,255,.20);
      --font:        'Poppins', sans-serif;
      --max-w:       420px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font);
      background: #0d1b3e;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* Centrar en desktop como tarjeta móvil */
    @media (min-width: 480px) {
      body {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 32px 0 64px;
      }
    }

    /* ── Página completa ─────────────────────────────────────── */
    .page {
      width: 100%;
      max-width: var(--max-w);
      min-height: 100vh;
      /* Degradado azul de referencia: más claro arriba (zona foto), más oscuro abajo */
      background: linear-gradient(
        180deg,
        #2a7de1 0%,      /* azul brillante arriba */
        #1e6dd8 30%,     /* transición media */
        #1a4fa0 65%,     /* azul profundo */
        #163d85 100%     /* azul muy oscuro al fondo */
      );
      overflow: hidden;
    }

    @media (min-width: 480px) {
      .page {
        min-height: auto;
        border-radius: 40px;
        box-shadow: 0 40px 100px rgba(0,0,0,.7);
        overflow: hidden;
      }
    }

    /* ══ HERO — foto + nombre ═══════════════════════════════════ */
    .hero {
      position: relative;
      width: 100%;
      /* Alto del hero: suficiente para que la foto sea protagonista */
      padding-bottom: 40px;
    }

    /* Foto ocupa la parte superior, sin recorte circular */
    .hero-foto-wrap {
      width: 100%;
      height: 320px;
      position: relative;
      overflow: hidden;
    }

    .hero-foto {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top; /* enfocar el rostro */
      display: block;
    }

    /* Placeholder cuando no hay foto */
    .hero-foto-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(160deg, #3a8eef 0%, #2060c0 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-foto-placeholder svg {
      width: 80px;
      height: 80px;
      color: rgba(255,255,255,.3);
    }

    /* Degradado que funde la foto con el fondo azul */
    /* Exactamente como en la imagen: transparente arriba, azul sólido abajo */
    .hero-fade {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 180px; /* cubre la mitad inferior de la foto */
      background: linear-gradient(
        to bottom,
        transparent 0%,
        rgba(26, 79, 160, 0.6) 40%,
        rgba(26, 79, 160, 0.92) 70%,
        #1a4fa0 100%
      );
      pointer-events: none;
    }

    /* Nombre y título sobre el degradado, dentro del hero-foto-wrap */
    .hero-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 0 24px 20px;
      z-index: 2;
    }

    .hero-name {
      font-size: 26px;
      font-weight: 800;
      color: var(--white);
      line-height: 1.1;
      letter-spacing: -.01em;
      text-shadow: 0 2px 12px rgba(0,0,0,.3);
    }

    .hero-title {
      font-size: 13px;
      font-weight: 400;
      color: var(--white-70);
      margin-top: 3px;
      letter-spacing: .01em;
    }

    /* ── Íconos de contacto/redes ────────────────────────────── */
    /* Fila de círculos blancos debajo del nombre, igual que la imagen */
    .redes-row {
      display: flex;
      justify-content: center;
      gap: 14px;
      padding: 20px 24px 8px;
    }

    .red-btn {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(255,255,255,.18);
      border: 1.5px solid rgba(255,255,255,.35);
      backdrop-filter: blur(6px);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      text-decoration: none;
      transition: background .15s, transform .15s;
      flex-shrink: 0;
    }
    .red-btn svg { width: 20px; height: 20px; }
    .red-btn:hover {
      background: rgba(255,255,255,.30);
      transform: scale(1.08);
    }

    /* ══ SECCIONES — tarjetas redondeadas ═══════════════════════ */
    .sections {
      padding: 12px 16px 48px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    /* Tarjeta con bordes muy redondeados — exacta a la imagen */
    .card {
      background: rgba(255,255,255,.15);
      border: 1px solid rgba(255,255,255,.22);
      border-radius: 20px;
      padding: 20px 20px;
      backdrop-filter: blur(4px);
    }

    .card-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 10px;
      letter-spacing: -.01em;
    }

    .card-text {
      font-size: 13px;
      color: var(--white-70);
      line-height: 1.7;
    }

    /* Logros / achievements — texto secundario en cursiva suave */
    .card-subtitle {
      font-size: 12px;
      color: var(--white-50);
      font-style: italic;
      margin-top: 4px;
    }

    /* ── Timeline dentro de tarjetas ────────────────────────── */
    .timeline { display: flex; flex-direction: column; gap: 14px; }

    .tl-item {
      padding-left: 14px;
      border-left: 2px solid rgba(255,255,255,.25);
      position: relative;
    }
    .tl-item::before {
      content: '';
      position: absolute;
      left: -5px; top: 5px;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--white);
      opacity: .8;
    }
    .tl-name   { font-size: 13px; font-weight: 700; color: var(--white); }
    .tl-sub    { font-size: 12px; color: var(--white-70); margin-top: 1px; }
    .tl-period { font-size: 11px; color: var(--white-50); margin-top: 2px; }
    .tl-desc   { font-size: 12px; color: var(--white-70); margin-top: 4px; line-height: 1.5; }

    /* ── Skills ─────────────────────────────────────────────── */
    .skills {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
    }
    .skill-tag {
      font-size: 11px;
      font-weight: 600;
      padding: 5px 13px;
      border-radius: 99px;
      background: rgba(255,255,255,.18);
      color: var(--white-90);
      border: 1px solid rgba(255,255,255,.25);
      letter-spacing: .02em;
    }

    /* ── Servicios ──────────────────────────────────────────── */
    .services { display: flex; flex-direction: column; gap: 10px; }
    .service-item {
      display: flex;
      gap: 12px;
      padding: 12px 14px;
      background: rgba(255,255,255,.08);
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.12);
    }
    .service-emoji { font-size: 22px; flex-shrink: 0; line-height: 1; margin-top: 1px; }
    .service-name  { font-size: 13px; font-weight: 700; color: var(--white); }
    .service-desc  { font-size: 12px; color: var(--white-70); margin-top: 2px; line-height: 1.5; }
    .service-price { font-size: 12px; font-weight: 700; color: rgba(255,255,255,.9); margin-top: 4px; display: inline-block; }

    /* ── Proyectos ──────────────────────────────────────────── */
    .projects { display: flex; flex-direction: column; gap: 10px; }
    .project-item {
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
    }
    .project-img { width: 100%; height: 140px; object-fit: cover; display: block; }
    .project-body { padding: 12px; }
    .project-name { font-size: 13px; font-weight: 700; color: var(--white); }
    .project-desc { font-size: 12px; color: var(--white-70); margin-top: 3px; line-height: 1.5; }
    .project-link {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 700;
      color: rgba(255,255,255,.9); text-decoration: none; margin-top: 6px;
    }

    /* ── Logros ─────────────────────────────────────────────── */
    .logros { display: flex; flex-direction: column; gap: 10px; }
    .logro-item {
      display: flex; gap: 12px;
      padding: 12px 14px;
      background: rgba(255,255,255,.08);
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.12);
    }
    .logro-num   { font-size: 18px; font-weight: 900; color: rgba(255,255,255,.25); min-width: 28px; line-height: 1; }
    .logro-name  { font-size: 13px; font-weight: 700; color: var(--white); }
    .logro-desc  { font-size: 12px; color: var(--white-70); margin-top: 2px; }
    .logro-fecha { font-size: 10px; color: var(--white-50); margin-top: 2px; }

    /* ── Capacitaciones ─────────────────────────────────────── */
    .caps { display: flex; flex-direction: column; gap: 10px; }
    .cap-item {
      display: flex; gap: 10px;
      padding: 12px 14px;
      background: rgba(255,255,255,.08);
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.12);
    }
    .cap-dot   { width: 8px; height: 8px; border-radius: 50%; background: var(--white); flex-shrink: 0; margin-top: 4px; opacity: .7; }
    .cap-name  { font-size: 13px; font-weight: 700; color: var(--white); }
    .cap-inst  { font-size: 12px; color: var(--white-70); margin-top: 1px; }
    .cap-fecha { font-size: 10px; color: var(--white-50); margin-top: 2px; }
    .cap-cert  {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 600; color: var(--white);
      text-decoration: none; margin-top: 4px;
    }

    /* ── CV button ──────────────────────────────────────────── */
    .cv-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 13px 20px;
      background: rgba(255,255,255,.20);
      border: 1.5px solid rgba(255,255,255,.40);
      border-radius: 14px;
      color: var(--white);
      text-decoration: none;
      font-size: 14px;
      font-weight: 700;
      transition: background .15s;
      margin: 0 16px;
    }
    .cv-btn:hover { background: rgba(255,255,255,.28); }
    .cv-btn svg { width: 18px; height: 18px; }

    /* ── Footer ─────────────────────────────────────────────── */
    .footer {
      text-align: center;
      padding: 24px 24px 40px;
      font-size: 11px;
      color: rgba(255,255,255,.35);
      letter-spacing: .04em;
    }
    .footer a { color: rgba(255,255,255,.6); text-decoration: none; font-weight: 600; }

    /* ── Animación de entrada ────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-info  { animation: fadeUp .5s ease-out .1s both; }
    .redes-row  { animation: fadeUp .5s ease-out .2s both; }
    .sections   { animation: fadeUp .5s ease-out .3s both; }
  </style>
</head>

<body>
<div class="page">

  <!-- ══ HERO ═══════════════════════════════════════════════════ -->
  <div class="hero">
    <div class="hero-foto-wrap">
      {perfil.foto_url
        ? <img src={perfil.foto_url} alt={nombre} class="hero-foto" />
        : (
          <div class="hero-foto-placeholder">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/>
            </svg>
          </div>
        )
      }
      <!-- Degradado que funde foto con fondo azul -->
      <div class="hero-fade"></div>
      <!-- Nombre + título sobre el degradado -->
      <div class="hero-info">
        <h1 class="hero-name">{nombre}</h1>
        {perfil.titulo_profesional && <p class="hero-title">{perfil.titulo_profesional}</p>}
      </div>
    </div>
  </div>

  <!-- ══ REDES — íconos circulares ══════════════════════════════ -->
  {redes.length > 0 && (
    <div class="redes-row">
      {redes.slice(0, 4).map(red => (
        <a
          href={red.url}
          target="_blank"
          rel="noopener noreferrer"
          class="red-btn track-red"
          data-plataforma={red.plataforma}
          title={red.plataforma}
        >
          <Fragment set:html={icon(red.plataforma)} />
        </a>
      ))}
    </div>
  )}

  <!-- ══ SECCIONES ══════════════════════════════════════════════ -->
  <div class="sections">

    <!-- Bio / About Me -->
    {perfil.bio && (
      <div class="card">
        <div class="card-title">Acerca de mi</div>
        <p class="card-text">{perfil.bio}</p>
      </div>
    )}

    <!-- CV -->
    {perfil.cv_pdf_url && (
      <a href={perfil.cv_pdf_url} target="_blank" rel="noopener noreferrer" class="cv-btn track-cv">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Descargar CV
      </a>
    )}

    <!-- Servicios -->
    {servicios.length > 0 && (
      <div class="card">
        <div class="card-title">Servicios</div>
        <div class="services">
          {servicios.map(s => (
            <div class="service-item">
              {s.icono && <div class="service-emoji">{s.icono}</div>}
              <div>
                <div class="service-name">{s.nombre}</div>
                {s.descripcion && <p class="service-desc">{s.descripcion}</p>}
                {s.precio_referencial && <span class="service-price">{s.precio_referencial}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Experiencia -->
    {experiencia.length > 0 && (
      <div class="card">
        <div class="card-title">Experiencia</div>
        <div class="timeline">
          {experiencia.map(exp => (
            <div class="tl-item">
              <div class="tl-name">{exp.cargo}</div>
              <div class="tl-sub">{exp.empresa}</div>
              {exp.periodo && <div class="tl-period">{exp.periodo}</div>}
              {exp.descripcion && <p class="tl-desc">{exp.descripcion}</p>}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Educación -->
    {estudios.length > 0 && (
      <div class="card">
        <div class="card-title">Educación</div>
        <div class="timeline">
          {estudios.map(e => (
            <div class="tl-item">
              <div class="tl-name">{e.titulo_obtenido ?? e.nivel}</div>
              <div class="tl-sub">{e.institucion}</div>
              {(e.fecha_inicio || e.fecha_fin) && (
                <div class="tl-period">
                  {e.fecha_inicio ?? ''}{e.fecha_fin ? ` — ${e.fecha_fin}` : ''}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Habilidades -->
    {habilidades.length > 0 && (
      <div class="card">
        <div class="card-title">Habilidades</div>
        <div class="skills">
          {habilidades.map(h => <span class="skill-tag">{h.nombre}</span>)}
        </div>
      </div>
    )}

    <!-- Proyectos -->
    {proyectos.length > 0 && (
      <div class="card">
        <div class="card-title">Proyectos</div>
        <div class="projects">
          {proyectos.map(p => (
            <div class="project-item">
              {p.imagen_url && <img src={p.imagen_url} alt={p.titulo} class="project-img" loading="lazy" />}
              <div class="project-body">
                <div class="project-name">{p.titulo}</div>
                {p.descripcion && <p class="project-desc">{p.descripcion}</p>}
                {p.enlace_url && (
                  <a href={p.enlace_url} target="_blank" rel="noopener noreferrer"
                     class="project-link track-proyecto" data-titulo={p.titulo}>
                    Ver proyecto →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Logros -->
    {logros.length > 0 && (
      <div class="card">
        <div class="card-title">Logros</div>
        <div class="logros">
          {logros.map((l, i) => (
            <div class="logro-item">
              <div class="logro-num">0{i + 1}</div>
              <div>
                <div class="logro-name">{l.titulo}</div>
                {l.descripcion && <p class="logro-desc">{l.descripcion}</p>}
                {l.fecha && <div class="logro-fecha">{l.fecha}</div>}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Capacitaciones -->
    {capacitaciones.length > 0 && (
      <div class="card">
        <div class="card-title">Cursos & Certificados</div>
        <div class="caps">
          {capacitaciones.map(c => (
            <div class="cap-item">
              <div class="cap-dot"></div>
              <div>
                <div class="cap-name">{c.nombre}</div>
                {c.institucion && <div class="cap-inst">{c.institucion}</div>}
                {c.fecha && <div class="cap-fecha">{c.fecha}</div>}
                {c.certificado_url && (
                  <a href={c.certificado_url} target="_blank" rel="noopener noreferrer" class="cap-cert">
                    Ver certificado →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>

  {referencias && referencias.length > 0 && (
    <div class="card">
      <div class="card-title">Referencias</div>
      <div class="caps">
        {referencias.map(r => (
          <div class="cap-item">
            <div class="cap-dot"></div> 
            <div style="flex:1;">
              <div class="cap-name">{r.nombre}</div>
              {(r.cargo || r.empresa) && <div class="cap-inst">{r.cargo} {r.empresa ? `en ${r.empresa}` : ''}</div>}
              {r.observaciones && <div class="tl-desc" style="font-style: italic;">"{r.observaciones}"</div>}
              
              <div style="display:flex; gap:12px; margin-top:8px; flex-wrap:wrap;">
                {r.telefono && (
                  <a href={`tel:${r.telefono.replace(/\s/g, '')}`} class="cap-cert">
                    📞 {r.telefono}
                  </a>
                )}
                {r.email && (
                  <a href={`mailto:${r.email}`} class="cap-cert">
                    ✉️ Correo
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <footer class="footer">Creado con <a href="/">TarjetaDigital</a></footer>
</div>
</body>
</html>