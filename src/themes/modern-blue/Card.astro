---
// src/themes/modern-blue/Card.astro
// THEME: Modern Blue
// Réplica del diseño de referencia:
// — Foto hero superior que se funde con degradado azul
// — Nombre + título sobre el degradado
// — 4 íconos circulares blancos de contacto/redes
// — Tarjetas redondeadas azules para cada sección
// — Todo visible, sin colapsables

import type { CardProps } from '../types'

const {
  perfil, experiencia, estudios, habilidades,
  servicios, proyectos, redes, logros, capacitaciones, referencias
} = Astro.props as CardProps

const nombre = [perfil.nombre, perfil.apellidos].filter(Boolean).join(' ')

// Íconos de redes sociales
const ICONOS: Record<string, string> = {
