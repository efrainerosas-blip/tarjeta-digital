---
// src/components/perfil/FotoEditorModal.astro

interface Props {
  fotoActual?: string | null
}
const { fotoActual } = Astro.props
---

<!-- ═══════════════════════════════════════════════════════════
     MODAL BACKDROP
═══════════════════════════════════════════════════════════ -->
<div
  id="foto-editor-backdrop"
  role="dialog"
  aria-modal="true"
  aria-labelledby="foto-editor-title"
  style="
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.75);
    backdrop-filter: blur(8px);
    z-index: 2000;
    align-items: center;
    justify-content: center;
    padding: 16px;
  "
>
  <div
    id="foto-editor-modal"
    style="
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: 24px;
      width: 100%;
      max-width: 680px;
      max-height: 92svh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: 0 32px 80px rgba(0,0,0,.6);
      animation: modalIn .25s cubic-bezier(.34,1.56,.64,1);
    "
  >

    <!-- Header del modal -->
    <div style="
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 24px 16px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    ">
      <div>
        <h2 id="foto-editor-title" style="font-size:16px;font-weight:700;color:var(--text-1)">
          Foto de perfil
        </h2>
        <!-- Indicador de paso -->
        <div style="display:flex;align-items:center;gap:6px;margin-top:6px">
          {[1,2,3].map(n => (
            <div
              class="paso-dot"
              data-paso={n}
              style="
                display: flex;
                align-items: center;
                gap: 6px;
                font-size: 11px;
                font-weight: 600;
                color: var(--text-3);
              "
            >
              <div style="
                width: 20px; height: 20px;
                border-radius: 50%;
                background: var(--bg-4);
                border: 1.5px solid var(--border);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 10px;
                font-weight: 700;
                transition: all .2s;
              ">{n}</div>
              <span class="paso-label">
                {n === 1 ? 'Elegir' : n === 2 ? 'Editar' : 'Confirmar'}
              </span>
              {n < 3 && <div style="width:16px;height:1px;background:var(--border)"></div>}
            </div>
          ))}
        </div>
      </div>
      <button
        id="foto-editor-close"
        style="
          width: 32px; height: 32px;
          border-radius: 8px;
          border: 1px solid var(--border);
          background: var(--bg-3);
          color: var(--text-2);
          cursor: pointer;
          display: flex; align-items: center; justify-content: center;
          font-size: 16px;
          transition: all .15s;
          flex-shrink: 0;
        "
        aria-label="Cerrar"
      >✕</button>
    </div>

    <!-- Contenido scrollable -->
    <div style="overflow-y: auto; flex: 1;">

      <!-- ═══ PASO 1: SELECCIÓN ═══════════════════════════════ -->
      <div id="paso-1" style="padding: 24px;">

        <!-- Zona de drop -->
        <div
          id="foto-dropzone"
          style="
            border: 2px dashed var(--border-2);
            border-radius: 20px;
            padding: 48px 24px;
            text-align: center;
            cursor: pointer;
            transition: border-color .15s, background .15s;
            position: relative;
          "
        >
          <!-- Fondo decorativo con gradiente sutil -->
          <div style="
            position: absolute; inset: 0;
            border-radius: 18px;
            background: radial-gradient(ellipse at center, rgba(99,102,241,.04) 0%, transparent 70%);
            pointer-events: none;
          "></div>

          <div style="position:relative">
            <!-- Ícono animado -->
            <div style="
              width: 64px; height: 64px;
              border-radius: 50%;
              background: var(--accent-bg);
              border: 1.5px solid rgba(99,102,241,.3);
              display: flex;
              align-items: center;
              justify-content: center;
              margin: 0 auto 16px;
            ">
              <svg width="28" height="28" fill="none" stroke="var(--accent-2)" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z"/>
              </svg>
            </div>

            <div style="font-size:15px;font-weight:700;color:var(--text-1);margin-bottom:6px">
              Arrastra tu foto aquí
            </div>
            <div style="font-size:13px;color:var(--text-3);margin-bottom:20px;line-height:1.5">
              o clica para explorar tus archivos<br/>
              <span style="font-size:11px">JPG, PNG, WEBP · Máximo 10 MB</span>
            </div>

            <button
              type="button"
              id="foto-examinar-btn"
              style="
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 10px 20px;
                background: var(--accent);
                color: #fff;
                border: none;
                border-radius: 10px;
                font-size: 13px;
                font-weight: 600;
                cursor: pointer;
                transition: all .15s;
              "
            >
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
              Examinar archivos
            </button>
          </div>
        </div>

        <input type="file" id="foto-file-input" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none" />

        <!-- Foto actual (si existe) -->
        {fotoActual && (
          <div style="
            margin-top: 16px;
            padding: 12px 14px;
            background: var(--bg-3);
            border: 1px solid var(--border);
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
          ">
            <img
              src={fotoActual}
              style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0"
              alt="Foto actual"
            />
            <div>
              <div style="font-size:12px;font-weight:600;color:var(--text-2)">Foto actual</div>
              <div style="font-size:11px;color:var(--text-3)">Selecciona una nueva para reemplazarla</div>
            </div>
          </div>
        )}

        <!-- Aviso de soporte -->
        <div id="soporte-warning" style="display:none;margin-top:12px;padding:10px 14px;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:10px;font-size:12px;color:var(--warn)">
          ⚠ Tu navegador tiene soporte limitado para el editor. La foto se subirá sin recorte ni filtros.
        </div>
      </div>

      <!-- ═══ PASO 2: EDITOR ══════════════════════════════════ -->
      <div id="paso-2" style="display:none;padding:20px 24px;">

        <div style="display:grid;grid-template-columns:1fr 200px;gap:20px;align-items:start">

          <!-- Canvas de edición -->
          <div>
            <div style="font-size:12px;font-weight:600;color:var(--text-3);margin-bottom:8px;letter-spacing:.04em;text-transform:uppercase">
              Arrastra para encuadrar
            </div>
            <div
              id="canvas-wrap"
              style="
                position: relative;
                border-radius: 16px;
                overflow: hidden;
                background: #111;
                cursor: grab;
                user-select: none;
                touch-action: none;
              "
            >
              <!-- Canvas donde se dibuja la imagen -->
              <canvas
                id="editor-canvas"
                style="display:block;width:100%;border-radius:16px"
              ></canvas>

              <!-- Overlay de recorte circular -->
              <div style="
                position: absolute; inset: 0;
                pointer-events: none;
                border-radius: 16px;
                overflow: hidden;
              ">
                <!-- Oscurecer las esquinas fuera del círculo -->
                <svg
                  id="crop-overlay"
                  style="position:absolute;inset:0;width:100%;height:100%"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <defs>
                    <mask id="circle-mask">
                      <rect width="100%" height="100%" fill="white"/>
                      <circle id="crop-circle" cx="50%" cy="50%" r="45%" fill="black"/>
                    </mask>
                  </defs>
                  <rect width="100%" height="100%" fill="rgba(0,0,0,.55)" mask="url(#circle-mask)"/>
                  <!-- Guía circular -->
                  <circle id="crop-guide" cx="50%" cy="50%" r="45%" fill="none" stroke="rgba(255,255,255,.4)" stroke-width="1.5" stroke-dasharray="4 4"/>
                </svg>
              </div>
            </div>

            <!-- Zoom -->
            <div style="margin-top:14px">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                <span style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.04em">Zoom</span>
                <span id="zoom-value" style="font-size:11px;color:var(--text-3);font-family:var(--font-mono)">1.0×</span>
              </div>
              <input
                type="range"
                id="zoom-slider"
                min="50"
                max="300"
                value="100"
                style="
                  width: 100%;
                  accent-color: var(--accent);
                  cursor: pointer;
                "
              />
            </div>
          </div>

          <!-- Preview circular + filtros -->
          <div>
            <!-- Preview -->
            <div style="font-size:12px;font-weight:600;color:var(--text-3);margin-bottom:8px;letter-spacing:.04em;text-transform:uppercase">
              Vista previa
            </div>
            <div style="display:flex;flex-direction:column;align-items:center;gap:10px">
              <!-- Preview grande -->
              <div style="
                width: 120px; height: 120px;
                border-radius: 50%;
                overflow: hidden;
                border: 3px solid var(--border);
                flex-shrink: 0;
                background: var(--bg-4);
              ">
                <canvas id="preview-canvas-lg" width="120" height="120" style="display:block;width:120px;height:120px"></canvas>
              </div>
              <!-- Preview pequeño (como se verá en el dashboard) -->
              <div style="
                width: 48px; height: 48px;
                border-radius: 50%;
                overflow: hidden;
                border: 2px solid var(--border);
                flex-shrink: 0;
                background: var(--bg-4);
              ">
                <canvas id="preview-canvas-sm" width="48" height="48" style="display:block;width:48px;height:48px"></canvas>
              </div>
              <div style="font-size:10px;color:var(--text-3);text-align:center">
                Vista en tarjeta<br/>y dashboard
              </div>
            </div>

            <!-- Filtros -->
            <div style="margin-top:16px">
              <div style="font-size:12px;font-weight:600;color:var(--text-3);margin-bottom:8px;letter-spacing:.04em;text-transform:uppercase">
                Filtro
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:5px" id="filtros-grid">
                <!-- Los filtros se generan con JS para tener preview dinámico -->
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- ═══ PASO 3: CONFIRMACIÓN ════════════════════════════ -->
      <div id="paso-3" style="display:none;padding:24px">

        <div style="display:flex;flex-direction:column;align-items:center;gap:20px">

          <!-- Preview final grande -->
          <div style="
            width: 160px; height: 160px;
            border-radius: 50%;
            overflow: hidden;
            border: 4px solid var(--accent);
            box-shadow: 0 0 0 8px var(--accent-bg);
            background: var(--bg-4);
          ">
            <canvas id="preview-final" width="160" height="160" style="display:block;width:160px;height:160px"></canvas>
          </div>

          <!-- Info de optimización -->
          <div style="
            text-align: center;
            background: var(--bg-3);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 16px 20px;
            width: 100%;
            max-width: 320px;
          ">
            <div style="font-size:13px;font-weight:700;color:var(--text-1);margin-bottom:8px">
              ✓ Lista para subir
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;text-align:left">
              <div>
                <div style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em">Tamaño original</div>
                <div id="info-original" style="font-size:13px;font-weight:600;color:var(--text-2)">—</div>
              </div>
              <div>
                <div style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em">Después de optimizar</div>
                <div id="info-optimizado" style="font-size:13px;font-weight:600;color:var(--success)">—</div>
              </div>
              <div>
                <div style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em">Formato</div>
                <div style="font-size:13px;font-weight:600;color:var(--text-2)">WebP</div>
              </div>
              <div>
                <div style="font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em">Reducción</div>
                <div id="info-reduccion" style="font-size:13px;font-weight:600;color:var(--success)">—</div>
              </div>
            </div>
          </div>

          <div style="font-size:12px;color:var(--text-3);text-align:center;max-width:280px;line-height:1.5">
            La foto se subirá cuando confirmes aquí.<br/>
            Todavía puedes volver a editar.
          </div>

        </div>
      </div>

    </div><!-- /contenido scrollable -->

    <!-- Footer con botones de navegación -->
    <div style="
      padding: 16px 24px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
      gap: 12px;
    ">
      <button
        id="btn-volver"
        type="button"
        style="display:none;align-items:center;gap:6px;padding:9px 16px;background:transparent;border:1px solid var(--border);border-radius:10px;color:var(--text-2);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s"
      >
        ← Volver
      </button>
      <div style="flex:1"></div>
      <button
        id="btn-cancelar-modal"
        type="button"
        style="padding:9px 16px;background:transparent;border:1px solid var(--border);border-radius:10px;color:var(--text-2);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s"
      >
        Cancelar
      </button>
      <button
        id="btn-siguiente"
        type="button"
        style="display:none;align-items:center;gap:6px;padding:9px 18px;background:var(--accent);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s"
      >
        Continuar →
      </button>
      <button
        id="btn-confirmar"
        type="button"
        style="display:none;align-items:center;gap:6px;padding:9px 18px;background:var(--success);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s"
      >
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Usar esta foto
      </button>
    </div>

  </div><!-- /modal -->
</div><!-- /backdrop -->

<style>
  @keyframes modalIn {
    from { opacity: 0; transform: scale(.95) translateY(8px); }
    to   { opacity: 1; transform: scale(1)  translateY(0);    }
  }

  /* Filtros en el grid */
  .filtro-btn {
    padding: 5px 4px;
    border-radius: 8px;
    border: 1.5px solid var(--border);
    background: var(--bg-3);
    cursor: pointer;
    transition: all .15s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .filtro-btn:hover  { border-color: var(--border-2); background: var(--bg-4); }
  .filtro-btn.active { border-color: var(--accent); background: var(--accent-bg); }
  .filtro-thumb {
    width: 44px; height: 44px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }
  .filtro-nombre {
    font-size: 9px;
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .filtro-btn.active .filtro-nombre { color: var(--accent-2); }

  /* Indicadores de paso */
  .paso-dot[data-activo="true"] > div {
    background: var(--accent) !important;
    border-color: var(--accent) !important;
    color: #fff !important;
  }
  .paso-dot[data-activo="true"] > span {
    color: var(--text-1) !important;
  }
  .paso-dot[data-completado="true"] > div {
    background: var(--success) !important;
    border-color: var(--success) !important;
    color: #fff !important;
  }

  /* Zoom slider personalizado */
  #zoom-slider {
    -webkit-appearance: none;
    height: 4px;
    border-radius: 99px;
    background: var(--bg-4);
    outline: none;
  }
  #zoom-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px; height: 16px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    box-shadow: 0 0 0 3px var(--accent-bg);
  }

  /* Mobile: layout vertical en paso 2 */
  @media (max-width: 520px) {
    #paso-2 > div {
      grid-template-columns: 1fr !important;
    }
    #foto-editor-modal {
      max-height: 96svh !important;
      border-radius: 20px !important;
    }
  }
</style>

<script>
  // ═══════════════════════════════════════════════════════════
  // FOTO EDITOR MODAL — lógica completa
  // Sin librerías externas — Canvas API puro
  // ═══════════════════════════════════════════════════════════

  // ── Definición de filtros ─────────────────────────────────
  // Cada filtro es una función CSS filter aplicada al canvas
  const FILTROS = [
    { id: 'normal',   nombre: 'Normal',   css: 'none' },
    { id: 'vivid',    nombre: 'Vivid',    css: 'saturate(1.8) contrast(1.1)' },
    { id: 'fade',     nombre: 'Fade',     css: 'saturate(0.6) brightness(1.1) contrast(0.9)' },
    { id: 'noir',     nombre: 'Noir',     css: 'grayscale(1) contrast(1.15)' },
    { id: 'warm',     nombre: 'Warm',     css: 'sepia(0.35) saturate(1.4) brightness(1.05)' },
    { id: 'cool',     nombre: 'Cool',     css: 'hue-rotate(20deg) saturate(1.2) brightness(1.02)' },
    { id: 'drama',    nombre: 'Drama',    css: 'contrast(1.4) saturate(1.2) brightness(0.9)' },
    { id: 'clarity',  nombre: 'Clarity',  css: 'contrast(1.2) brightness(1.08) saturate(1.1)' },
  ]

  // ── Estado del editor ─────────────────────────────────────
  let imagenOriginal: HTMLImageElement | null = null
  let imagenOriginalSize = 0
  let filtroActual = 'normal'
  let zoom = 1
  let offsetX = 0
  let offsetY = 0
  let dragging = false
  let lastX = 0, lastY = 0
  let pasoActual = 1

  // ── Referencias DOM ───────────────────────────────────────
  const backdrop      = document.getElementById('foto-editor-backdrop')!
  const modal         = document.getElementById('foto-editor-modal')!
  const paso1         = document.getElementById('paso-1')!
  const paso2         = document.getElementById('paso-2')!
  const paso3         = document.getElementById('paso-3')!
  const fileInput     = document.getElementById('foto-file-input') as HTMLInputElement
  const dropzone      = document.getElementById('foto-dropzone')!
  const examinarBtn   = document.getElementById('foto-examinar-btn')!
  const editorCanvas  = document.getElementById('editor-canvas') as HTMLCanvasElement
  const previewLg     = document.getElementById('preview-canvas-lg') as HTMLCanvasElement
  const previewSm     = document.getElementById('preview-canvas-sm') as HTMLCanvasElement
  const previewFinal  = document.getElementById('preview-final') as HTMLCanvasElement
  const zoomSlider    = document.getElementById('zoom-slider') as HTMLInputElement
  const zoomValue     = document.getElementById('zoom-value')!
  const filtrosGrid   = document.getElementById('filtros-grid')!
  const btnVolver     = document.getElementById('btn-volver') as HTMLButtonElement
  const btnSiguiente  = document.getElementById('btn-siguiente') as HTMLButtonElement
  const btnConfirmar  = document.getElementById('btn-confirmar') as HTMLButtonElement
  const btnCancelar   = document.getElementById('btn-cancelar-modal') as HTMLButtonElement
  const btnCerrar     = document.getElementById('foto-editor-close') as HTMLButtonElement
  const soporteWarn   = document.getElementById('soporte-warning')!
  const infoOriginal  = document.getElementById('info-original')!
  const infoOptimizado = document.getElementById('info-optimizado')!
  const infoReduccion = document.getElementById('info-reduccion')!

  // ── Verificar soporte del browser ─────────────────────────
  function verificarSoporte(): boolean {
    try {
      const c = document.createElement('canvas')
      if (!c.getContext) return false
      if (!c.toBlob)     return false
      return true
    } catch {
      return false
    }
  }

  const haysSoporte = verificarSoporte()

  // ── Helpers ───────────────────────────────────────────────
  function formatBytes(b: number): string {
    if (b < 1024) return `${b} B`
    if (b < 1024*1024) return `${(b/1024).toFixed(0)} KB`
    return `${(b/1024/1024).toFixed(1)} MB`
  }

  function irAPaso(n: number) {
    pasoActual = n
    paso1.style.display = n === 1 ? '' : 'none'
    paso2.style.display = n === 2 ? '' : 'none'
    paso3.style.display = n === 3 ? '' : 'none'

    // Botones del footer
    btnVolver.style.display   = n > 1  ? 'flex'  : 'none'
    btnSiguiente.style.display = n === 2 ? 'flex'  : 'none'
    btnConfirmar.style.display = n === 3 ? 'flex'  : 'none'

    // Indicadores de paso
    document.querySelectorAll<HTMLElement>('.paso-dot').forEach(dot => {
      const num = parseInt(dot.dataset.paso ?? '0')
      dot.dataset.activo     = String(num === n)
      dot.dataset.completado = String(num < n)
    })

    // Al llegar al paso 3, generar preview final y calcular tamaño optimizado
    if (n === 3) generarPreviewFinal()
  }

  // ── Abrir / cerrar modal ──────────────────────────────────
  function abrirModal() {
    // Resetear estado
    imagenOriginal    = null
    imagenOriginalSize = 0
    filtroActual      = 'normal'
    zoom              = 1
    offsetX           = 0
    offsetY           = 0
    zoomSlider.value  = '100'
    zoomValue.textContent = '1.0×'

    if (!haysSoporte) {
      soporteWarn.style.display = ''
    }

    irAPaso(1)
    backdrop.style.display = 'flex'
    document.body.style.overflow = 'hidden'
  }

  function cerrarModal() {
    backdrop.style.display = 'none'
    document.body.style.overflow = ''
    // Limpiar el input para permitir reseleccionar el mismo archivo
    fileInput.value = ''
  }

  // Exponer al padre
  ;(window as any).abrirEditorFoto = abrirModal

  // Listeners de cierre
  btnCerrar.addEventListener('click', cerrarModal)
  btnCancelar.addEventListener('click', cerrarModal)
  backdrop.addEventListener('click', e => {
    if (e.target === backdrop) cerrarModal()
  })
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && backdrop.style.display === 'flex') cerrarModal()
  })

  // ── Selección de archivo ──────────────────────────────────
  examinarBtn.addEventListener('click', () => fileInput.click())
  dropzone.addEventListener('click', e => {
    if (e.target === examinarBtn) return
    fileInput.click()
  })

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0]
    if (file) procesarArchivo(file)
  })

  // Drag & drop en dropzone
  dropzone.addEventListener('dragover', e => {
    e.preventDefault()
    dropzone.style.borderColor = 'var(--accent)'
    dropzone.style.background  = 'rgba(99,102,241,.05)'
  })
  dropzone.addEventListener('dragleave', () => {
    dropzone.style.borderColor = 'var(--border-2)'
    dropzone.style.background  = ''
  })
  dropzone.addEventListener('drop', e => {
    e.preventDefault()
    dropzone.style.borderColor = 'var(--border-2)'
    dropzone.style.background  = ''
    const file = e.dataTransfer?.files[0]
    if (file) procesarArchivo(file)
  })

  function procesarArchivo(file: File) {
    // Validar tipo
    if (!file.type.startsWith('image/')) {
      alert('Solo se aceptan imágenes (JPG, PNG, WEBP)')
      return
    }

    // Límite de 10MB para la selección (luego se optimiza)
    if (file.size > 10 * 1024 * 1024) {
      alert(`La imagen es demasiado grande (${formatBytes(file.size)}). El máximo es 10 MB.`)
      return
    }

    imagenOriginalSize = file.size

    // Si el browser no soporta Canvas, disparar evento directo con el archivo original
    if (!haysSoporte) {
      const reader = new FileReader()
      reader.onload = e => {
        window.dispatchEvent(new CustomEvent('foto-confirmada', {
          detail: { blob: file, previewUrl: e.target!.result as string }
        }))
        cerrarModal()
      }
      reader.readAsDataURL(file)
      return
    }

    // Cargar imagen en memory
    const reader = new FileReader()
    reader.onload = e => {
      const img = new Image()
      img.onload = () => {
        imagenOriginal = img
        // Centrar imagen al cargar
        offsetX = 0
        offsetY = 0
        zoom    = 1
        zoomSlider.value = '100'
        filtroActual = 'normal'

        generarFiltrosThumbs()
        irAPaso(2)
        requestAnimationFrame(() => {
            inicializarEditor()
            dibujarEditor()
        })
      }
      img.onerror = () => alert('No se pudo cargar la imagen. Intenta con otro archivo.')
      img.src = e.target!.result as string
    }
    reader.readAsDataURL(file)
  }

  // ── Inicializar canvas del editor ─────────────────────────
  function inicializarEditor() {
    const wrap = document.getElementById('canvas-wrap')!
    const size = Math.min(wrap.clientWidth, 400)
    editorCanvas.width  = size
    editorCanvas.height = size
    editorCanvas.style.width  = `${size}px`
    editorCanvas.style.height = `${size}px`
  }

  // ── Dibujar en el canvas principal ────────────────────────
  function dibujarEditor() {
    if (!imagenOriginal) return
    const ctx = editorCanvas.getContext('2d')!
    const W   = editorCanvas.width
    const H   = editorCanvas.height

    ctx.clearRect(0, 0, W, H)

    // Aplicar filtro CSS al contexto
    const filtro = FILTROS.find(f => f.id === filtroActual)
    ctx.filter = filtro?.css === 'none' ? 'none' : (filtro?.css ?? 'none')

    // Calcular dimensiones con zoom
    const imgW = imagenOriginal.width
    const imgH = imagenOriginal.height
    const escala = Math.max(W / imgW, H / imgH) * (zoom)

    const dw = imgW * escala
    const dh = imgH * escala

    // Centrar + offset del drag
    const dx = (W - dw) / 2 + offsetX
    const dy = (H - dh) / 2 + offsetY

    ctx.drawImage(imagenOriginal, dx, dy, dw, dh)
    ctx.filter = 'none'

    // Actualizar previews en tiempo real
    actualizarPreviews()
  }

  // ── Previews circulares ───────────────────────────────────
  function actualizarPreviews() {
    dibujarPreviewCircular(previewLg, 120)
    dibujarPreviewCircular(previewSm, 48)
  }

  function dibujarPreviewCircular(canvas: HTMLCanvasElement, size: number) {
    const ctx = canvas.getContext('2d')!
    ctx.clearRect(0, 0, size, size)

    // Clip circular
    ctx.beginPath()
    ctx.arc(size/2, size/2, size/2, 0, Math.PI*2)
    ctx.clip()

    // Copiar desde el canvas principal con la misma proporción
    const editorSize = editorCanvas.width
    const radio      = editorSize * 0.45  // mismo 45% que el overlay SVG
    const cx         = editorSize / 2
    const cy         = editorSize / 2

    ctx.drawImage(
      editorCanvas,
      cx - radio, cy - radio, radio*2, radio*2,
      0, 0, size, size
    )
  }

  // ── Zoom ──────────────────────────────────────────────────
  zoomSlider.addEventListener('input', () => {
    zoom = parseInt(zoomSlider.value) / 100
    zoomValue.textContent = `${zoom.toFixed(1)}×`
    dibujarEditor()
  })

  // ── Drag para mover la imagen ─────────────────────────────
  // Mouse
  editorCanvas.addEventListener('mousedown', e => {
    dragging = true
    lastX = e.clientX
    lastY = e.clientY
    editorCanvas.style.cursor = 'grabbing'
  })
  window.addEventListener('mousemove', e => {
    if (!dragging) return
    offsetX += e.clientX - lastX
    offsetY += e.clientY - lastY
    lastX = e.clientX
    lastY = e.clientY
    dibujarEditor()
  })
  window.addEventListener('mouseup', () => {
    dragging = false
    editorCanvas.style.cursor = 'grab'
  })

  // Touch (mobile)
  editorCanvas.addEventListener('touchstart', e => {
    if (e.touches.length === 1) {
      dragging = true
      lastX = e.touches[0].clientX
      lastY = e.touches[0].clientY
    }
  }, { passive: true })
  editorCanvas.addEventListener('touchmove', e => {
    if (!dragging || e.touches.length !== 1) return
    offsetX += e.touches[0].clientX - lastX
    offsetY += e.touches[0].clientY - lastY
    lastX = e.touches[0].clientX
    lastY = e.touches[0].clientY
    dibujarEditor()
  }, { passive: true })
  editorCanvas.addEventListener('touchend', () => { dragging = false })

  // Pinch zoom (mobile)
  let lastPinchDist = 0
  editorCanvas.addEventListener('touchstart', e => {
    if (e.touches.length === 2) {
      lastPinchDist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      )
    }
  }, { passive: true })
  editorCanvas.addEventListener('touchmove', e => {
    if (e.touches.length !== 2) return
    const dist = Math.hypot(
      e.touches[0].clientX - e.touches[1].clientX,
      e.touches[0].clientY - e.touches[1].clientY
    )
    const delta = dist / lastPinchDist
    lastPinchDist = dist
    zoom = Math.max(0.5, Math.min(3, zoom * delta))
    zoomSlider.value = String(Math.round(zoom * 100))
    zoomValue.textContent = `${zoom.toFixed(1)}×`
    dibujarEditor()
  }, { passive: true })

  // Wheel zoom (desktop)
  editorCanvas.addEventListener('wheel', e => {
    e.preventDefault()
    zoom = Math.max(0.5, Math.min(3, zoom - e.deltaY * 0.001))
    zoomSlider.value = String(Math.round(zoom * 100))
    zoomValue.textContent = `${zoom.toFixed(1)}×`
    dibujarEditor()
  }, { passive: false })

  // ── Generar thumbnails de filtros ─────────────────────────
  function generarFiltrosThumbs() {
    filtrosGrid.innerHTML = ''

    FILTROS.forEach(filtro => {
      const btn  = document.createElement('button')
      btn.type   = 'button'
      btn.className = `filtro-btn ${filtro.id === filtroActual ? 'active' : ''}`
      btn.dataset.filtro = filtro.id

      // Canvas miniatura con el filtro aplicado
      const thumbCanvas      = document.createElement('canvas')
      thumbCanvas.width      = 44
      thumbCanvas.height     = 44
      thumbCanvas.className  = 'filtro-thumb'

      const tCtx = thumbCanvas.getContext('2d')!
      tCtx.filter = filtro.css === 'none' ? 'none' : filtro.css

      if (imagenOriginal) {
        // Encuadrar la imagen en el thumb
        const s = Math.min(imagenOriginal.width, imagenOriginal.height)
        const sx = (imagenOriginal.width  - s) / 2
        const sy = (imagenOriginal.height - s) / 2
        tCtx.beginPath()
        tCtx.arc(22, 22, 22, 0, Math.PI * 2)
        tCtx.clip()
        tCtx.drawImage(imagenOriginal, sx, sy, s, s, 0, 0, 44, 44)
      }
      tCtx.filter = 'none'

      const nombre   = document.createElement('span')
      nombre.className = 'filtro-nombre'
      nombre.textContent = filtro.nombre

      btn.appendChild(thumbCanvas)
      btn.appendChild(nombre)

      btn.addEventListener('click', () => {
        filtroActual = filtro.id
        document.querySelectorAll<HTMLElement>('.filtro-btn').forEach(b => b.classList.remove('active'))
        btn.classList.add('active')
        dibujarEditor()
      })

      filtrosGrid.appendChild(btn)
    })
  }

  // ── Botón Siguiente (paso 2 → 3) ─────────────────────────
  btnSiguiente.addEventListener('click', () => irAPaso(3))

  // ── Botón Volver ──────────────────────────────────────────
  btnVolver.addEventListener('click', () => irAPaso(pasoActual - 1))

  // ── Generar preview final y calcular tamaño optimizado ────
  function generarPreviewFinal() {
    dibujarPreviewCircular(previewFinal, 160)

    // Calcular tamaño optimizado generando el blob
    const outputCanvas       = document.createElement('canvas')
    outputCanvas.width       = 800
    outputCanvas.height      = 800
    const oCtx               = outputCanvas.getContext('2d')!

    // Aplicar filtro
    const filtro = FILTROS.find(f => f.id === filtroActual)
    oCtx.filter = filtro?.css === 'none' ? 'none' : (filtro?.css ?? 'none')

    // Renderizar la región circular del canvas editor en 800×800
    const editorSize = editorCanvas.width
    const radio      = editorSize * 0.45
    const cx         = editorSize / 2
    const cy         = editorSize / 2

    oCtx.drawImage(
      editorCanvas,
      cx - radio, cy - radio, radio*2, radio*2,
      0, 0, 800, 800
    )
    oCtx.filter = 'none'

    // Obtener tamaño estimado con calidad 85%
    outputCanvas.toBlob(blob => {
      if (!blob) return
      const pct = Math.round((1 - blob.size / imagenOriginalSize) * 100)
      infoOriginal.textContent   = formatBytes(imagenOriginalSize)
      infoOptimizado.textContent = formatBytes(blob.size)
      infoReduccion.textContent  = pct > 0 ? `-${pct}%` : 'Sin cambio'
    }, 'image/webp', 0.85)
  }

  // ── Confirmar foto ────────────────────────────────────────
  btnConfirmar.addEventListener('click', async () => {
    btnConfirmar.disabled = true
    btnConfirmar.innerHTML = '<span style="opacity:.6">Procesando…</span>'

    // Timeout de seguridad — si toBlob no responde en 8s, desbloquear
    const timeoutId = setTimeout(() => {
      btnConfirmar.disabled = false
      btnConfirmar.innerHTML = `<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Usar esta foto`
      ;(window as any).toast?.('Error al procesar. Intenta de nuevo.', 'error')
    }, 8000)

    // Canvas de salida 800×800
    const outputCanvas   = document.createElement('canvas')
    outputCanvas.width   = 800
    outputCanvas.height  = 800
    const oCtx           = outputCanvas.getContext('2d')!

    const filtro = FILTROS.find(f => f.id === filtroActual)
    oCtx.filter  = filtro?.css === 'none' ? 'none' : (filtro?.css ?? 'none')

    const editorSize = editorCanvas.width
    const radio      = editorSize * 0.45
    const cx         = editorSize / 2
    const cy         = editorSize / 2

    oCtx.drawImage(
      editorCanvas,
      cx - radio, cy - radio, radio * 2, radio * 2,
      0, 0, 800, 800
    )
    oCtx.filter = 'none'

    // Convertir a WebP 85%
    outputCanvas.toBlob(blob => {
      if (!blob) {
        alert('No se pudo procesar la imagen. Intenta de nuevo.')
        btnConfirmar.disabled = false
        btnConfirmar.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Usar esta foto'
        return
      }

      // Preview URL para mostrar en el dashboard inmediatamente
      const previewUrl = URL.createObjectURL(blob)

      // Disparar evento al padre — el padre (index.astro) sube el blob al bucket
      window.dispatchEvent(new CustomEvent('foto-confirmada', {
        detail: { blob, previewUrl }
      }))

      clearTimeout(timeoutId)
      cerrarModal()

      cerrarModal()
    }, 'image/webp', 0.85)
  })
</script>