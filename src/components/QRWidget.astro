---
// src/components/QRWidget.astro
// QR flotante para tarjetas públicas — funciona en todos los themes.

interface Props {
  url:      string
  fotoUrl?: string | null
}
const { url, fotoUrl } = Astro.props
const QR_COLOR = '#000000'   // negro — máximo contraste en cualquier luz
const ACCENT   = '#4B6CF7'   // azul CardVirtual para el FAB
---

<!-- CDN qrcode.js — ~42 KB, sin dependencias -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" is:inline></script>

<!-- FAB + Modal del QR -->
<div id="qr-root">

  <!-- ── FAB flotante ──────────────────────────────────────── -->
  <button id="qr-fab" aria-label="Mostrar QR" title="Mostrar código QR">
    <svg id="qr-fab-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3"  y="3"  width="7" height="7" rx="1"/>
      <rect x="14" y="3"  width="7" height="7" rx="1"/>
      <rect x="3"  y="14" width="7" height="7" rx="1"/>
      <path d="M14 14h2v2h-2zM18 14h3M14 18v3M18 18h3v3h-3z"/>
    </svg>
    <span id="qr-fab-label">QR</span>
  </button>

  <!-- ── Modal fullscreen ──────────────────────────────────── -->
  <div id="qr-modal" role="dialog" aria-modal="true" aria-label="Código QR">
    <div id="qr-backdrop"></div>

    <div id="qr-sheet">

      <!-- Handle para swipe down en mobile -->
      <div id="qr-handle"></div>

      <!-- Cabecera -->
      <div id="qr-header">
        <div id="qr-header-info">
          <div id="qr-header-title">Código QR</div>
          <div id="qr-header-url">{url}</div>
        </div>
        <button id="qr-close" aria-label="Cerrar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- QR canvas -->
      <div id="qr-canvas-wrap">
        <div id="qr-canvas"></div>
        <!-- Loader mientras genera -->
        <div id="qr-loader">
          <div id="qr-spinner"></div>
        </div>
      </div>

      <!-- Instrucción -->
      <p id="qr-hint">Apunta la cámara de tu móvil para abrir esta tarjeta</p>

      <!-- Acciones -->
      <div id="qr-actions">
        <button id="qr-btn-share" class="qr-btn qr-btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"/>
          </svg>
          Compartir
        </button>
        <button id="qr-btn-download" class="qr-btn qr-btn-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
          </svg>
          Descargar
        </button>
        <button id="qr-btn-copy" class="qr-btn qr-btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2"/>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
          </svg>
          Copiar enlace
        </button>
      </div>

      <!-- Brillo (solo Android/Chrome) -->
      <div id="qr-brightness-row">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <span>Pantalla activa para facilitar escaneo</span>
        <div id="qr-wakelock-dot"></div>
      </div>

      <!-- Toast interno -->
      <div id="qr-toast"></div>

    </div>
  </div>
</div>

<style define:vars={{ accent: ACCENT }}>
  /* ── FAB ─────────────────────────────────────────────────── */
  #qr-fab {
    position: fixed;
    bottom: 24px;
    right: 20px;
    z-index: 900;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 18px 12px 14px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 99px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 700;
    font-family: -apple-system, 'Segoe UI', sans-serif;
    box-shadow:
      0 4px 16px color-mix(in srgb, var(--accent) 50%, transparent),
      0 2px 6px rgba(0,0,0,.2);
    transition: transform .15s, box-shadow .15s, opacity .15s;
    letter-spacing: .01em;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
  }
  #qr-fab:hover {
    transform: translateY(-2px);
    box-shadow:
      0 8px 24px color-mix(in srgb, var(--accent) 55%, transparent),
      0 3px 8px rgba(0,0,0,.25);
  }
  #qr-fab:active { transform: scale(.96); }
  #qr-fab-label  { line-height: 1; }

  /* ── Modal / backdrop ───────────────────────────────────── */
  #qr-modal {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity .2s;
  }
  #qr-modal.open {
    opacity: 1;
    pointer-events: all;
  }
  #qr-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  /* ── Sheet (bottom sheet en mobile, centrado en desktop) ── */
  #qr-sheet {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 400px;
    background: #fff;
    border-radius: 24px 24px 0 0;
    padding: 0 0 env(safe-area-inset-bottom, 16px);
    transform: translateY(100%);
    transition: transform .35s cubic-bezier(.34,1.2,.64,1);
    overflow: hidden;
    box-shadow: 0 -8px 48px rgba(0,0,0,.2);
  }
  #qr-modal.open #qr-sheet {
    transform: translateY(0);
  }

  /* Handle */
  #qr-handle {
    width: 40px;
    height: 4px;
    background: #e2e8f0;
    border-radius: 99px;
    margin: 12px auto 0;
  }

  /* Header */
  #qr-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px 12px;
  }
  #qr-header-title {
    font-size: 16px;
    font-weight: 800;
    color: #0d1236;
    font-family: -apple-system, 'Segoe UI', sans-serif;
    letter-spacing: -.02em;
  }
  #qr-header-url {
    font-size: 11px;
    color: #7b84ad;
    margin-top: 2px;
    font-family: monospace;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 220px;
  }
  #qr-close {
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    background: #f1f5f9;
    border: none;
    cursor: pointer;
    color: #64748b;
    flex-shrink: 0;
    transition: background .15s;
    -webkit-tap-highlight-color: transparent;
  }
  #qr-close:hover { background: #e2e8f0; }

  /* Canvas wrap */
  #qr-canvas-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 24px 12px;
  }
  #qr-canvas {
    /* qrcode.js crea un canvas o img dentro */
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 0 0 8px #fff,
      0 0 0 10px color-mix(in srgb, var(--accent) 15%, transparent),
      0 8px 32px rgba(0,0,0,.1);
  }
  #qr-canvas canvas,
  #qr-canvas img {
    display: block;
    border-radius: 12px;
  }

  /* Loader */
  #qr-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,.8);
    border-radius: 16px;
    transition: opacity .2s;
  }
  #qr-loader.hidden { opacity: 0; pointer-events: none; }
  #qr-spinner {
    width: 28px; height: 28px;
    border: 3px solid #e2e8f0;
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: qr-spin .7s linear infinite;
  }
  @keyframes qr-spin { to { transform: rotate(360deg); } }

  /* Hint */
  #qr-hint {
    text-align: center;
    font-size: 12px;
    color: #94a3b8;
    padding: 0 24px 16px;
    font-family: -apple-system, 'Segoe UI', sans-serif;
    line-height: 1.5;
  }

  /* Acciones */
  #qr-actions {
    display: flex;
    gap: 8px;
    padding: 0 16px 12px;
    flex-wrap: wrap;
  }
  .qr-btn {
    flex: 1;
    min-width: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 11px 8px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 600;
    font-family: -apple-system, 'Segoe UI', sans-serif;
    border: none;
    cursor: pointer;
    transition: opacity .15s, transform .1s;
    -webkit-tap-highlight-color: transparent;
    white-space: nowrap;
  }
  .qr-btn:active { transform: scale(.97); }
  .qr-btn-primary {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .qr-btn-primary:hover { opacity: .9; }
  .qr-btn-secondary {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
  }
  .qr-btn-secondary:hover { background: color-mix(in srgb, var(--accent) 20%, transparent); }
  .qr-btn-ghost {
    background: #f1f5f9;
    color: #475569;
  }
  .qr-btn-ghost:hover { background: #e2e8f0; }

  /* Fila de brillo/wakeLock */
  #qr-brightness-row {
    display: none; /* se muestra via JS si wakeLock disponible */
    align-items: center;
    gap: 6px;
    padding: 8px 20px 14px;
    font-size: 11px;
    color: #94a3b8;
    font-family: -apple-system, 'Segoe UI', sans-serif;
  }
  #qr-brightness-row.visible { display: flex; }
  #qr-wakelock-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #94a3b8;
    flex-shrink: 0;
    margin-left: auto;
  }
  #qr-wakelock-dot.active {
    background: #10b981;
    box-shadow: 0 0 5px #10b981;
  }

  /* Toast */
  #qr-toast {
    position: absolute;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: #0d1236;
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    font-family: -apple-system, 'Segoe UI', sans-serif;
    padding: 8px 16px;
    border-radius: 99px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity .2s, transform .2s;
    z-index: 10;
  }
  #qr-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Desktop: centrado, no bottom sheet ─────────────────── */
  @media (min-width: 480px) {
    #qr-modal { align-items: center; }
    #qr-sheet {
      border-radius: 24px;
      max-width: 360px;
      transform: scale(.92);
      transition: transform .25s cubic-bezier(.34,1.2,.64,1), opacity .2s;
    }
    #qr-modal.open #qr-sheet { transform: scale(1); }
    #qr-handle { display: none; }
    #qr-fab { bottom: 28px; right: 28px; }
  }
</style>

<script define:vars={{ url, fotoUrl, QR_COLOR, ACCENT }}>
  // ── Estado ─────────────────────────────────────────────────
  let qrGenerado    = false
  let wakeLock      = null
  let touchStartY   = 0

  const modal        = document.getElementById('qr-modal')
  const fab          = document.getElementById('qr-fab')
  const backdrop     = document.getElementById('qr-backdrop')
  const closeBtn     = document.getElementById('qr-close')
  const sheet        = document.getElementById('qr-sheet')
  const canvasWrap   = document.getElementById('qr-canvas')
  const loader       = document.getElementById('qr-loader')
  const btnShare     = document.getElementById('qr-btn-share')
  const btnDownload  = document.getElementById('qr-btn-download')
  const btnCopy      = document.getElementById('qr-btn-copy')
  const brightnessRow= document.getElementById('qr-brightness-row')
  const wakeDot      = document.getElementById('qr-wakelock-dot')
  const toastEl      = document.getElementById('qr-toast')

  // ── Toast interno ────────────────────────────────────────────
  function showToast(msg) {
    toastEl.textContent = msg
    toastEl.classList.add('show')
    setTimeout(() => toastEl.classList.remove('show'), 2000)
  }

  // ── Superponer foto centrada en el QR ───────────────────────
  function superponerLogo(canvasEl, size) {
    if (!fotoUrl) return
    setTimeout(() => {
      const qrCanvas = canvasEl.querySelector('canvas')
      if (!qrCanvas) return
      const ctx      = qrCanvas.getContext('2d')
      const logoSize = Math.round(size * 0.22)
      const logoX    = (size - logoSize) / 2
      const logoY    = (size - logoSize) / 2
      const radius   = logoSize / 2
      const img      = new Image()
      img.crossOrigin = 'anonymous'
      img.onload = () => {
        ctx.beginPath()
        ctx.arc(logoX + radius, logoY + radius, radius + 4, 0, Math.PI * 2)
        ctx.fillStyle = '#ffffff'
        ctx.fill()
        ctx.save()
        ctx.beginPath()
        ctx.arc(logoX + radius, logoY + radius, radius, 0, Math.PI * 2)
        ctx.clip()
        ctx.drawImage(img, logoX, logoY, logoSize, logoSize)
        ctx.restore()
      }
      img.onerror = () => {
        ctx.beginPath()
        ctx.arc(logoX + radius, logoY + radius, radius + 4, 0, Math.PI * 2)
        ctx.fillStyle = '#ffffff'
        ctx.fill()
        ctx.beginPath()
        ctx.arc(logoX + radius, logoY + radius, radius, 0, Math.PI * 2)
        ctx.fillStyle = ACCENT
        ctx.fill()
      }
      img.src = fotoUrl
    }, 120)
  }

  // ── Generar QR (solo la primera vez) ────────────────────────
  function generarQR() {
    if (qrGenerado) return
    qrGenerado = true

    new QRCode(canvasWrap, {
      text:         url,
      width:        240,
      height:       240,
      colorDark:    QR_COLOR,   // negro — máximo contraste
      colorLight:   '#ffffff',
      correctLevel: QRCode.CorrectLevel.H,
    })

    requestAnimationFrame(() => {
      loader.classList.add('hidden')
      superponerLogo(canvasWrap, 240)
    })
  }

  // ── WakeLock — mantiene pantalla activa (Android/Chrome) ────
  async function pedirWakeLock() {
    if (!('wakeLock' in navigator)) return
    try {
      wakeLock = await navigator.wakeLock.request('screen')
      brightnessRow.classList.add('visible')
      wakeDot.classList.add('active')
      wakeLock.addEventListener('release', () => {
        wakeDot.classList.remove('active')
      })
    } catch (e) {
      // Silencioso — el navegador puede denegar en batería baja
    }
  }

  async function liberarWakeLock() {
    if (wakeLock) {
      await wakeLock.release()
      wakeLock = null
    }
    wakeDot.classList.remove('active')
  }

  // ── Abrir modal ─────────────────────────────────────────────
  function abrirQR() {
    modal.classList.add('open')
    document.body.style.overflow = 'hidden'
    generarQR()
    pedirWakeLock()
    // Foco accesible
    setTimeout(() => closeBtn.focus(), 300)
  }

  // ── Cerrar modal ─────────────────────────────────────────────
  function cerrarQR() {
    modal.classList.remove('open')
    document.body.style.overflow = ''
    liberarWakeLock()
  }

  // ── Compartir ────────────────────────────────────────────────
  async function compartir() {
    if (navigator.share) {
      try {
        await navigator.share({
          title: document.title,
          text:  'Mira mi tarjeta digital',
          url:   url,
        })
        return
      } catch (e) {
        if (e.name === 'AbortError') return // usuario canceló
      }
    }
    // Fallback: copiar URL
    await copiarEnlace()
  }

  // ── Copiar enlace ────────────────────────────────────────────
  async function copiarEnlace() {
    try {
      await navigator.clipboard.writeText(url)
      showToast('✓ Enlace copiado')
    } catch {
      // Fallback para navegadores sin clipboard API
      const el = document.createElement('textarea')
      el.value = url
      el.style.cssText = 'position:fixed;opacity:0'
      document.body.appendChild(el)
      el.select()
      document.execCommand('copy')
      document.body.removeChild(el)
      showToast('✓ Enlace copiado')
    }
  }

  // ── Descargar QR como PNG ────────────────────────────────────
  function descargarQR() {
    // qrcode.js genera un <canvas> o un <img>
    const canvas  = canvasWrap.querySelector('canvas')
    const imgEl   = canvasWrap.querySelector('img')

    if (canvas) {
      const link    = document.createElement('a')
      link.download = 'mi-qr-cardvirtual.png'
      link.href     = canvas.toDataURL('image/png')
      link.click()
      showToast('✓ QR descargado')
      return
    }

    if (imgEl) {
      // Si qrcode.js generó <img> (algunos navegadores) → convertir via canvas
      const c   = document.createElement('canvas')
      c.width   = imgEl.naturalWidth  || 240
      c.height  = imgEl.naturalHeight || 240
      const ctx = c.getContext('2d')
      ctx.drawImage(imgEl, 0, 0)
      const link    = document.createElement('a')
      link.download = 'mi-qr-cardvirtual.png'
      link.href     = c.toDataURL('image/png')
      link.click()
      showToast('✓ QR descargado')
    }
  }

  // ── Swipe down para cerrar (mobile) ─────────────────────────
  sheet.addEventListener('touchstart', e => {
    touchStartY = e.touches[0].clientY
  }, { passive: true })

  sheet.addEventListener('touchend', e => {
    const delta = e.changedTouches[0].clientY - touchStartY
    if (delta > 72) cerrarQR()
  }, { passive: true })

  // ── Eventos ──────────────────────────────────────────────────
  fab.addEventListener('click',        abrirQR)
  closeBtn.addEventListener('click',   cerrarQR)
  backdrop.addEventListener('click',   cerrarQR)
  btnShare.addEventListener('click',   compartir)
  btnDownload.addEventListener('click',descargarQR)
  btnCopy.addEventListener('click',    copiarEnlace)

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && modal.classList.contains('open')) cerrarQR()
  })

  // Re-solicitar wakeLock si la página vuelve a primer plano
  document.addEventListener('visibilitychange', async () => {
    if (document.visibilityState === 'visible' && modal.classList.contains('open') && !wakeLock) {
      await pedirWakeLock()
    }
  })
</script>