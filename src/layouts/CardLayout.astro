---
// src/layouts/CardLayout.astro
import QRWidget      from '../components/QRWidget.astro'
import InstallBanner from '../components/InstallBanner.astro'

interface Props {
  title:        string
  description?: string
  ogImage?:     string
  bgColor?:     string
  cardUrl?:     string
  fotoUrl?:     string | null
  slug?:        string | null
  nombre?:      string | null
  tituloProf?:  string | null
  accentColor?: string | null
}

const {
  title,
  description = 'Tarjeta digital profesional',
  ogImage,
  bgColor     = '#ffffff',
  cardUrl,
  fotoUrl,
  slug,
  nombre,
  tituloProf,
  accentColor,
} = Astro.props

const qrUrl       = cardUrl ?? Astro.url.href
const manifestUrl = slug ? `/${slug}/manifest.json` : null
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:type" content="profile" />
  <meta name="mobile-web-app-capable"       content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title"   content={nombre ?? title} />
  {accentColor && <meta name="theme-color" content={accentColor} />}
  {manifestUrl && <link rel="manifest" href={manifestUrl} />}
  {fotoUrl
    ? <link rel="apple-touch-icon" href={fotoUrl} />
    : <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  }
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  </style>
  <slot name="head" />
</head>
<body style={`background:${bgColor}`}>
  <slot />
  <QRWidget url={qrUrl} fotoUrl={fotoUrl} />
  {slug && nombre && (
    <InstallBanner
      slug={slug}
      nombre={nombre}
      titulo={tituloProf}
      fotoUrl={fotoUrl}
      accent={accentColor ?? '#4B6CF7'}
    />
  )}
</body>
{slug && (
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker
          .register('/sw.js', { scope: '/' })
          .catch(() => {})
      })
    }
  </script>
)}
</html>