---
// src/layouts/AdminLayout.astro

interface Props {
  title:     string
  tabActivo: 'overview' | 'usuarios' | 'planes' | 'analytics'
  user: {
    email: string
    id:    string
  }
}

const { title, tabActivo, user } = Astro.props

// Navegación del admin — completamente independiente del dashboard
const NAV = [
  {
    id:    'overview',
    label: 'Overview',
    href:  '/admin',
    icon:  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>`,
  },
  {
    id:    'usuarios',
    label: 'Usuarios',
    href:  '/admin/usuarios',
    icon:  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>`,
  },
  {
    id:    'planes',
    label: 'Planes',
    href:  '/admin/planes',
    icon:  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 6h.008v.008H6V6z"/>`,
  },
  {
    id:    'analytics',
    label: 'Analytics',
    href:  '/admin/analytics',
    icon:  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>`,
  },
]
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Credenciales Supabase para el cliente browser -->
    <meta name="supabase-url"  content={import.meta.env.PUBLIC_SUPABASE_URL} />
    <meta name="supabase-anon" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY} />
    <title>{title} — Admin · Tarjeta Digital</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* ── Tokens compartidos con DashboardLayout ─────────────── */
      :root {
        --bg:        #0d0d0f;
        --bg-2:      #141416;
        --bg-3:      #1c1c1f;
        --bg-4:      #242428;
        --border:    #2a2a2e;
        --border-2:  #3a3a3f;
        --text-1:    #f4f4f5;
        --text-2:    #a1a1aa;
        --text-3:    #71717a;

        /* Acento del dashboard — índigo */
        --accent:    #6366f1;
        --accent-2:  #818cf8;
        --accent-bg: rgba(99,102,241,.12);

        /* ── Acento exclusivo del admin — rojo/ámbar ─────────── */
        /* Señal visual clara: estás en zona de superusuario       */
        --admin:        #ef4444;
        --admin-2:      #f87171;
        --admin-bg:     rgba(239,68,68,.1);
        --admin-border: rgba(239,68,68,.25);

        --success:   #22c55e;
        --warn:      #f59e0b;
        --danger:    #ef4444;
        --radius:    10px;
        --radius-lg: 16px;
        --font:      'Geist', sans-serif;
        --font-mono: 'Geist Mono', monospace;
        --nav-w:     220px;
        --header-h:  56px;
        --transition: 150ms cubic-bezier(.4,0,.2,1);
      }

      html, body { height: 100%; }

      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text-1);
        font-size: 14px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 99px; }

      :focus-visible {
        outline: 2px solid var(--admin);
        outline-offset: 2px;
        border-radius: 6px;
      }

      input, textarea, select {
        font-family: var(--font);
        font-size: 14px;
        background: var(--bg-3);
        color: var(--text-1);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 9px 12px;
        width: 100%;
        transition: border-color var(--transition), box-shadow var(--transition);
        outline: none;
      }
      input:hover, textarea:hover, select:hover { border-color: var(--border-2); }
      input:focus, textarea:focus, select:focus {
        border-color: var(--admin);
        box-shadow: 0 0 0 3px var(--admin-bg);
      }
      input::placeholder, textarea::placeholder { color: var(--text-3); }

      label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-2);
        margin-bottom: 6px;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: var(--radius);
        font-size: 13px;
        font-weight: 500;
        font-family: var(--font);
        cursor: pointer;
        transition: all var(--transition);
        border: none;
        white-space: nowrap;
        text-decoration: none;
      }
      /* Botón primario en admin usa el acento admin (rojo) */
      .btn-primary {
        background: var(--admin);
        color: #fff;
      }
      .btn-primary:hover { background: var(--admin-2); transform: translateY(-1px); }
      .btn-primary:active { transform: translateY(0); }
      .btn-ghost {
        background: transparent;
        color: var(--text-2);
        border: 1px solid var(--border);
      }
      .btn-ghost:hover { background: var(--bg-3); color: var(--text-1); }
      .btn-accent {
        background: var(--accent);
        color: #fff;
      }
      .btn-accent:hover { background: var(--accent-2); transform: translateY(-1px); }
      .btn-danger {
        background: rgba(239,68,68,.12);
        color: var(--danger);
        border: 1px solid rgba(239,68,68,.2);
      }
      .btn-danger:hover { background: rgba(239,68,68,.2); }
      .btn-success {
        background: rgba(34,197,94,.12);
        color: var(--success);
        border: 1px solid rgba(34,197,94,.2);
      }
      .btn-success:hover { background: rgba(34,197,94,.2); }
      .btn:disabled { opacity: .45; cursor: not-allowed; transform: none !important; }

      .badge {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: 99px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .03em;
      }
      .badge-admin   { background: var(--admin-bg); color: var(--admin-2); border: 1px solid var(--admin-border); }
      .badge-free    { background: var(--bg-4); color: var(--text-3); }
      .badge-premium { background: linear-gradient(135deg,#f59e0b,#f97316); color: #fff; }
      .badge-success { background: rgba(34,197,94,.12); color: var(--success); }
      .badge-warn    { background: rgba(245,158,11,.12); color: var(--warn); }
      .badge-danger  { background: rgba(239,68,68,.12); color: var(--danger); }

      .card {
        background: var(--bg-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px;
      }

      /* Stat card para el overview */
      .stat-card {
        background: var(--bg-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        transition: border-color var(--transition);
      }
      .stat-card:hover { border-color: var(--border-2); }
      .stat-label {
        font-size: 12px;
        font-weight: 500;
        color: var(--text-3);
        text-transform: uppercase;
        letter-spacing: .06em;
      }
      .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-1);
        line-height: 1;
        font-variant-numeric: tabular-nums;
      }
      .stat-delta {
        font-size: 12px;
        color: var(--text-3);
        display: flex;
        align-items: center;
        gap: 4px;
      }
      .stat-delta.up   { color: var(--success); }
      .stat-delta.down { color: var(--danger); }

      /* Tabla admin */
      .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }
      .admin-table th {
        text-align: left;
        padding: 10px 14px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--text-3);
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }
      .admin-table td {
        padding: 12px 14px;
        border-bottom: 1px solid var(--border);
        color: var(--text-2);
        vertical-align: middle;
      }
      .admin-table tr:last-child td { border-bottom: none; }
      .admin-table tbody tr {
        transition: background var(--transition);
        cursor: default;
      }
      .admin-table tbody tr:hover { background: var(--bg-3); }

      /* Toast */
      #toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 8px;
        pointer-events: none;
      }
      .toast-item {
        background: var(--bg-3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 10px 16px;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 8px 32px rgba(0,0,0,.4);
        animation: slideIn .2s ease;
        pointer-events: all;
        max-width: 320px;
      }
      .toast-item.success { border-left: 3px solid var(--success); }
      .toast-item.error   { border-left: 3px solid var(--danger); }
      .toast-item.warn    { border-left: 3px solid var(--warn); }
      @keyframes slideIn {
        from { opacity: 0; transform: translateX(16px); }
        to   { opacity: 1; transform: translateX(0); }
      }

      /* Modal */
      .modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.65);
        backdrop-filter: blur(4px);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        opacity: 0;
        pointer-events: none;
        transition: opacity .2s;
      }
      .modal-backdrop.open { opacity: 1; pointer-events: all; }
      .modal {
        background: var(--bg-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 24px;
        width: 100%;
        max-width: 520px;
        max-height: 90vh;
        overflow-y: auto;
        transform: scale(.96);
        transition: transform .2s;
      }
      .modal-backdrop.open .modal { transform: scale(1); }
      .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
      }
      .modal-title { font-size: 16px; font-weight: 700; }
      .modal-close {
        width: 28px; height: 28px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 6px; border: none;
        background: var(--bg-3); color: var(--text-2);
        cursor: pointer; font-size: 16px;
        transition: all var(--transition);
      }
      .modal-close:hover { background: var(--bg-4); color: var(--text-1); }

      /* Form helpers */
      .form-grid   { display: grid; gap: 16px; }
      .form-grid-2 { grid-template-columns: 1fr 1fr; }
      .form-group  { display: flex; flex-direction: column; }
      .form-hint   { font-size: 12px; color: var(--text-3); margin-top: 4px; }
      .section-card {
        background: var(--bg-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 24px;
        margin-bottom: 16px;
      }
      .section-card-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-1);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      /* ── Layout shell — idéntico al DashboardLayout ──────────── */
      .dash-shell {
        display: grid;
        grid-template-rows: var(--header-h) 1fr;
        grid-template-columns: var(--nav-w) 1fr;
        grid-template-areas:
          "header header"
          "nav    main";
        min-height: 100vh;
      }

      /* Header — con banda admin roja en la parte inferior */
      .dash-header {
        grid-area: header;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        background: var(--bg-2);
        border-bottom: 1px solid var(--admin-border);
        /* Línea inferior roja que señala visualmente la zona admin */
        box-shadow: 0 1px 0 var(--admin-border);
        position: sticky;
        top: 0;
        z-index: 100;
        gap: 16px;
      }
      .dash-logo {
        font-size: 15px;
        font-weight: 700;
        color: var(--text-1);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
      }
      /* Punto del logo en rojo para el admin */
      .dash-logo-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: var(--admin);
        box-shadow: 0 0 8px var(--admin);
      }
      .dash-header-right {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-left: auto;
      }
      .dash-user-chip {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--bg-3);
        border: 1px solid var(--border);
        border-radius: 99px;
        padding: 4px 12px 4px 4px;
        font-size: 13px;
        color: var(--text-2);
      }
      /* Avatar con color admin */
      .dash-avatar {
        width: 26px; height: 26px;
        border-radius: 50%;
        background: var(--admin-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: var(--admin-2);
        flex-shrink: 0;
      }

      /* Nav lateral — sidebar con acento admin */
      .dash-nav {
        grid-area: nav;
        background: var(--bg-2);
        /* Borde derecho del sidebar en rojo sutil */
        border-right: 1px solid var(--admin-border);
        padding: 12px 8px;
        overflow-y: auto;
        position: sticky;
        top: var(--header-h);
        height: calc(100vh - var(--header-h));
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .nav-section-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--text-3);
        padding: 8px 10px 4px;
        margin-top: 8px;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 8px;
        color: var(--text-2);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: all var(--transition);
        cursor: pointer;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
      }
      .nav-item svg { flex-shrink: 0; opacity: .7; }
      .nav-item:hover { background: var(--bg-3); color: var(--text-1); }
      .nav-item:hover svg { opacity: 1; }
      /* Item activo usa acento admin */
      .nav-item.active {
        background: var(--admin-bg);
        color: var(--admin-2);
      }
      .nav-item.active svg { opacity: 1; }

      /* Separador de "volver al dashboard" en el nav */
      .nav-divider {
        border: none;
        border-top: 1px solid var(--border);
        margin: 8px 0;
      }

      /* Main content */
      .dash-main {
        grid-area: main;
        padding: 28px 32px;
        overflow-y: auto;
        /* Sin max-width en admin — las tablas necesitan más espacio */
      }

      .page-header { margin-bottom: 24px; }
      .page-title  { font-size: 22px; font-weight: 700; color: var(--text-1); line-height: 1.2; }
      .page-desc   { font-size: 13px; color: var(--text-3); margin-top: 4px; }

      /* Responsive */
      @media (max-width: 768px) {
        :root { --nav-w: 0px; }
        .dash-shell {
          grid-template-columns: 1fr;
          grid-template-areas: "header" "main";
        }
        .dash-nav {
          display: none;
          position: fixed;
          left: 0; top: var(--header-h);
          width: 240px;
          height: calc(100vh - var(--header-h));
          z-index: 200;
          box-shadow: 4px 0 32px rgba(0,0,0,.4);
        }
        .dash-nav.mobile-open { display: flex; }
        .dash-main { padding: 16px; }
        .form-grid-2 { grid-template-columns: 1fr; }
        .admin-table { display: block; overflow-x: auto; }
      }
    </style>
  </head>
  <body>
    <div class="dash-shell">

      <!-- ── HEADER ─────────────────────────────────────────────── -->
      <header class="dash-header">
        <!-- Botón hamburguesa mobile -->
        <button
          id="mobile-menu-btn"
          style="width:36px;padding:6px;display:none;align-items:center;justify-content:center;border:none;background:transparent;color:var(--text-2);cursor:pointer;border-radius:8px"
          aria-label="Menú"
        >
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Logo con punto rojo -->
        <a href="/admin" class="dash-logo">
          <span class="dash-logo-dot"></span>
          TarjetaDigital
        </a>

        <!-- Badge SUPER ADMIN — señal visual de zona restringida -->
        <span class="badge badge-admin" style="font-size:10px;letter-spacing:.08em">
          ⚙ SUPER ADMIN
        </span>

        <div class="dash-header-right">
          <!-- Atajo para volver al dashboard propio -->
          <a href="/dashboard" class="btn btn-ghost" style="font-size:12px;padding:5px 12px">
            ← Mi dashboard
          </a>

          <!-- Chip de usuario -->
          <div class="dash-user-chip">
            <div class="dash-avatar" id="user-avatar">?</div>
            <span
              id="user-email-short"
              style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:13px"
            >
              {user.email}
            </span>
          </div>

          <!-- Logout -->
          <button class="btn btn-danger" id="btn-logout" style="padding:5px 12px;font-size:12px">
            Salir
          </button>
        </div>
      </header>

      <!-- ── NAV LATERAL ────────────────────────────────────────── -->
      <nav class="dash-nav" id="dash-nav" role="navigation" aria-label="Panel de administración">

        <span class="nav-section-label">Administración</span>

        {NAV.map(item => (
          <a
            href={item.href}
            class={`nav-item ${tabActivo === item.id ? 'active' : ''}`}
            data-tab={item.id}
          >
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon} />
            {item.label}
          </a>
        ))}

        <!-- Separador y link de vuelta al dashboard de usuario -->
        <hr class="nav-divider" style="margin-top:auto" />
        <a href="/dashboard" class="nav-item" style="color:var(--text-3)">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"/>
          </svg>
          Volver al dashboard
        </a>

      </nav>

      <!-- ── CONTENIDO PRINCIPAL ────────────────────────────────── -->
      <main class="dash-main" id="dash-main" role="main">
        <slot />
      </main>

    </div>

    <!-- Toast container -->
    <div id="toast" aria-live="polite"></div>

    <!-- Overlay mobile -->
    <div
      id="mobile-overlay"
      style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:199"
      onclick="closeMobileNav()"
    ></div>

    <script>
      import { createBrowserClient } from '@supabase/ssr'

      // ── Logout ────────────────────────────────────────────────
      document.getElementById('btn-logout')?.addEventListener('click', async function() {
        const btn = this as HTMLButtonElement
        btn.textContent = 'Saliendo...'
        btn.disabled = true

        const sb = createBrowserClient(
          document.querySelector<HTMLMetaElement>('meta[name="supabase-url"]')!.content,
          document.querySelector<HTMLMetaElement>('meta[name="supabase-anon"]')!.content,
        )
        await sb.auth.signOut()
        window.location.href = '/auth/login'
      })

      // ── Avatar con inicial del email ──────────────────────────
      const emailEl  = document.getElementById('user-email-short')
      const avatarEl = document.getElementById('user-avatar')
      if (emailEl && avatarEl) {
        avatarEl.textContent = (emailEl.textContent?.trim() ?? '?')[0].toUpperCase()
      }

      // ── Mobile nav ────────────────────────────────────────────
      const mobileBtn = document.getElementById('mobile-menu-btn')  as HTMLButtonElement
      const dashNav   = document.getElementById('dash-nav')         as HTMLElement
      const overlay   = document.getElementById('mobile-overlay')   as HTMLElement

      function syncMobileBtn() {
        mobileBtn.style.display = window.innerWidth <= 768 ? 'flex' : 'none'
      }
      syncMobileBtn()
      window.addEventListener('resize', syncMobileBtn)

      mobileBtn.addEventListener('click', () => {
        const open = dashNav.classList.toggle('mobile-open')
        overlay.style.display = open ? 'block' : 'none'
      })

      ;(window as any).closeMobileNav = () => {
        dashNav.classList.remove('mobile-open')
        overlay.style.display = 'none'
      }

      // ── Keyboard nav (Alt+1…4 para las 4 secciones admin) ────
      const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-item[data-tab]')
      document.addEventListener('keydown', (e) => {
        if (e.altKey && !e.shiftKey && !e.ctrlKey && !e.metaKey) {
          const n = parseInt(e.key)
          if (n >= 1 && n <= navLinks.length) {
            e.preventDefault()
            navLinks[n - 1].click()
          }
        }
        if (e.key === 'Escape') {
          document.querySelectorAll('.modal-backdrop.open').forEach(m =>
            m.classList.remove('open')
          )
        }
      })

      // ── Toast global ──────────────────────────────────────────
      ;(window as any).toast = (
        msg: string,
        type: 'success' | 'error' | 'warn' = 'success'
      ) => {
        const container = document.getElementById('toast')!
        const el = document.createElement('div')
        el.className = `toast-item ${type}`
        const icons = { success: '✓', error: '✕', warn: '⚠' }
        el.innerHTML = `<span style="font-weight:700">${icons[type]}</span> ${msg}`
        container.appendChild(el)
        setTimeout(() => {
          el.style.cssText += 'opacity:0;transform:translateX(16px);transition:.3s'
          setTimeout(() => el.remove(), 300)
        }, 3500)
      }
    </script>
  </body>
</html>