---
// src/layouts/AdminLayout.astro
import '../styles/global.css'

interface Props {
  title:     string
  tabActivo: 'overview' | 'usuarios' | 'planes' | 'analytics' | 'crear-usuario'
  user: { email: string; id: string }
}

const { title, tabActivo, user } = Astro.props

const NAV = [
  {
    id: 'overview', label: 'Overview', href: '/admin',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>`,
  },
  {
    id: 'usuarios', label: 'Usuarios', href: '/admin/usuarios',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>`,
  },
  {
    id: 'planes', label: 'Planes', href: '/admin/planes',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 6h.008v.008H6V6z"/>`,
  },
  {
    id: 'analytics', label: 'Analytics', href: '/admin/analytics',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>`,
  },
]
---

<!doctype html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="supabase-url"  content={import.meta.env.PUBLIC_SUPABASE_URL} />
  <meta name="supabase-anon" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY} />
  <title>{title} — Admin · CardVirtual</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style is:global>
    /* Inputs */
    input, textarea, select {
      font-family: var(--font);
      font-size: 14px;
      background: var(--bg-2);
      color: var(--text-1);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 9px 12px;
      width: 100%;
      transition: border-color var(--transition), box-shadow var(--transition);
      outline: none;
    }
    input:hover, textarea:hover, select:hover { border-color: var(--border-2); }
    input:focus, textarea:focus, select:focus {
      border-color: var(--admin);
      box-shadow: 0 0 0 3px var(--admin-bg);
    }
    input::placeholder, textarea::placeholder { color: var(--text-3); }
    label { display: block; font-size: 13px; font-weight: 500; color: var(--text-2); margin-bottom: 6px; }

    /* Botones */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 16px; border-radius: var(--radius);
      font-size: 13px; font-weight: 500; font-family: var(--font);
      cursor: pointer; transition: all var(--transition);
      border: none; white-space: nowrap; text-decoration: none;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--cyan));
      color: #fff;
      box-shadow: 0 2px 8px var(--accent-bg);
    }
    .btn-primary:hover { opacity: .9; transform: translateY(-1px); }
    .btn-primary:active { transform: translateY(0); }
    .btn-ghost { background: transparent; color: var(--text-2); border: 1px solid var(--border); }
    .btn-ghost:hover { background: var(--bg-3); color: var(--text-1); }
    .btn-accent { background: var(--accent); color: #fff; }
    .btn-accent:hover { background: var(--accent-2); transform: translateY(-1px); }
    .btn-danger { background: rgba(239,68,68,.08); color: var(--danger); border: 1px solid rgba(239,68,68,.2); }
    .btn-danger:hover { background: rgba(239,68,68,.15); }
    .btn-success { background: rgba(16,185,129,.08); color: var(--success); border: 1px solid rgba(16,185,129,.2); }
    .btn-success:hover { background: rgba(16,185,129,.15); }
    .btn:disabled { opacity: .45; cursor: not-allowed; transform: none !important; }

    /* Badges */
    .badge {
      display: inline-flex; align-items: center;
      padding: 2px 8px; border-radius: 99px;
      font-size: 11px; font-weight: 600; letter-spacing: .03em;
    }
    .badge-admin   { background: var(--admin-bg); color: var(--admin-2); border: 1px solid var(--admin-border); }
    .badge-free    { background: var(--bg-4); color: var(--text-3); border: 1px solid var(--border); }
    .badge-premium { background: linear-gradient(135deg,#f59e0b,#f97316); color: #fff; }
    .badge-success { background: rgba(16,185,129,.1); color: var(--success); }
    .badge-warn    { background: rgba(245,158,11,.1); color: var(--warn); }
    .badge-danger  { background: rgba(239,68,68,.1); color: var(--danger); }

    /* Cards */
    .card { background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px; }

    .stat-card {
      background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 20px 24px;
      display: flex; flex-direction: column; gap: 8px;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .stat-card:hover { border-color: var(--accent-border); box-shadow: 0 2px 8px var(--accent-bg); }
    .stat-label { font-size: 12px; font-weight: 500; color: var(--text-3); text-transform: uppercase; letter-spacing: .06em; }
    .stat-value { font-size: 28px; font-weight: 700; color: var(--text-1); line-height: 1; font-variant-numeric: tabular-nums; }
    .stat-delta { font-size: 12px; color: var(--text-3); display: flex; align-items: center; gap: 4px; }
    .stat-delta.up   { color: var(--success); }
    .stat-delta.down { color: var(--danger); }

    /* Tabla */
    .admin-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .admin-table th {
      text-align: left; padding: 10px 14px;
      font-size: 11px; font-weight: 600; text-transform: uppercase;
      letter-spacing: .06em; color: var(--text-3);
      border-bottom: 1px solid var(--border); white-space: nowrap;
    }
    .admin-table td { padding: 12px 14px; border-bottom: 1px solid var(--border); color: var(--text-2); vertical-align: middle; }
    .admin-table tr:last-child td { border-bottom: none; }
    .admin-table tbody tr { transition: background var(--transition); }
    .admin-table tbody tr:hover { background: var(--bg-3); }

    /* Toast */
    #toast { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
    .toast-item {
      background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 10px 16px;
      font-size: 13px; color: var(--text-1);
      display: flex; align-items: center; gap: 8px;
      box-shadow: 0 4px 20px rgba(75,108,247,.1);
      animation: slideIn .2s ease; pointer-events: all; max-width: 320px;
    }
    .toast-item.success { border-left: 3px solid var(--success); }
    .toast-item.error   { border-left: 3px solid var(--danger); }
    .toast-item.warn    { border-left: 3px solid var(--warn); }
    @keyframes slideIn { from { opacity:0;transform:translateX(16px); } to { opacity:1;transform:translateX(0); } }

    /* Modal */
    .modal-backdrop {
      position: fixed; inset: 0;
      background: rgba(13,18,54,.4); backdrop-filter: blur(4px);
      z-index: 1000; display: flex; align-items: center; justify-content: center;
      padding: 16px; opacity: 0; pointer-events: none; transition: opacity .2s;
    }
    .modal-backdrop.open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 24px;
      width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto;
      transform: scale(.96); transition: transform .2s;
      box-shadow: 0 20px 60px rgba(75,108,247,.12);
    }
    .modal-backdrop.open .modal { transform: scale(1); }
    .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .modal-title { font-size: 16px; font-weight: 700; color: var(--text-1); }
    .modal-close {
      width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
      border-radius: 6px; border: none; background: var(--bg-3); color: var(--text-2);
      cursor: pointer; font-size: 16px; transition: all var(--transition);
    }
    .modal-close:hover { background: var(--bg-4); color: var(--text-1); }

    /* Form helpers */
    .form-grid   { display: grid; gap: 16px; }
    .form-grid-2 { grid-template-columns: 1fr 1fr; }
    .form-group  { display: flex; flex-direction: column; }
    .form-hint   { font-size: 12px; color: var(--text-3); margin-top: 4px; }
    .section-card { background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; margin-bottom: 16px; }
    .section-card-title { font-size: 15px; font-weight: 600; color: var(--text-1); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }

    /* Layout */
    .dash-shell {
      display: grid;
      grid-template-rows: var(--header-h) 1fr;
      grid-template-columns: var(--nav-w) 1fr;
      grid-template-areas: "header header" "nav main";
      min-height: 100vh;
    }

    /* Header con borde cian sutil */
    .dash-header {
      grid-area: header;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 20px;
      background: var(--bg-2);
      border-bottom: 2px solid var(--admin);
      position: sticky; top: 0; z-index: 100; gap: 16px;
      box-shadow: 0 2px 16px var(--admin-bg);
    }
    .dash-logo {
      font-size: 15px; font-weight: 700; color: var(--text-1);
      text-decoration: none; display: flex; align-items: center; gap: 8px; flex-shrink: 0;
    }
    .dash-logo img { height: 28px; width: auto; object-fit: contain; }
    .dash-header-right { display: flex; align-items: center; gap: 10px; margin-left: auto; }
    .dash-user-chip {
      display: flex; align-items: center; gap: 8px;
      background: var(--bg-3); border: 1px solid var(--border);
      border-radius: 99px; padding: 4px 12px 4px 4px;
      font-size: 13px; color: var(--text-2);
    }
    .dash-avatar {
      width: 26px; height: 26px; border-radius: 50%;
      background: var(--admin-bg);
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700; color: var(--admin-2); flex-shrink: 0;
    }

    /* Sidebar con borde cian */
    .dash-nav {
      grid-area: nav;
      background: var(--bg-2);
      border-right: 1px solid var(--admin-border);
      padding: 12px 8px; overflow-y: auto;
      position: sticky; top: var(--header-h);
      height: calc(100vh - var(--header-h));
      display: flex; flex-direction: column; gap: 2px;
    }
    .nav-section-label {
      font-size: 10px; font-weight: 600; letter-spacing: .1em;
      text-transform: uppercase; color: var(--text-3);
      padding: 8px 10px 4px; margin-top: 8px;
    }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; border-radius: 8px;
      color: var(--text-2); text-decoration: none;
      font-size: 13px; font-weight: 500;
      transition: all var(--transition);
      cursor: pointer; border: none; background: transparent;
      width: 100%; text-align: left;
    }
    .nav-item svg { flex-shrink: 0; opacity: .6; }
    .nav-item:hover { background: var(--bg-3); color: var(--text-1); }
    .nav-item:hover svg { opacity: 1; }
    .nav-item.active { background: var(--admin-bg); color: var(--admin-2); font-weight: 600; }
    .nav-item.active svg { opacity: 1; }
    .nav-divider { border: none; border-top: 1px solid var(--border); margin: 8px 0; }

    .dash-main { grid-area: main; padding: 28px 32px; overflow-y: auto; }
    .page-header { margin-bottom: 24px; }
    .page-title  { font-size: 22px; font-weight: 700; color: var(--text-1); line-height: 1.2; }
    .page-desc   { font-size: 13px; color: var(--text-3); margin-top: 4px; }

    /* Responsive */
    @media (max-width: 768px) {
      :root { --nav-w: 0px; }
      .dash-shell { grid-template-columns: 1fr; grid-template-areas: "header" "main"; }
      .dash-nav {
        display: none; position: fixed;
        left: 0; top: var(--header-h); width: 240px;
        height: calc(100vh - var(--header-h)); z-index: 200;
        box-shadow: 4px 0 32px rgba(0,212,255,.1);
      }
      .dash-nav.mobile-open { display: flex; }
      .dash-main { padding: 16px; }
      .form-grid-2 { grid-template-columns: 1fr; }
      .admin-table { display: block; overflow-x: auto; }
    }
  </style>
</head>

<body>
  <div class="dash-shell">

    <header class="dash-header">
      <button
        id="mobile-menu-btn"
        style="width:36px;padding:6px;display:none;align-items:center;justify-content:center;border:none;background:transparent;color:var(--text-2);cursor:pointer;border-radius:8px"
        aria-label="Menú"
      >
        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <!-- Logo con imagen -->
      <a href="/admin" class="dash-logo">
        <img
          src="/CardVirtual.png"
          alt="CardVirtual"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <span style="display:none;align-items:center;gap:6px">
          <span style="width:8px;height:8px;border-radius:50%;background:var(--cyan);box-shadow:0 0 8px var(--cyan)"></span>
          CardVirtual
        </span>
      </a>

      <!-- Badge Admin con cian -->
      <span class="badge badge-admin" style="font-size:10px;letter-spacing:.08em">
        ⚙ SUPER ADMIN
      </span>

      <div class="dash-header-right">
        <a href="/dashboard" class="btn btn-ghost" style="font-size:12px;padding:5px 12px">
          ← Mi dashboard
        </a>
        <div class="dash-user-chip">
          <div class="dash-avatar" id="user-avatar">?</div>
          <span id="user-email-short" style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:13px">
            {user.email}
          </span>
        </div>
        <button class="btn btn-danger" id="btn-logout" style="padding:5px 12px;font-size:12px">Salir</button>
      </div>
    </header>

    <nav class="dash-nav" id="dash-nav" role="navigation">
      <span class="nav-section-label">Administración</span>

      {NAV.map(item => (
        <a href={item.href} class={`nav-item ${tabActivo === item.id ? 'active' : ''}`} data-tab={item.id}>
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon} />
          {item.label}
        </a>
      ))}

      <a
        href="/admin/crear-usuario"
        class={`nav-item ${tabActivo === 'crear-usuario' ? 'active' : ''}`}
        style="margin-top:4px;border:1px dashed var(--border)"
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z"/>
        </svg>
        Crear usuario
      </a>

      <hr class="nav-divider" style="margin-top:auto" />
      <a href="/dashboard" class="nav-item" style="color:var(--text-3)">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"/>
        </svg>
        Volver al dashboard
      </a>
    </nav>

    <main class="dash-main" id="dash-main" role="main">
      <slot />
    </main>
  </div>

  <div id="toast" aria-live="polite"></div>
  <div id="mobile-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,212,255,.08);z-index:199" onclick="closeMobileNav()"></div>

  <script>
    import { createBrowserClient } from '@supabase/ssr'

    document.getElementById('btn-logout')?.addEventListener('click', async function() {
      const btn = this as HTMLButtonElement
      btn.textContent = 'Saliendo...'
      btn.disabled = true
      const sb = createBrowserClient(
        document.querySelector<HTMLMetaElement>('meta[name="supabase-url"]')!.content,
        document.querySelector<HTMLMetaElement>('meta[name="supabase-anon"]')!.content,
      )
      await sb.auth.signOut()
      window.location.href = '/auth/login'
    })

    const emailEl  = document.getElementById('user-email-short')
    const avatarEl = document.getElementById('user-avatar')
    if (emailEl && avatarEl) {
      avatarEl.textContent = (emailEl.textContent?.trim() ?? '?')[0].toUpperCase()
    }

    const mobileBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement
    const dashNav   = document.getElementById('dash-nav') as HTMLElement
    const overlay   = document.getElementById('mobile-overlay') as HTMLElement

    function syncMobileBtn() { mobileBtn.style.display = window.innerWidth <= 768 ? 'flex' : 'none' }
    syncMobileBtn()
    window.addEventListener('resize', syncMobileBtn)

    mobileBtn.addEventListener('click', () => {
      const open = dashNav.classList.toggle('mobile-open')
      overlay.style.display = open ? 'block' : 'none'
    })
    ;(window as any).closeMobileNav = () => {
      dashNav.classList.remove('mobile-open')
      overlay.style.display = 'none'
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-backdrop.open').forEach(m => m.classList.remove('open'))
      }
    })

    ;(window as any).toast = (msg: string, type: 'success'|'error'|'warn' = 'success') => {
      const container = document.getElementById('toast')!
      const el = document.createElement('div')
      el.className = `toast-item ${type}`
      const icons = { success: '✓', error: '✕', warn: '⚠' }
      el.innerHTML = `<span style="font-weight:700">${icons[type]}</span> ${msg}`
      container.appendChild(el)
      setTimeout(() => {
        el.style.cssText += 'opacity:0;transform:translateX(16px);transition:.3s'
        setTimeout(() => el.remove(), 300)
      }, 3500)
    }
  </script>
</body>
</html>