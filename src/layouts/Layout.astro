---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Tarjeta de presentación digital profesional' } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="supabase-url" content={import.meta.env.PUBLIC_SUPABASE_URL} />
    <meta name="supabase-anon" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <slot />
  </body>
</html>
