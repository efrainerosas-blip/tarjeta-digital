---
// src/layouts/DashboardLayout.astro
import '../styles/global.css'

interface Props {
  title?:      string
  tabActivo?:  string
  user?:       { email: string; id: string }
  slug?:       string
  tipoPerfil?: 'profesional' | 'negocio'
}

const {
  title      = 'Dashboard',
  tabActivo  = 'perfil',
  user,
  slug,
  tipoPerfil = 'profesional',
} = Astro.props

const esNegocio     = tipoPerfil === 'negocio'

// ── Navegación según tipo ─────────────────────────────────────
// Profesional: CV completo
// Negocio: catálogo, horario, dirección, redes
const tabsProfesional = [
  { id: 'perfil',         label: 'Perfil',      icon: 'user',      href: '/dashboard',                     section: 'tarjeta' },
  { id: 'experiencia',    label: 'Experiencia', icon: 'briefcase', href: '/dashboard/experiencia',          section: 'tarjeta' },
  { id: 'estudios',       label: 'Educación',   icon: 'academic',  href: '/dashboard/estudios',             section: 'tarjeta' },
  { id: 'servicios',      label: 'Servicios',   icon: 'sparkles',  href: '/dashboard/servicios',            section: 'tarjeta' },
  { id: 'proyectos',      label: 'Proyectos',   icon: 'code',      href: '/dashboard/proyectos',            section: 'tarjeta' },
  { id: 'habilidades',    label: 'Habilidades', icon: 'chip',      href: '/dashboard/habilidades',          section: 'tarjeta' },
  { id: 'redes',          label: 'Redes',       icon: 'share',     href: '/dashboard/redes',                section: 'tarjeta' },
  { id: 'logros',         label: 'Logros',      icon: 'trophy',    href: '/dashboard/logros',               section: 'tarjeta' },
  { id: 'capacitaciones', label: 'Cursos',      icon: 'book',      href: '/dashboard/capacitaciones',       section: 'tarjeta' },
  { id: 'referencias',    label: 'Referencias', icon: 'users',     href: '/dashboard/referencias',          section: 'tarjeta' },
  { id: 'temas',          label: 'Plantillas',  icon: 'palette',   href: '/dashboard/temas',                section: 'personalizar' },
  { id: 'analytics',      label: 'Analytics',   icon: 'chart',     href: '/dashboard/analytics',            section: 'metricas' },
  { id: 'seguridad',      label: 'Seguridad',   icon: 'lock',      href: '/dashboard/seguridad',            section: 'cuenta' },
]

const tabsNegocio = [
  { id: 'perfil',    label: 'Mi negocio', icon: 'store',   href: '/dashboard',              section: 'negocio' },
  { id: 'servicios', label: 'Catálogo',   icon: 'sparkles',href: '/dashboard/servicios',    section: 'negocio' },
  { id: 'proyectos', label: 'Galería',    icon: 'photo',   href: '/dashboard/proyectos',    section: 'negocio' },
  { id: 'redes',     label: 'Redes',      icon: 'share',   href: '/dashboard/redes',        section: 'negocio' },
  { id: 'temas',     label: 'Plantillas', icon: 'palette', href: '/dashboard/temas',        section: 'personalizar' },
  { id: 'analytics', label: 'Analytics',  icon: 'chart',   href: '/dashboard/analytics',    section: 'metricas' },
  { id: 'seguridad', label: 'Seguridad',  icon: 'lock',    href: '/dashboard/seguridad',    section: 'cuenta' },
]

const tabs = esNegocio ? tabsNegocio : tabsProfesional

// Bottom nav: 4 tabs principales según tipo
const BOTTOM_IDS_PROF   = ['perfil', 'experiencia', 'redes', 'temas']
const BOTTOM_IDS_NEG    = ['perfil', 'servicios', 'redes', 'temas']
const BOTTOM_IDS        = esNegocio ? BOTTOM_IDS_NEG : BOTTOM_IDS_PROF

const bottomTabs  = tabs.filter(t => BOTTOM_IDS.includes(t.id))
const drawerTabs  = tabs.filter(t => !BOTTOM_IDS.includes(t.id))

// ── SVG paths ─────────────────────────────────────────────────
const iconSVG: Record<string, string> = {
  user:      `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>`,
