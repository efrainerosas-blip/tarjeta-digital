---
// src/layouts/DashboardLayout.astro
import { createServerClient } from '@supabase/ssr'

export interface Props {
  title?: string
  tabActivo?: string
  user?: { email: string; id: string }
}

const { title = 'Dashboard', tabActivo = 'perfil', user } = Astro.props

const tabs = [
  { id: 'perfil',      label: 'Perfil',        icon: 'user',       href: '/dashboard' },
  { id: 'experiencia', label: 'Experiencia',   icon: 'briefcase',  href: '/dashboard/experiencia' },
  { id: 'estudios',    label: 'Educación',     icon: 'academic',   href: '/dashboard/estudios' },
  { id: 'servicios',   label: 'Servicios',     icon: 'sparkles',   href: '/dashboard/servicios' },
  { id: 'proyectos',   label: 'Proyectos',     icon: 'code',       href: '/dashboard/proyectos' },
  { id: 'habilidades', label: 'Habilidades',   icon: 'chip',       href: '/dashboard/habilidades' },
  { id: 'redes',       label: 'Redes',         icon: 'share',      href: '/dashboard/redes' },
  { id: 'logros',      label: 'Logros',        icon: 'trophy',     href: '/dashboard/logros' },
  { id: 'capacitaciones', label: 'Cursos',     icon: 'book',       href: '/dashboard/capacitaciones' },
  { id: 'temas',       label: 'Plantillas',    icon: 'palette',    href: '/dashboard/temas' },
  { id: 'analytics',   label: 'Analytics',     icon: 'chart',      href: '/dashboard/analytics' },
]

