// Secciones del sidebar agrupadas
const secciones = [...new Set(tabs.map(t => t.section))]
const labelSeccion: Record<string, string> = {
  tarjeta:      'Tu tarjeta',
  negocio:      'Tu negocio',
  personalizar: 'Personalizar',
  metricas:     'Métricas',
  cuenta:       'Cuenta',
}
---

<!doctype html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="supabase-url"  content={import.meta.env.PUBLIC_SUPABASE_URL} />
  <meta name="supabase-anon" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY} />
  <title>{title} — CardVirtual</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style is:global>
    body { background: var(--bg); color: var(--text-1); }

    /* ── Inputs ─────────────────────────────────────────────── */
    input, textarea, select {
      font-family: var(--font); font-size: 14px;
      background: var(--bg-2); color: var(--text-1);
      border: 1px solid var(--border); border-radius: var(--radius);
      padding: 9px 12px; width: 100%;
      transition: border-color var(--transition), box-shadow var(--transition);
      outline: none;
    }
    input:hover, textarea:hover, select:hover { border-color: var(--border-2); }
    input:focus, textarea:focus, select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-bg);
    }
    input::placeholder, textarea::placeholder { color: var(--text-3); }
    label { display: block; font-size: 13px; font-weight: 500; color: var(--text-2); margin-bottom: 6px; }

    /* ── Botones ─────────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 16px; border-radius: var(--radius);
      font-size: 13px; font-weight: 500; font-family: var(--font);
      cursor: pointer; transition: all var(--transition);
      border: none; white-space: nowrap; text-decoration: none;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #fff; box-shadow: 0 2px 8px var(--accent-bg);
    }
    .btn-primary:hover { opacity: .9; transform: translateY(-1px); box-shadow: 0 4px 16px var(--accent-bg); }
    .btn-primary:active { transform: translateY(0); }
    .btn-ghost { background: transparent; color: var(--text-2); border: 1px solid var(--border); }
    .btn-ghost:hover { background: var(--bg-3); color: var(--text-1); border-color: var(--border-2); }
    .btn-danger { background: rgba(239,68,68,.08); color: var(--danger); border: 1px solid rgba(239,68,68,.2); }
    .btn-danger:hover { background: rgba(239,68,68,.15); }
    .btn:disabled { opacity: .45; cursor: not-allowed; transform: none !important; box-shadow: none !important; }

    /* ── Badges ─────────────────────────────────────────────── */
    .badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 99px; font-size: 11px; font-weight: 600; letter-spacing: .03em; text-transform: uppercase; }
    .badge-pro     { background: linear-gradient(135deg,#f59e0b,#f97316); color: #fff; }
    .badge-free    { background: var(--bg-4); color: var(--text-3); border: 1px solid var(--border); }
    .badge-premium { background: linear-gradient(135deg,#f59e0b,#f97316); color: #fff; }

    /* ── Toast ──────────────────────────────────────────────── */
    #toast { position: fixed; bottom: 80px; right: 16px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
    .toast-item { background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius); padding: 10px 14px; font-size: 13px; color: var(--text-1); display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 20px rgba(75,108,247,.12); animation: slideIn .2s ease; pointer-events: all; max-width: 280px; }
    .toast-item.success { border-left: 3px solid var(--success); }
    .toast-item.error   { border-left: 3px solid var(--danger); }
    .toast-item.warn    { border-left: 3px solid var(--warn); }
    @keyframes slideIn { from { opacity:0; transform:translateX(12px); } to { opacity:1; transform:translateX(0); } }

    /* ── Layout shell ───────────────────────────────────────── */
    .dash-shell { display: grid; grid-template-rows: var(--header-h) 1fr; grid-template-columns: var(--nav-w) 1fr; grid-template-areas: "header header" "nav main"; min-height: 100vh; }

    /* ── Header ─────────────────────────────────────────────── */
    .dash-header { grid-area: header; display: flex; align-items: center; padding: 0 20px; background: var(--bg-2); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; gap: 12px; box-shadow: 0 1px 8px rgba(75,108,247,.06); }
    .dash-logo { font-size: 15px; font-weight: 700; color: var(--text-1); text-decoration: none; display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .dash-logo img { height: 28px; width: auto; object-fit: contain; }

    /* Chip tipo perfil en header */
    .dash-tipo-chip {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 10px; font-weight: 700; letter-spacing: .06em;
      padding: 3px 10px; border-radius: 99px;
      text-transform: uppercase; flex-shrink: 0;
    }
    .dash-tipo-chip.profesional { background: var(--accent-bg); color: var(--accent); border: 1px solid var(--accent-border); }
    .dash-tipo-chip.negocio     { background: var(--cyan-bg); color: var(--cyan-2); border: 1px solid rgba(0,212,255,.25); }

    .dash-header-right { display: flex; align-items: center; gap: 8px; margin-left: auto; }
    .dash-user-chip { display: flex; align-items: center; gap: 8px; background: var(--bg-3); border: 1px solid var(--border); border-radius: 99px; padding: 4px 12px 4px 4px; font-size: 13px; color: var(--text-2); }
    .dash-avatar { width: 26px; height: 26px; border-radius: 50%; background: var(--accent-bg); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; color: var(--accent); flex-shrink: 0; }
    .dash-preview-link { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: var(--accent); background: var(--accent-bg); border: 1px solid var(--accent-border); padding: 5px 10px; border-radius: var(--radius); text-decoration: none; transition: all var(--transition); white-space: nowrap; font-weight: 500; }
    .dash-preview-link:hover { background: var(--accent); color: #fff; }

    /* ── Sidebar ─────────────────────────────────────────────── */
    .dash-nav { grid-area: nav; background: var(--bg-2); border-right: 1px solid var(--border); padding: 12px 8px; overflow-y: auto; position: sticky; top: var(--header-h); height: calc(100vh - var(--header-h)); display: flex; flex-direction: column; gap: 2px; }
    .nav-section-label { font-size: 10px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--text-3); padding: 8px 10px 4px; margin-top: 8px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; color: var(--text-2); text-decoration: none; font-size: 13px; font-weight: 500; transition: all var(--transition); cursor: pointer; border: none; background: transparent; width: 100%; text-align: left; }
    .nav-item svg { flex-shrink: 0; opacity: .6; }
    .nav-item:hover { background: var(--bg-3); color: var(--text-1); }
    .nav-item:hover svg { opacity: 1; }
    .nav-item.active { background: var(--accent-bg); color: var(--accent); font-weight: 600; }
    .nav-item.active svg { opacity: 1; }

    /* ── Main ────────────────────────────────────────────────── */
    .dash-main { grid-area: main; padding: 28px 32px; overflow-y: auto; max-width: 860px; }

    /* ── Page helpers ────────────────────────────────────────── */
    .page-header { margin-bottom: 24px; }
    .page-title  { font-size: 22px; font-weight: 700; color: var(--text-1); line-height: 1.2; }
    .page-desc   { font-size: 13px; color: var(--text-3); margin-top: 4px; }

    /* ── Form helpers ────────────────────────────────────────── */
    .form-grid   { display: grid; gap: 16px; }
    .form-grid-2 { grid-template-columns: 1fr 1fr; }
    .form-grid-3 { grid-template-columns: 1fr 1fr 1fr; }
    .form-group  { display: flex; flex-direction: column; }
    .form-row    { display: flex; gap: 16px; align-items: flex-end; }
    .form-hint   { font-size: 12px; color: var(--text-3); margin-top: 4px; }
    .form-divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }

    /* ── Section card ────────────────────────────────────────── */
    .section-card { background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; margin-bottom: 16px; box-shadow: 0 1px 4px rgba(75,108,247,.04); }
    .section-card-title { font-size: 15px; font-weight: 600; color: var(--text-1); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }

    /* ── List items ──────────────────────────────────────────── */
    .list-item { display: flex; align-items: flex-start; gap: 12px; padding: 14px; background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 8px; transition: border-color var(--transition), box-shadow var(--transition); }
    .list-item:hover { border-color: var(--accent-border); box-shadow: 0 2px 8px var(--accent-bg); }
    .list-item-body  { flex: 1; min-width: 0; }
    .list-item-title { font-size: 14px; font-weight: 600; color: var(--text-1); }
    .list-item-sub   { font-size: 12px; color: var(--text-3); margin-top: 2px; }
    .list-item-actions { display: flex; gap: 4px; flex-shrink: 0; }
    .icon-btn { display: flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; border: none; background: transparent; color: var(--text-3); cursor: pointer; transition: all var(--transition); }
    .icon-btn:hover { background: var(--bg-3); color: var(--text-1); }
    .icon-btn.danger:hover { background: rgba(239,68,68,.1); color: var(--danger); }

    /* ── Modal ───────────────────────────────────────────────── */
    .modal-backdrop { position: fixed; inset: 0; background: rgba(13,18,54,.4); backdrop-filter: blur(4px); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 16px; opacity: 0; pointer-events: none; transition: opacity .2s; }
    .modal-backdrop.open { opacity: 1; pointer-events: all; }
    .modal { background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; transform: scale(.96); transition: transform .2s; box-shadow: 0 20px 60px rgba(75,108,247,.12); }
    .modal-backdrop.open .modal { transform: scale(1); }
    .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .modal-title { font-size: 16px; font-weight: 700; color: var(--text-1); }
    .modal-close { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 6px; border: none; background: var(--bg-3); color: var(--text-2); cursor: pointer; font-size: 16px; transition: all var(--transition); }
    .modal-close:hover { background: var(--bg-4); color: var(--text-1); }

    /* ── Misc ────────────────────────────────────────────────── */
    .slug-preview { font-family: var(--font-mono); font-size: 12px; color: var(--accent); background: var(--accent-bg); padding: 4px 10px; border-radius: 6px; display: inline-flex; align-items: center; gap: 6px; margin-top: 6px; border: 1px solid var(--accent-border); }
    .char-counter { font-size: 11px; color: var(--text-3); text-align: right; margin-top: 4px; }
    .char-counter.warn { color: var(--warn); }
    .char-counter.over { color: var(--danger); }
    .toggle { position: relative; display: inline-flex; align-items: center; cursor: pointer; gap: 10px; font-size: 13px; color: var(--text-2); }
    .toggle input { width: 0; height: 0; opacity: 0; position: absolute; }
    .toggle-track { width: 36px; height: 20px; background: var(--bg-4); border-radius: 99px; border: 1px solid var(--border); position: relative; transition: all var(--transition); flex-shrink: 0; }
    .toggle-thumb { position: absolute; top: 2px; left: 2px; width: 14px; height: 14px; background: var(--text-3); border-radius: 50%; transition: all var(--transition); }
    .toggle input:checked + .toggle-track { background: var(--accent); border-color: var(--accent); }
    .toggle input:checked + .toggle-track .toggle-thumb { transform: translateX(16px); background: #fff; }

    /* ── Bottom nav ──────────────────────────────────────────── */
    .bottom-nav { display: none; }
    .drawer-backdrop { display: none; position: fixed; inset: 0; background: rgba(13,18,54,.3); backdrop-filter: blur(4px); z-index: 299; }
    .drawer-backdrop.open { display: block; }
    .drawer { position: fixed; bottom: 0; left: 0; right: 0; background: var(--bg-2); border-top: 1px solid var(--border); border-radius: 20px 20px 0 0; padding: 8px 16px calc(var(--bottom-h) + 8px); z-index: 300; transform: translateY(100%); transition: transform .3s cubic-bezier(.32,0,.67,0); max-height: 80svh; overflow-y: auto; }
    .drawer.open { transform: translateY(0); transition: transform .35s cubic-bezier(.34,1.2,.64,1); }
    .drawer-handle { width: 36px; height: 4px; background: var(--border-2); border-radius: 99px; margin: 0 auto 16px; }
    .drawer-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding-bottom: 8px; }
    .drawer-item { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 12px 4px; border-radius: 12px; color: var(--text-2); text-decoration: none; font-size: 11px; font-weight: 500; transition: all var(--transition); border: 1px solid transparent; text-align: center; }
    .drawer-item:hover { background: var(--bg-3); }
    .drawer-item.active { background: var(--accent-bg); color: var(--accent); border-color: var(--accent-border); }
    .drawer-item svg { opacity: .6; }
    .drawer-item.active svg { opacity: 1; }

    /* ── Responsive ──────────────────────────────────────────── */
    @media (max-width: 767px) {
      .dash-nav { display: none !important; }
      .dash-shell { grid-template-columns: 1fr; grid-template-areas: "header" "main"; }
      .dash-main { padding: 16px 14px calc(var(--bottom-h) + 16px); max-width: 100%; }
      .dash-user-email { display: none; }
      .dash-preview-link { display: none; }
      .btn-logout-text { display: none; }
      .dash-tipo-chip { display: none; }
      .form-grid-2, .form-grid-3 { grid-template-columns: 1fr; }
      .section-card { padding: 16px; }
      .page-title { font-size: 18px; }
      #toast { bottom: calc(var(--bottom-h) + 12px); right: 12px; }
      .bottom-nav { display: flex; position: fixed; bottom: 0; left: 0; right: 0; height: var(--bottom-h); background: var(--bg-2); border-top: 1px solid var(--border); z-index: 200; align-items: center; justify-content: space-around; padding: 0 8px; padding-bottom: env(safe-area-inset-bottom, 0px); box-shadow: 0 -2px 12px rgba(75,108,247,.06); }
      .bn-item { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; flex: 1; height: 100%; color: var(--text-3); text-decoration: none; font-size: 10px; font-weight: 500; transition: color var(--transition); border: none; background: transparent; cursor: pointer; position: relative; padding: 8px 4px; }
      .bn-item svg { transition: transform var(--transition); }
      .bn-item:hover { color: var(--text-2); }
      .bn-item:hover svg { transform: translateY(-1px); }
      .bn-item.active { color: var(--accent); }
      .bn-item.active::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 24px; height: 2px; background: var(--accent); border-radius: 0 0 99px 99px; }
      .modal { max-width: 100%; border-radius: 20px 20px 0 0; position: fixed; bottom: 0; left: 0; right: 0; max-height: 92svh; }
      .modal-backdrop { align-items: flex-end; padding: 0; }
    }
    @media (min-width: 768px) and (max-width: 1023px) {
      :root { --nav-w: 64px; }
      .dash-nav { padding: 12px 8px; width: 64px; overflow: hidden; }
      .nav-item { justify-content: center; padding: 10px; }
      .nav-item span, .nav-section-label, .nav-footer-label { display: none; }
      .nav-item svg { margin: 0; }
      .dash-main { padding: 20px 24px; max-width: 100%; }
      .form-grid-3 { grid-template-columns: 1fr 1fr; }
      .dash-user-email { display: none; }
      .dash-tipo-chip { display: none; }
      .section-card { padding: 20px; }
    }
    @media (min-width: 1024px) {
      .bottom-nav { display: none !important; }
      .drawer-backdrop { display: none !important; }
      .drawer { display: none !important; }
      #toast { bottom: 24px; right: 24px; }
      .toast-item { max-width: 320px; }
    }
  </style>
</head>

<body>
  <div class="dash-shell">

    <!-- ── HEADER ─────────────────────────────────────────────── -->
    <header class="dash-header">
      <a href="/dashboard" class="dash-logo">
        <img src="/CardVirtual.png" alt="CardVirtual"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <span style="display:none;align-items:center;gap:6px">
          <span style="width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent)"></span>
          CardVirtual
        </span>
      </a>

      <!-- Chip de tipo perfil — visible en desktop/tablet -->
      <span class={`dash-tipo-chip ${tipoPerfil}`}>
        {esNegocio ? '🏪 Negocio' : '👔 Profesional'}
      </span>

      <div class="dash-header-right">
        <a href={slug ? `/${slug}` : '#'} target="_blank"
          class="dash-preview-link" id="preview-link">
          <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          Ver tarjeta
        </a>

        <div class="dash-user-chip">
          <div class="dash-avatar" id="user-avatar">?</div>
          <span id="user-email-short" class="dash-user-email"
            style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
            {user?.email ?? ''}
          </span>
        </div>

        <button class="btn btn-danger" id="btn-logout" style="padding:5px 12px;font-size:12px">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/>
          </svg>
          <span class="btn-logout-text">Salir</span>
        </button>
      </div>
    </header>

    <!-- ── SIDEBAR ─────────────────────────────────────────────── -->
    <nav class="dash-nav" id="dash-nav" role="navigation">
      {secciones.map(sec => (
        <>
          <span class="nav-section-label">{labelSeccion[sec] ?? sec}</span>
          {tabs.filter(t => t.section === sec).map(tab => (
            <a href={tab.href}
              class={`nav-item ${tabActivo === tab.id ? 'active' : ''}`}
              data-tab={tab.id}>
              <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                set:html={iconSVG[tab.icon]} />
              <span>{tab.label}</span>
            </a>
          ))}
        </>
      ))}

      <!-- Footer del nav: plan + mejorar -->
      <div style="flex:1"></div>
      <div class="nav-footer-label"
        style="padding:16px 10px 8px;margin-top:8px;border-top:1px solid var(--border)">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
          <span style="font-size:12px;color:var(--text-3)">Plan actual</span>
          <span class="badge badge-free" id="plan-badge">Free</span>
        </div>
        <a href="/dashboard/plan" class="btn btn-ghost"
          style="width:100%;justify-content:center;font-size:12px">
          ✦ Mejorar plan
        </a>
      </div>
    </nav>

    <!-- ── MAIN ─────────────────────────────────────────────────── -->
    <main class="dash-main" id="dash-main" role="main">
      <slot />
    </main>
  </div>

  <!-- ── BOTTOM NAV MOBILE ──────────────────────────────────────── -->
  <nav class="bottom-nav" id="bottom-nav">
    {bottomTabs.map(tab => (
      <a href={tab.href}
        class={`bn-item ${tabActivo === tab.id ? 'active' : ''}`}
        aria-label={tab.label}>
        <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          set:html={iconSVG[tab.icon]} />
        <span>{tab.label}</span>
      </a>
    ))}

    <!-- Ver tarjeta -->
    <a href={slug ? `/${slug}` : '#'} id="btn-ver-tarjeta"
      class="bn-item" target="_blank" aria-label="Ver mi tarjeta"
      style={!slug ? 'opacity:.35;pointer-events:none' : ''}>
      <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <span>Ver</span>
    </a>

    <!-- Más -->
    {drawerTabs.length > 0 && (
      <button class={`bn-item ${drawerTabs.some(t => t.id === tabActivo) ? 'active' : ''}`}
        id="btn-mas" aria-label="Más opciones">
        <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
        <span>Más</span>
      </button>
    )}
  </nav>

  <!-- ── DRAWER "MÁS" ────────────────────────────────────────────── -->
  <div class="drawer-backdrop" id="drawer-backdrop" onclick="cerrarDrawer()"></div>
  <div class="drawer" id="drawer" role="dialog" aria-label="Más secciones">
    <div class="drawer-handle"></div>
    <div class="drawer-grid">
      {drawerTabs.map(tab => (
        <a href={tab.href}
          class={`drawer-item ${tabActivo === tab.id ? 'active' : ''}`}
          onclick="cerrarDrawer()">
          <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            set:html={iconSVG[tab.icon]} />
          <span>{tab.label}</span>
        </a>
      ))}
    </div>
  </div>

  <div id="toast" aria-live="polite"></div>

  <script>
    import { createBrowserClient } from '@supabase/ssr'

    // ── Logout ────────────────────────────────────────────────
    document.getElementById('btn-logout')?.addEventListener('click', async function() {
      const btn = this as HTMLButtonElement
      btn.disabled = true
      const sb = createBrowserClient(
        document.querySelector<HTMLMetaElement>('meta[name="supabase-url"]')!.content,
        document.querySelector<HTMLMetaElement>('meta[name="supabase-anon"]')!.content,
      )
      await sb.auth.signOut()
      window.location.href = '/auth/login'
    })

    // ── Avatar ────────────────────────────────────────────────
    const emailEl  = document.getElementById('user-email-short')
    const avatarEl = document.getElementById('user-avatar')
    if (emailEl && avatarEl) {
      avatarEl.textContent = (emailEl.textContent?.trim() ?? '?')[0].toUpperCase()
    }

    // ── Drawer ────────────────────────────────────────────────
    const btnMas         = document.getElementById('btn-mas')
    const drawer         = document.getElementById('drawer')!
    const drawerBackdrop = document.getElementById('drawer-backdrop')!

    function abrirDrawer() {
      drawer.classList.add('open')
      drawerBackdrop.classList.add('open')
      btnMas?.setAttribute('aria-expanded', 'true')
      document.body.style.overflow = 'hidden'
    }
    ;(window as any).cerrarDrawer = function() {
      drawer.classList.remove('open')
      drawerBackdrop.classList.remove('open')
      btnMas?.setAttribute('aria-expanded', 'false')
      document.body.style.overflow = ''
    }
    btnMas?.addEventListener('click', () => {
      drawer.classList.contains('open')
        ? (window as any).cerrarDrawer()
        : abrirDrawer()
    })

    // Swipe down para cerrar drawer
    let touchStartY = 0
    drawer.addEventListener('touchstart', e => { touchStartY = e.touches[0].clientY }, { passive: true })
    drawer.addEventListener('touchend',   e => {
      if (e.changedTouches[0].clientY - touchStartY > 60) (window as any).cerrarDrawer()
    }, { passive: true })

    // ── Keyboard ──────────────────────────────────────────────
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        ;(window as any).cerrarDrawer?.()
        document.querySelectorAll('.modal-backdrop.open').forEach(m => m.classList.remove('open'))
      }
    })

    // ── Toast global ──────────────────────────────────────────
    ;(window as any).toast = (msg: string, type: 'success'|'error'|'warn' = 'success') => {
      const container = document.getElementById('toast')!
      const el = document.createElement('div')
      el.className = `toast-item ${type}`
      const icons = { success: '✓', error: '✕', warn: '⚠' }
      el.innerHTML = `<span style="font-weight:700">${icons[type]}</span> ${msg}`
      container.appendChild(el)
      setTimeout(() => {
        el.style.cssText += 'opacity:0;transform:translateX(12px);transition:.3s'
        setTimeout(() => el.remove(), 300)
      }, 3500)
    }
  </script>
</body>
</html>